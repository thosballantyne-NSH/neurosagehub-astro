---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
---

<BaseLayout
  title="Kids Play for Free — Autism-Friendly Games | Neurosage Hub"
  description="Create a free Neurosage Hub parent account and give your child unlimited, ad-free access to a therapeutic video game built for autistic kids — no credit card, no time limits."
>
  <Header />

  <main>

    <!-- ===== HERO ===== -->
    <section class="py-20" style="background:#082438;">
      <div class="container">
        <div class="max-w-2xl mx-auto text-center">
          <p class="nsh-eyebrow mb-4 fade-up" style="color:#D8896A;">Free for Families</p>
          <h1 class="nsh-heading-display mb-6 fade-up" style="color:white;">
            Let Your Child Play.<br>Know It's Actually Helping.
          </h1>
          <p class="nsh-body-lg mb-8 fade-up" style="color:rgba(255,255,255,0.8); max-width:30rem; margin-left:auto; margin-right:auto;">
            Your free Neurosage Hub account gives your child unlimited, ad-free access to a therapeutic video game built specifically for autistic kids — no credit card, no time limits, no separate download.
          </p>
          <div class="fade-up">
            <a
              href="/family-sign-up"
              class="nsh-btn-cta"
              style="font-size:1.0625rem; padding:1rem 2.25rem;"
            >
              Create Your Free Account
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
            </a>
            <p class="mt-4 text-sm" style="color:rgba(255,255,255,0.4); font-family:'DM Sans',sans-serif;">
              No credit card required · No commitment · Cancel any time
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- ===== WHAT'S INCLUDED ===== -->
    <section class="py-20" style="background:white;">
      <div class="container">
        <div class="max-w-2xl mx-auto text-center mb-14">
          <p class="nsh-eyebrow mb-4 fade-up">What You Get</p>
          <h2 class="nsh-heading-2 mb-4 fade-up">What your free account includes.</h2>
          <p class="nsh-body fade-up">
            Everything you need to get started — from day one. Your child gets a game they'll actually want to play, and you get the peace of mind that it's doing something real.
          </p>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6 max-w-4xl mx-auto">
          {[
            {
              icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="6" width="20" height="12" rx="3"/><path d="M8 12h.01M12 10v4M10 12h4"/></svg>`,
              title: 'One Game, Unlimited Play',
              desc: 'Unlimited, ad-free access to a therapeutic game built around regulation and sensory processing. No timers, no interruptions — just play.',
            },
            {
              icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2a10 10 0 1 0 0 20 10 10 0 0 0 0-20z"/><path d="M12 6v6l4 2"/></svg>`,
              title: 'Bedtime & Morning Routines',
              desc: 'Use games as a calm-down tool before bed or a brain-stimulation warm-up to start the morning — integrated into your daily home routine.',
            },
            {
              icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>`,
              title: 'Progress Visible to Your Practitioner',
              desc: 'If your child works with a Neurosage Hub practitioner, they can see usage logs — keeping everyone aligned between visits.',
            },
          ].map(({ icon, title, desc }, i) => (
            <div class="nsh-card p-7 fade-up" style={`transition-delay:${i * 80}ms;`}>
              <div class="w-12 h-12 rounded-xl flex items-center justify-center mb-5" style="background:#F7F2EB; color:#123D5A;">
                <Fragment set:html={icon} />
              </div>
              <h3 class="nsh-heading-3 mb-3">{title}</h3>
              <p class="nsh-body">{desc}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ===== DR. KYLE CREDIBILITY ===== -->
    <section class="py-16" style="background:#f9f7f4;">
      <div class="container">
        <div class="max-w-3xl mx-auto">
          <div class="nsh-card p-8 md:p-10 fade-up">
            <p class="nsh-eyebrow mb-4" style="color:#D8896A;">13 Years in the Making</p>
            <blockquote class="mb-5" style="border-left:3px solid #D8896A; padding:0.75rem 1.25rem; background:#f9f7f4; border-radius:0 0.5rem 0.5rem 0;">
              <p style="font-family:'DM Sans',sans-serif; font-size:1.0625rem; color:#082438; font-style:italic; line-height:1.65;">
                "How do we make the games these kids are already attracted to into a therapy tool?"
              </p>
              <footer class="mt-2 text-sm font-semibold" style="font-family:'DM Sans',sans-serif; color:#5F6975;">— Dr. Kyle</footer>
            </blockquote>
            <p class="nsh-body mb-4">
              While most people were telling parents to limit screen time, Dr. Kyle was researching a different question. Over 13 years of clinical application, he refined video games as a structured therapeutic tool — using them in clinic as a session start, warm-up, calm-down, and grounding activity.
            </p>
            <p class="nsh-body mb-6">
              Kids started looking forward to clinic. Games became rewards, incentives, and entry points into more demanding therapeutic work. And now that same tool is available to families at home — one game free with every account, and a full library ready when you want more.
            </p>
            <a href="/podcast" class="inline-flex items-center gap-2 text-sm font-semibold" style="color:#123D5A; font-family:'DM Sans',sans-serif;">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="#123D5A"><polygon points="6 3 20 12 6 21 6 3"/></svg>
              Hear Dr. Kyle on the podcast
            </a>
          </div>
        </div>
      </div>
    </section>

    <!-- ===== INLINE SIGN UP FORM ===== -->
    <section class="py-20 relative overflow-hidden">
      <div class="absolute inset-0" style="background:linear-gradient(135deg, #123D5A 0%, #082438 100%);"></div>
      <div class="container relative z-10">
        <div class="max-w-lg mx-auto">

          <!-- Heading -->
          <div class="text-center mb-8">
            <p class="nsh-eyebrow mb-3 fade-up" style="color:#D8896A;">Start Today — It's Free</p>
            <h2 style="font-family:'DM Sans',sans-serif; font-weight:800; font-size:clamp(1.75rem,4vw,2.25rem); color:white; line-height:1.15; margin-bottom:0.75rem;" class="fade-up">GET FREE GAMES</h2>
            <p style="font-family:'DM Sans',sans-serif; font-size:1.0625rem; color:rgba(255,255,255,0.75); line-height:1.7;" class="fade-up">
              Start playing today for free inside the Hub.
            </p>
          </div>

          <!-- Form card -->
          <div class="rounded-2xl p-8 md:p-10 fade-up" style="background:white;">

            <form id="play-free-form" novalidate>

              <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mb-4">
                <div>
                  <label for="pf_first" style="font-family:'DM Sans',sans-serif; font-size:0.875rem; font-weight:600; color:#082438; display:block; margin-bottom:0.375rem;">First Name</label>
                  <input
                    type="text"
                    id="pf_first"
                    name="first_name"
                    placeholder="First name"
                    required
                    autocomplete="given-name"
                    style="width:100%; padding:0.75rem 1rem; border:1.5px solid #ddd9d2; border-radius:0.625rem; font-family:'DM Sans',sans-serif; font-size:1rem; color:#082438; outline:none; transition:border-color 150ms; box-sizing:border-box;"
                    onfocus="this.style.borderColor='#2E6E8E'"
                    onblur="this.style.borderColor='#ddd9d2'"
                  />
                </div>
                <div>
                  <label for="pf_last" style="font-family:'DM Sans',sans-serif; font-size:0.875rem; font-weight:600; color:#082438; display:block; margin-bottom:0.375rem;">Last Name</label>
                  <input
                    type="text"
                    id="pf_last"
                    name="last_name"
                    placeholder="Last name"
                    required
                    autocomplete="family-name"
                    style="width:100%; padding:0.75rem 1rem; border:1.5px solid #ddd9d2; border-radius:0.625rem; font-family:'DM Sans',sans-serif; font-size:1rem; color:#082438; outline:none; transition:border-color 150ms; box-sizing:border-box;"
                    onfocus="this.style.borderColor='#2E6E8E'"
                    onblur="this.style.borderColor='#ddd9d2'"
                  />
                </div>
              </div>

              <div class="mb-4">
                <label for="pf_email" style="font-family:'DM Sans',sans-serif; font-size:0.875rem; font-weight:600; color:#082438; display:block; margin-bottom:0.375rem;">Email Address</label>
                <input
                  type="email"
                  id="pf_email"
                  name="email"
                  placeholder="you@email.com"
                  required
                  autocomplete="email"
                  style="width:100%; padding:0.75rem 1rem; border:1.5px solid #ddd9d2; border-radius:0.625rem; font-family:'DM Sans',sans-serif; font-size:1rem; color:#082438; outline:none; transition:border-color 150ms; box-sizing:border-box;"
                  onfocus="this.style.borderColor='#2E6E8E'"
                  onblur="this.style.borderColor='#ddd9d2'"
                />
              </div>

              <div class="mb-6">
                <label for="pf_phone" style="font-family:'DM Sans',sans-serif; font-size:0.875rem; font-weight:600; color:#082438; display:block; margin-bottom:0.375rem;">
                  Phone
                  <span style="font-weight:400; color:#5F6975;">(optional)</span>
                </label>
                <input
                  type="tel"
                  id="pf_phone"
                  name="phone"
                  placeholder="Your phone number"
                  autocomplete="tel"
                  style="width:100%; padding:0.75rem 1rem; border:1.5px solid #ddd9d2; border-radius:0.625rem; font-family:'DM Sans',sans-serif; font-size:1rem; color:#082438; outline:none; transition:border-color 150ms; box-sizing:border-box;"
                  onfocus="this.style.borderColor='#2E6E8E'"
                  onblur="this.style.borderColor='#ddd9d2'"
                />
              </div>

              <!-- Error message -->
              <p id="pf-error" style="display:none; font-family:'DM Sans',sans-serif; font-size:0.875rem; color:#c0392b; margin-bottom:1rem; background:#fdf0ea; border-radius:0.5rem; padding:0.75rem 1rem;"></p>

              <button
                type="submit"
                id="pf-submit"
                style="width:100%; background:#D8896A; color:white; font-family:'DM Sans',sans-serif; font-weight:700; font-size:1.0625rem; padding:1rem; border-radius:0.625rem; border:none; cursor:pointer; transition:background 0.16s; display:flex; align-items:center; justify-content:center; gap:0.5rem;"
                onmouseover="this.style.background='#b8694a'"
                onmouseout="this.style.background='#D8896A'"
              >
                <span id="pf-btn-label">Create My Free Account</span>
                <svg id="pf-btn-arrow" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
                <svg id="pf-btn-spinner" style="display:none;" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><path d="M21 12a9 9 0 1 1-6.219-8.56"/></svg>
              </button>

              <p style="font-family:'DM Sans',sans-serif; font-size:0.8125rem; color:#5F6975; text-align:center; margin-top:1rem; line-height:1.5;">
                By signing up you agree to our
                <a href="/privacy-policy" style="color:#2E6E8E; text-decoration:underline;" target="_blank">Privacy Policy</a>
                and
                <a href="/terms-of-service" style="color:#2E6E8E; text-decoration:underline;" target="_blank">Terms of Service</a>.
              </p>

            </form>

            <!-- Trust badges -->
            <div class="flex flex-wrap gap-2 mt-6 pt-5" style="border-top:1px solid #ddd9d2;">
              {['Free to join', 'No diagnosis required', 'Secure & private'].map((badge) => (
                <span class="flex items-center gap-1.5 text-xs font-medium px-3 py-1.5 rounded-full" style="background:#E4EFF6; color:#1A4A6B; font-family:'DM Sans',sans-serif;">
                  <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><polyline points="20 6 9 17 4 12"/></svg>
                  {badge}
                </span>
              ))}
            </div>

          </div>

          <p class="text-center mt-5 fade-up" style="font-family:'DM Sans',sans-serif; font-size:0.875rem; color:rgba(255,255,255,0.3); letter-spacing:0.06em; text-transform:uppercase;">
            Build Hope. Walk Together.
          </p>

        </div>
      </div>
    </section>

    <script is:inline>
      document.getElementById('play-free-form').addEventListener('submit', function(e) {
        e.preventDefault();
        var first  = document.getElementById('pf_first').value.trim();
        var last   = document.getElementById('pf_last').value.trim();
        var email  = document.getElementById('pf_email').value.trim();
        var phone  = document.getElementById('pf_phone').value.trim();
        var errEl  = document.getElementById('pf-error');

        errEl.style.display = 'none';
        if (!first) { pfError('Please enter your first name.'); return; }
        if (!last)  { pfError('Please enter your last name.'); return; }
        if (!email || !email.includes('@')) { pfError('Please enter a valid email address.'); return; }

        document.getElementById('pf-btn-label').textContent = 'Creating your account…';
        document.getElementById('pf-btn-arrow').style.display = 'none';
        document.getElementById('pf-btn-spinner').style.display = 'block';
        document.getElementById('pf-submit').disabled = true;
        document.getElementById('pf-submit').style.opacity = '0.8';

        var params = new URLSearchParams({ first_name: first, last_name: last, email: email, phone: phone });
        setTimeout(function() {
          window.location.href = '/family-signup-thank-you/?' + params.toString();
        }, 600);
      });

      function pfError(msg) {
        var el = document.getElementById('pf-error');
        el.textContent = msg;
        el.style.display = 'block';
        el.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
      }
    </script>

  </main>

  <Footer />
</BaseLayout>
