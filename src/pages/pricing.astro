---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const familyFeatures = [
  'Autism Pathways Quiz',
  'Personalised learning pathway',
  'Structured educational modules',
  'Home routine protocols (10–20 min/day)',
  'Therapeutic sensory games library',
  'Eva — AI autism mentor (24/7)',
  'Progress tracking & logs',
  'Practitioner-shareable progress reports',
  'Parent community access',
];

const practitionerFeatures = [
  'Everything in Family Plan',
  'Dedicated practitioner portal',
  'Assign pathways to patients',
  'Track family compliance between visits',
  'Custom home protocol builder',
  'Branded parent-facing content',
  'Progress reporting dashboard',
  'Multi-family management',
  'Priority onboarding support',
];

const faqs = [
  {
    q: 'Do I need an autism diagnosis to join?',
    a: 'No. Many families join before or during the diagnostic process. Neurosage Hub is designed to support any family navigating neurodevelopmental challenges — diagnosed or not.',
  },
  {
    q: 'Is this therapy?',
    a: 'No. Neurosage Hub provides structured educational content and parent-support tools. We don\'t diagnose, treat, or replace the work of your practitioners. We extend it.',
  },
  {
    q: 'Can I cancel anytime?',
    a: 'Yes. There\'s no long-term commitment. You can cancel your membership at any time from your account settings.',
  },
  {
    q: 'What makes Neurosage different from a course or YouTube?',
    a: 'Structure and personalization. Rather than random videos, you get a sequenced pathway built for your child\'s specific profile — with home routines, a progress tracker, Eva for guidance, and therapeutic games, all in one place.',
  },
  {
    q: 'How does the practitioner plan work?',
    a: 'Practitioners get their own portal to manage multiple families, assign specific pathways, and track engagement between visits — without adding to their clinical workload.',
  },
];
---

<BaseLayout
  title="Pricing | Neurosage Hub"
  description="Free to start. Built around your family. See what's included in every Neurosage Hub plan."
>
  <Header />

  <main>

    <!-- ===== HERO ===== -->
    <section class="py-20" style="background:#082438;">
      <div class="container">
        <div class="max-w-2xl mx-auto text-center">
          <p class="nsh-eyebrow mb-4 fade-up" style="color:#7B9E8B;">Pricing</p>
          <h1 class="fade-up mb-5" style="font-family:'DM Sans',sans-serif; font-weight:800; font-size:clamp(2rem,5vw,3rem); color:white; line-height:1.1;">
            More value than anything else<br>you'll find at this price.
          </h1>
          <p class="fade-up" style="font-family:'DM Sans',sans-serif; font-size:1.125rem; color:rgba(255,255,255,0.68); line-height:1.75; max-width:34rem; margin:0 auto;">
            Start free. Upgrade when you're ready. No diagnosis required, no commitment, no surprise charges.
          </p>
        </div>
      </div>
    </section>

    <!-- ===== PLANS ===== -->
    <section class="py-20" style="background:#F7F2EB;">
      <div class="container">
        <div class="max-w-5xl mx-auto">
          <div class="grid grid-cols-1 md:grid-cols-3 gap-6 items-start">

            <!-- FREE TIER -->
            <div class="rounded-2xl p-8 fade-up" style="background:white; border:2px solid #ddd9d2;">
              <p class="nsh-eyebrow mb-3" style="color:#5F6975;">Get Started</p>
              <h2 style="font-family:'DM Sans',sans-serif; font-weight:800; font-size:1.5rem; color:#082438; margin-bottom:0.5rem;">Free</h2>
              <div style="margin-bottom:1.25rem;">
                <span style="font-family:'DM Sans',sans-serif; font-size:2.5rem; font-weight:800; color:#082438;">$0</span>
                <span style="font-family:'DM Sans',sans-serif; font-size:0.9375rem; color:#5F6975;"> / forever</span>
              </div>
              <p style="font-family:'DM Sans',sans-serif; font-size:0.9375rem; color:#5F6975; line-height:1.65; margin-bottom:1.75rem;">
                Take the quiz, explore your pathway, and see what's waiting for your family — no card required.
              </p>

              <a href="/family-sign-up" class="nsh-btn-secondary w-full justify-center mb-6" style="display:flex;">
                Start Free Today
              </a>

              <ul class="space-y-3">
                {['Autism Pathways Quiz', 'Personalised pathway overview', 'Sensory games (free forever)', 'Eva AI mentor — basic access'].map((f) => (
                  <li class="flex items-start gap-2.5">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#7B9E8B" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" style="flex-shrink:0; margin-top:3px;"><polyline points="20 6 9 17 4 12"/></svg>
                    <span style="font-family:'DM Sans',sans-serif; font-size:0.9375rem; color:#1F2A33;">{f}</span>
                  </li>
                ))}
              </ul>
            </div>

            <!-- FAMILY PLAN — FEATURED -->
            <div class="rounded-2xl p-8 fade-up relative" style="background:#082438; border:2px solid #2E6E8E; transition-delay:80ms;">
              <div class="absolute -top-3.5 left-1/2 -translate-x-1/2">
                <span style="background:#D8896A; color:white; font-family:'DM Sans',sans-serif; font-size:0.75rem; font-weight:700; letter-spacing:0.06em; padding:0.3rem 1rem; border-radius:99px; white-space:nowrap;">MOST POPULAR</span>
              </div>

              <p class="nsh-eyebrow mb-3" style="color:#7B9E8B;">Family Plan</p>
              <h2 style="font-family:'DM Sans',sans-serif; font-weight:800; font-size:1.5rem; color:white; margin-bottom:0.5rem;">Full Access</h2>
              <div style="margin-bottom:0.5rem;">
                <span style="font-family:'DM Sans',sans-serif; font-size:2.5rem; font-weight:800; color:white;">$19</span>
                <span style="font-family:'DM Sans',sans-serif; font-size:0.9375rem; color:rgba(255,255,255,0.5);"> / month</span>
              </div>
              <p style="font-family:'DM Sans',sans-serif; font-size:0.8125rem; color:#7B9E8B; margin-bottom:0.75rem;">or $149/year — save 35%</p>
              <p style="font-family:'DM Sans',sans-serif; font-size:0.9375rem; color:rgba(255,255,255,0.65); line-height:1.65; margin-bottom:1.75rem;">
                Everything your family needs to move from overwhelmed to consistent — one structured day at a time.
              </p>

              <a href="/family-sign-up" class="nsh-btn-cta w-full justify-center mb-6" style="display:flex;">
                Start Free — Upgrade Anytime
              </a>

              <ul class="space-y-3">
                {familyFeatures.map((f) => (
                  <li class="flex items-start gap-2.5">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#7B9E8B" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" style="flex-shrink:0; margin-top:3px;"><polyline points="20 6 9 17 4 12"/></svg>
                    <span style="font-family:'DM Sans',sans-serif; font-size:0.9375rem; color:rgba(255,255,255,0.82);">{f}</span>
                  </li>
                ))}
              </ul>
            </div>

            <!-- PRACTITIONER PLAN -->
            <div class="rounded-2xl p-8 fade-up" style="background:white; border:2px solid #ddd9d2; transition-delay:160ms;">
              <p class="nsh-eyebrow mb-3" style="color:#2E6E8E;">For Clinics</p>
              <h2 style="font-family:'DM Sans',sans-serif; font-weight:800; font-size:1.5rem; color:#082438; margin-bottom:0.5rem;">Practitioner</h2>
              <div style="margin-bottom:0.5rem;">
                <span style="font-family:'DM Sans',sans-serif; font-size:2rem; font-weight:800; color:#082438;">Custom</span>
              </div>
              <p style="font-family:'DM Sans',sans-serif; font-size:0.8125rem; color:#5F6975; margin-bottom:0.75rem;">Priced per clinic / patient volume</p>
              <p style="font-family:'DM Sans',sans-serif; font-size:0.9375rem; color:#5F6975; line-height:1.65; margin-bottom:1.75rem;">
                Extend your care into every home. The clinical bridge your families have been waiting for.
              </p>

              <a href="/for-practitioners#demo" class="nsh-btn-primary w-full justify-center mb-6" style="display:flex;">
                Book a Demo
              </a>

              <ul class="space-y-3">
                {practitionerFeatures.map((f) => (
                  <li class="flex items-start gap-2.5">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#2E6E8E" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" style="flex-shrink:0; margin-top:3px;"><polyline points="20 6 9 17 4 12"/></svg>
                    <span style="font-family:'DM Sans',sans-serif; font-size:0.9375rem; color:#1F2A33;">{f}</span>
                  </li>
                ))}
              </ul>
            </div>

          </div>

          <!-- Value reinforcement -->
          <div class="mt-10 text-center fade-up">
            <p style="font-family:'DM Sans',sans-serif; font-size:0.9375rem; color:#5F6975;">
              🔒 Secure checkout &nbsp;·&nbsp; Cancel anytime &nbsp;·&nbsp; No diagnosis required &nbsp;·&nbsp; 7-day money-back guarantee
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- ===== WHAT YOU GET (value reinforcement) ===== -->
    <section class="py-20" style="background:white;">
      <div class="container">
        <div class="max-w-3xl mx-auto text-center mb-12 fade-up">
          <p class="nsh-eyebrow mb-3" style="color:#7B9E8B;">The Real Question</p>
          <h2 style="font-family:'DM Sans',sans-serif; font-weight:800; font-size:clamp(1.75rem,4vw,2.25rem); color:#082438; line-height:1.2;">
            What does $19 a month actually buy?
          </h2>
        </div>

        <div class="max-w-3xl mx-auto grid grid-cols-1 sm:grid-cols-2 gap-5">
          {[
            { label: '1 missed therapy session', value: '$150–300', compare: true },
            { label: 'Neurosage Hub — full month', value: '$19', compare: false },
            { label: '1 specialist consultation', value: '$200–500', compare: true },
            { label: 'Daily home support for your family', value: '$0.63/day', compare: false },
          ].map(({ label, value, compare }) => (
            <div class="rounded-2xl p-6 flex items-center justify-between fade-up" style={`background:${compare ? '#F7F2EB' : '#082438'}; border:1px solid ${compare ? '#ddd9d2' : '#1A4A6B'};`}>
              <span style={`font-family:'DM Sans',sans-serif; font-size:0.9375rem; font-weight:500; color:${compare ? '#5F6975' : 'rgba(255,255,255,0.8)'};`}>{label}</span>
              <span style={`font-family:'DM Sans',sans-serif; font-size:1.125rem; font-weight:800; color:${compare ? '#5F6975' : '#D8896A'};`}>{value}</span>
            </div>
          ))}
        </div>

        <p class="text-center mt-8 fade-up" style="font-family:'DM Sans',sans-serif; font-size:0.875rem; color:#5F6975; max-width:30rem; margin-left:auto; margin-right:auto; line-height:1.65;">
          We're not replacing your practitioners. We're making everything that happens between visits count.
        </p>
      </div>
    </section>

    <!-- ===== FAQ ===== -->
    <section class="py-20" style="background:#F7F2EB;">
      <div class="container">
        <div class="max-w-2xl mx-auto">
          <div class="text-center mb-12 fade-up">
            <p class="nsh-eyebrow mb-3" style="color:#7B9E8B;">Questions</p>
            <h2 style="font-family:'DM Sans',sans-serif; font-weight:800; font-size:clamp(1.75rem,4vw,2.25rem); color:#082438;">Common questions answered</h2>
          </div>

          <div class="flex flex-col gap-0">
            {faqs.map(({ q, a }, i) => (
              <div class="fade-up py-6" style={`border-bottom:1px solid #ddd9d2; ${i === 0 ? 'border-top:1px solid #ddd9d2;' : ''}`}>
                <p style="font-family:'DM Sans',sans-serif; font-weight:700; font-size:1rem; color:#082438; margin-bottom:0.625rem;">{q}</p>
                <p style="font-family:'DM Sans',sans-serif; font-size:0.9375rem; color:#5F6975; line-height:1.7;">{a}</p>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>

    <!-- ===== FINAL CTA ===== -->
    <section class="py-20" style="background:#082438;">
      <div class="container">
        <div class="max-w-xl mx-auto text-center fade-up">
          <p class="nsh-eyebrow mb-4" style="color:#7B9E8B;">Ready to Start?</p>
          <h2 style="font-family:'DM Sans',sans-serif; font-weight:800; font-size:clamp(1.75rem,4vw,2.25rem); color:white; line-height:1.2; margin-bottom:1rem;">
            Your family's path forward<br>starts with a free quiz.
          </h2>
          <p style="font-family:'DM Sans',sans-serif; font-size:1rem; color:rgba(255,255,255,0.65); margin-bottom:2rem; line-height:1.7;">
            3 minutes. No card required. A personalised pathway on the other side.
          </p>
          <div class="flex flex-col sm:flex-row gap-4 justify-center">
            <a href="/quiz" class="nsh-btn-cta" style="font-size:1rem; padding:0.875rem 2rem;">
              Take the Free Quiz
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
            </a>
            <a href="/family-sign-up" class="inline-flex items-center justify-center px-7 py-3.5 rounded-xl font-semibold" style="font-family:'DM Sans',sans-serif; font-size:1rem; color:white; border:1.5px solid rgba(255,255,255,0.25); text-decoration:none;">
              Sign Up Free
            </a>
          </div>
        </div>
      </div>
    </section>

  </main>

  <Footer />
</BaseLayout>
