---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
---

<BaseLayout
  title="How to Help During an Autism Meltdown | Neurosage Hub"
  description="Practical, compassionate guidance for parents on how to respond during and after an autism meltdown — what to do, what to avoid, and how to support recovery."
>
  <Header />
  <main class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-20">
    <nav class="text-sm text-stone-400 mb-8">
      <a href="/" class="hover:text-stone-600">Home</a>
      <span class="mx-2">/</span>
      <a href="/autism-meltdowns" class="hover:text-stone-600">Autism Meltdowns</a>
      <span class="mx-2">/</span>
      <span class="text-stone-600">How to Help</span>
    </nav>
    <h1 class="text-display font-bold text-stone-900 mb-6">How to Help During an Autism Meltdown</h1>
    <p class="text-xl text-stone-500 leading-relaxed mb-10">
      The right response in the moment can help your child feel safe, shorten the duration, and reduce the frequency over time.
    </p>
    <div class="prose prose-stone max-w-none">
      <p class="text-stone-500 text-sm italic">Subpage content — full article goes here (Day 6 of build timeline).</p>
    </div>
  </main>
  <Footer />
</BaseLayout>
