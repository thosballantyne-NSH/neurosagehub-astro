---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout
  title="Sensory Processing in Autism: A Parent's Guide | Neurosage Hub"
  description="Understand sensory processing and sensory integration in children with autism — learn to identify your child's sensory profile, common triggers, and calming strategies for home."
>
  <Header />
  <main class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-20">
    <h1 class="text-display font-bold text-stone-900 mb-4">Sensory Processing: A Parent's Guide</h1>
    <p class="text-xl text-stone-500 leading-relaxed mb-10">
      Every child has a unique sensory profile. Understanding yours helps you build a home environment where your child can regulate, focus, and thrive.
    </p>
    <div class="prose prose-stone max-w-none">
      <p class="text-stone-500 text-sm italic">Full page content goes here (Day 10 of build timeline).</p>
    </div>
  </main>
  <Footer />
</BaseLayout>
