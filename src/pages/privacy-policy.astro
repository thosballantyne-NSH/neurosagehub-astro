---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const sections = [
  {
    title: 'Definitions',
    items: [
      ['Service', 'Access to and use of https://neurosagehub.com, the Neurosage Hub platform operated by Learning Source, LLC, and any associated products and services.'],
      ['Personal Data', 'Data about a living individual who can be identified from those data (alone or with other information in our possession).'],
      ['Usage Data', 'Data collected automatically, either generated by the use of the Service or from the Service infrastructure itself (e.g., duration of a page visit).'],
      ['Cookies', 'Small files stored on your device (computer or mobile).'],
      ['Data Controller', 'Determines the purposes and means of processing personal information. For this policy, Learning Source, LLC is the Data Controller.'],
      ['Data Processors (or Service Providers)', 'Third parties engaged to process data on our behalf to deliver the Service more effectively.'],
      ['Data Subject (or User)', 'Any living individual using our Service who is the subject of Personal Data.'],
    ],
  },
];
---

<BaseLayout
  title="Privacy Policy | Neurosage Hub"
  description="Neurosage Hub Privacy Policy — how we collect, use, and protect your personal data. Operated by Learning Source, LLC."
>
  <Header />

  <main>

    <!-- Hero -->
    <section class="py-16" style="background:#082438;">
      <div class="container">
        <div class="max-w-2xl mx-auto text-center">
          <p class="nsh-eyebrow mb-3" style="color:#7B9E8B;">Legal</p>
          <h1 style="font-family:'DM Sans',sans-serif; font-weight:800; font-size:clamp(2rem,4vw,2.75rem); color:white; line-height:1.15;">Privacy Policy</h1>
          <p style="font-family:'DM Sans',sans-serif; font-size:0.9375rem; color:rgba(255,255,255,0.45); margin-top:0.75rem;">Updated: August 18, 2025</p>
        </div>
      </div>
    </section>

    <!-- Content -->
    <section class="py-16" style="background:white;">
      <div class="container">
        <div class="max-w-3xl mx-auto">

          <!-- Intro -->
          <p style="font-family:'DM Sans',sans-serif; font-size:0.9375rem; color:#3d5a6e; line-height:1.8; margin-bottom:1rem;">
            Neurosage Hub, operated by <strong style="color:#082438;">Learning Source, LLC</strong> ("Learning Source," "Neurosage Hub," "us," "we," or "our"), operates the website <a href="https://neurosagehub.com" style="color:#2E6E8E; text-decoration:underline;">https://neurosagehub.com</a> (the "Service").
          </p>
          <p style="font-family:'DM Sans',sans-serif; font-size:0.9375rem; color:#3d5a6e; line-height:1.8; margin-bottom:2.5rem;">
            This Privacy Policy informs you of our policies regarding the collection, use, and disclosure of personal data when you use our Service and the choices you have associated with that data. We use your data to provide and improve the Service. By using the Service, you agree to the collection and use of information in accordance with this policy.
          </p>

          <!-- Definitions -->
          <div style="margin-bottom:2.25rem; padding-bottom:2.25rem; border-bottom:1px solid #ddd9d2;">
            <h2 style="font-family:'DM Sans',sans-serif; font-weight:700; font-size:1.0625rem; color:#082438; margin-bottom:1rem;">Definitions</h2>
            <div class="space-y-3">
              {sections[0].items.map(([term, def]) => (
                <div class="rounded-xl p-4" style="background:#F7F2EB; border:1px solid #ddd9d2;">
                  <span style="font-family:'DM Sans',sans-serif; font-weight:700; font-size:0.9375rem; color:#082438;">{term}: </span>
                  <span style="font-family:'DM Sans',sans-serif; font-size:0.9375rem; color:#3d5a6e;">{def}</span>
                </div>
              ))}
            </div>
          </div>

          <!-- Information Collection -->
          <div style="margin-bottom:2.25rem; padding-bottom:2.25rem; border-bottom:1px solid #ddd9d2;">
            <h2 style="font-family:'DM Sans',sans-serif; font-weight:700; font-size:1.0625rem; color:#082438; margin-bottom:0.875rem;">Information Collection and Use</h2>
            <p style="font-family:'DM Sans',sans-serif; font-size:0.9375rem; color:#3d5a6e; line-height:1.8; margin-bottom:0.875rem;">We collect several types of information to provide and improve our Service. When using our Service, we may ask you to provide personally identifiable information such as:</p>
            <ul style="font-family:'DM Sans',sans-serif; font-size:0.9375rem; color:#3d5a6e; line-height:1.8; padding-left:1.5rem; list-style:disc; margin-bottom:0.875rem;">
              <li>Name (first and last)</li>
              <li>Email address</li>
              <li>Phone number</li>
              <li>Address (street, city, state/province, postal code)</li>
              <li>Cookies and Usage Data</li>
            </ul>
            <p style="font-family:'DM Sans',sans-serif; font-size:0.9375rem; color:#3d5a6e; line-height:1.8; margin-bottom:0.875rem;">We may also collect <strong style="color:#082438;">Usage Data</strong> on how the Service is accessed and used, such as IP address, browser type/version, pages visited, time/date of visit, time spent, and device identifiers.</p>
            <p style="font-family:'DM Sans',sans-serif; font-size:0.9375rem; color:#3d5a6e; line-height:1.8;">We use <strong style="color:#082438;">cookies, beacons, tags, and scripts</strong> to track activity on the Service and store certain preferences. You can set your browser to refuse cookies, though some features may not function properly without them.</p>
          </div>

          <!-- Use of Data -->
          <div style="margin-bottom:2.25rem; padding-bottom:2.25rem; border-bottom:1px solid #ddd9d2;">
            <h2 style="font-family:'DM Sans',sans-serif; font-weight:700; font-size:1.0625rem; color:#082438; margin-bottom:0.875rem;">Use of Data</h2>
            <p style="font-family:'DM Sans',sans-serif; font-size:0.9375rem; color:#3d5a6e; line-height:1.8; margin-bottom:0.625rem;">We use collected data to:</p>
            <ul style="font-family:'DM Sans',sans-serif; font-size:0.9375rem; color:#3d5a6e; line-height:1.8; padding-left:1.5rem; list-style:disc;">
              <li>Provide and maintain our Service</li>
              <li>Notify you of changes</li>
              <li>Allow participation in interactive features</li>
              <li>Provide customer support</li>
              <li>Analyse and improve functionality</li>
              <li>Monitor usage and prevent technical/security issues</li>
              <li>Share relevant offers, services, or events (unless you opt out)</li>
            </ul>
          </div>

          <!-- Legal Basis GDPR -->
          <div style="margin-bottom:2.25rem; padding-bottom:2.25rem; border-bottom:1px solid #ddd9d2;">
            <h2 style="font-family:'DM Sans',sans-serif; font-weight:700; font-size:1.0625rem; color:#082438; margin-bottom:0.875rem;">Legal Basis (GDPR)</h2>
            <p style="font-family:'DM Sans',sans-serif; font-size:0.9375rem; color:#3d5a6e; line-height:1.8;">If you are from the EEA, we process your Personal Data under one or more of the following: contract performance, your consent, our legitimate business interests (balanced with your rights), and legal obligations.</p>
          </div>

          <!-- California -->
          <div style="margin-bottom:2.25rem; padding-bottom:2.25rem; border-bottom:1px solid #ddd9d2;">
            <h2 style="font-family:'DM Sans',sans-serif; font-weight:700; font-size:1.0625rem; color:#082438; margin-bottom:0.875rem;">California Privacy Rights (CCPA)</h2>
            <p style="font-family:'DM Sans',sans-serif; font-size:0.9375rem; color:#3d5a6e; line-height:1.8;">California residents may request details regarding our disclosure of personal information to third parties for marketing purposes. To submit a request, email us at <a href="mailto:info@neurosagehub.com" style="color:#2E6E8E; text-decoration:underline;">info@neurosagehub.com</a>.</p>
          </div>

          <!-- Data Retention -->
          <div style="margin-bottom:2.25rem; padding-bottom:2.25rem; border-bottom:1px solid #ddd9d2;">
            <h2 style="font-family:'DM Sans',sans-serif; font-weight:700; font-size:1.0625rem; color:#082438; margin-bottom:0.875rem;">Data Retention</h2>
            <p style="font-family:'DM Sans',sans-serif; font-size:0.9375rem; color:#3d5a6e; line-height:1.8;">We retain Personal Data only as long as necessary to fulfill this Privacy Policy's purposes or comply with law. Usage Data is generally retained for shorter periods unless needed for security, functionality, or compliance.</p>
          </div>

          <!-- Data Transfer -->
          <div style="margin-bottom:2.25rem; padding-bottom:2.25rem; border-bottom:1px solid #ddd9d2;">
            <h2 style="font-family:'DM Sans',sans-serif; font-weight:700; font-size:1.0625rem; color:#082438; margin-bottom:0.875rem;">Data Transfer</h2>
            <p style="font-family:'DM Sans',sans-serif; font-size:0.9375rem; color:#3d5a6e; line-height:1.8;">Your data may be transferred to — and maintained on — servers outside your region, including in the United States. By submitting information, you consent to this transfer and processing.</p>
          </div>

          <!-- Disclosure -->
          <div style="margin-bottom:2.25rem; padding-bottom:2.25rem; border-bottom:1px solid #ddd9d2;">
            <h2 style="font-family:'DM Sans',sans-serif; font-weight:700; font-size:1.0625rem; color:#082438; margin-bottom:0.875rem;">Disclosure of Data</h2>
            <p style="font-family:'DM Sans',sans-serif; font-size:0.9375rem; color:#3d5a6e; line-height:1.8;">We may disclose Personal Data when required by law, to protect our rights, prevent misconduct, ensure safety, or defend against liability.</p>
          </div>

          <!-- Security -->
          <div style="margin-bottom:2.25rem; padding-bottom:2.25rem; border-bottom:1px solid #ddd9d2;">
            <h2 style="font-family:'DM Sans',sans-serif; font-weight:700; font-size:1.0625rem; color:#082438; margin-bottom:0.875rem;">Security of Data</h2>
            <p style="font-family:'DM Sans',sans-serif; font-size:0.9375rem; color:#3d5a6e; line-height:1.8;">We use commercially acceptable safeguards to protect your Personal Data, but no method of online transmission or storage is 100% secure.</p>
          </div>

          <!-- GDPR Rights -->
          <div style="margin-bottom:2.25rem; padding-bottom:2.25rem; border-bottom:1px solid #ddd9d2;">
            <h2 style="font-family:'DM Sans',sans-serif; font-weight:700; font-size:1.0625rem; color:#082438; margin-bottom:0.875rem;">Your GDPR Rights</h2>
            <p style="font-family:'DM Sans',sans-serif; font-size:0.9375rem; color:#3d5a6e; line-height:1.8; margin-bottom:0.625rem;">If you are in the EEA, you have the right to:</p>
            <ul style="font-family:'DM Sans',sans-serif; font-size:0.9375rem; color:#3d5a6e; line-height:1.8; padding-left:1.5rem; list-style:disc;">
              <li>Access, update, or delete your Personal Data</li>
              <li>Correct inaccurate information</li>
              <li>Object to processing</li>
              <li>Restrict processing</li>
              <li>Request portability of your data</li>
              <li>Withdraw consent</li>
            </ul>
          </div>

          <!-- Service Providers -->
          <div style="margin-bottom:2.25rem; padding-bottom:2.25rem; border-bottom:1px solid #ddd9d2;">
            <h2 style="font-family:'DM Sans',sans-serif; font-weight:700; font-size:1.0625rem; color:#082438; margin-bottom:0.875rem;">Service Providers & Analytics</h2>
            <p style="font-family:'DM Sans',sans-serif; font-size:0.9375rem; color:#3d5a6e; line-height:1.8;">We may employ third-party companies for analytics, remarketing, hosting, and support. We use <strong style="color:#082438;">Google Analytics</strong> to monitor Service usage. We may also use services like Google Ads, Facebook, and Twitter to show ads based on past visits — you can manage preferences through each platform's privacy settings.</p>
          </div>

          <!-- Children -->
          <div style="margin-bottom:2.25rem; padding-bottom:2.25rem; border-bottom:1px solid #ddd9d2;">
            <h2 style="font-family:'DM Sans',sans-serif; font-weight:700; font-size:1.0625rem; color:#082438; margin-bottom:0.875rem;">Children's Privacy</h2>
            <p style="font-family:'DM Sans',sans-serif; font-size:0.9375rem; color:#3d5a6e; line-height:1.8;">Our Service is not directed to anyone under 18. We do not knowingly collect data from minors. If we become aware of such collection, we will remove it promptly.</p>
          </div>

          <!-- Changes -->
          <div style="margin-bottom:2.25rem; padding-bottom:2.25rem; border-bottom:1px solid #ddd9d2;">
            <h2 style="font-family:'DM Sans',sans-serif; font-weight:700; font-size:1.0625rem; color:#082438; margin-bottom:0.875rem;">Changes to This Policy</h2>
            <p style="font-family:'DM Sans',sans-serif; font-size:0.9375rem; color:#3d5a6e; line-height:1.8;">We may update this Privacy Policy periodically. Changes are effective once posted on this page.</p>
          </div>

          <!-- Contact -->
          <div class="rounded-2xl p-7" style="background:#F7F2EB; border:1px solid #ddd9d2;">
            <h2 style="font-family:'DM Sans',sans-serif; font-weight:700; font-size:1.0625rem; color:#082438; margin-bottom:0.75rem;">Contact Us</h2>
            <p style="font-family:'DM Sans',sans-serif; font-size:0.9375rem; color:#3d5a6e; line-height:1.8;">
              If you have questions about this Privacy Policy, please contact us:<br/>
              <a href="mailto:info@neurosagehub.com" style="color:#2E6E8E; font-weight:600; text-decoration:underline;">info@neurosagehub.com</a>
            </p>
          </div>

        </div>
      </div>
    </section>

  </main>

  <Footer />
</BaseLayout>
