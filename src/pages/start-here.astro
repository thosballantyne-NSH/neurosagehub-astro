---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const HERO_IMG = "https://d2xsxph8kpxj0f.cloudfront.net/310519663645323174/cAF6S26VtT36Uyb4yyZGdw/nsh_parent_child-ivuL9QAhsMZpMhgtzbS5ot.webp";

// ➜ Replace with Eva's embed script src or iframe src when ready
const EVA_EMBED_SRC = ""; // e.g. "https://cdn.yourplatform.com/widget/eva.js"
---

<BaseLayout
  title="Start Here | Neurosage Hub"
  description="Not sure where to begin? Ask Eva — our AI mentor — or create your free parent account and take the Autism Pathways Quiz to get your structured next steps."
>
  <Header />

  <main>

    <!-- ===== EVA SECTION ===== -->
    <section class="py-16" style="background:oklch(0.22 0.12 258);">
      <div class="container">
        <div class="max-w-3xl mx-auto text-center mb-10">
          <p class="nsh-eyebrow mb-3 fade-up" style="color:oklch(0.75 0.12 195);">Meet Eva</p>
          <h1 class="nsh-heading-2 mb-4 fade-up" style="color:white;">
            Not sure where to start?<br>Ask Eva anything.
          </h1>
          <p class="nsh-body-lg fade-up" style="color:rgba(255,255,255,0.72); max-width:28rem; margin:0 auto;">
            Share what challenge you'd like to tackle and Eva will help you find your structured next steps.
          </p>
        </div>

        <!-- Eva embed container -->
        <div class="max-w-3xl mx-auto fade-up">
          {EVA_EMBED_SRC ? (
            <!-- Live Eva embed — swap in script or iframe here -->
            <div id="eva-widget" style="min-height:480px; border-radius:1.25rem; overflow:hidden;"></div>
          ) : (
            <!-- Placeholder until Eva embed is connected -->
            <div
              class="rounded-2xl flex flex-col items-center justify-center gap-5 text-center"
              style="background:oklch(0.28 0.10 258); border:1px solid oklch(0.35 0.10 258); min-height:380px; padding:3rem 2rem;"
            >
              <!-- Eva avatar -->
              <div class="w-20 h-20 rounded-full flex items-center justify-center" style="background:oklch(0.46 0.22 258);">
                <svg width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M12 2a10 10 0 1 0 10 10"/>
                  <path d="M12 6v6l4 2"/>
                  <circle cx="19" cy="5" r="3" fill="oklch(0.67 0.13 28)" stroke="none"/>
                </svg>
              </div>
              <div>
                <p class="font-bold text-lg mb-2" style="font-family:'DM Sans',sans-serif; color:white;">Eva is ready to help</p>
                <p class="text-sm mb-1" style="font-family:'DM Sans',sans-serif; color:rgba(255,255,255,0.5);">What challenge would you like to tackle?</p>
                <p class="text-xs mt-4" style="font-family:'DM Sans',sans-serif; color:rgba(255,255,255,0.25);">Eva embed — connect widget to activate</p>
              </div>
              <!-- Fake input bar for visual -->
              <div class="w-full max-w-lg flex items-center gap-3 px-5 py-3.5 rounded-xl" style="background:oklch(0.32 0.09 258); border:1px solid oklch(0.40 0.09 258);">
                <span style="font-family:'DM Sans',sans-serif; font-size:0.9375rem; color:rgba(255,255,255,0.3); flex:1; text-align:left;">Ask Eva a question...</span>
                <div class="w-9 h-9 rounded-lg flex items-center justify-center flex-shrink-0" style="background:oklch(0.46 0.22 258);">
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
                </div>
              </div>
            </div>
          )}
        </div>

        <p class="text-center mt-6 text-sm fade-up" style="color:rgba(255,255,255,0.3); font-family:'DM Sans',sans-serif;">
          Eva is an AI mentor. She provides educational guidance, not medical advice.
        </p>
      </div>
    </section>

    <!-- ===== DIVIDER ===== -->
    <div style="background:white; padding:2rem 0; text-align:center; border-bottom:1px solid oklch(0.92 0.03 258);">
      <p style="font-family:'DM Sans',sans-serif; font-size:0.875rem; color:oklch(0.55 0.04 258); letter-spacing:0.06em; text-transform:uppercase;">— Or, ready to get started? —</p>
    </div>

    <!-- ===== SIGN UP SECTION ===== -->
    <section id="quiz" class="py-16" style="background:oklch(0.97 0.02 258);">
      <div class="container">
        <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 lg:gap-12 items-start">

          <!-- Left: copy -->
          <div class="lg:col-span-5">
            <p class="nsh-eyebrow mb-4 fade-up" style="color:oklch(0.67 0.13 28);">For Parents Navigating Autism</p>
            <h2 class="nsh-heading-display mb-4 fade-up" style="color:oklch(0.22 0.12 258);">
              Overwhelmed by autism and don't know where to start?
            </h2>
            <div class="mb-6" style="width:3rem; height:3px; background:oklch(0.67 0.13 28); border-radius:2px;"></div>
            <p class="nsh-body-lg mb-8 fade-up" style="color:oklch(0.35 0.06 258);">
              Neurosage Hub helps families find clarity through structured pathways, educational tools, and trusted guidance.
            </p>

            <!-- Steps -->
            <div class="space-y-4 mb-8 fade-up">
              {[
                { icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 11l3 3L22 4"/><path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"/></svg>`, label: 'Take the Autism Pathways Quiz' },
                { icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"/><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"/></svg>`, label: 'Get Personalised Content & Guidance' },
                { icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="20" x2="18" y2="10"/><line x1="12" y1="20" x2="12" y2="4"/><line x1="6" y1="20" x2="6" y2="14"/></svg>`, label: 'Track Progress & Build Consistency' },
                { icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>`, label: 'Connect With Help' },
              ].map(({ icon, label }) => (
                <div class="flex items-center gap-4">
                  <div class="w-10 h-10 rounded-full flex items-center justify-center flex-shrink-0" style="background:oklch(0.46 0.22 258);">
                    <Fragment set:html={icon} />
                  </div>
                  <p class="font-semibold text-sm" style="font-family:'DM Sans',sans-serif; color:oklch(0.22 0.12 258);">{label}</p>
                </div>
              ))}
            </div>

            <!-- Trust statement -->
            <div class="flex items-start gap-3 p-4 rounded-xl fade-up" style="background:white; border:1px solid oklch(0.90 0.03 258);">
              <div class="w-9 h-9 rounded-lg flex items-center justify-center flex-shrink-0 mt-0.5" style="background:oklch(0.67 0.13 28 / 0.1);">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="oklch(0.55 0.12 28)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
              </div>
              <div>
                <p class="font-bold text-sm mb-0.5" style="font-family:'DM Sans',sans-serif; color:oklch(0.22 0.12 258);">No hype. No miracle cures.</p>
                <p class="text-sm" style="font-family:'DM Sans',sans-serif; color:oklch(0.45 0.05 258); line-height:1.6;">
                  Just proven, structured guidance designed to help families take the <strong style="color:oklch(0.46 0.22 258);">next right step.</strong>
                </p>
              </div>
            </div>
          </div>

          <!-- Center: hero image -->
          <div class="hidden lg:block lg:col-span-4 fade-up" style="transition-delay:80ms;">
            <img
              src={HERO_IMG}
              alt="Parent and child hugging"
              class="w-full rounded-2xl object-cover"
              style="min-height:500px; box-shadow:0 16px 48px oklch(0.22 0.12 258 / 0.12);"
              loading="lazy"
            />
          </div>

          <!-- Right: sign-up card -->
          <div class="lg:col-span-3 fade-up" style="transition-delay:160ms;">
            <div class="rounded-2xl p-7" style="background:white; box-shadow:0 8px 40px oklch(0.22 0.12 258 / 0.10); border:1px solid oklch(0.93 0.03 258);">

              <div class="flex justify-center mb-5">
                <img src="/logo-blue.png" alt="Neurosage Hub" class="h-10 w-auto" />
              </div>

              <h3 class="text-center font-bold mb-1" style="font-family:'DM Sans',sans-serif; font-size:1.25rem; color:oklch(0.22 0.12 258);">
                Start Your Free<br>Parent Account
              </h3>
              <div class="mx-auto mb-6" style="width:2.5rem; height:3px; background:oklch(0.67 0.13 28); border-radius:2px;"></div>

              <a
                href="https://app.neurosagehub.com/signup"
                class="nsh-btn-cta w-full justify-center mb-5"
                style="font-size:1rem; padding:0.9rem; letter-spacing:0.03em; font-weight:700;"
              >
                Sign Up Free
              </a>

              <div class="grid grid-cols-3 gap-2 pt-4" style="border-top:1px solid oklch(0.93 0.03 258);">
                {[
                  { icon: `<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="oklch(0.46 0.22 258)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>`, label: 'Secure Platform' },
                  { icon: `<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="oklch(0.46 0.22 258)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>`, label: 'No Diagnosis Required' },
                  { icon: `<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="oklch(0.46 0.22 258)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>`, label: 'Start Today' },
                ].map(({ icon, label }) => (
                  <div class="flex flex-col items-center gap-1.5 text-center">
                    <Fragment set:html={icon} />
                    <span style="font-family:'DM Sans',sans-serif; font-size:0.7rem; color:oklch(0.50 0.04 258); line-height:1.3;">{label}</span>
                  </div>
                ))}
              </div>

              <p class="text-center mt-4 text-xs" style="font-family:'DM Sans',sans-serif; color:oklch(0.60 0.04 258);">
                Already have an account?
                <a href="https://app.neurosagehub.com/login" style="color:oklch(0.46 0.22 258); font-weight:600;"> Log in</a>
              </p>
            </div>
          </div>

        </div>
      </div>
    </section>

    <!-- ===== TAGLINE ===== -->
    <div style="background:oklch(0.46 0.22 258); padding:1.25rem 0;">
      <div class="container flex items-center gap-4">
        <div class="w-10 h-10 rounded-full flex items-center justify-center flex-shrink-0" style="background:rgba(255,255,255,0.15);">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
        </div>
        <p style="font-family:'DM Sans',sans-serif; font-size:1.0625rem; color:white;">
          <strong>Build hope.</strong> Walk together.
        </p>
      </div>
    </div>

  </main>

  <Footer />
</BaseLayout>
