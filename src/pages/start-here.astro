---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const HERO_IMG = "https://d2xsxph8kpxj0f.cloudfront.net/310519663645323174/cAF6S26VtT36Uyb4yyZGdw/nsh_parent_child-ivuL9QAhsMZpMhgtzbS5ot.webp";

const EVA_EMBED_SRC = "";
---

<BaseLayout
  title="Start Here | Neurosage Hub"
  description="Not sure where to begin? Ask Eva — our AI mentor — or create your free parent account and take the Autism Pathways Quiz to get your structured next steps."
>
  <Header />

  <main>

    <!-- ===== EVA SECTION ===== -->
    <section id="eva-section" class="eva-collapsed" style="background:#082438; transition:padding 400ms ease;">
      <div class="container">
        <div id="eva-inner" class="mx-auto" style="max-width:680px;">

          <!-- ── Collapsed header (always visible) ── -->
          <div id="eva-header" class="text-center" style="padding-top:3.5rem; padding-bottom:2rem; transition:padding 300ms ease;">
            <h1 class="fade-up mb-2" style="font-family:'DM Sans',sans-serif; font-weight:800; font-size:clamp(1.75rem, 4vw, 2.5rem); color:white; line-height:1.15;">
              Where would you like to start?
            </h1>
            <p id="eva-subheading" class="fade-up" style="font-family:'DM Sans',sans-serif; font-size:1rem; color:rgba(255,255,255,0.55); transition:opacity 300ms ease, max-height 300ms ease; overflow:hidden; max-height:0; opacity:0; margin-top:0;">
              Tell Eva what's going on and she'll point you to your best next step.
            </p>
          </div>

          <!-- ── Chat UI ── -->
          <div id="eva-chat-wrap" class="fade-up" style="padding-bottom:2.5rem;">

            {EVA_EMBED_SRC ? (
              /* ── Live Eva embed ── */
              <div id="eva-widget" style="min-height:480px; border-radius:1.25rem; overflow:hidden;">
                <iframe src={EVA_EMBED_SRC} style="width:100%; height:480px; border:none;" title="Eva — Neurosage Hub AI Mentor" loading="lazy"></iframe>
              </div>
            ) : (
              /* ── Native expandable chat ── */
              <div id="eva-native" style="border-radius:1.25rem; overflow:hidden; border:1px solid rgba(255,255,255,0.10); transition:all 400ms ease;">

                <!-- Collapsed: single input bar -->
                <div
                  id="eva-collapsed-bar"
                  role="button"
                  tabindex="0"
                  onclick="expandEva()"
                  onkeydown="if(event.key==='Enter'||event.key===' ')expandEva()"
                  style="display:none; align-items:center; gap:0.875rem; padding:1rem 1.25rem; background:rgba(255,255,255,0.06); cursor:text; user-select:none;"
                >
                  <!-- Eva avatar -->
                  <div style="width:36px; height:36px; border-radius:50%; background:#123D5A; border:2px solid rgba(123,158,139,0.5); flex-shrink:0; display:flex; align-items:center; justify-content:center;">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#7B9E8B" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="8" r="4"/><path d="M4 20c0-4 3.6-7 8-7s8 3 8 7"/></svg>
                  </div>
                  <span style="font-family:'DM Sans',sans-serif; font-size:0.9375rem; color:rgba(255,255,255,0.35); flex:1;">What challenge would you like to solve?</span>
                  <div style="width:34px; height:34px; border-radius:0.5rem; background:#D8896A; flex-shrink:0; display:flex; align-items:center; justify-content:center;">
                    <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
                  </div>
                </div>

                <!-- Expanded: full chat -->
                <div id="eva-expanded" style="display:flex; flex-direction:column; background:white; border-radius:1.25rem;">

                  <!-- Chat header -->
                  <div style="display:flex; align-items:center; justify-content:space-between; padding:1rem 1.25rem; border-bottom:1px solid #ddd9d2; background:#f9f7f4; border-radius:1.25rem 1.25rem 0 0;">
                    <div style="display:flex; align-items:center; gap:0.75rem;">
                      <div style="position:relative;">
                        <div style="width:40px; height:40px; border-radius:50%; background:#123D5A; display:flex; align-items:center; justify-content:center;">
                          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#7B9E8B" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="8" r="4"/><path d="M4 20c0-4 3.6-7 8-7s8 3 8 7"/></svg>
                        </div>
                        <!-- Online dot -->
                        <div style="position:absolute; bottom:1px; right:1px; width:10px; height:10px; border-radius:50%; background:#7B9E8B; border:2px solid #f9f7f4;"></div>
                      </div>
                      <div>
                        <p style="font-family:'DM Sans',sans-serif; font-weight:700; font-size:0.9375rem; color:#082438; margin:0;">Eva</p>
                        <p style="font-family:'DM Sans',sans-serif; font-size:0.75rem; color:#7B9E8B; margin:0;">Neurosage Hub Mentor · Online</p>
                      </div>
                    </div>
                    <button
                      onclick="collapseEva()"
                      aria-label="Minimise chat"
                      style="width:32px; height:32px; border-radius:0.5rem; border:1px solid #ddd9d2; background:white; cursor:pointer; display:flex; align-items:center; justify-content:center; color:#5F6975; transition:all 160ms ease;"
                      onmouseover="this.style.background='#F7F2EB'"
                      onmouseout="this.style.background='white'"
                    >
                      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="18 15 12 9 6 15"/></svg>
                    </button>
                  </div>

                  <!-- Message thread -->
                  <div
                    id="eva-messages"
                    style="flex:1; overflow-y:auto; padding:1.25rem; display:flex; flex-direction:column; gap:1rem; min-height:280px; max-height:400px; scroll-behavior:smooth;"
                  >
                    <!-- Eva opening message -->
                    <div class="eva-msg-row eva-msg-eva" style="display:flex; align-items:flex-end; gap:0.625rem;">
                      <div style="width:30px; height:30px; border-radius:50%; background:#123D5A; flex-shrink:0; display:flex; align-items:center; justify-content:center;">
                        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="#7B9E8B" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="8" r="4"/><path d="M4 20c0-4 3.6-7 8-7s8 3 8 7"/></svg>
                      </div>
                      <div style="max-width:78%; background:#F7F2EB; border-radius:1rem 1rem 1rem 0; padding:0.75rem 1rem;">
                        <p style="font-family:'DM Sans',sans-serif; font-size:0.9375rem; color:#082438; margin:0; line-height:1.6;">Hi there 👋 I'm Eva. I'm here to help you figure out where to start on Neurosage Hub.</p>
                        <p style="font-family:'DM Sans',sans-serif; font-size:0.9375rem; color:#082438; margin:0.5rem 0 0; line-height:1.6;">Tell me a bit about what's going on for your family right now — what's the biggest challenge you're facing?</p>
                      </div>
                    </div>

                    <!-- Suggestion chips -->
                    <div id="eva-chips" style="display:flex; flex-wrap:wrap; gap:0.5rem; padding-left:2.375rem;">
                      {[
                        'Meltdowns & sensory overload',
                        'Sleep problems',
                        'Communication & connection',
                        'Building daily routines',
                        'We just got a diagnosis',
                        'I don\'t know where to start',
                      ].map((chip) => (
                        <button
                          class="eva-chip"
                          onclick={`sendChip(this, '${chip}')`}
                          style="font-family:'DM Sans',sans-serif; font-size:0.8125rem; color:#123D5A; background:white; border:1.5px solid #b8d0c8; border-radius:100px; padding:0.375rem 0.875rem; cursor:pointer; transition:all 160ms ease; white-space:nowrap;"
                          onmouseover="this.style.background='#deeae5'; this.style.borderColor='#7B9E8B';"
                          onmouseout="this.style.background='white'; this.style.borderColor='#b8d0c8';"
                        >
                          {chip}
                        </button>
                      ))}
                    </div>
                  </div>

                  <!-- Typing indicator (hidden) -->
                  <div id="eva-typing" style="display:none; padding:0 1.25rem 0.75rem; align-items:flex-end; gap:0.625rem;">
                    <div style="width:30px; height:30px; border-radius:50%; background:#123D5A; flex-shrink:0; display:flex; align-items:center; justify-content:center;">
                      <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="#7B9E8B" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="8" r="4"/><path d="M4 20c0-4 3.6-7 8-7s8 3 8 7"/></svg>
                    </div>
                    <div style="background:#F7F2EB; border-radius:1rem 1rem 1rem 0; padding:0.75rem 1rem;">
                      <div class="eva-typing-dots" style="display:flex; gap:4px; align-items:center;">
                        <span style="width:7px; height:7px; border-radius:50%; background:#5F6975; display:inline-block; animation:evaDot 1.2s infinite;"></span>
                        <span style="width:7px; height:7px; border-radius:50%; background:#5F6975; display:inline-block; animation:evaDot 1.2s 0.2s infinite;"></span>
                        <span style="width:7px; height:7px; border-radius:50%; background:#5F6975; display:inline-block; animation:evaDot 1.2s 0.4s infinite;"></span>
                      </div>
                    </div>
                  </div>

                  <!-- Input bar -->
                  <div style="padding:0.875rem 1.25rem; border-top:1px solid #ddd9d2; background:#faf9f7; border-radius:0 0 1.25rem 1.25rem; display:flex; align-items:center; gap:0.75rem;">
                    <input
                      id="eva-input"
                      type="text"
                      placeholder="Type your message…"
                      maxlength="400"
                      style="flex:1; border:1.5px solid #ddd9d2; border-radius:0.625rem; padding:0.625rem 0.875rem; font-family:'DM Sans',sans-serif; font-size:0.9375rem; color:#082438; outline:none; background:white; transition:border-color 200ms ease;"
                      onfocus="this.style.borderColor='#7B9E8B'"
                      onblur="this.style.borderColor='#ddd9d2'"
                      onkeydown="if(event.key==='Enter' && !event.shiftKey){event.preventDefault(); evaSubmit();}"
                    />
                    <button
                      onclick="evaSubmit()"
                      aria-label="Send message"
                      style="width:40px; height:40px; border-radius:0.625rem; background:#D8896A; border:none; cursor:pointer; display:flex; align-items:center; justify-content:center; flex-shrink:0; transition:all 160ms ease;"
                      onmouseover="this.style.background='#b8694a'"
                      onmouseout="this.style.background='#D8896A'"
                    >
                      <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="22" y1="2" x2="11" y2="13"/><polygon points="22 2 15 22 11 13 2 9 22 2"/></svg>
                    </button>
                  </div>

                </div><!-- /eva-expanded -->
              </div>
            )}

          </div><!-- /eva-chat-wrap -->

          <p id="eva-disclaimer" class="text-center fade-up" style="font-size:0.75rem; color:rgba(255,255,255,0.22); font-family:'DM Sans',sans-serif; padding-bottom:2rem; transition:opacity 300ms ease;">
            Eva provides educational guidance, not medical advice.
          </p>

        </div>
      </div>
    </section>

    <style>
      @keyframes evaDot {
        0%, 60%, 100% { transform: translateY(0); opacity: 0.4; }
        30%            { transform: translateY(-5px); opacity: 1; }
      }
      .eva-chip:focus-visible {
        outline: 2px solid #7B9E8B;
        outline-offset: 2px;
      }
      #eva-messages::-webkit-scrollbar { width: 4px; }
      #eva-messages::-webkit-scrollbar-track { background: transparent; }
      #eva-messages::-webkit-scrollbar-thumb { background: #ddd9d2; border-radius: 4px; }
    </style>

    <script>
      /* ─── Eva conversation responses ─── */
      const evaResponses: Record<string, { reply: string; followUp?: string }> = {
        default: {
          reply: "Thank you for sharing that. It sounds like your family is going through a really challenging time. You're in the right place.",
          followUp: "On Neurosage Hub, we have structured learning pathways, home routine guides, and therapeutic tools designed specifically for families like yours. Would you like me to point you to the best place to start?",
        },
        meltdowns: {
          reply: "Meltdowns can be overwhelming for everyone — your child and your whole family. What's often happening is a sensory or emotional nervous system response that's completely involuntary.",
          followUp: "I'd recommend starting with our **Sensory Regulation** pathway, and taking a look at our Handling Meltdowns guide. Would you like to create a free account to get started?",
        },
        sleep: {
          reply: "Sleep is one of the most common and most exhausting challenges for families navigating autism. When sleep breaks down, everything else gets harder.",
          followUp: "Our **Sleep & Regulation** pathway walks through circadian rhythm support, evening protocols, and regulation strategies that actually work at home. Would you like to explore it?",
        },
        communication: {
          reply: "Connection and communication are at the heart of everything. Whether your child is pre-verbal, developing language, or verbal but struggling to connect — there are strategies that genuinely help.",
          followUp: "The **Communication Readiness** pathway on Neurosage Hub is built for exactly this. It focuses on daily home interactions that support language and connection. Ready to dive in?",
        },
        routines: {
          reply: "Building consistent daily routines is one of the most impactful things you can do — especially for autistic children who thrive on predictability and structure.",
          followUp: "Our **Home Routines** library has complete morning, after-school, and evening protocols. And the **Home-Based Support** pathway gives you the full daily framework. Want to start there?",
        },
        diagnosis: {
          reply: "A new diagnosis can feel like the ground shifting under your feet — relief, grief, uncertainty, and hope all at once. First: you're not alone in this.",
          followUp: "The best starting point is usually our **ASD Essentials** pathway, which explains the neuroscience behind your child's behaviour and gives you the foundation to understand everything else. Would you like to begin there?",
        },
        start: {
          reply: "That's exactly why Eva is here. Not knowing where to begin is the most common thing parents tell us — and it's completely understandable given how much information is out there.",
          followUp: "The fastest way to find your starting point is our **Autism Pathways Quiz** — 7 quick questions and we'll recommend the best pathway for your family. Would you like to take it?",
        },
      };

      function getResponseKey(msg: string): string {
        const m = msg.toLowerCase();
        if (m.includes('meltdown') || m.includes('sensory') || m.includes('overload')) return 'meltdowns';
        if (m.includes('sleep') || m.includes('bedtime') || m.includes('night')) return 'sleep';
        if (m.includes('communicat') || m.includes('language') || m.includes('verbal') || m.includes('connect')) return 'communication';
        if (m.includes('routine') || m.includes('morning') || m.includes('schedule') || m.includes('structure')) return 'routines';
        if (m.includes('diagnosis') || m.includes('diagnosed') || m.includes('assessment') || m.includes('just found')) return 'diagnosis';
        if (m.includes('don\'t know') || m.includes('not sure') || m.includes('where to start') || m.includes('no idea') || m.includes('overwhelm')) return 'start';
        return 'default';
      }

      function expandEva() {
        const bar      = document.getElementById('eva-collapsed-bar');
        const expanded = document.getElementById('eva-expanded');
        const input    = document.getElementById('eva-input') as HTMLInputElement | null;
        const section  = document.getElementById('eva-section');
        const subhead  = document.getElementById('eva-subheading');

        if (!bar || !expanded) return;
        bar.style.display = 'none';
        expanded.style.display = 'flex';
        if (subhead) { subhead.style.maxHeight = '0'; subhead.style.opacity = '0'; subhead.style.marginTop = '0'; }
        if (section) section.style.paddingBottom = '0';
        setTimeout(() => input?.focus(), 50);
      }

      function collapseEva() {
        const bar      = document.getElementById('eva-collapsed-bar');
        const expanded = document.getElementById('eva-expanded');
        const subhead  = document.getElementById('eva-subheading');

        if (!bar || !expanded) return;
        expanded.style.display = 'none';
        bar.style.display = 'flex';
        if (subhead) { subhead.style.maxHeight = ''; subhead.style.opacity = '1'; subhead.style.marginTop = ''; }
      }

      function addMessage(text: string, sender: 'user' | 'eva') {
        const thread = document.getElementById('eva-messages');
        if (!thread) return;

        const row = document.createElement('div');
        row.style.cssText = 'display:flex; align-items:flex-end; gap:0.625rem;';

        if (sender === 'user') {
          row.style.flexDirection = 'row-reverse';
          const bubble = document.createElement('div');
          bubble.style.cssText = 'max-width:78%; background:#123D5A; border-radius:1rem 1rem 0 1rem; padding:0.75rem 1rem; color:white; font-family:"DM Sans",sans-serif; font-size:0.9375rem; line-height:1.6;';
          bubble.textContent = text;
          row.appendChild(bubble);
        } else {
          const avatar = document.createElement('div');
          avatar.style.cssText = 'width:30px; height:30px; border-radius:50%; background:#123D5A; flex-shrink:0; display:flex; align-items:center; justify-content:center;';
          avatar.innerHTML = '<svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="#7B9E8B" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="8" r="4"/><path d="M4 20c0-4 3.6-7 8-7s8 3 8 7"/></svg>';
          const bubble = document.createElement('div');
          bubble.style.cssText = 'max-width:78%; background:#F7F2EB; border-radius:1rem 1rem 1rem 0; padding:0.75rem 1rem; color:#082438; font-family:"DM Sans",sans-serif; font-size:0.9375rem; line-height:1.6;';
          // Convert **bold** markdown to <strong>
          bubble.innerHTML = text.replace(/\*\*(.+?)\*\*/g, '<strong>$1</strong>');
          row.appendChild(avatar);
          row.appendChild(bubble);
        }

        thread.appendChild(row);
        thread.scrollTop = thread.scrollHeight;
      }

      function showTyping() {
        const t = document.getElementById('eva-typing');
        if (t) t.style.display = 'flex';
        const thread = document.getElementById('eva-messages');
        if (thread) thread.scrollTop = thread.scrollHeight;
      }

      function hideTyping() {
        const t = document.getElementById('eva-typing');
        if (t) t.style.display = 'none';
      }

      function sendChip(btn: HTMLButtonElement, text: string) {
        // Hide chips
        const chips = document.getElementById('eva-chips');
        if (chips) chips.style.display = 'none';

        addMessage(text, 'user');
        setTimeout(() => {
          showTyping();
          const key = getResponseKey(text);
          const resp = evaResponses[key];
          setTimeout(() => {
            hideTyping();
            addMessage(resp.reply, 'eva');
            if (resp.followUp) {
              setTimeout(() => {
                showTyping();
                setTimeout(() => {
                  hideTyping();
                  addMessage(resp.followUp!, 'eva');
                  showCTAChips();
                }, 1400);
              }, 600);
            } else {
              showCTAChips();
            }
          }, 1200);
        }, 300);
      }

      function showCTAChips() {
        const thread = document.getElementById('eva-messages');
        if (!thread) return;
        const row = document.createElement('div');
        row.style.cssText = 'display:flex; flex-wrap:wrap; gap:0.5rem; padding-left:2.375rem;';
        [
          { label: 'Take the Pathways Quiz →', href: '/quiz' },
          { label: 'Create Free Account →', href: 'https://app.neurosagehub.com/signup' },
          { label: 'Ask something else', href: '' },
        ].forEach(({ label, href }) => {
          if (href) {
            const a = document.createElement('a');
            a.href = href;
            a.textContent = label;
            a.style.cssText = 'font-family:"DM Sans",sans-serif; font-size:0.8125rem; color:white; background:#123D5A; border:none; border-radius:100px; padding:0.375rem 0.875rem; cursor:pointer; text-decoration:none; white-space:nowrap; display:inline-block;';
            row.appendChild(a);
          } else {
            const b = document.createElement('button');
            b.textContent = label;
            b.style.cssText = 'font-family:"DM Sans",sans-serif; font-size:0.8125rem; color:#123D5A; background:white; border:1.5px solid #b8d0c8; border-radius:100px; padding:0.375rem 0.875rem; cursor:pointer; white-space:nowrap;';
            b.onclick = () => {
              row.remove();
              document.getElementById('eva-input')?.focus();
            };
            row.appendChild(b);
          }
        });
        thread.appendChild(row);
        thread.scrollTop = thread.scrollHeight;
      }

      function evaSubmit() {
        const input = document.getElementById('eva-input') as HTMLInputElement | null;
        if (!input) return;
        const text = input.value.trim();
        if (!text) return;
        input.value = '';

        // Hide chips if still visible
        const chips = document.getElementById('eva-chips');
        if (chips) chips.style.display = 'none';

        addMessage(text, 'user');

        setTimeout(() => {
          showTyping();
          const key = getResponseKey(text);
          const resp = evaResponses[key];
          setTimeout(() => {
            hideTyping();
            addMessage(resp.reply, 'eva');
            if (resp.followUp) {
              setTimeout(() => {
                showTyping();
                setTimeout(() => {
                  hideTyping();
                  addMessage(resp.followUp!, 'eva');
                  showCTAChips();
                }, 1400);
              }, 700);
            } else {
              showCTAChips();
            }
          }, 1300);
        }, 300);
      }
    </script>

    <!-- ===== SIGN UP SECTION ===== -->
    <section id="quiz" class="py-16" style="background:#F7F2EB;">
      <div class="container">
        <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 lg:gap-12 items-start">

          <!-- Left: copy -->
          <div class="lg:col-span-5">
            <p class="nsh-eyebrow mb-4 fade-up" style="color:#D8896A;">For Parents Navigating Autism</p>
            <h2 class="nsh-heading-display mb-4 fade-up" style="color:#082438;">
              Overwhelmed by autism and don't know where to start?
            </h2>
            <div class="mb-6" style="width:3rem; height:3px; background:#D8896A; border-radius:2px;"></div>
            <p class="nsh-body-lg mb-8 fade-up" style="color:#1F2A33;">
              Neurosage Hub helps families find clarity through structured pathways, educational tools, and trusted guidance.
            </p>

            <!-- Steps -->
            <div class="space-y-4 mb-8 fade-up">
              {[
                { icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 11l3 3L22 4"/><path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"/></svg>`, label: 'Take the Autism Pathways Quiz' },
                { icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"/><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"/></svg>`, label: 'Get Personalised Content & Guidance' },
                { icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="20" x2="18" y2="10"/><line x1="12" y1="20" x2="12" y2="4"/><line x1="6" y1="20" x2="6" y2="14"/></svg>`, label: 'Track Progress & Build Consistency' },
                { icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>`, label: 'Connect With Help' },
              ].map(({ icon, label }) => (
