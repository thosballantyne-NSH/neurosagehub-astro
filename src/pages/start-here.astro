---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const HERO_IMG = "https://d2xsxph8kpxj0f.cloudfront.net/310519663645323174/cAF6S26VtT36Uyb4yyZGdw/nsh_parent_child-ivuL9QAhsMZpMhgtzbS5ot.webp";
---

<BaseLayout
  title="Start Here | Neurosage Hub"
  description="Not sure where to begin? Tell us where you are and we'll point you to your best next step."
>
  <Header ctaText="Get FREE Access" ctaHref="/family-sign-up" />

  <main>

    <!-- ===== EVA — OPEN DIALOG ===== -->
    <section style="background:#082438; padding:4rem 0 5rem;">
      <div class="container">
        <div class="max-w-xl mx-auto">

          <!-- Label -->
          <div class="flex items-center justify-center gap-2 mb-8 fade-up">
            <img src="/sage-bubble.png" alt="Sage™" style="width:32px; height:32px; border-radius:50%; object-fit:cover; flex-shrink:0;" />
            <span style="font-family:'DM Sans',sans-serif; font-size:0.8125rem; font-weight:600; color:rgba(255,255,255,0.5); letter-spacing:0.06em; text-transform:uppercase;">Sage™ · Neurosage Guide</span>
          </div>

          <!-- Dialog box -->
          <div class="fade-up" style="background:white; border-radius:1.5rem; overflow:hidden; box-shadow:0 24px 64px rgba(0,0,0,0.25);">

            <!-- Eva message -->
            <div style="padding:1.75rem 1.75rem 0;">
              <div style="display:flex; align-items:flex-start; gap:0.875rem;">
                <img src="/sage-face.png" alt="Sage™" style="width:36px; height:36px; border-radius:50%; object-fit:cover; flex-shrink:0; margin-top:2px;" />
                <div style="background:#F7F2EB; border-radius:0 1rem 1rem 1rem; padding:1rem 1.125rem; flex:1;">
                  <p style="font-family:'DM Sans',sans-serif; font-size:0.9375rem; color:#082438; line-height:1.7; margin:0;">
                    Hi — I'm Sage™. I help families figure out where to start. <strong>Where are you right now?</strong>
                  </p>
                </div>
              </div>
            </div>

            <!-- Reply options -->
            <div style="padding:1.25rem 1.75rem 1.75rem; display:flex; flex-direction:column; gap:0.625rem;">

              <a href="/resources/assessments" data-lc-prompt="We just got a diagnosis and don't know what to do next" style="display:flex; align-items:center; padding:0.875rem 1.125rem; border-radius:0.875rem; border:1.5px solid #ddd9d2; text-decoration:none; background:white; transition:border-color 0.15s, background 0.15s;" onmouseover="this.style.borderColor='#2E6E8E'; this.style.background='#f0f6fa'" onmouseout="this.style.borderColor='#ddd9d2'; this.style.background='white'">
                <span style="font-family:'DM Sans',sans-serif; font-size:0.9375rem; color:#082438; font-weight:500;">We just got a diagnosis and don't know what to do next</span>
              </a>

              <a href="/resources/meltdowns" data-lc-prompt="We're struggling with meltdowns and need help now" style="display:flex; align-items:center; padding:0.875rem 1.125rem; border-radius:0.875rem; border:1.5px solid #ddd9d2; text-decoration:none; background:white; transition:border-color 0.15s, background 0.15s;" onmouseover="this.style.borderColor='#2E6E8E'; this.style.background='#f0f6fa'" onmouseout="this.style.borderColor='#ddd9d2'; this.style.background='white'">
                <span style="font-family:'DM Sans',sans-serif; font-size:0.9375rem; color:#082438; font-weight:500;">We're struggling with meltdowns and need help now</span>
              </a>

              <a href="/quiz" data-lc-prompt="I'm not sure where to begin — help me figure it out" style="display:flex; align-items:center; padding:0.875rem 1.125rem; border-radius:0.875rem; border:1.5px solid #ddd9d2; text-decoration:none; background:white; transition:border-color 0.15s, background 0.15s;" onmouseover="this.style.borderColor='#2E6E8E'; this.style.background='#f0f6fa'" onmouseout="this.style.borderColor='#ddd9d2'; this.style.background='white'">
                <span style="font-family:'DM Sans',sans-serif; font-size:0.9375rem; color:#082438; font-weight:500;">I'm not sure where to begin — help me figure it out</span>
              </a>

              <a href="/games" style="display:flex; align-items:center; padding:0.875rem 1.125rem; border-radius:0.875rem; border:1.5px solid #ddd9d2; text-decoration:none; background:white; transition:border-color 0.15s, background 0.15s;" onmouseover="this.style.borderColor='#2E6E8E'; this.style.background='#f0f6fa'" onmouseout="this.style.borderColor='#ddd9d2'; this.style.background='white'">
                <span style="font-family:'DM Sans',sans-serif; font-size:0.9375rem; color:#082438; font-weight:500;">I'm looking for activities and games we can do at home</span>
              </a>

              <a href="/for-practitioners" style="display:flex; align-items:center; padding:0.875rem 1.125rem; border-radius:0.875rem; border:1.5px solid #ddd9d2; text-decoration:none; background:white; transition:border-color 0.15s, background 0.15s;" onmouseover="this.style.borderColor='#2E6E8E'; this.style.background='#f0f6fa'" onmouseout="this.style.borderColor='#ddd9d2'; this.style.background='white'">
                <span style="font-family:'DM Sans',sans-serif; font-size:0.9375rem; color:#082438; font-weight:500;">I'm a practitioner looking to support my families</span>
              </a>

              <!-- Other: open text input -->
              <div style="margin-top:0.25rem; border-top:1px solid #f0ede8; padding-top:0.875rem;">
                <p style="font-family:'DM Sans',sans-serif; font-size:0.8125rem; font-weight:600; color:#9a9187; margin:0 0 0.5rem 0.25rem;">Something else?</p>
                <div id="eva-other-form" style="display:flex; gap:0.5rem;">
                  <input
                    id="eva-other-input"
                    type="text"
                    placeholder="Tell me where you want to go…"
                    style="flex:1; font-family:'DM Sans',sans-serif; font-size:0.9375rem; color:#082438; background:#F7F2EB; border:1.5px solid #ddd9d2; border-radius:0.875rem; padding:0.75rem 1rem; outline:none; transition:border-color 0.15s;"
                    onfocus="this.style.borderColor='#2E6E8E'"
                    onblur="this.style.borderColor='#ddd9d2'"
                  />
                  <button
                    id="eva-other-send"
                    onclick="evaHandleOther()"
                    style="width:44px; height:44px; border-radius:0.875rem; background:#2E6E8E; border:none; cursor:pointer; display:flex; align-items:center; justify-content:center; flex-shrink:0; transition:background 0.15s;"
                    onmouseover="this.style.background='#1A4A6B'"
                    onmouseout="this.style.background='#2E6E8E'"
                    aria-label="Send"
                  >
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="22" y1="2" x2="11" y2="13"/><polygon points="22 2 15 22 11 13 2 9 22 2"/></svg>
                  </button>
                </div>
                <!-- Eva reply bubble (hidden until user sends) -->
                <div id="eva-other-reply" style="display:none; margin-top:0.875rem; padding:0.875rem 1rem; background:#F7F2EB; border-radius:0.75rem;">
                  <div style="display:flex; align-items:flex-start; gap:0.625rem;">
                    <img src="/sage-face.png" alt="Sage™" style="width:28px; height:28px; border-radius:50%; object-fit:cover; flex-shrink:0; margin-top:1px;" />
                    <p id="eva-other-reply-text" style="font-family:'DM Sans',sans-serif; font-size:0.875rem; color:#082438; line-height:1.65; margin:0;"></p>
                  </div>
                </div>
              </div>

            </div>

          </div>

          <p class="fade-up text-center mt-5" style="font-family:'DM Sans',sans-serif; font-size:0.75rem; color:rgba(255,255,255,0.25);">
            Sage™ provides educational guidance, not medical advice.
          </p>

        </div>
      </div>
    </section>

    <!-- ===== SIGN UP SECTION ===== -->
    <section id="quiz" class="py-16" style="background:#F7F2EB;">
      <div class="container">
        <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 lg:gap-12 items-start">

          <!-- Left: copy -->
          <div class="lg:col-span-5">
            <p class="nsh-eyebrow mb-4 fade-up" style="color:#D8896A;">For Parents Navigating Autism</p>
            <h2 class="nsh-heading-display mb-4 fade-up" style="color:#082438;">
              Overwhelmed by autism and don't know where to start?
            </h2>
            <div class="mb-6" style="width:3rem; height:3px; background:#D8896A; border-radius:2px;"></div>
            <p class="nsh-body-lg mb-8 fade-up" style="color:#1F2A33;">
              Neurosage Hub helps families find clarity through structured pathways, educational tools, and trusted guidance.
            </p>

            <!-- Steps -->
            <div class="space-y-4 mb-8 fade-up">
              {[
                { icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 11l3 3L22 4"/><path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"/></svg>`, label: 'Take the Autism Pathways Quiz' },
                { icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"/><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"/></svg>`, label: 'Get Personalized Content & Guidance' },
                { icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="20" x2="18" y2="10"/><line x1="12" y1="20" x2="12" y2="4"/><line x1="6" y1="20" x2="6" y2="14"/></svg>`, label: 'Track Progress & Build Consistency' },
                { icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>`, label: 'Connect With Help' },
              ].map(({ icon, label }) => (
                <div class="flex items-center gap-4">
                  <div class="w-10 h-10 rounded-full flex items-center justify-center flex-shrink-0" style="background:#123D5A;">
                    <Fragment set:html={icon} />
                  </div>
                  <p class="font-semibold text-sm" style="font-family:'DM Sans',sans-serif; color:#082438;">{label}</p>
                </div>
              ))}
            </div>

            <!-- CTA to quiz page -->
            <a href="/quiz" class="nsh-btn-cta fade-up" style="font-size:1rem; padding:0.9rem 1.75rem;">
              Take the Autism Pathways Quiz
              <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
            </a>

            <!-- Trust statement -->
            <div class="flex items-start gap-3 p-4 rounded-xl fade-up mt-6" style="background:white; border:1px solid #ddd9d2;">
              <div class="w-9 h-9 rounded-lg flex items-center justify-center flex-shrink-0 mt-0.5" style="background:rgba(216,137,106,0.1);">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#b8694a" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
              </div>
              <div>
                <p class="font-bold text-sm mb-0.5" style="font-family:'DM Sans',sans-serif; color:#082438;">No hype. No miracle cures.</p>
                <p class="text-sm" style="font-family:'DM Sans',sans-serif; color:#3d4f5c; line-height:1.6;">
                  Just proven, structured guidance designed to help families take the <strong style="color:#123D5A;">next right step.</strong>
                </p>
              </div>
            </div>
          </div>

          <!-- Center: hero image -->
          <div class="hidden lg:block lg:col-span-4 fade-up" style="transition-delay:80ms;">
            <img
              src={HERO_IMG}
              alt="Parent and child hugging"
              class="w-full rounded-2xl object-cover"
              style="min-height:500px; box-shadow:0 16px 48px rgba(8,36,56,0.12);"
              loading="lazy"
            />
          </div>

          <!-- Right: sign-up card -->
          <div class="lg:col-span-3 fade-up" style="transition-delay:160ms;">
            <div class="rounded-2xl p-7" style="background:white; box-shadow:0 8px 40px rgba(8,36,56,0.10); border:1px solid #e5e1da;">

              <div class="flex justify-center mb-5">
                <img src="/logo-blue.png" alt="Neurosage Hub" class="h-10 w-auto" />
              </div>

              <h3 class="text-center font-bold mb-1" style="font-family:'DM Sans',sans-serif; font-size:1.25rem; color:#082438;">
                Start Your Free<br>Parent Account
              </h3>
              <div class="mx-auto mb-6" style="width:2.5rem; height:3px; background:#D8896A; border-radius:2px;"></div>

              <a
                href="/family-sign-up"
                class="nsh-btn-cta w-full justify-center mb-5"
                style="font-size:1rem; padding:0.9rem; letter-spacing:0.03em; font-weight:700;"
              >
                Sign Up Free
              </a>

              <div class="grid grid-cols-3 gap-2 pt-4" style="border-top:1px solid #e5e1da;">
                {[
                  { icon: `<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#123D5A" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>`, label: 'Secure Platform' },
                  { icon: `<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#123D5A" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>`, label: 'No Diagnosis Required' },
                  { icon: `<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#123D5A" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>`, label: 'Start Today' },
                ].map(({ icon, label }) => (
                  <div class="flex flex-col items-center gap-1.5 text-center">
                    <Fragment set:html={icon} />
                    <span style="font-family:'DM Sans',sans-serif; font-size:0.7rem; color:#5F6975; line-height:1.3;">{label}</span>
                  </div>
                ))}
              </div>

              <p class="text-center mt-4 text-xs" style="font-family:'DM Sans',sans-serif; color:#6B7A86;">
                Already have an account?
                <a href="https://app.neurosagehub.com/login" style="color:#123D5A; font-weight:600;"> Log in</a>
              </p>
            </div>
          </div>

        </div>
      </div>
    </section>

    <!-- ===== RESOURCES ===== -->
    <section id="resources" class="py-16" style="background:white;">
      <div class="container">
        <div class="max-w-2xl mx-auto text-center mb-10">
          <p class="nsh-eyebrow mb-3 fade-up" style="color:#D8896A;">Explore Resources</p>
          <h2 class="nsh-heading-2 fade-up" style="color:#082438;">Start with what matters most to you.</h2>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">

          <!-- Video Games -->
          <div class="nsh-card p-6 flex flex-col fade-up" style="transition-delay:0ms;">
            <div class="w-11 h-11 rounded-xl flex items-center justify-center mb-5 flex-shrink-0" style="background:#deeae5; color:#123D5A;">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="6" width="20" height="12" rx="3"/><path d="M8 12h.01M12 10v4M10 12h4"/></svg>
            </div>
            <p class="nsh-eyebrow mb-2" style="color:#123D5A; font-size:0.65rem;">Featured</p>
            <h3 class="nsh-heading-3 mb-2">Therapeutic Video Games</h3>
            <p class="nsh-body flex-1" style="font-size:0.9rem;">13 years of research turned into games that support regulation, social processing, and focus — built for autistic kids.</p>
            <div class="mt-5 flex flex-col gap-2">
              <a href="/games" class="nsh-btn-cta justify-center" style="font-size:0.875rem; padding:0.625rem 1rem;">Explore Sensory Games</a>
            </div>
          </div>

          <!-- Handling Meltdowns -->
          <div class="nsh-card p-6 flex flex-col fade-up" style="transition-delay:70ms;">
            <div class="w-11 h-11 rounded-xl flex items-center justify-center mb-5 flex-shrink-0" style="background:#fef5f0; color:#b8694a;">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M18 8h1a4 4 0 0 1 0 8h-1"/><path d="M2 8h16v9a4 4 0 0 1-4 4H6a4 4 0 0 1-4-4V8z"/><line x1="6" y1="1" x2="6" y2="4"/><line x1="10" y1="1" x2="10" y2="4"/><line x1="14" y1="1" x2="14" y2="4"/></svg>
            </div>
            <p class="nsh-eyebrow mb-2" style="color:#D8896A; font-size:0.65rem;">Guide</p>
            <h3 class="nsh-heading-3 mb-2">Handling Meltdowns</h3>
            <p class="nsh-body flex-1" style="font-size:0.9rem;">What's really happening during a meltdown — and what actually helps. Practical strategies for in-the-moment and prevention.</p>
            <div class="mt-5">
              <a href="/resources/meltdowns" class="nsh-btn-secondary w-full justify-center" style="font-size:0.875rem; padding:0.625rem 1rem;">Read the Guide</a>
            </div>
          </div>

          <!-- Understanding Diagnosis -->
          <div class="nsh-card p-6 flex flex-col fade-up" style="transition-delay:140ms;">
            <div class="w-11 h-11 rounded-xl flex items-center justify-center mb-5 flex-shrink-0" style="background:#deeae5; color:#123D5A;">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><polyline points="10 9 9 9 8 9"/></svg>
            </div>
            <p class="nsh-eyebrow mb-2" style="color:#123D5A; font-size:0.65rem;">Guide</p>
            <h3 class="nsh-heading-3 mb-2">Understanding Diagnosis</h3>
            <p class="nsh-body flex-1" style="font-size:0.9rem;">What the assessment process looks like, what the results mean, and how to use a diagnosis as a starting point — not a label.</p>
            <div class="mt-5">
              <a href="/resources/assessments" class="nsh-btn-secondary w-full justify-center" style="font-size:0.875rem; padding:0.625rem 1rem;">Read the Guide</a>
            </div>
          </div>

          <!-- Nutrition -->
          <div class="nsh-card p-6 flex flex-col fade-up" style="transition-delay:210ms;">
            <div class="w-11 h-11 rounded-xl flex items-center justify-center mb-5 flex-shrink-0" style="background:#fef5f0; color:#b8694a;">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2a10 10 0 1 0 0 20A10 10 0 0 0 12 2z"/><path d="M12 8v4l3 3"/><path d="M9.5 9.5c.5-1.5 2-2.5 3.5-2"/></svg>
            </div>
            <p class="nsh-eyebrow mb-2" style="color:#D8896A; font-size:0.65rem;">Guide</p>
            <h3 class="nsh-heading-3 mb-2">Nutrition & Diet</h3>
            <p class="nsh-body flex-1" style="font-size:0.9rem;">The gut-brain connection, sensory food challenges, and dietary approaches that have shown real impact for autistic children.</p>
            <div class="mt-5">
              <a href="/resources/nutrition" class="nsh-btn-secondary w-full justify-center" style="font-size:0.875rem; padding:0.625rem 1rem;">Read the Guide</a>
            </div>
          </div>

        </div>

        <!-- Browse all resources link -->
        <div class="mt-10 text-center fade-up">
          <a
            href="/resources"
            style="display:inline-flex; align-items:center; gap:0.5rem; font-family:'DM Sans',sans-serif; font-size:0.9375rem; font-weight:600; color:#2E6E8E; text-decoration:none; padding:0.75rem 1.5rem; border-radius:9999px; border:1.5px solid #2E6E8E; transition:background 0.15s;"
            onmouseover="this.style.background='#E4EFF6'"
            onmouseout="this.style.background='transparent'"
          >
            Browse all resources
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
          </a>
        </div>

      </div>
    </section>

    <!-- ===== TAGLINE ===== -->
    <div style="background:#123D5A; padding:1.25rem 0;">
      <div class="container flex items-center gap-4">
        <div class="w-10 h-10 rounded-full flex items-center justify-center flex-shrink-0" style="background:rgba(255,255,255,0.15);">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
        </div>
        <p style="font-family:'DM Sans',sans-serif; font-size:1.0625rem; color:white;">
          <strong>Build hope.</strong> Walk together.
        </p>
      </div>
    </div>

  </main>

  <Footer />

  <script is:inline>
    function evaHandleOther() {
      var input = document.getElementById('eva-other-input');
      var reply = document.getElementById('eva-other-reply');
      var replyText = document.getElementById('eva-other-reply-text');
      var val = (input.value || '').trim();
      if (!val) return;

      // Disable input while "replying"
      input.disabled = true;
      input.style.opacity = '0.5';

      // Simple keyword routing
      var lower = val.toLowerCase();
      var msg = '';

      if (lower.match(/sleep|bedtime|night|wak/)) {
        msg = 'Sleep is a big one for many families. Head to our <a href="/resources/sleep" style="color:#2E6E8E; font-weight:600;">Sleep hub</a> — we\'re building guides there now.';
      } else if (lower.match(/communicat|speech|talk|language|word/)) {
        msg = 'Communication support is something we cover. Start in our <a href="/resources/communication" style="color:#2E6E8E; font-weight:600;">Communication hub</a> for guidance and tools.';
      } else if (lower.match(/behav|stimm|self.harm|aggress|bite|hit/)) {
        msg = 'That sounds really hard. Our <a href="/resources/behavior" style="color:#2E6E8E; font-weight:600;">Behaviour hub</a> has strategies that can help — and a practitioner partnership might be worth exploring too.';
      } else if (lower.match(/diet|food|eat|gut|nutrition|feed/)) {
        msg = 'Nutrition and sensory feeding challenges are closely connected. Check out our <a href="/resources/nutrition" style="color:#2E6E8E; font-weight:600;">Nutrition hub</a> for where to start.';
      } else if (lower.match(/routine|schedule|transit|morning|change/)) {
        msg = 'Routines can make or break a day. Our <a href="/resources/routines" style="color:#2E6E8E; font-weight:600;">Routines hub</a> walks through building structure that actually holds.';
      } else if (lower.match(/sensory|overwhelm|noise|light|touch|smell/)) {
        msg = 'Sensory processing is often at the root of a lot of challenges. Start in our <a href="/resources/sensory-processing" style="color:#2E6E8E; font-weight:600;">Sensory Processing hub</a>.';
      } else if (lower.match(/game|play|activ|fun|home/)) {
        msg = 'We\'ve got therapeutic games built for autistic kids — 13 years of research in every one. <a href="/games" style="color:#2E6E8E; font-weight:600;">Explore the games →</a>';
      } else if (lower.match(/school|teacher|classroom|iep|aide/)) {
        msg = 'School support is a big part of the picture. Our <a href="/resources" style="color:#2E6E8E; font-weight:600;">Resource Centre</a> has guides across regulation and communication that translate well to school settings.';
      } else if (lower.match(/practi|therapist|clinician|provider|doctor/)) {
        msg = 'It sounds like you may be a clinician or work with one. <a href="/for-practitioners" style="color:#2E6E8E; font-weight:600;">Our practitioner page</a> covers how we partner with therapists, OTs, and specialists.';
      } else {
        msg = 'Thanks for sharing that. Our <a href="/resources" style="color:#2E6E8E; font-weight:600;">Resource Centre</a> is the best place to start — browse by topic and find what\'s most relevant to where you are right now.';
      }

      replyText.innerHTML = msg;
      reply.style.display = 'block';
    }

    // Allow Enter key to submit
    document.getElementById('eva-other-input').addEventListener('keydown', function(e) {
      if (e.key === 'Enter') evaHandleOther();
    });

    // ── Wire option links → LC chat ──────────────────────────────
    // Each link has data-lc-prompt with the selection text.
    // If nshOpenLC is ready, open the chat with that context.
    // If not yet ready, fall through to normal navigation.
    document.querySelectorAll('[data-lc-prompt]').forEach(function(el) {
      el.addEventListener('click', function(e) {
        var prompt = el.getAttribute('data-lc-prompt');
        if (typeof window.nshOpenLC === 'function') {
          e.preventDefault();
          window.nshOpenLC(prompt);
        }
        // else: LC not loaded → href navigates normally (safe fallback)
      });
    });

    // ── Wire "Something else?" input → LC chat ───────────────────
    // Override evaHandleOther to open LC with the typed text
    // instead of (or after) showing the keyword-matched reply.
    var _origEvaHandle = evaHandleOther;
    evaHandleOther = function() {
      var input = document.getElementById('eva-other-input');
      var val   = (input ? input.value : '').trim();
      if (val && typeof window.nshOpenLC === 'function') {
        window.nshOpenLC(val);
        return;
      }
      _origEvaHandle(); // fallback to keyword reply if LC not ready
    };
  </script>

</BaseLayout>
