---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout
  title="Autism-Friendly Video Games | Neurosage Hub"
  description="A library of video games designed specifically for autistic children — built to support regulation, social processing, and focused attention. Free for families. Available as a clinical tool for practitioners."
>
  <Header />

  <main>

    <!-- ===== HERO ===== -->
    <section class="relative overflow-hidden" style="background:#082438; min-height:520px;">
      <!-- Neural network graphic — decorative right panel -->
      <div class="absolute right-0 top-0 bottom-0 hidden md:block" style="width:45%; opacity:0.55;">
        <img
          src="/games-neural.jpg"
          alt=""
          aria-hidden="true"
          class="w-full h-full object-cover object-left"
        />
        <!-- fade-left overlay -->
        <div class="absolute inset-0" style="background:linear-gradient(to right, #082438 0%, transparent 40%);"></div>
      </div>

      <div class="container relative py-20">
        <div class="max-w-2xl">
          <p class="nsh-eyebrow mb-4 fade-up" style="color:#7B9E8B;">Inside the Hub</p>
          <h1 class="nsh-heading-display mb-6 fade-up" style="color:white;">
            Play Is Development.<br>We Built the Games to Prove It.
          </h1>
          <p class="nsh-body-lg mb-8 fade-up" style="color:rgba(255,255,255,0.8); max-width:36rem;">
            Neurosage Hub includes a growing library of video games purposefully designed for autistic children — not games that happen to be popular, but games built around neurological development, regulation, and focused engagement.
          </p>
          <div class="flex flex-wrap gap-4 fade-up">
            <a href="/games/play-free" class="nsh-btn-cta">
              Kids Play for Free
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
            </a>
            <a href="#clinic" class="nsh-btn-secondary" style="border-color:rgba(255,255,255,0.35); color:white;">
              Use Games in Your Clinic
            </a>
          </div>
        </div>
      </div>
    </section>

    <!-- ===== WHY GAMES ===== -->
    <section class="py-20" style="background:white;">
      <div class="container">
        <div class="max-w-2xl mx-auto text-center mb-14">
          <p class="nsh-eyebrow mb-4 fade-up">The Science Behind It</p>
          <h2 class="nsh-heading-2 mb-4 fade-up">Why Video Games — and Why These Specific Games</h2>
          <p class="nsh-body fade-up">
            Play-based engagement isn't a compromise. For many autistic children, video games are among the highest-engagement environments they experience. The question isn't whether they'll play — it's what they're playing and whether it's working for them.
          </p>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
          {[
            {
              icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3"/><line x1="12" y1="17" x2="12.01" y2="17"/><circle cx="12" cy="12" r="10"/></svg>`,
              title: 'Built Around Regulation',
              desc: 'Every game in the library is designed with nervous system regulation in mind — pacing, sensory input, and reward structures that support rather than overstimulate.',
            },
            {
              icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>`,
              title: 'Social Processing Support',
              desc: 'Games that model turn-taking, cause and effect, and social scenarios in low-pressure environments — practice that transfers to real-world interaction.',
            },
            {
              icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>`,
              title: 'Progress You Can Track',
              desc: 'Play sessions generate data that families and practitioners can review — time on task, engagement patterns, and behavioral observations over time.',
            },
          ].map(({ icon, title, desc }, i) => (
            <div class="nsh-card p-7 fade-up" style={`transition-delay:${i * 80}ms;`}>
              <div class="w-12 h-12 rounded-xl flex items-center justify-center mb-5" style="background:#F7F2EB; color:#123D5A;">
                <Fragment set:html={icon} />
              </div>
              <h3 class="nsh-heading-3 mb-3">{title}</h3>
              <p class="nsh-body">{desc}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ===== FOR FAMILIES ===== -->
    <section class="py-20" style="background:#f9f7f4;">
      <div class="container">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
          <div>
            <p class="nsh-eyebrow mb-4 fade-up" style="color:#D8896A;">For Families</p>
            <h2 class="nsh-heading-2 mb-5 fade-up">Your child already wants to play.<br>Now it counts for something.</h2>
            <p class="nsh-body-lg mb-4 fade-up">
              Free accounts include one game to get started. Upgrade to Full Access ($199/year) to unlock all 6 games — included alongside your learning pathways and home routines, no separate download required.
            </p>
            <p class="nsh-body mb-8 fade-up">
              You don't have to choose between screen time and support. These games are designed to work together with your broader home routine — not replace it.
            </p>
            <div class="flex flex-wrap gap-4 fade-up">
              <a href="/games/play-free" class="nsh-btn-cta">
                Kids Play for Free
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
              </a>
              <a href="/quiz" class="nsh-btn-secondary">
                Take the Quiz First
              </a>
            </div>
          </div>
          <div class="fade-up rounded-2xl flex items-center justify-center" style="background:#082438; min-height:320px; border:1px solid #0d2d42;">
            <div class="text-center p-8">
              <div class="w-16 h-16 rounded-2xl flex items-center justify-center mx-auto mb-4" style="background:#123D5A;">
                <svg width="30" height="30" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="6" width="20" height="12" rx="3"/><path d="M8 12h.01M12 10v4M10 12h4"/></svg>
              </div>
              <p class="font-bold text-white mb-1" style="font-family:'DM Sans',sans-serif; font-size:1.125rem;">Game Library</p>
              <p style="font-family:'DM Sans',sans-serif; color:rgba(255,255,255,0.5); font-size:0.875rem;">Available inside the Hub</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ===== FOR CLINICS ===== -->
    <section id="clinic" class="py-20" style="background:white;">
      <div class="container">

        <!-- Origin story -->
        <div class="max-w-3xl mx-auto mb-16 text-center">
          <p class="nsh-eyebrow mb-4 fade-up">For Practitioners &amp; Clinics</p>
          <h2 class="nsh-heading-2 mb-6 fade-up">
            While everyone said "video games are bad," <br class="hidden lg:block"/>Dr. Kyle asked a different question.
          </h2>
          <blockquote class="fade-up" style="border-left:3px solid #D8896A; padding:1rem 1.5rem; text-align:left; background:#f9f7f4; border-radius:0 0.75rem 0.75rem 0; margin-bottom:1.5rem;">
            <p style="font-family:'DM Sans',sans-serif; font-size:1.125rem; color:#082438; font-style:italic; line-height:1.65;">
              "How do we make the games these kids are already attracted to into a therapy tool?"
            </p>
            <footer class="mt-2 text-sm font-semibold" style="font-family:'DM Sans',sans-serif; color:#5F6975;">— Dr. Kyle</footer>
          </blockquote>
          <p class="nsh-body-lg fade-up">
            That question drove more than 13 years of research, refinement, and clinical application. What started as an experiment in his own clinic became a proven protocol — and now it's a tool you can use in yours.
          </p>
        </div>

        <!-- How it works in clinic -->
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-5 mb-16">
          {[
            { label: 'Session Start',    desc: 'Use as a structured warm-up to ease the transition into the clinical environment and build a predictable routine.' },
            { label: 'Calm Down',        desc: 'When a child is dysregulated, games provide a familiar, low-demand activity that supports nervous system reset.' },
            { label: 'Ground & Focus',   desc: 'Use before a demanding task to bring attention online — the same way a sensory warm-up prepares the body for learning.' },
            { label: 'Reward & Incentive', desc: 'Kids look forward to game time. That anticipation becomes a powerful motivator for engagement throughout the session.' },
          ].map(({ label, desc }, i) => (
            <div class="rounded-xl p-6 fade-up" style={`background:#F7F2EB; border:1px solid #deeae5; transition-delay:${i * 60}ms;`}>
              <div class="w-9 h-9 rounded-lg flex items-center justify-center mb-4" style="background:#123D5A;">
                <span class="text-xs font-bold text-white" style="font-family:'DM Sans',sans-serif;">{String(i + 1).padStart(2, '0')}</span>
              </div>
              <p class="font-bold mb-2" style="font-family:'DM Sans',sans-serif; font-size:0.9375rem; color:#082438;">{label}</p>
              <p style="font-family:'DM Sans',sans-serif; font-size:0.875rem; color:#3d5a6e; line-height:1.65;">{desc}</p>
            </div>
          ))}
        </div>

        <!-- Bridge to home + reporting -->
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 mb-12">

          <div class="rounded-2xl p-8 fade-up" style="background:#082438;">
            <div class="w-12 h-12 rounded-xl flex items-center justify-center mb-5" style="background:rgba(216,137,106,0.2);">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#e8a080" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
            </div>
            <h3 class="mb-3 font-bold" style="font-family:'DM Sans',sans-serif; font-size:1.0625rem; color:white;">The Tool Goes Home With the Family</h3>
            <p style="font-family:'DM Sans',sans-serif; font-size:0.9375rem; color:rgba(255,255,255,0.7); line-height:1.7;">
              Parents get the same game library in their account. They can use it for <strong style="color:white;">bedtime regulation</strong> — winding the nervous system down before sleep — and <strong style="color:white;">morning brain stimulation</strong> to help the child transition into the day. The clinical protocol becomes a home routine.
            </p>
          </div>

          <div class="rounded-2xl p-8 fade-up" style="background:#f9f7f4; border:1px solid #deeae5; transition-delay:80ms;">
            <div class="w-12 h-12 rounded-xl flex items-center justify-center mb-5" style="background:#F7F2EB;">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#123D5A" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="20" x2="18" y2="10"/><line x1="12" y1="20" x2="12" y2="4"/><line x1="6" y1="20" x2="6" y2="14"/></svg>
            </div>
            <h3 class="nsh-heading-3 mb-3">You See Everything in the Hub</h3>
            <p class="nsh-body" style="color:#123D5A;">
              Usage logs and reporting in the Neurosage Hub practitioner portal let you see how and when a child engages with the games at home. Add games to the protocols your clinic assigns — and track compliance alongside your other home activities.
            </p>
          </div>

        </div>

        <div class="text-center fade-up">
          <a href="/for-practitioners#demo" class="nsh-btn-primary">
            Use Games in Your Clinic
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
          </a>
        </div>

      </div>
    </section>

    <!-- ===== PODCAST TIE-IN ===== -->
    <section class="py-16" style="background:#f9f7f4;">
      <div class="container">
        <div class="max-w-3xl mx-auto">
          <div class="nsh-card p-8 md:p-10 flex flex-col md:flex-row items-start gap-6 fade-up">
            <div class="w-14 h-14 rounded-xl flex items-center justify-center flex-shrink-0" style="background:#123D5A;">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="white"><polygon points="6 3 20 12 6 21 6 3"/></svg>
            </div>
            <div>
              <p class="nsh-eyebrow mb-2" style="color:#D8896A;">From the Podcast</p>
              <h3 class="nsh-heading-3 mb-2">The Surprising Connection Between Autism and Video Games</h3>
              <p class="nsh-body mb-4">
                Dr. Kyle shares how a speech therapist's question sparked more than 13 years of research into video games as a therapeutic and developmental tool for autistic children.
              </p>
              <a href="/practitioner-perspectives" class="nsh-btn-primary" style="font-size:0.875rem; padding:0.5rem 1.25rem;">
                Listen to the Episode
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
              </a>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ===== FINAL CTA ===== -->
    <section class="py-20 relative overflow-hidden">
      <div class="absolute inset-0" style="background:linear-gradient(135deg, #123D5A 0%, #123D5A 100%);"></div>
      <div class="container relative z-10">
        <div class="max-w-xl mx-auto text-center">
          <h2 class="nsh-heading-2 mb-5 fade-up" style="color:white;">Ready to get started?</h2>
          <p class="nsh-body-lg mb-8 fade-up" style="color:rgba(255,255,255,0.8);">
            Create a free account to play your first game — or unlock all 8 with Full Access.
          </p>
          <div class="flex flex-col sm:flex-row gap-4 justify-center fade-up">
            <a href="/family-sign-up" class="nsh-btn-cta" style="font-size:1.0625rem; padding:1rem 2rem;">
              Get Started Free
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
            </a>
            <a href="/for-practitioners#demo" class="nsh-btn-secondary" style="border-color:rgba(255,255,255,0.4); color:white;">
              Use Games in Your Clinic
            </a>
          </div>
        </div>
      </div>
    </section>

  </main>

  <Footer />
</BaseLayout>
