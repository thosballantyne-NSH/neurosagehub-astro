---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout
  title="For Parents | Neurosage Hub"
  description="Neurosage Hub is built for parents who want to understand their child's nervous system and build consistent, calming support at home — no therapy degree required."
>
  <Header />
  <main class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-20">
    <h1 class="text-display font-bold text-stone-900 mb-4">Support that starts at home</h1>
    <p class="text-xl text-stone-500 leading-relaxed mb-10">
      You don't need to become a therapist. You need a clear plan, the right information, and small consistent routines you can actually do together.
    </p>
    <div class="prose prose-stone max-w-none">
      <p class="text-stone-500 text-sm italic">Full page content goes here (Day 8 of build timeline).</p>
    </div>
  </main>
  <Footer />
</BaseLayout>
