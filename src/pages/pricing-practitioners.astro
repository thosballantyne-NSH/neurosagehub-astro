---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout
  title="Practitioner Pricing | Neurosage Hub"
  description="Partner with Neurosage Hub. A branded clinical portal, revenue sharing, and a direct bridge between your sessions and your families' homes."
>
  <Header />

  <main>

    <!-- ===== HERO ===== -->
    <section class="py-20" style="background:#082438;">
      <div class="container">
        <div class="max-w-2xl mx-auto text-center">
          <p class="nsh-eyebrow mb-4 fade-up" style="color:#7B9E8B;">Practitioner Partnership</p>
          <h1 class="fade-up mb-5" style="font-family:'DM Sans',sans-serif; font-weight:800; font-size:clamp(2rem,5vw,3rem); color:white; line-height:1.1;">
            You have 50 minutes.<br>They have 10,080.
          </h1>
          <p class="fade-up" style="font-family:'DM Sans',sans-serif; font-size:1.125rem; color:rgba(255,255,255,0.68); line-height:1.75; max-width:34rem; margin:0 auto 1.5rem;">
            Bridge the gap between your sessions and your families' homes — with your own branded portal, structured parent pathways, and a revenue share model that rewards your impact.
          </p>
          <a href="/pricing" class="fade-up inline-flex items-center gap-1.5 text-sm font-semibold" style="font-family:'DM Sans',sans-serif; color:rgba(255,255,255,0.40); text-decoration:underline; text-underline-offset:3px;">
            Looking for family pricing? Click here →
          </a>
        </div>
      </div>
    </section>

    <!-- ===== MAIN PLAN ===== -->
    <section class="py-20" style="background:#F7F2EB;">
      <div class="container">
        <div class="max-w-4xl mx-auto">

          <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 items-start">

            <!-- Pricing card -->
            <div class="rounded-2xl p-8 fade-up" style="background:#082438; border:2px solid #2E6E8E;">
              <p class="nsh-eyebrow mb-3" style="color:#7B9E8B;">Clinical Partnership Plan</p>
              <h2 style="font-family:'DM Sans',sans-serif; font-weight:800; font-size:1.75rem; color:white; margin-bottom:0.375rem;">Branded Portal</h2>
              <div style="margin-bottom:0.5rem;">
                <span style="font-family:'DM Sans',sans-serif; font-size:3rem; font-weight:800; color:white; line-height:1;">$495</span>
                <span style="font-family:'DM Sans',sans-serif; font-size:1rem; color:rgba(255,255,255,0.5);"> / month</span>
              </div>
              <p style="font-family:'DM Sans',sans-serif; font-size:0.875rem; color:#7B9E8B; font-weight:600; margin-bottom:1.25rem;">+ Revenue sharing from client participation</p>

              <a href="/for-practitioners#demo" class="nsh-btn-cta w-full justify-center mb-6" style="display:flex;">
                Contact Us About Partnership
              </a>

              <ul class="space-y-3">
                {[
                  'Your own branded Neurosage portal',
                  'Assign pathways & protocols to your patients',
                  'Track family compliance between visits',
                  'All parent-facing courses & content included',
                  '8 therapeutic video games for patient families',
                  'Progress reports — shareable & practitioner-formatted',
                  'Revenue share from client platform participation',
                  'Priority onboarding & dedicated support',
                  'Early access to new clinical tools & content',
                ].map((f) => (
                  <li class="flex items-start gap-2.5">
                    <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="#7B9E8B" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" style="flex-shrink:0; margin-top:3px;"><polyline points="20 6 9 17 4 12"/></svg>
                    <span style="font-family:'DM Sans',sans-serif; font-size:0.9375rem; color:rgba(255,255,255,0.82);">{f}</span>
                  </li>
                ))}
              </ul>
            </div>

            <!-- What you get detail -->
            <div class="flex flex-col gap-6 fade-up" style="transition-delay:80ms;">

              <div class="rounded-2xl p-6" style="background:white; border:1px solid #ddd9d2;">
                <div class="w-10 h-10 rounded-xl flex items-center justify-center mb-4" style="background:#E4EFF6;">
                  <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#2E6E8E" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="3" width="20" height="14" rx="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>
                </div>
                <h3 style="font-family:'DM Sans',sans-serif; font-weight:700; font-size:1rem; color:#082438; margin-bottom:0.375rem;">Your Branded Portal</h3>
                <p style="font-family:'DM Sans',sans-serif; font-size:0.9375rem; color:#5F6975; line-height:1.65;">A white-label portal your families see under your brand — reinforcing your authority and keeping care connected to your clinic between sessions.</p>
              </div>

              <div class="rounded-2xl p-6" style="background:white; border:1px solid #ddd9d2;">
                <div class="w-10 h-10 rounded-xl flex items-center justify-center mb-4" style="background:#deeae5;">
                  <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#7B9E8B" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg>
                </div>
                <h3 style="font-family:'DM Sans',sans-serif; font-weight:700; font-size:1rem; color:#082438; margin-bottom:0.375rem;">Revenue Sharing</h3>
                <p style="font-family:'DM Sans',sans-serif; font-size:0.9375rem; color:#5F6975; line-height:1.65;">When your client families participate on the platform, you share in the revenue. Your clinical network becomes a meaningful income stream — beyond the session hour.</p>
              </div>

              <div class="rounded-2xl p-6" style="background:white; border:1px solid #ddd9d2;">
                <div class="w-10 h-10 rounded-xl flex items-center justify-center mb-4" style="background:#fdf0ea;">
                  <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#D8896A" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
                </div>
                <h3 style="font-family:'DM Sans',sans-serif; font-weight:700; font-size:1rem; color:#082438; margin-bottom:0.375rem;">Special Partnership Deals</h3>
                <p style="font-family:'DM Sans',sans-serif; font-size:0.9375rem; color:#5F6975; line-height:1.65;">Multi-clinic, group practice, and referral partnerships available. Contact us to discuss a structure that fits your practice's scale and goals.</p>
              </div>

            </div>

          </div>

          <!-- The maths -->
          <div class="mt-10 rounded-2xl p-8 fade-up" style="background:white; border:1px solid #ddd9d2;">
            <p class="nsh-eyebrow mb-3" style="color:#7B9E8B;">The Numbers</p>
            <h3 style="font-family:'DM Sans',sans-serif; font-weight:700; font-size:1.25rem; color:#082438; margin-bottom:1rem;">What does the partnership actually cost?</h3>
            <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
              {[
                { label: 'Portal fee', value: '$495/mo', note: 'Flat monthly partnership fee' },
                { label: 'Revenue share', value: 'Earned back', note: 'From your client participation' },
                { label: 'Net cost', value: 'Contact us', note: 'Depends on your patient volume' },
              ].map(({ label, value, note }) => (
                <div class="rounded-xl p-5 text-center" style="background:#F7F2EB;">
                  <p style="font-family:'DM Sans',sans-serif; font-size:0.8125rem; font-weight:600; color:#5F6975; text-transform:uppercase; letter-spacing:0.06em; margin-bottom:0.375rem;">{label}</p>
                  <p style="font-family:'DM Sans',sans-serif; font-weight:800; font-size:1.375rem; color:#082438; margin-bottom:0.25rem;">{value}</p>
                  <p style="font-family:'DM Sans',sans-serif; font-size:0.8125rem; color:#5F6975;">{note}</p>
                </div>
              ))}
            </div>
          </div>

        </div>
      </div>
    </section>

    <!-- ===== WHO IT'S FOR ===== -->
    <section class="py-20" style="background:white;">
      <div class="container">
        <div class="max-w-3xl mx-auto">
          <div class="text-center mb-12 fade-up">
            <p class="nsh-eyebrow mb-3" style="color:#7B9E8B;">Built For</p>
            <h2 style="font-family:'DM Sans',sans-serif; font-weight:800; font-size:clamp(1.75rem,4vw,2.25rem); color:#082438;">Who partners with Neurosage Hub?</h2>
          </div>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
            {[
              { title: 'Occupational Therapists', desc: 'Extend sensory and regulation work into the home with structured daily protocols your families can actually follow.' },
              { title: 'Speech-Language Pathologists', desc: 'Reinforce communication goals between sessions with parent-guided modules and progress tracking.' },
              { title: 'Functional Neurologists', desc: 'Assign neurological warm-up routines and development protocols — calibrated to your clinical approach.' },
              { title: 'ABA & Behaviour Therapists', desc: 'Give parents a structured home environment that supports the consistency behaviour intervention requires.' },
              { title: 'Paediatricians & GPs', desc: 'Refer families to a trusted, evidence-aligned platform the moment they leave your room — with progress reports you can review.' },
              { title: 'Private Clinics & Group Practices', desc: 'A branded portal that positions your clinic as the hub of your families\' entire support ecosystem.' },
            ].map(({ title, desc }) => (
              <div class="rounded-2xl p-6 fade-up" style="background:#F7F2EB; border:1px solid #ddd9d2;">
                <h3 style="font-family:'DM Sans',sans-serif; font-weight:700; font-size:1rem; color:#082438; margin-bottom:0.4rem;">{title}</h3>
                <p style="font-family:'DM Sans',sans-serif; font-size:0.9375rem; color:#5F6975; line-height:1.65;">{desc}</p>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>

    <!-- ===== CTA ===== -->
    <section class="py-20" style="background:#082438;">
      <div class="container">
        <div class="max-w-xl mx-auto text-center fade-up">
          <p class="nsh-eyebrow mb-4" style="color:#7B9E8B;">Let's Talk</p>
          <h2 style="font-family:'DM Sans',sans-serif; font-weight:800; font-size:clamp(1.75rem,4vw,2.25rem); color:white; line-height:1.2; margin-bottom:1rem;">
            Contact us about<br>a special partnership deal.
          </h2>
          <p style="font-family:'DM Sans',sans-serif; font-size:1rem; color:rgba(255,255,255,0.65); margin-bottom:2rem; line-height:1.7;">
            Every practice is different. Let's find a structure that works for your clinic, your families, and your goals.
          </p>
          <div class="flex flex-col sm:flex-row gap-4 justify-center">
            <a href="/for-practitioners#demo" class="nsh-btn-cta" style="font-size:1rem; padding:0.875rem 2rem;">
              Book a Discovery Call →
            </a>
            <a href="/pricing" class="inline-flex items-center justify-center px-7 py-3.5 rounded-xl font-semibold" style="font-family:'DM Sans',sans-serif; font-size:1rem; color:rgba(255,255,255,0.65); border:1.5px solid rgba(255,255,255,0.2); text-decoration:none;">
              Family Pricing
            </a>
          </div>
        </div>
      </div>
    </section>

  </main>

  <Footer />
</BaseLayout>
