---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

// ── UPDATE THIS with the iframe URL from your GHL dashboard ──
// Go to: GHL → Conversations → Chat Widget → [your widget] → Embed → Copy iframe src
const GHL_CHAT_IFRAME = 'https://widgets.leadconnectorhq.com/chat-widget/index.html?widget_id=6a21de9de53da97e71aef3b6';
---

<BaseLayout
  title="Chat with Campus Assistant | Neurosage Hub"
  description="Get answers from the Neurosage Campus Assistant — powered by curated, trusted autism content."
>
  <Header ctaText="Get FREE Access" ctaHref="/family-sign-up" />

  <main>
    <section style="background:#082438; min-height:calc(100vh - 72px); display:flex; align-items:flex-start; padding:3rem 0 4rem;">
      <div class="container w-full">
        <div class="max-w-2xl mx-auto">

          <!-- Sage label row -->
          <div class="flex items-center justify-center gap-3 mb-6 fade-up">
            <img src="/eva-bubble.png" alt="Eva™" style="width:32px; height:32px; object-fit:contain; flex-shrink:0;" />
            <span style="font-family:'DM Sans',sans-serif; font-size:0.8125rem; font-weight:600; color:rgba(255,255,255,0.5); letter-spacing:0.06em; text-transform:uppercase;">Eva™ · Campus Assistant</span>
          </div>

          <!-- Main card -->
          <div class="fade-up" style="background:white; border-radius:1.5rem; overflow:hidden; box-shadow:0 24px 64px rgba(0,0,0,0.3);">

            <!-- Sage intro row -->
            <div style="padding:1.5rem 1.75rem 1.25rem; border-bottom:1px solid #eee9e2;">
              <div style="display:flex; align-items:flex-start; gap:0.875rem;">
                <img src="/eva-face.png" alt="Eva™" style="width:34px; height:34px; border-radius:50%; object-fit:cover; flex-shrink:0; margin-top:2px;" />
                <div>
                  <p id="eva-chat-intro" style="font-family:'DM Sans',sans-serif; font-size:0.9375rem; color:#082438; line-height:1.7; margin:0 0 0.25rem;">
                    I'm connecting you with the campus assistant now — they'll have the answer for you shortly.
                  </p>
                  <!-- User question echo — shown only when ?q= is present -->
                  <div id="q-echo-wrap" style="display:none; margin-top:0.75rem;">
                    <div id="q-echo" style="display:inline-block; background:#082438; border-radius:10px 2px 10px 10px; padding:0.6rem 0.875rem; font-family:'DM Sans',sans-serif; font-size:0.875rem; color:white; line-height:1.6; max-width:90%;"></div>
                  </div>
                </div>
              </div>
            </div>

            <!-- ── INLINE CHAT IFRAME ── -->
            <div style="position:relative; background:#F7F2EB;">
              <iframe
                id="campus-chat-frame"
                src={GHL_CHAT_IFRAME}
                style="display:block; width:100%; height:580px; border:none;"
                allow="microphone; camera"
                title="Campus Assistant Chat"
              ></iframe>
            </div>

          </div>

          <p class="fade-up text-center mt-5" style="font-family:'DM Sans',sans-serif; font-size:0.75rem; color:rgba(255,255,255,0.2);">
            Eva™ provides educational guidance, not medical advice.
          </p>

        </div>
      </div>
    </section>
  </main>

  <Footer />

  <script is:inline>
  (function() {
    /* ── Hide Eva bubble — not needed on the dedicated chat page ── */
    var evaWidget = document.getElementById('eva-widget');
    if (evaWidget) evaWidget.style.display = 'none';

    /* ── Parse URL params ── */
    var params = new URLSearchParams(window.location.search);
    var q      = params.get('q')     || '';

    /* ── Show user's question above the iframe ── */
    if (q) {
      var introEl  = document.getElementById('eva-chat-intro');
      var echoWrap = document.getElementById('q-echo-wrap');
      var echoEl   = document.getElementById('q-echo');
      if (introEl)  introEl.textContent = "Got it — I've passed your question to the campus assistant.";
      if (echoEl)   echoEl.textContent  = q;
      if (echoWrap) echoWrap.style.display = 'block';
    }
  })();
  </script>

</BaseLayout>
