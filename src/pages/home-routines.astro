---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const routines = [
  {
    time: '10 min',
    title: 'Morning Brain-Body Activation',
    desc: 'Cross-crawl, balance, and vestibular warm-up to prepare the nervous system for the day.',
    steps: [
      'Cross-crawl march — 2 minutes',
      'Balance beam or line walking — 2 minutes',
      'Spinning or swinging (vestibular input) — 2 minutes',
      'Deep pressure squeeze or joint compression — 2 minutes',
      'Breathing reset and transition preview — 2 minutes',
    ],
  },
  {
    time: '8 min',
    title: 'After-School Sensory Reset',
    desc: 'Proprioceptive input, deep pressure, and calming activities to help transition from school.',
    steps: [
      'Heavy work activity (carry books, push/pull) — 2 minutes',
      'Deep pressure squeeze or weighted blanket — 2 minutes',
      'Quiet sensory bin or fidget time — 2 minutes',
      'Snack with crunchy or chewy texture — 2 minutes',
    ],
  },
  {
    time: '12 min',
    title: 'Evening Calm-Down Routine',
    desc: 'Breathing, gentle movement, and sensory wind-down to support sleep readiness.',
    steps: [
      'Dim lights and reduce screen stimulation — ongoing',
      'Slow, rhythmic rocking or gentle swinging — 3 minutes',
      'Deep pressure massage or brushing protocol — 3 minutes',
      'Belly breathing together — 3 minutes',
      'Predictable bedtime visual schedule review — 3 minutes',
    ],
  },
];
---

<BaseLayout
  title="Home Routines | Neurosage Hub"
  description="Simple, science-backed home routines for parents — morning brain-body activation, after-school sensory resets, and evening calm-down sequences designed for real family life."
>
  <Header />
  <main>

    <!-- Hero -->
    <section class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-20">
      <p class="text-sm font-semibold text-sage-600 uppercase tracking-widest mb-3">What You'll Actually Do</p>
      <h1 class="text-display font-bold text-stone-900 mb-4">Simple routines designed for real home life</h1>
      <p class="text-xl text-stone-500 leading-relaxed max-w-2xl">
        Neurosage doesn't just teach concepts — it gives you protocol cards, daily routines, sensory logs, and progress tracking you can use starting today.
      </p>
    </section>

    <!-- Routines -->
    <section class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 pb-20 space-y-8">
      {routines.map(({ time, title, desc, steps }) => (
        <div class="bg-stone-50 rounded-2xl p-8 border border-stone-100">
          <div class="flex items-start justify-between gap-4 mb-3">
            <h2 class="text-xl font-bold text-stone-900">{title}</h2>
            <span class="shrink-0 text-xs font-semibold text-sage-700 bg-sage-100 px-3 py-1 rounded-full">{time}</span>
          </div>
          <p class="text-stone-500 mb-6 leading-relaxed">{desc}</p>
          <ol class="space-y-2">
            {steps.map((step, i) => (
              <li class="flex items-start gap-3 text-sm text-stone-600">
                <span class="shrink-0 w-5 h-5 rounded-full bg-sage-600 text-white text-xs flex items-center justify-center font-semibold mt-0.5">{i + 1}</span>
                {step}
              </li>
            ))}
          </ol>
        </div>
      ))}
    </section>

    <!-- CTA -->
    <section class="bg-sage-600 py-16">
      <div class="max-w-2xl mx-auto px-4 text-center">
        <h2 class="text-2xl font-bold text-white mb-4">Want a personalised routine plan?</h2>
        <p class="text-sage-100 mb-8">Take the Parent Pathway Quiz and we'll build a starting plan around your child's specific needs.</p>
        <a href="/start-here#quiz" class="inline-flex items-center px-6 py-3 rounded-lg bg-white text-sage-700 font-semibold hover:bg-sage-50 transition-colors">
          Take the Quiz — It's Free
        </a>
      </div>
    </section>

  </main>
  <Footer />
</BaseLayout>
