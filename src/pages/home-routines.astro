---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const IMG_HERO = "/hero-routines.png";

const principles = [
  { title: 'Regulation before learning', desc: 'A dysregulated nervous system cannot learn effectively.' },
  { title: 'Movement before cognition', desc: 'Physical movement primes the brain for cognitive tasks.' },
  { title: 'Consistency over intensity', desc: 'Daily 10-minute routines outperform weekly 60-minute sessions.' },
  { title: 'Small wins build momentum', desc: 'Progress in neurodevelopment is cumulative. Every win matters.' },
];

const routines = [
  {
    tag: 'Morning',
    tagColor: '#b8694a',
    tagBg: '#fdf0ea',
    iconBg: '#fdf0ea',
    icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#b8694a" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="4"/><line x1="12" y1="2" x2="12" y2="4"/><line x1="12" y1="20" x2="12" y2="22"/><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/><line x1="2" y1="12" x2="4" y2="12"/><line x1="20" y1="12" x2="22" y2="12"/><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/></svg>`,
    time: '10–15 min',
    title: 'Morning Brain-Body Activation',
    desc: 'Prepare the nervous system for the day with movement, vestibular input, and bilateral coordination.',
    steps: [
      { num: 1, label: 'Cross-Crawl March', duration: '2 min', detail: 'Alternate knee-to-elbow, slow and rhythmic.' },
      { num: 2, label: 'Balance Board or Wobble Cushion', duration: '2 min', detail: 'Eyes open, then eyes closed if safe.' },
      { num: 3, label: 'Wall Push-Ups (Proprioception)', duration: '1 min', detail: 'Slow, firm pressure into the wall.' },
      { num: 4, label: 'Jumping Jacks or Trampoline', duration: '2 min', detail: 'Alerting vestibular input.' },
      { num: 5, label: 'Deep Breathing Together', duration: '2 min', detail: '4-count inhale, 6-count exhale.' },
    ],
    benefit: 'Reduces morning meltdowns and improves school readiness',
  },
  {
    tag: 'After School',
    tagColor: '#123D5A',
    tagBg: '#deeae5',
    iconBg: '#deeae5',
    icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#123D5A" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"/><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"/></svg>`,
    time: '8–10 min',
    title: 'After-School Sensory Reset',
    desc: 'Help your child decompress and transition from the sensory demands of school to the safety of home.',
    steps: [
      { num: 1, label: 'Proprioceptive Input (Heavy Work)', duration: '2 min', detail: 'Carry books, push a laundry basket, or do wall push-ups.' },
      { num: 2, label: 'Calming Sensory Bin', duration: '2 min', detail: 'Sand, rice, or kinetic sand for tactile grounding.' },
      { num: 3, label: 'Quiet Corner / Cozy Space', duration: '2 min', detail: 'Weighted blanket, dim light, no demands.' },
      { num: 4, label: 'Snack with Crunchy or Chewy Foods', duration: '2 min', detail: 'Oral motor input supports regulation.' },
    ],
    benefit: 'Reduces after-school meltdowns and emotional overwhelm',
  },
  {
    tag: 'Movement Break',
    tagColor: '#4F7563',
    tagBg: '#eaf2ed',
    iconBg: '#eaf2ed',
    icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#4F7563" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="5" r="1"/><path d="M9 20l3-7 3 7"/><path d="M6 8l6 2 6-2"/><path d="M9 8l-1 4"/><path d="M15 8l1 4"/></svg>`,
    time: '5 min',
    title: 'Focus & Regulation Movement Break',
    desc: 'A quick mid-day reset to restore attention, reduce dysregulation, and prepare for learning or transitions.',
    steps: [
      { num: 1, label: 'Animal Walks', duration: '1 min', detail: 'Bear crawl, crab walk, or frog jumps.' },
      { num: 2, label: 'Cross-Body Movements', duration: '1 min', detail: 'Touch opposite elbow to knee, alternating.' },
      { num: 3, label: 'Spinning or Rolling (if tolerated)', duration: '1 min', detail: 'Vestibular input — observe response carefully.' },
      { num: 4, label: 'Slow Breathing Reset', duration: '1 min', detail: 'Breathe out longer than in.' },
    ],
    benefit: 'Improves focus and reduces dysregulation mid-day',
  },
  {
    tag: 'Daily',
    tagColor: '#123D5A',
    tagBg: '#deeae5',
    iconBg: '#deeae5',
    icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#123D5A" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2a5 5 0 0 1 5 5v3a5 5 0 0 1-10 0V7a5 5 0 0 1 5-5z"/><path d="M12 14v8"/><path d="M8 18h8"/></svg>`,
    time: '10 min',
    title: 'Primitive Reflex Integration',
    desc: 'Gentle, play-based movements to support the integration of retained primitive reflexes. Always coordinate with your OT.',
    steps: [
      { num: 1, label: 'Rocking on Hands and Knees', duration: '2 min', detail: 'Supports STNR integration.' },
      { num: 2, label: 'Rolling Side to Side', duration: '2 min', detail: 'Supports Moro reflex integration.' },
      { num: 3, label: 'Tummy Time Activities', duration: '2 min', detail: 'Supports ATNR and spinal Galant.' },
      { num: 4, label: 'Cross-Crawl on Floor', duration: '2 min', detail: 'Bilateral coordination and midline crossing.' },
    ],
    benefit: 'Supports focus, coordination, and emotional regulation over time',
  },
  {
    tag: 'Evening',
    tagColor: '#1a3d52',
    tagBg: '#deeae5',
    iconBg: '#deeae5',
    icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#1a3d52" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg>`,
    time: '12–15 min',
    title: 'Evening Calm-Down Routine',
    desc: 'Wind down the nervous system and prepare for sleep readiness through gentle sensory and breathing activities.',
    steps: [
      { num: 1, label: 'Dim Lights and Reduce Screens', duration: 'ongoing', detail: 'Begin 60 minutes before bed.' },
      { num: 2, label: 'Warm Bath or Shower', duration: '5 min', detail: 'Proprioceptive and thermal calming.' },
      { num: 3, label: 'Deep Pressure Massage', duration: '3 min', detail: 'Firm strokes on arms, legs, and back.' },
      { num: 4, label: 'Breathing or Visualization', duration: '2 min', detail: 'Guided imagery or slow breathing together.' },
    ],
    benefit: 'Improves sleep onset and reduces bedtime resistance',
  },
];
---

<BaseLayout
  title="Home Routines for Autism Families | Neurosage Hub"
  description="Five practitioner-informed home routines for autism families — morning activation, sensory resets, movement breaks, reflex integration, and evening calm-down. Free workbook download."
>
  <Header />
  <main>

    <!-- ===== HERO + DOWNLOAD ===== -->
    <section class="py-14 lg:py-16" style="background:white;">
      <div class="container">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-10 lg:gap-14 items-center">

          <div>
            <p class="nsh-eyebrow mb-4 fade-up" style="color:#D8896A;">Home-Based Support</p>
            <h1 class="fade-up mb-4" style="font-family:'DM Sans',sans-serif; font-weight:800; font-size:clamp(2rem, 4.5vw, 3.25rem); line-height:1.1; color:#082438;">
              A daily routine your family can actually follow.
            </h1>
            <div class="mb-5" style="width:3rem; height:3px; background:#D8896A; border-radius:2px;"></div>
            <p class="nsh-body-lg mb-8 fade-up" style="color:#2d3f4c; max-width:28rem;">
              Five practitioner-informed routines — morning to evening — each under 15 minutes and designed for real family life.
            </p>
            <div class="flex flex-wrap gap-4 fade-up">
              <button id="download-cta-hero" class="nsh-btn-cta" style="font-size:1rem; padding:0.875rem 1.75rem;">
                <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
                Download Home Routines Workbook
              </button>
              <a href="#routines" class="nsh-btn-secondary" style="font-size:1rem; padding:0.875rem 1.5rem;">See the Routines</a>
            </div>
            <p class="mt-3 text-sm fade-up" style="font-family:'DM Sans',sans-serif; color:#6B7A86;">Free — no credit card required.</p>
          </div>

          <div class="fade-up" style="transition-delay:80ms;">
            <img
              src={IMG_HERO}
              alt="Mom and child with visual routine schedule on the table"
              class="w-full rounded-2xl object-cover"
              style="min-height:380px; max-height:480px; object-position:center top; box-shadow:0 12px 40px rgba(8,36,56,0.10);"
              loading="eager"
            />
          </div>

        </div>
      </div>
    </section>

    <!-- ===== TRUST BAR ===== -->
    <div style="background:#F7F2EB; border-top:1px solid #ddd9d2; border-bottom:1px solid #ddd9d2; padding:0.875rem 0;">
      <div class="container flex items-center justify-center gap-2.5">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#123D5A" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
        <p style="font-family:'DM Sans',sans-serif; font-size:0.9375rem; font-weight:600; color:#1F2A33;">All routines are practitioner-informed and parent-implementable</p>
      </div>
    </div>

    <!-- ===== PRINCIPLES ===== -->
    <section class="py-12" style="background:#082438;">
      <div class="container">
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">
          {principles.map(({ title, desc }, i) => (
            <div class="p-6 rounded-xl fade-up" style={`background:#0d2d42; border:1px solid #1a3d52; transition-delay:${i * 60}ms;`}>
              <p class="font-bold mb-2" style="font-family:'DM Sans',sans-serif; font-size:1rem; color:white;">{title}</p>
              <p class="text-sm" style="font-family:'DM Sans',sans-serif; color:rgba(255,255,255,0.60); line-height:1.6;">{desc}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ===== ROUTINE LIBRARY ===== -->
    <section id="routines" class="py-16" style="background:white;">
      <div class="container">

        <div class="max-w-2xl mx-auto text-center mb-12">
          <p class="nsh-eyebrow mb-3 fade-up" style="color:#D8896A;">The Routine Library</p>
          <h2 class="nsh-heading-2 mb-4 fade-up" style="color:#082438;">Five foundational home routines.</h2>
          <p class="nsh-body fade-up" style="color:#3d4f5c;">Each routine is designed to be done at home, in real life, with real families. Start with one. Build from there.</p>
        </div>

        <div class="space-y-6 max-w-3xl mx-auto">
          {routines.map(({ tag, tagColor, tagBg, iconBg, icon, time, title, desc, steps, benefit }, i) => (
            <div class="rounded-2xl overflow-hidden fade-up" style={`background:white; border:1px solid #ddd9d2; box-shadow:0 4px 24px rgba(8,36,56,0.06); transition-delay:${i * 60}ms;`}>

              <!-- Card header -->
              <div class="px-7 pt-6 pb-5" style="border-bottom:1px solid #e5e1da;">
                <div class="flex items-start gap-4">
                  <!-- Routine icon -->
                  <div class="w-12 h-12 rounded-xl flex items-center justify-center flex-shrink-0" style="background:rgba(8,36,56,0.06);">
                    <Fragment set:html={icon} />
                  </div>
                  <div class="flex-1 min-w-0">
                    <div class="flex items-center gap-3 mb-2">
                      <span class="text-xs font-bold px-3 py-1 rounded-full" style={`font-family:'DM Sans',sans-serif; background:rgba(8,36,56,0.05); color:${tagColor}; letter-spacing:0.04em; text-transform:uppercase;`}>{tag}</span>
                      <div class="flex items-center gap-1.5" style="color:#5F6975;">
                        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                        <span style="font-family:'DM Sans',sans-serif; font-size:0.8125rem;">{time}</span>
                      </div>
                    </div>
                    <h3 class="font-bold mb-1" style="font-family:'DM Sans',sans-serif; font-size:1.1875rem; color:#082438;">{title}</h3>
                    <p class="text-sm" style="font-family:'DM Sans',sans-serif; color:#3d4f5c; line-height:1.6;">{desc}</p>
                  </div>
                </div>
              </div>

              <!-- Steps — checklist style -->
              <div class="px-7 pt-5 pb-2">
                <p class="text-xs font-bold mb-3" style="font-family:'DM Sans',sans-serif; color:#5F6975; letter-spacing:0.08em; text-transform:uppercase;">Step-by-Step</p>
              </div>
              <div>
                {steps.map(({ num, label, duration, detail }, si) => (
                  <div class="flex items-start gap-4 px-7 py-4" style="border-top:1px solid #e5e1da; background:white;">
                    <div class="w-8 h-8 rounded-full flex items-center justify-center flex-shrink-0 text-sm font-bold" style="background:#082438; color:white; font-family:'DM Sans',sans-serif;">{num}</div>
                    <div class="flex-1 min-w-0 pt-0.5">
                      <div class="flex items-center gap-2.5 flex-wrap mb-1">
                        <span class="font-semibold text-sm" style="font-family:'DM Sans',sans-serif; color:#082438;">{label}</span>
                        <span class="text-xs font-semibold px-2.5 py-0.5 rounded-full" style="font-family:'DM Sans',sans-serif; background:#F7F2EB; color:#5F6975;">{duration}</span>
                      </div>
                      <p class="text-xs" style="font-family:'DM Sans',sans-serif; color:#5F6975; line-height:1.55;">{detail}</p>
                    </div>
                  </div>
                ))}
              </div>

              <!-- Benefit -->
              <div class="mx-7 my-5 flex items-center gap-2.5 px-4 py-3 rounded-xl" style="background:rgba(123,158,139,0.12);">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#4F7563" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
                <p class="text-sm font-semibold" style="font-family:'DM Sans',sans-serif; color:#4F7563;">{benefit}</p>
              </div>

            </div>
          ))}
        </div>

        <!-- Disclaimer -->
        <p class="text-center mt-10 text-sm max-w-2xl mx-auto" style="font-family:'DM Sans',sans-serif; color:#6B7A86; line-height:1.7;">
          These routines are for educational purposes only. Always consult your child's occupational therapist, physician, or care team before beginning new activities.
        </p>

      </div>
    </section>

    <!-- ===== DOWNLOAD BAND ===== -->
    <section class="py-16" style="background:#082438;">
      <div class="container">
        <div class="max-w-3xl mx-auto grid grid-cols-1 lg:grid-cols-2 gap-10 items-center">
          <div class="fade-up">
            <p class="nsh-eyebrow mb-3" style="color:#a8c4b8;">Free Download</p>
            <h2 class="nsh-heading-2 mb-4" style="color:white;">Get the full workbook — protocol cards, logs, and trackers.</h2>
            <p class="nsh-body" style="color:rgba(255,255,255,0.60);">Printable protocol cards for every routine, a sensory trigger log, weekly tracker, meal strategy guide, and a print-ready bedtime visual schedule.</p>
          </div>
          <div class="fade-up" style="transition-delay:80ms;">
            <div class="rounded-2xl p-6" style="background:#0d2d42; border:1px solid #1a3d52;">
              <div class="space-y-3 mb-5">
                {[
                  'Morning, afternoon & evening protocol cards',
                  'Sensory trigger log and observation sheets',
                  'Weekly progress tracker and journaling prompts',
                  'Meal and nutrition strategy guide',
                  'Print-ready bedtime visual schedule template',
                ].map((item) => (
                  <div class="flex items-start gap-2.5">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#a8c4b8" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" style="flex-shrink:0; margin-top:3px;"><polyline points="20 6 9 17 4 12"/></svg>
                    <p class="text-sm" style="font-family:'DM Sans',sans-serif; color:rgba(255,255,255,0.72);">{item}</p>
                  </div>
                ))}
              </div>
              <button id="download-cta-band" class="nsh-btn-cta w-full justify-center" style="font-size:1rem; padding:0.875rem;">
                <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
                Download Free Workbook
              </button>
              <p class="text-center text-xs mt-3" style="font-family:'DM Sans',sans-serif; color:rgba(255,255,255,0.28);">Enter your email — we'll send it instantly.</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ===== BOTTOM CTA ===== -->
    <section class="py-16" style="background:white;">
      <div class="container max-w-2xl mx-auto text-center">
        <p class="nsh-eyebrow mb-3 fade-up" style="color:#D8896A;">Get Your Personalized Routine Plan</p>
        <h2 class="nsh-heading-2 mb-4 fade-up" style="color:#082438;">Start with the right routine for your child.</h2>
        <p class="nsh-body mb-8 fade-up" style="color:#3d4f5c;">Take the free Parent Pathway Quiz to get a personalized routine recommendation based on your child's specific needs and developmental stage.</p>
        <div class="flex flex-wrap justify-center gap-4 fade-up">
          <a href="/family-sign-up" class="nsh-btn-cta" style="font-size:1rem; padding:0.9rem 1.75rem;">
            Take the Pathway Quiz
            <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
          </a>
          <a href="/family-sign-up" class="nsh-btn-secondary" style="font-size:1rem; padding:0.9rem 1.5rem;">Sign Up Free</a>
        </div>
      </div>
    </section>

    <!-- ===== TAGLINE ===== -->
    <div style="background:#123D5A; padding:1.25rem 0;">
      <div class="container flex items-center gap-4">
        <div class="w-10 h-10 rounded-full flex items-center justify-center flex-shrink-0" style="background:rgba(255,255,255,0.15);">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
        </div>
        <p style="font-family:'DM Sans',sans-serif; font-size:1.0625rem; color:white;">
          <strong>Build hope.</strong> Walk together.
        </p>
      </div>
    </div>

  </main>
  <Footer />

  <!-- ===== EMAIL GATE MODAL ===== -->
  <div
    id="workbook-modal"
    class="fixed inset-0 z-50 flex items-center justify-center p-4"
    style="display:none; background:rgba(0,0,0,0.55); backdrop-filter:blur(4px);"
    aria-modal="true"
    role="dialog"
  >
    <div class="w-full max-w-md rounded-2xl p-8 relative" style="background:white; box-shadow:0 24px 64px rgba(0,0,0,0.20);">
      <button id="modal-close" class="absolute top-4 right-4 w-8 h-8 flex items-center justify-center rounded-full" style="background:#F7F2EB; color:#5F6975;" aria-label="Close">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
      </button>
      <div class="w-14 h-14 rounded-2xl flex items-center justify-center mb-5" style="background:#fef5f0;">
        <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="#b8694a" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
      </div>
      <h2 style="font-family:'DM Sans',sans-serif; font-weight:800; font-size:1.375rem; color:#082438; margin-bottom:0.375rem;">Home Routines Workbook</h2>
      <p style="font-family:'DM Sans',sans-serif; font-size:0.9375rem; color:#5F6975; margin-bottom:1.5rem; line-height:1.6;">Enter your email and we'll send the workbook straight to your inbox — free.</p>
      <form id="workbook-form" novalidate>
        <label for="modal-email" style="font-family:'DM Sans',sans-serif; font-size:0.8125rem; font-weight:600; color:#1F2A33; display:block; margin-bottom:0.5rem;">Your email address</label>
        <input type="email" id="modal-email" name="email" placeholder="you@example.com" required class="w-full px-4 py-3 rounded-xl text-sm mb-1" style="font-family:'DM Sans',sans-serif; border:1.5px solid #d5d0c9; color:#082438; outline:none;" />
        <p id="modal-error" style="font-family:'DM Sans',sans-serif; font-size:0.75rem; color:#c0392b; margin-bottom:0.75rem; display:none;">Please enter a valid email address.</p>
        <button type="submit" class="nsh-btn-cta w-full justify-center mt-3" style="font-size:1rem; padding:0.875rem;">
          Send Me the Workbook
          <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
        </button>
      </form>
      <div id="modal-success" style="display:none; text-align:center; padding:1rem 0;">
        <div class="w-14 h-14 rounded-full flex items-center justify-center mx-auto mb-4" style="background:#e8f5ee;">
          <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="#4F7563" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
        </div>
        <p class="font-bold mb-2" style="font-family:'DM Sans',sans-serif; font-size:1.125rem; color:#082438;">Check your inbox!</p>
        <p style="font-family:'DM Sans',sans-serif; font-size:0.9375rem; color:#5F6975;">The workbook is on its way. While you wait — your free Hub account is ready.</p>
        <a href="/family-sign-up" class="nsh-btn-cta inline-flex mt-5" style="font-size:0.9375rem; padding:0.75rem 1.5rem;">Start Your Free Account</a>
      </div>
      <p class="text-center mt-4 text-xs" style="font-family:'DM Sans',sans-serif; color:#6B7A86;">No spam, ever. Unsubscribe any time.</p>
    </div>
  </div>

  <script>
    const modal    = document.getElementById('workbook-modal');
    const closeBtn = document.getElementById('modal-close');
    const form     = document.getElementById('workbook-form');
    const success  = document.getElementById('modal-success');
    const errorMsg = document.getElementById('modal-error');

    function openModal() {
      modal.style.display = 'flex';
      document.body.style.overflow = 'hidden';
      setTimeout(() => document.getElementById('modal-email')?.focus(), 50);
    }
    function closeModal() {
      modal.style.display = 'none';
      document.body.style.overflow = '';
    }

    document.getElementById('download-cta-hero')?.addEventListener('click', openModal);
    document.getElementById('download-cta-band')?.addEventListener('click', openModal);
    closeBtn?.addEventListener('click', closeModal);
    modal?.addEventListener('click', (e) => { if (e.target === modal) closeModal(); });
    document.addEventListener('keydown', (e) => { if (e.key === 'Escape') closeModal(); });

    form?.addEventListener('submit', (e) => {
      e.preventDefault();
      const emailInput = document.getElementById('modal-email');
      const email = emailInput?.value.trim() ?? '';
      if (!/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)) {
        errorMsg.style.display = 'block';
        emailInput?.focus();
        return;
      }
      errorMsg.style.display = 'none';
      // ➜ TODO: POST email to your capture endpoint (ConvertKit, Mailchimp, etc.)
      const link = document.createElement('a');
      link.href = '/downloads/home-routines-workbook.pdf';
      link.download = 'Home-Routines-Workbook-NeurosageHub.pdf';
      document.body.appendChild(link);
      link.click();
      document.body.removeChild(link);
      form.style.display = 'none';
      success.style.display = 'block';
    });

    const vp = window.innerHeight;
    document.querySelectorAll('.fade-up').forEach(el => {
      const { top, bottom } = el.getBoundingClientRect();
      if (top < vp && bottom > 0) el.classList.add('visible');
    });
    const observer = new IntersectionObserver(
      (entries) => entries.forEach(e => { if (e.isIntersecting) e.target.classList.add('visible'); }),
      { threshold: 0.08, rootMargin: '0px 0px -30px 0px' }
    );
    document.querySelectorAll('.fade-up:not(.visible)').forEach(el => observer.observe(el));
    setTimeout(() => {
      document.querySelectorAll('.fade-up').forEach(el => el.classList.add('visible'));
    }, 700);
  </script>

</BaseLayout>
