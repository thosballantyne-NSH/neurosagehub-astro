---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';
---

<BaseLayout
  noindex={true}
  title="Autism Behavior: Guides & Strategies | Neurosage Hub"
  description="Understanding the function behind behavior in autism and learning strategies that address root causes, not just surface symptoms. For families and practitioners."
>
  <Header />

  <main>

    <section class="py-20" style="background:#082438;">
      <div class="container">
        <div class="max-w-2xl mx-auto">
          <nav class="mb-6">
            <a href="/resources" style="font-family:'DM Sans',sans-serif; font-size:0.8125rem; color:rgba(255,255,255,0.5); text-decoration:none;">← Resources</a>
          </nav>
          <p class="nsh-eyebrow mb-4 fade-up" style="color:#D8896A;">Hub 6 of 7</p>
          <h1 class="fade-up mb-5" style="font-family:'DM Sans',sans-serif; font-weight:800; font-size:clamp(2rem,5vw,3rem); color:white; line-height:1.1;">
            Behavior
          </h1>
          <p class="fade-up" style="font-family:'DM Sans',sans-serif; font-size:1.125rem; color:rgba(255,255,255,0.65); line-height:1.7; max-width:34rem;">
            Every behavior has a function. Understanding what a child's behavior is communicating is the first step toward meaningful, lasting change.
          </p>
        </div>
      </div>
    </section>

    <section class="py-16" style="background:white;">
      <div class="container">
        <div class="max-w-3xl mx-auto text-center">
          <div class="rounded-2xl p-12 fade-up" style="background:#F7F2EB; border:1px solid #ddd9d2;">
            <p class="nsh-eyebrow mb-3" style="color:#7B9E8B;">Coming soon</p>
            <h2 style="font-family:'DM Sans',sans-serif; font-weight:700; font-size:1.375rem; color:#082438; margin-bottom:0.75rem;">Behavior guides are on the way</h2>
            <p style="font-family:'DM Sans',sans-serif; font-size:0.9375rem; color:#5F6975; line-height:1.75; max-width:28rem; margin:0 auto 1.5rem;">
              We're building practical guides on understanding behavior function, working with repetitive behaviors, and addressing aggression and self-injury from a nervous system perspective.
            </p>
            <button onclick="window.nshOpenNotify('Autism Behavior Support')" style="display:inline-flex; align-items:center; gap:0.5rem; padding:0.625rem 1.375rem; background:#2E6E8E; color:white; border:none; border-radius:0.75rem; cursor:pointer; font-family:'DM Sans',sans-serif; font-size:0.875rem; font-weight:700; margin-bottom:1.25rem; transition:background 0.15s;" onmouseover="this.style.background='#1A4A6B'" onmouseout="this.style.background='#2E6E8E'">
              Get notified of new guides for Autism Behavior Support →
            </button>
            <br />
            <a href="/resources" style="font-family:'DM Sans',sans-serif; font-size:0.875rem; font-weight:600; color:#2E6E8E; text-decoration:none;">← Back to all resources</a>
          </div>
        </div>
      </div>
    </section>

    <section class="py-16" style="background:#082438;">
      <div class="container">
        <div class="max-w-xl mx-auto text-center">
          <p class="nsh-eyebrow mb-3" style="color:#D8896A;">Neurosage Hub</p>
          <h2 style="font-family:'DM Sans',sans-serif; font-weight:800; font-size:clamp(1.5rem,3.5vw,2.125rem); color:white; margin-bottom:0.875rem; line-height:1.25;">Get started today</h2>
          <p style="font-family:'DM Sans',sans-serif; font-size:1rem; color:rg