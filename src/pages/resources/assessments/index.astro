---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';

const articles = [
  {
    slug: 'what-is-an-autism-assessment',
    title: 'What Is an Autism Assessment?',
    desc: 'A clear explanation of what an autism assessment involves, who conducts it, and what it tells you about your child.',
    readTime: '5 min',
  },
  {
    slug: 'how-long-does-autism-assessment-take',
    title: 'How Long Does an Autism Assessment Take?',
    desc: 'From referral to results — a realistic timeline for the autism assessment process, including what causes delays.',
    readTime: '4 min',
  },
  {
    slug: 'what-happens-during-autism-assessment',
    title: 'What Happens During an Autism Assessment?',
    desc: 'A step-by-step walkthrough of the autism assessment process — what your child will be asked to do, and what practitioners observe.',
    readTime: '6 min',
  },
  {
    slug: 'how-to-prepare-for-autism-assessment',
    title: 'How to Prepare Your Child for an Autism Assessment',
    desc: 'Practical steps parents can take before assessment day to reduce anxiety, gather the right information, and set their child up for success.',
    readTime: '5 min',
  },
];
---

<BaseLayout
  title="Autism Assessments: What You Need to Know | Neurosage Hub"
  description="Guides on autism assessments — what they involve, how long they take, what to expect, and how to prepare. Written for families and practitioners."
>
  <Header />

  <main>

    <!-- ===== HERO ===== -->
    <section class="py-20" style="background:#082438;">
      <div class="container">
        <div class="max-w-2xl mx-auto">

          <nav class="mb-6">
            <a href="/resources" style="font-family:'DM Sans',sans-serif; font-size:0.8125rem; color:rgba(255,255,255,0.5); text-decoration:none;">← Resources</a>
          </nav>

          <p class="nsh-eyebrow mb-4 fade-up" style="color:#D8896A;">Hub 1 of 7</p>
          <h1 class="fade-up mb-5" style="font-family:'DM Sans',sans-serif; font-weight:800; font-size:clamp(2rem,5vw,3rem); color:white; line-height:1.1;">
            Autism Assessments
          </h1>
          <p class="fade-up" style="font-family:'DM Sans',sans-serif; font-size:1.125rem; color:rgba(255,255,255,0.65); line-height:1.7; max-width:34rem;">
            The first step toward understanding is knowing what's happening. These guides answer the questions families ask most — before, during, and after the assessment process.
          </p>

        </div>
      </div>
    </section>

    <!-- ===== KEY QUESTION ===== -->
    <section class="py-12" style="background:#E4EFF6;">
      <div class="container">
        <div class="max-w-2xl mx-auto text-center">
          <p style="font-family:'DM Sans',sans-serif; font-size:1.0625rem; font-weight:700; color:#082438; line-height:1.6; margin-bottom:0.5rem;">
            "What is happening with my child?"
          </p>
          <p style="font-family:'DM Sans',sans-serif; font-size:0.9375rem; color:#3d5a6e; line-height:1.75;">
            An autism assessment answers this question. It's not about labels — it's about understanding how your child's brain works so you can get them the right support.
          </p>
        </div>
      </div>
    </section>

    <!-- ===== ARTICLES ===== -->
    <section class="py-16" style="background:white;">
      <div class="container">
        <div class="max-w-3xl mx-auto">

          <p class="nsh-eyebrow mb-8 fade-up" style="color:#7B9E8B;">{articles.length} Guides</p>

          <div>
            {articles.map((article, i) => (
              <a
                href={`/resources/assessments/${article.slug}`}
                class="fade-up group"
                style={`display:block; padding:1.5rem 0; border-bottom:1px solid #ddd9d2; ${i === 0 ? 'border-top:1px solid #ddd9d2;' : ''} text-decoration:none; transition-delay:${i * 50}ms;`}
              >
                <div class="flex items-start gap-4">
                  <div style="width:36px; height:36px; border-radius:50%; background:#E4EFF6; flex-shrink:0; display:flex; align-items:center; justify-content:center; margin-top:2px;">
                    <span style="font-family:'DM Sans',sans-serif; font-size:0.75rem; font-weight:700; color:#1A4A6B;">{i + 1}</span>
                  </div>
                  <div class="flex-1">
                    <div class="flex items-center gap-2 mb-1">
                      <p class="group-hover:underline" style="font-family:'DM Sans',sans-serif; font-weight:700; font-size:1rem; color:#082438; line-height:1.4;">{article.title}</p>
                      <span style="font-family:'DM Sans',sans-serif; font-size:0.75rem; color:#7B9E8B; white-space:nowrap;">{article.readTime}</span>
                    </div>
                    <p style="font-family:'DM Sans',sans-serif; font-size:0.875rem; color:#5F6975; line-height:1.65;">{article.desc}</p>
                  </div>
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#2E6E8E" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="flex-shrink:0; margin-top:4px;"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
                </div>
              </a>
            ))}
          </div>

        </div>
      </div>
    </section>

    <!-- ===== PODCAST TIE-IN ===== -->
    <section class="py-12" style="background:#F7F2EB;">
      <div class="container">
        <div class="max-w-3xl mx-auto">
          <div class="rounded-2xl p-7 flex flex-col md:flex-row gap-5 items-start" style="background:white; border:1px solid #ddd9d2;">
            <div style="width:44px; height:44px; border-radius:10px; background:#E4EFF6; display:flex; align-items:center; justify-content:center; flex-shrink:0; font-size:1.25rem;">🎙️</div>
            <div>
              <p class="nsh-eyebrow mb-1" style="color:#7B9E8B;">Podcast</p>
              <h3 style="font-family:'DM Sans',sans-serif; font-weight:700; font-size:1.0625rem; color:#082438; margin-bottom:0.375rem;">Listen: Autism Assessments — What Actually Matters</h3>
              <p style="font-family:'DM Sans',sans-serif; font-size:0.875rem; color:#5F6975; line-height:1.65; margin-bottom:0.875rem;">Ashley Tamayo breaks down the most common autism assessments, the difference between a screening and a formal diagnosis, and why patience matters.</p>
              <a
                href="/podcasts/autism-assessments-what-actually-matters-and-what-doesnt"
                style="font-family:'DM Sans',sans-serif; font-size:0.875rem; font-weight:600; color:#2E6E8E; text-decoration:none; display:inline-flex; align-items:center; gap:0.25rem;"
              >
                Listen to the episode →
              </a>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ===== FIND A PRACTITIONER ===== -->
    <section class="py-16" style="background:white;">
      <div class="container">
        <div class="max-w-3xl mx-auto">
          <div class="rounded-2xl p-8 md:p-10 fade-up" style="background:linear-gradient(135deg, #082438 0%, #1A4A6B 100%); position:relative; overflow:hidden;">
            <!-- Subtle decorative arc -->
            <div style="position:absolute; top:-40px; right:-40px; width:180px; height:180px; border-radius:50%; background:rgba(255,255,255,0.04);"></div>
            <div style="position:absolute; bottom:-20px; right:60px; width:100px; height:100px; border-radius:50%; background:rgba(255,255,255,0.03);"></div>
            <div style="position:relative; z-index:1;">
              <p class="nsh-eyebrow mb-3" style="color:#7B9E8B;">Find a Practitioner</p>
              <h2 style="font-family:'DM Sans',sans-serif; font-weight:800; font-size:clamp(1.375rem,3vw,1.875rem); color:white; margin-bottom:0.875rem; line-height:1.2;">
                Need an assessment done?
              </h2>
              <p style="font-family:'DM Sans',sans-serif; font-size:1rem; color:rgba(255,255,255,0.7); line-height:1.75; max-width:32rem; margin-bottom:0.5rem;">
                Create your free account and connect with trusted practitioners who specialise in autism assessments. We'll help you find the right support for your family.
              </p>
              <p style="font-family:'DM Serif Display',serif; font-size:1.0625rem; color:#E8C98F; font-style:italic; margin-bottom:2rem;">
                Let's Build Hope and Walk Together.
              </p>
              <a
                href="/family-sign-up"
                style="display:inline-flex; align-items:center; gap:0.5rem; font-family:'DM Sans',sans-serif; font-size:0.9375rem; font-weight:700; background:#D8896A; color:white; padding:0.875rem 1.875rem; border-radius:9999px; text-decoration:none; transition:background 0.15s;"
                onmouseover="this.style.background='#b8694a'"
                onmouseout="this.style.background='#D8896A'"
              >
                Create Free Account
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
              </a>
              <p style="font-family:'DM Sans',sans-serif; font-size:0.8rem; color:rgba(255,255,255,0.35); margin-top:1rem;">No credit card required · No diagnosis needed to start</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ===== CTA ===== -->
    <section class="py-16" style="background:#082438;">
      <div class="container">
        <div class="max-w-xl mx-auto text-center">
          <p class="nsh-eyebrow mb-3" style="color:#D8896A;">Neurosage Hub</p>
          <h2 style="font-family:'DM Sans',sans-serif; font-weight:800; font-size:clamp(1.5rem,3.5vw,2.125rem); color:white; margin-bottom:0.875rem; line-height:1.25;">
            Got your assessment results?
          </h2>
          <p style="font-family:'DM Sans',sans-serif; font-size:1rem; color:rgba(255,255,255,0.65); max-width:28rem; margin:0 auto 2rem; line-height:1.7;">
            The Neurosage Hub Platform helps families and practitioners put diagnosis into action — guided activities, therapeutic games, and community support.
          </p>
          <a
            href="/family-sign-up"
            style="font-family:'DM Sans',sans-serif; font-size:0.9375rem; font-weight:700; background:#D8896A; color:white; padding:0.875rem 2rem; border-radius:9999px; text-decoration:none; display:inline-block;"
          >
            Get Started Free
          </a>
        </div>
      </div>
    </section>

  </main>

  <Footer />
</BaseLayout>
