---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';

const hubs = [
  {
    slug: 'assessments',
    title: 'Autism Assessments',
    eyebrow: 'Understanding Diagnosis',
    icon: '🔍',
    color: '#2E6E8E',
    colorBg: '#E4EFF6',
    description: 'What is happening? Understand autism assessments, how to prepare your child, what to expect on the day, and how to interpret the results.',
    articles: [
      { label: 'What is an autism assessment?',             href: '/resources/assessments/what-is-an-autism-assessment' },
      { label: 'How long does an assessment take?',         href: '/resources/assessments/how-long-does-autism-assessment-take' },
      { label: 'What happens during an assessment?',        href: '/resources/assessments/what-happens-during-autism-assessment' },
      { label: 'How to prepare your child',                 href: '/resources/assessments/how-to-prepare-for-autism-assessment' },
    ],
    priority: true,
  },
  {
    slug: 'meltdowns',
    title: 'Autism Meltdowns',
    eyebrow: 'In-the-Moment Support',
    icon: '🌊',
    color: '#D8896A',
    colorBg: '#fdf0ea',
    description: 'How do I survive today? What causes meltdowns, how to help in the moment, and practical strategies to reduce them over time.',
    articles: [
      { label: 'What causes autism meltdowns?',             href: '/resources/meltdowns/what-causes-autism-meltdowns' },
      { label: 'Meltdown vs tantrum — what\'s the difference?', href: '/resources/meltdowns/meltdown-vs-tantrum' },
      { label: 'Common meltdown triggers',                  href: '/resources/meltdowns/common-meltdown-triggers' },
      { label: 'How to help during a meltdown',             href: '/resources/meltdowns/how-to-help' },
    ],
    priority: true,
  },
  {
    slug: 'sensory-processing',
    title: 'Sensory Processing',
    eyebrow: 'Sensory & Environment',
    icon: '👁️',
    color: '#4F7563',
    colorBg: '#eaf2ed',
    description: 'Understand how autistic children experience the sensory world and how to create environments where they can thrive.',
    articles: [
      { label: 'Vestibular activities that calm and centre', href: '/resources/sensory-processing/vestibular-activities-that-calm-and-center' },
    ],
    priority: false,
  },
  {
    slug: 'regulation',
    title: 'Regulation',
    eyebrow: 'Nervous System Support',
    icon: '⚡',
    color: '#7B9E8B',
    colorBg: '#deeae5',
    description: 'Tools, activities, and approaches for building emotional and nervous system regulation in children on the spectrum.',
    articles: [
      { label: '5 fine motor activities you can do today',  href: '/resources/regulation/5-fine-motor-activities-you-can-do-today' },
      { label: 'How games drive neurodevelopment',          href: '/resources/regulation/unlocking-potential-how-games-drive-neurodevelopment' },
    ],
    priority: false,
  },
  {
    slug: 'communication',
    title: 'Communication',
    eyebrow: 'Language & Connection',
    icon: '💬',
    color: '#B8944A',
    colorBg: '#faf5e4',
    description: 'From first words to AAC devices — practical guidance on supporting communication development at every stage.',
    articles: [],
    priority: false,
    comingSoon: true,
  },
  {
    slug: 'behavior',
    title: 'Behaviour',
    eyebrow: 'Understanding Behaviour',
    icon: '🧩',
    color: '#123D5A',
    colorBg: '#deeae5',
    description: 'Understand the function behind behaviour and learn strategies that address root causes, not just surface symptoms.',
    articles: [],
    priority: false,
    comingSoon: true,
  },
  {
    slug: 'sleep',
    title: 'Sleep',
    eyebrow: 'Rest & Recovery',
    icon: '🌙',
    color: '#4F7563',
    colorBg: '#eaf2ed',
    description: 'Why autistic children struggle with sleep — and evidence-based approaches to improve sleep quality for the whole family.',
    articles: [],
    priority: false,
    comingSoon: true,
  },
  {
    slug: 'nutrition',
    title: 'Nutrition',
    eyebrow: 'Diet & Gut Health',
    icon: '🥦',
    color: '#7B9E8B',
    colorBg: '#deeae5',
    description: 'How diet and gut health affect autistic children — sensory-related feeding challenges, nutritional needs, and practical meal strategies.',
    articles: [],
    priority: false,
    comingSoon: true,
  },
  {
    slug: 'routines',
    title: 'Routines',
    eyebrow: 'Structure & Predictability',
    icon: '📅',
    color: '#2E6E8E',
    colorBg: '#E4EFF6',
    description: 'Why predictable routines are a regulation tool — how to build, protect, and adapt routines that help autistic children thrive.',
    articles: [],
    priority: false,
    comingSoon: true,
  },
];

const liveHubs = hubs.filter(h => !h.comingSoon);
const comingHubs = hubs.filter(h => h.comingSoon);
---

<BaseLayout
  title="Autism Resource Library | Guides for Families | Neurosage Hub"
  description="Free, evidence-based autism guides for parents — covering assessments, meltdowns, sensory processing, regulation, communication, sleep, nutrition, and routines. Written in plain language for families."
>
  <Header />

  <main>

    <!-- ===== HERO ===== -->
    <section class="py-20" style="background:#082438;">
      <div class="container">
        <div class="max-w-2xl mx-auto text-center">
          <p class="nsh-eyebrow mb-4 fade-up" style="color:#D8896A;">Free Resource Library</p>
          <h1 class="fade-up mb-5" style="font-family:'DM Sans',sans-serif; font-weight:800; font-size:clamp(2rem,5vw,3rem); color:white; line-height:1.1;">
            Answers for every stage<br>of the autism journey
          </h1>
          <p class="fade-up" style="font-family:'DM Sans',sans-serif; font-size:1.125rem; color:rgba(255,255,255,0.65); line-height:1.7; max-width:36rem; margin:0 auto 2rem;">
            Evidence-based guides organised by what your family is dealing with right now — not by clinical category. Written in plain language. Free to access.
          </p>
          <!-- Trust badges -->
          <div class="flex flex-wrap justify-center gap-3 fade-up">
            {['No sign-up required', 'Written for parents', 'Evidence-aligned'].map(b => (
              <span style="font-family:'DM Sans',sans-serif; font-size:0.8125rem; font-weight:600; color:rgba(255,255,255,0.75); background:rgba(255,255,255,0.1); border:1px solid rgba(255,255,255,0.15); padding:0.375rem 0.875rem; border-radius:9999px;">
                ✓ {b}
              </span>
            ))}
          </div>
        </div>
      </div>
    </section>

    <!-- ===== MOST SEARCHED — PRIORITY HUBS ===== -->
    <section class="py-16" style="background:#F7F2EB;">
      <div class="container">
        <div class="max-w-4xl mx-auto">
          <p class="nsh-eyebrow mb-2 text-center fade-up" style="color:#7B9E8B;">Most searched</p>
          <h2 class="text-center mb-3 fade-up" style="font-family:'DM Sans',sans-serif; font-weight:800; font-size:clamp(1.375rem,3vw,1.875rem); color:#082438;">
            Start here
          </h2>
          <p class="text-center mb-10 fade-up" style="font-family:'DM Sans',sans-serif; font-size:0.9375rem; color:#5F6975; max-width:32rem; margin-left:auto; margin-right:auto;">
            The two topics families search for most — with detailed Q&amp;A guides for each.
          </p>

          <div class="grid gap-6 md:grid-cols-2">
            {hubs.filter(h => h.priority).map((hub, i) => (
              <div class="fade-up rounded-2xl overflow-hidden" style={`background:white; border:1px solid #ddd9d2; box-shadow:0 2px 12px rgba(8,36,56,0.06); transition-delay:${i * 60}ms;`}>
                <!-- Hub header -->
                <div class="px-7 pt-6 pb-5" style={`border-bottom:1px solid #f0ede8;`}>
                  <div class="flex items-start gap-4 mb-3">
                    <div style={`width:48px; height:48px; border-radius:12px; background:${hub.colorBg}; display:flex; align-items:center; justify-content:center; font-size:1.375rem; flex-shrink:0;`}>
                      {hub.icon}
                    </div>
                    <div>
                      <p style={`font-family:'DM Sans',sans-serif; font-size:0.7rem; font-weight:700; letter-spacing:0.08em; text-transform:uppercase; color:${hub.color}; margin-bottom:0.25rem;`}>{hub.eyebrow}</p>
                      <a href={`/resources/${hub.slug}`} style={`font-family:'DM Sans',sans-serif; font-weight:700; font-size:1.1875rem; color:#082438; text-decoration:none;`}>
                        <h3 style="margin:0;">{hub.title}</h3>
                      </a>
                    </div>
                  </div>
                  <p style="font-family:'DM Sans',sans-serif; font-size:0.875rem; color:#5F6975; line-height:1.65;">{hub.description}</p>
                </div>
                <!-- Articles -->
                <div class="px-7 py-5">
                  <p style="font-family:'DM Sans',sans-serif; font-size:0.7rem; font-weight:700; letter-spacing:0.08em; text-transform:uppercase; color:#9a9187; margin-bottom:0.75rem;">Articles in this hub</p>
                  <ul style="padding:0; margin:0 0 1.25rem; list-style:none; display:flex; flex-direction:column; gap:0.5rem;">
                    {hub.articles.map(article => (
                      <li>
                        <a href={article.href} style="font-family:'DM Sans',sans-serif; font-size:0.875rem; color:#082438; text-decoration:none; display:flex; align-items:flex-start; gap:0.5rem;">
                          <span style={`color:${hub.color}; margin-top:2px; flex-shrink:0; font-weight:700;`}>→</span>
                          <span style="text-decoration:underline; text-decoration-color:rgba(0,0,0,0.15); text-underline-offset:2px;">{article.label}</span>
                        </a>
                      </li>
                    ))}
                  </ul>
                  <a href={`/resources/${hub.slug}`} style={`font-family:'DM Sans',sans-serif; font-size:0.875rem; font-weight:700; color:${hub.color}; text-decoration:none; display:inline-flex; align-items:center; gap:0.375rem;`}>
                    View all {hub.title} guides →
                  </a>
                </div>
              </div>
            ))}
          </div>

        </div>
      </div>
    </section>

    <!-- ===== LIVE TOPIC HUBS ===== -->
    <section class="py-16" style="background:white;">
      <div class="container">
        <div class="max-w-4xl mx-auto">
          <p class="nsh-eyebrow mb-2 text-center fade-up" style="color:#7B9E8B;">More topics</p>
          <h2 class="text-center mb-10 fade-up" style="font-family:'DM Sans',sans-serif; font-weight:800; font-size:clamp(1.375rem,3vw,1.875rem); color:#082438;">
            Browse by topic
          </h2>

          <div class="grid gap-5 sm:grid-cols-2 md:grid-cols-2">
            {liveHubs.filter(h => !h.priority).map((hub, i) => (
              <div class="fade-up rounded-2xl overflow-hidden" style={`background:#F7F2EB; border:1px solid #ddd9d2; transition-delay:${i * 50}ms;`}>
                <div class="px-6 pt-5 pb-4" style="border-bottom:1px solid #e8e4db;">
                  <div class="flex items-center gap-3 mb-2">
                    <div style={`width:40px; height:40px; border-radius:10px; background:${hub.colorBg}; display:flex; align-items:center; justify-content:center; font-size:1.25rem; flex-shrink:0;`}>{hub.icon}</div>
                    <div>
                      <p style={`font-family:'DM Sans',sans-serif; font-size:0.65rem; font-weight:700; letter-spacing:0.08em; text-transform:uppercase; color:${hub.color};`}>{hub.eyebrow}</p>
                      <a href={`/resources/${hub.slug}`} style="font-family:'DM Sans',sans-serif; font-weight:700; font-size:1.0625rem; color:#082438; text-decoration:none;">
                        <h3 style="margin:0;">{hub.title}</h3>
                      </a>
                    </div>
                  </div>
                  <p style="font-family:'DM Sans',sans-serif; font-size:0.8125rem; color:#5F6975; line-height:1.65;">{hub.description}</p>
                </div>
                <div class="px-6 py-4">
                  <ul style="padding:0; margin:0 0 0.875rem; list-style:none; display:flex; flex-direction:column; gap:0.4rem;">
                    {hub.articles.map(article => (
                      <li>
                        <a href={article.href} style={`font-family:'DM Sans',sans-serif; font-size:0.8125rem; color:#082438; text-decoration:none; display:flex; align-items:flex-start; gap:0.4rem;`}>
                          <span style={`color:${hub.color}; font-weight:700; flex-shrink:0;`}>→</span>
                          <span style="text-decoration:underline; text-decoration-color:rgba(0,0,0,0.12); text-underline-offset:2px;">{article.label}</span>
                        </a>
                      </li>
                    ))}
                  </ul>
                  <a href={`/resources/${hub.slug}`} style={`font-family:'DM Sans',sans-serif; font-size:0.8125rem; font-weight:700; color:${hub.color}; text-decoration:none;`}>
                    See all articles →
                  </a>
                </div>
              </div>
            ))}
          </div>

        </div>
      </div>
    </section>

    <!-- ===== COMING SOON HUBS ===== -->
    <section class="py-12" style="background:#F7F2EB;">
      <div class="container">
        <div class="max-w-4xl mx-auto">
          <p class="nsh-eyebrow mb-2 text-center fade-up" style="color:#9a9187;">Coming soon</p>
          <h2 class="text-center mb-8 fade-up" style="font-family:'DM Sans',sans-serif; font-weight:700; font-size:1.25rem; color:#5F6975;">
            More guides on the way
          </h2>
          <div class="grid gap-4 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-5">
            {comingHubs.map((hub, i) => (
              <a
                href={`/resources/${hub.slug}`}
                class="fade-up rounded-xl p-5 block"
                style={`background:white; border:1px solid #ddd9d2; text-decoration:none; opacity:0.7; transition-delay:${i*40}ms;`}
              >
                <div style="font-size:1.25rem; margin-bottom:0.5rem;">{hub.icon}</div>
                <p style="font-family:'DM Sans',sans-serif; font-weight:700; font-size:0.9375rem; color:#082438; margin-bottom:0.25rem;">{hub.title}</p>
                <p style="font-family:'DM Sans',sans-serif; font-size:0.75rem; color:#9a9187;">Coming soon</p>
              </a>
            ))}
          </div>
        </div>
      </div>
    </section>

    <!-- ===== CTA ===== -->
    <section class="py-16" style="background:#082438;">
      <div class="container">
        <div class="max-w-xl mx-auto text-center">
          <p class="nsh-eyebrow mb-3" style="color:#D8896A;">Neurosage Hub Platform</p>
          <h2 style="font-family:'DM Sans',sans-serif; font-weight:800; font-size:clamp(1.5rem,3.5vw,2.125rem); color:white; margin-bottom:0.875rem; line-height:1.25;">
            Ready to go beyond reading?
          </h2>
          <p style="font-family:'DM Sans',sans-serif; font-size:1rem; color:rgba(255,255,255,0.65); max-width:28rem; margin:0 auto 2rem; line-height:1.7;">
            Guided pathways, therapeutic games, and practitioner-connected support — all in one place, free to start.
          </p>
          <div class="flex flex-wrap justify-center gap-3">
            <a href="/family-sign-up" style="font-family:'DM Sans',sans-serif; font-size:0.9375rem; font-weight:700; background:#D8896A; color:white; padding:0.875rem 2rem; border-radius:9999px; text-decoration:none;">
              Get Started Free
            </a>
            <a href="/for-practitioners" style="font-family:'DM Sans',sans-serif; font-size:0.9375rem; font-weight:600; background:rgba(255,255,255,0.1); color:white; padding:0.875rem 2rem; border-radius:9999px; text-decoration:none; border:1px solid rgba(255,255,255,0.2);">
              I'm a Practitioner
            </a>
          </div>
        </div>
      </div>
    </section>

  </main>

  <Footer />
</BaseLayout>
