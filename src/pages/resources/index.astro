---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';

const hubs = [
  {
    slug: 'assessments',
    title: 'Assessments',
    icon: '🔍',
    description: 'What is happening? Understand autism assessments, how to prepare, what to expect, and what the results mean.',
    articles: ['What is an autism assessment?', 'How long does it take?', 'What happens during an assessment?', 'How to prepare your child'],
    priority: true,
  },
  {
    slug: 'meltdowns',
    title: 'Meltdowns',
    icon: '🌊',
    description: 'How do I survive today? What causes meltdowns, how to help in the moment, and how to reduce them over time.',
    articles: ['Meltdown vs tantrum', 'Common meltdown triggers', 'How to help during a meltdown', 'What causes autism meltdowns'],
    priority: true,
  },
  {
    slug: 'sensory-processing',
    title: 'Sensory Processing',
    icon: '👁️',
    description: 'Understand how autistic children experience the sensory world — and how to create environments where they can thrive.',
    articles: ['Vestibular activities that calm and center', 'What is sensory processing disorder?', 'Sensory-friendly home tips'],
    priority: false,
  },
  {
    slug: 'regulation',
    title: 'Regulation',
    icon: '⚡',
    description: 'Tools, activities, and approaches for building emotional and nervous system regulation in children on the spectrum.',
    articles: ['Fine motor activities you can do today', 'How games drive neurodevelopment', 'Building regulation routines'],
    priority: false,
  },
  {
    slug: 'communication',
    title: 'Communication',
    icon: '💬',
    description: 'From first words to AAC devices — practical guidance on supporting communication development at every stage.',
    articles: ['Coming soon'],
    priority: false,
  },
  {
    slug: 'behavior',
    title: 'Behavior',
    icon: '🧩',
    description: 'Understand the function behind behavior and learn strategies that address root causes, not just surface symptoms.',
    articles: ['Coming soon'],
    priority: false,
  },
  {
    slug: 'sleep',
    title: 'Sleep',
    icon: '🌙',
    description: 'Why autistic children struggle with sleep — and evidence-based approaches to improve sleep quality for the whole family.',
    articles: ['Coming soon'],
    priority: false,
  },
];
---

<BaseLayout
  title="Autism Resource Center | Neurosage Hub"
  description="Evidence-based guides on autism assessments, meltdowns, sensory processing, regulation, communication, behavior, and sleep — written for families and practitioners."
>
  <Header />

  <main>

    <!-- ===== HERO ===== -->
    <section class="py-20" style="background:#082438;">
      <div class="container">
        <div class="max-w-2xl mx-auto text-center">
          <p class="nsh-eyebrow mb-4 fade-up" style="color:#D8896A;">Resource Center</p>
          <h1 class="fade-up mb-5" style="font-family:'DM Sans',sans-serif; font-weight:800; font-size:clamp(2rem,5vw,3rem); color:white; line-height:1.1;">
            Answers for every stage<br>of the autism journey
          </h1>
          <p class="fade-up" style="font-family:'DM Sans',sans-serif; font-size:1.125rem; color:rgba(255,255,255,0.65); line-height:1.7; max-width:36rem; margin:0 auto;">
            Evidence-based guides organized by what you're dealing with right now — not by clinical category.
          </p>
        </div>
      </div>
    </section>

    <!-- ===== PRIORITY HUBS ===== -->
    <section class="py-16" style="background:#F7F2EB;">
      <div class="container">
        <div class="max-w-4xl mx-auto">

          <p class="nsh-eyebrow mb-2 text-center fade-up" style="color:#7B9E8B;">Most searched</p>
          <h2 class="text-center mb-10 fade-up" style="font-family:'DM Sans',sans-serif; font-weight:800; font-size:clamp(1.375rem,3vw,1.875rem); color:#082438;">
            Start here
          </h2>

          <div class="grid gap-6 md:grid-cols-2">
            {hubs.filter(h => h.priority).map((hub, i) => (
              <a
                href={`/resources/${hub.slug}`}
                class="fade-up group rounded-2xl p-7 block"
                style={`background:white; border:1px solid #ddd9d2; text-decoration:none; transition-delay:${i * 60}ms; box-shadow:0 2px 12px rgba(8,36,56,0.06);`}
              >
                <div class="flex items-start gap-4 mb-4">
                  <div style="width:48px; height:48px; border-radius:12px; background:#E4EFF6; display:flex; align-items:center; justify-content:center; font-size:1.375rem; flex-shrink:0;">
                    {hub.icon}
                  </div>
                  <div>
                    <h3 class="group-hover:underline" style="font-family:'DM Sans',sans-serif; font-weight:700; font-size:1.1875rem; color:#082438; margin-bottom:0.25rem;">{hub.title}</h3>
                    <p style="font-family:'DM Sans',sans-serif; font-size:0.875rem; color:#5F6975; line-height:1.6;">{hub.description}</p>
                  </div>
                </div>
                <ul style="padding:0; margin:0; list-style:none; display:flex; flex-direction:column; gap:0.375rem;">
                  {hub.articles.map(article => (
                    <li style="font-family:'DM Sans',sans-serif; font-size:0.8125rem; color:#3d5a6e; display:flex; align-items:flex-start; gap:0.375rem;">
                      <span style="color:#2E6E8E; margin-top:2px; flex-shrink:0;">→</span>
                      {article}
                    </li>
                  ))}
                </ul>
              </a>
            ))}
          </div>

        </div>
      </div>
    </section>

    <!-- ===== ALL HUBS ===== -->
    <section class="py-16" style="background:white;">
      <div class="container">
        <div class="max-w-4xl mx-auto">

          <p class="nsh-eyebrow mb-2 text-center fade-up" style="color:#7B9E8B;">All topics</p>
          <h2 class="text-center mb-10 fade-up" style="font-family:'DM Sans',sans-serif; font-weight:800; font-size:clamp(1.375rem,3vw,1.875rem); color:#082438;">
            Browse by topic
          </h2>

          <div class="grid gap-5 sm:grid-cols-2 md:grid-cols-3">
            {hubs.filter(h => !h.priority).map((hub, i) => (
              <a
                href={`/resources/${hub.slug}`}
                class="fade-up group rounded-2xl p-6 block"
                style={`background:#F7F2EB; border:1px solid #ddd9d2; text-decoration:none; transition-delay:${i * 50}ms;`}
              >
                <div style="font-size:1.375rem; margin-bottom:0.75rem;">{hub.icon}</div>
                <h3 class="group-hover:underline" style="font-family:'DM Sans',sans-serif; font-weight:700; font-size:1.0625rem; color:#082438; margin-bottom:0.375rem;">{hub.title}</h3>
                <p style="font-family:'DM Sans',sans-serif; font-size:0.8125rem; color:#5F6975; line-height:1.65;">{hub.description}</p>
              </a>
            ))}
          </div>

        </div>
      </div>
    </section>

    <!-- ===== CTA ===== -->
    <section class="py-16" style="background:#082438;">
      <div class="container">
        <div class="max-w-xl mx-auto text-center">
          <p class="nsh-eyebrow mb-3" style="color:#D8896A;">Neurosage Hub Platform</p>
          <h2 style="font-family:'DM Sans',sans-serif; font-weight:800; font-size:clamp(1.5rem,3.5vw,2.125rem); color:white; margin-bottom:0.875rem; line-height:1.25;">
            Ready to go beyond reading?
          </h2>
          <p style="font-family:'DM Sans',sans-serif; font-size:1rem; color:rgba(255,255,255,0.65); max-width:28rem; margin:0 auto 2rem; line-height:1.7;">
            Guided activities, therapeutic games, and practitioner support — all in one place.
          </p>
          <div class="flex flex-wrap justify-center gap-3">
            <a
              href="/family-sign-up"
              style="font-family:'DM Sans',sans-serif; font-size:0.9375rem; font-weight:700; background:#D8896A; color:white; padding:0.875rem 2rem; border-radius:9999px; text-decoration:none;"
            >
              Get Started Free
            </a>
            <a
              href="/for-practitioners"
              style="font-family:'DM Sans',sans-serif; font-size:0.9375rem; font-weight:600; background:rgba(255,255,255,0.1); color:white; padding:0.875rem 2rem; border-radius:9999px; text-decoration:none; border:1px solid rgba(255,255,255,0.2);"
            >
              I'm a Practitioner
            </a>
          </div>
        </div>
      </div>
    </section>

  </main>

  <Footer />
</BaseLayout>
