---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';

const foundations = [
  {
    slug: 'what-causes-autism-meltdowns',
    title: 'What Causes Autism Meltdowns?',
    desc: 'Why meltdowns happen — the neurological and sensory roots of autistic meltdowns, explained clearly for families and practitioners.',
    readTime: '5 min',
  },
  {
    slug: 'meltdown-vs-tantrum',
    title: 'Autism Meltdown vs Tantrum: What\'s the Difference?',
    desc: 'A meltdown and a tantrum look similar on the surface but have completely different causes — and require different responses.',
    readTime: '5 min',
  },
  {
    slug: 'common-meltdown-triggers',
    title: 'Common Autism Meltdown Triggers',
    desc: 'Understanding what triggers meltdowns is the first step toward preventing them. Here are the most common triggers and why they overwhelm the autistic nervous system.',
    readTime: '6 min',
  },
  {
    slug: 'how-to-help',
    title: 'How to Help During and After an Autism Meltdown',
    desc: 'What to do — and what not to do — in the moment, and how to support your child in recovery after a meltdown.',
    readTime: '7 min',
  },
  {
    slug: 'autism-meltdown-guide',
    title: '2026 Autism Meltdown Guide: Essential Steps for Parents',
    desc: 'The complete parent guide: early warning signs, the 3-Minute Reset framework, co-regulation techniques, trigger tracking, and building a data-driven support plan.',
    readTime: '18 min',
  },
];

const teenArticles = [
  {
    slug: 'high-functioning-teen-meltdowns',
    title: 'High-Functioning Teen Meltdowns: Spot, Prevent, Empower',
    desc: 'Why meltdowns in high-functioning autistic teens are so often missed — and the evidence-based strategies that help families prevent and respond effectively.',
    readTime: '14 min',
  },
  {
    slug: 'subtle-meltdown-signs-teens',
    title: 'Subtle Meltdown Signs in High-Functioning Teens: Quick Guide',
    desc: 'The 5 most commonly missed early warning signs in autistic teenagers, and the actionable steps to take the moment you notice them.',
    readTime: '10 min',
  },
];

const adultArticles = [
  {
    slug: 'autistic-adult-caregiver-checklist',
    title: 'Caregiver Checklist: Supporting Autistic Adults During Meltdowns',
    desc: 'A complete caregiver checklist for supporting autistic adults before, during, and after meltdowns — covering early warning signs unique to adults who mask, safety planning, and recovery.',
    readTime: '15 min',
  },
  {
    slug: 'adult-autism-meltdown-management',
    title: 'Adult Autism Meltdown Management: Strategies for Work & Home',
    desc: 'Recognizing early warning signs and applying a three-step de-escalation framework — with a personalized regulation plan built for adult life at work and at home.',
    readTime: '19 min',
  },
  {
    slug: 'workplace-triggers-autistic-adults',
    title: 'Workplace Triggers for Autistic Adults and Coping Techniques',
    desc: 'The most common workplace triggers — sensory overload, schedule disruptions, communication demands — and the practical accommodations and coping techniques that prevent meltdowns at work.',
    readTime: '18 min',
  },
];
---

<BaseLayout
  title="Autism Meltdowns: Causes, Triggers & How to Help | Neurosage Hub"
  description="Evidence-based guides on autism meltdowns — what causes them, how they differ from tantrums, common triggers, and how to help in the moment. For families and practitioners."
>
  <Header />

  <main>

    <!-- ===== HERO ===== -->
    <section class="py-20" style="background:#082438;">
      <div class="container">
        <div class="max-w-2xl mx-auto">

          <nav class="mb-6">
            <a href="/resources" style="font-family:'DM Sans',sans-serif; font-size:0.8125rem; color:rgba(255,255,255,0.5); text-decoration:none;">← Resources</a>
          </nav>

          <p class="nsh-eyebrow mb-4 fade-up" style="color:#D8896A;">Hub 2 of 7</p>
          <h1 class="fade-up mb-5" style="font-family:'DM Sans',sans-serif; font-weight:800; font-size:clamp(2rem,5vw,3rem); color:white; line-height:1.1;">
            Autism Meltdowns
          </h1>
          <p class="fade-up" style="font-family:'DM Sans',sans-serif; font-size:1.125rem; color:rgba(255,255,255,0.65); line-height:1.7; max-width:34rem;">
            Meltdowns aren't behavior problems — they're nervous system responses. These guides help you understand what's happening, what triggers it, and how to respond in a way that actually helps.
          </p>

          <div class="flex items-center gap-3 mt-6">
            <span style="font-family:'DM Sans',sans-serif; font-size:0.8125rem; color:rgba(255,255,255,0.4);">{foundations.length + teenArticles.length + adultArticles.length} guides</span>
            <span style="color:rgba(255,255,255,0.2);">·</span>
            <span style="font-family:'DM Sans',sans-serif; font-size:0.8125rem; color:rgba(255,255,255,0.4);">Children, teens & adults</span>
          </div>

        </div>
      </div>
    </section>

    <!-- ===== KEY QUESTION ===== -->
    <section class="py-12" style="background:#E4EFF6;">
      <div class="container">
        <div class="max-w-2xl mx-auto text-center">
          <p style="font-family:'DM Sans',sans-serif; font-size:1.0625rem; font-weight:700; color:#082438; line-height:1.6; margin-bottom:0.5rem;">
            "How do I survive today?"
          </p>
          <p style="font-family:'DM Sans',sans-serif; font-size:0.9375rem; color:#3d5a6e; line-height:1.75;">
            If your child is having frequent meltdowns, start with the article on <a href="/resources/meltdowns/how-to-help" style="color:#2E6E8E; text-decoration:underline; font-weight:600;">how to help during a meltdown</a>. For teens, start with <a href="/resources/meltdowns/high-functioning-teen-meltdowns" style="color:#2E6E8E; text-decoration:underline; font-weight:600;">high-functioning teen meltdowns</a>. For adult caregivers, see the <a href="/resources/meltdowns/autistic-adult-caregiver-checklist" style="color:#2E6E8E; text-decoration:underline; font-weight:600;">adult caregiver checklist</a>.
          </p>
        </div>
      </div>
    </section>

    <!-- ===== FOUNDATIONS ===== -->
    <section class="py-16" style="background:white;">
      <div class="container">
        <div class="max-w-3xl mx-auto">
          <p class="nsh-eyebrow mb-2 fade-up" style="color:#7B9E8B;">Start here</p>
          <h2 class="fade-up mb-8" style="font-family:'DM Sans',sans-serif; font-weight:800; font-size:1.5rem; color:#082438;">Foundations</h2>
          <div>
            {foundations.map((article, i) => (
              <a
                href={`/resources/meltdowns/${article.slug}`}
                class="fade-up group"
                style={`display:block; padding:1.5rem 0; border-bottom:1px solid #ddd9d2; ${i === 0 ? 'border-top:1px solid #ddd9d2;' : ''} text-decoration:none;`}
              >
                <div class="flex items-start gap-4">
                  <div style="width:36px; height:36px; border-radius:50%; background:#E4EFF6; flex-shrink:0; display:flex; align-items:center; justify-content:center; margin-top:2px;">
                    <span style="font-family:'DM Sans',sans-serif; font-size:0.75rem; font-weight:700; color:#1A4A6B;">{i + 1}</span>
                  </div>
                  <div class="flex-1">
                    <div class="flex items-center gap-2 mb-1">
                      <p class="group-hover:underline" style="font-family:'DM Sans',sans-serif; font-weight:700; font-size:1rem; color:#082438; line-height:1.4;">{article.title}</p>
                      <span style="font-family:'DM Sans',sans-serif; font-size:0.75rem; color:#7B9E8B; white-space:nowrap;">{article.readTime}</span>
                    </div>
                    <p style="font-family:'DM Sans',sans-serif; font-size:0.875rem; color:#5F6975; line-height:1.65;">{article.desc}</p>
                  </div>
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#2E6E8E" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="flex-shrink:0; margin-top:4px;"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
                </div>
              </a>
            ))}
          </div>
        </div>
      </div>
    </section>

    <!-- ===== TEENS ===== -->
    <section class="py-16" style="background:#F7F2EB;">
      <div class="container">
        <div class="max-w-3xl mx-auto">
          <p class="nsh-eyebrow mb-2 fade-up" style="color:#7B9E8B;">Ages 13–19</p>
          <h2 class="fade-up mb-8" style="font-family:'DM Sans',sans-serif; font-weight:800; font-size:1.5rem; color:#082438;">Teens & Adolescents</h2>
          <div>
            {teenArticles.map((article, i) => (
              <a
                href={`/resources/meltdowns/${article.slug}`}
                class="fade-up group"
                style={`display:block; padding:1.5rem 0; border-bottom:1px solid #ddd9d2; ${i === 0 ? 'border-top:1px solid #ddd9d2;' : ''} text-decoration:none;`}
              >
                <div class="flex items-start gap-4">
                  <div style="width:36px; height:36px; border-radius:50%; background:#E4EFF6; flex-shrink:0; display:flex; align-items:center; justify-content:center; margin-top:2px;">
                    <span style="font-family:'DM Sans',sans-serif; font-size:0.75rem; font-weight:700; color:#1A4A6B;">{i + 1}</span>
                  </div>
                  <div class="flex-1">
                    <div class="flex items-center gap-2 mb-1">
                      <p class="group-hover:underline" style="font-family:'DM Sans',sans-serif; font-weight:700; font-size:1rem; color:#082438; line-height:1.4;">{article.title}</p>
                      <span style="font-family:'DM Sans',sans-serif; font-size:0.75rem; color:#7B9E8B; white-space:nowrap;">{article.readTime}</span>
                    </div>
                    <p style="font-family:'DM Sans',sans-serif; font-size:0.875rem; color:#5F6975; line-height:1.65;">{article.desc}</p>
                  </div>
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#2E6E8E" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="flex-shrink:0; margin-top:4px;"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
                </div>
              </a>
            ))}
          </div>
        </div>
      </div>
    </section>

    <!-- ===== ADULTS ===== -->
    <section class="py-16" style="background:white;">
      <div class="container">
        <div class="max-w-3xl mx-auto">
          <p class="nsh-eyebrow mb-2 fade-up" style="color:#7B9E8B;">Adults & caregivers</p>
          <h2 class="fade-up mb-8" style="font-family:'DM Sans',sans-serif; font-weight:800; font-size:1.5rem; color:#082438;">Adults</h2>
          <div>
            {adultArticles.map((article, i) => (
              <a
                href={`/resources/meltdowns/${article.slug}`}
                class="fade-up group"
                style={`display:block; padding:1.5rem 0; border-bottom:1px solid #ddd9d2; ${i === 0 ? 'border-top:1px solid #ddd9d2;' : ''} text-decoration:none;`}
              >
                <div class="flex items-start gap-4">
                  <div style="width:36px; height:36px; border-radius:50%; background:#E4EFF6; flex-shrink:0; display:flex; align-items:center; justify-content:center; margin-top:2px;">
                    <span style="font-family:'DM Sans',sans-serif; font-size:0.75rem; font-weight:700; color:#1A4A6B;">{i + 1}</span>
                  </div>
                  <div class="flex-1">
                    <div class="flex items-center gap-2 mb-1">
                      <p class="group-hover:underline" style="font-family:'DM Sans',sans-serif; font-weight:700; font-size:1rem; color:#082438; line-height:1.4;">{article.title}</p>
                      <span style="font-family:'DM Sans',sans-serif; font-size:0.75rem; color:#7B9E8B; white-space:nowrap;">{article.readTime}</span>
                    </div>
                    <p style="font-family:'DM Sans',sans-serif; font-size:0.875rem; color:#5F6975; line-height:1.65;">{article.desc}</p>
                  </div>
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#2E6E8E" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="flex-shrink:0; margin-top:4px;"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
                </div>
              </a>
            ))}
          </div>
        </div>
      </div>
    </section>

    <!-- ===== CTA ===== -->
    <section class="py-16" style="background:#082438;">
      <div class="container">
        <div class="max-w-xl mx-auto text-center">
          <p class="nsh-eyebrow mb-3" style="color:#D8896A;">Neurosage Hub</p>
          <h2 style="font-family:'DM Sans',sans-serif; font-weight:800; font-size:clamp(1.5rem,3.5vw,2.125rem); color:white; margin-bottom:0.875rem; line-height:1.25;">Get started today</h2>
          <p style="font-family:'DM Sans',sans-serif; font-size:1rem; color:rgba(255,255,255,0.65); max-width:28rem; margin:0 auto 1.5rem; line-height:1.7;">Evidence-based courses and tools to help autistic individuals and their families build skills and reduce meltdown frequency.</p>
          <a href="/resources" style="display:inline-flex; align-items:center; gap:0.5rem; padding:0.75rem 1.625rem; background:#D8896A; color:white; border-radius:0.875rem; text-decoration:none; font-family:'DM Sans',sans-serif; font-size:0.9375rem; font-weight:700;">
            Browse all resources →
          </a>
        </div>
      </div>
    </section>

  </main>

  <Footer />
</BaseLayout>
