---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';
---

<BaseLayout
  title="Communication in Autism: Guides & Resources | Neurosage Hub"
  description="Practical guidance on supporting communication development in autistic children — from first words to AAC devices. For families and practitioners."
>
  <Header />

  <main>

    <section class="py-20" style="background:#082438;">
      <div class="container">
        <div class="max-w-2xl mx-auto">
          <nav class="mb-6">
            <a href="/resources" style="font-family:'DM Sans',sans-serif; font-size:0.8125rem; color:rgba(255,255,255,0.5); text-decoration:none;">← Resources</a>
          </nav>
          <p class="nsh-eyebrow mb-4 fade-up" style="color:#D8896A;">Hub 5 of 7</p>
          <h1 class="fade-up mb-5" style="font-family:'DM Sans',sans-serif; font-weight:800; font-size:clamp(2rem,5vw,3rem); color:white; line-height:1.1;">
            Communication
          </h1>
          <p class="fade-up" style="font-family:'DM Sans',sans-serif; font-size:1.125rem; color:rgba(255,255,255,0.65); line-height:1.7; max-width:34rem;">
            From first words to AAC devices — practical guidance on supporting communication development at every stage of the autism journey.
          </p>
        </div>
      </div>
    </section>

    <section class="py-16" style="background:white;">
      <div class="container">
        <div class="max-w-3xl mx-auto text-center">
          <div class="rounded-2xl p-12 fade-up" style="background:#F7F2EB; border:1px solid #ddd9d2;">
            <p class="nsh-eyebrow mb-3" style="color:#7B9E8B;">Coming soon</p>
            <h2 style="font-family:'DM Sans',sans-serif; font-weight:700; font-size:1.375rem; color:#082438; margin-bottom:0.75rem;">Communication guides are on the way</h2>
            <p style="font-family:'DM Sans',sans-serif; font-size:0.9375rem; color:#5F6975; line-height:1.75; max-width:28rem; margin:0 auto 1.5rem;">
              We're building practical, evidence-based guides covering AAC, speech development, and supporting non-speaking autistic children.
            </p>
            <button onclick="window.nshOpenNotify('communication')" style="display:inline-flex; align-items:center; gap:0.5rem; padding:0.625rem 1.375rem; background:#2E6E8E; color:white; border:none; border-radius:0.75rem; cursor:pointer; font-family:'DM Sans',sans-serif; font-size:0.875rem; font-weight:700; margin-bottom:1.25rem; transition:background 0.15s;" onmouseover="this.style.background='#1A4A6B'" onmouseout="this.style.background='#2E6E8E'">
              Get notified when communication guides are added →
            </button>
            <br />
            <a href="/resources" style="font-family:'DM Sans',sans-serif; font-size:0.875rem; font-weight:600; color:#2E6E8E; text-decoration:none;">← Back to all resources</a>
          </div>
        </div>
      </div>
    </section>

    <section class="py-16" style="background:#082438;">
      <div class="container">
        <div class="max-w-xl mx-auto text-center">
          <p class="nsh-eyebrow mb-3" style="color:#D8896A;">Neurosage Hub</p>
          <h2 style="font-family:'DM Sans',sans-serif; font-weight:800; font-size:clamp(1.5rem,3.5vw,2.125rem); color:white; margin-bottom:0.875rem; line-height:1.25;">Get started today</h2>
          <p style="font-family:'DM Sans',sans-serif; font-size:1rem; color:rgba(255,255,255,0.65); max-width:28rem; margin:0 auto 2rem; line-height:1.7;">
            The Neurosage Hub Platform supports communication development through guided activities and therapeutic games.
          </p>
          <a href="/family-sign-up" style="font-family:'DM Sans',sans-serif; font-size:0.9375rem; font-weight:700; background:#D8896A; color:white; padding:0.875rem 2rem; border-radius:9999px; text-decoration:none; display:inline-block;">
            Get Started Free
          </a>
        </div>
      </div>
    </section>

    <!-- ===== GET NOTIFIED ===== -->
    <section class="py-12" style="background:#F7F2EB;">
      <div class="container">
        <div class="max-w-3xl mx-auto">
          <div style="background:white; border-radius:1.5rem; padding:1.5rem 1.75rem; border:1px solid #ddd9d2; display:flex; align-items:center; justify-content:space-between; gap:1.25rem; flex-wrap:wrap;">
            <div style="display:flex; align-items:center; gap:0.875rem; flex:1; min-width:180px;">
              <div style="width:40px; height:40px; border-radius:10px; background:#E4EFF6; display:flex; align-items:center; justify-content:center; flex-shrink:0;">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#1A4A6B" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"/><path d="M13.73 21a2 2 0 0 1-3.46 0"/></svg>
              </div>
              <div>
                <p style="font-family:'DM Sans',sans-serif; font-weight:700; font-size:0.9375rem; color:#082438; margin:0 0 0.125rem;">Get notified of new communication guides</p>
                <p style="font-family:'DM Sans',sans-serif; font-size:0.8125rem; color:#5F6975; margin:0; line-height:1.5;">We'll email you when new content is added to this hub.</p>
              </div>
            </div>
            <button onclick="window.nshOpenNotify('communication')" style="padding:0.625rem 1.25rem; background:#2E6E8E; color:white; border:none; border-radius:0.75rem; cursor:pointer; font-family:'DM Sans',sans-serif; font-size:0.875rem; font-weight:700; white-space:nowrap; transition:background 0.15s;" onmouseover="this.style.background='#1A4A6B'" onmouseout="this.style.background='#2E6E8E'">
              Notify Me →
            </button>
          </div>
        </div>
      </div>
    </section>

  </main>
  <Footer />
</BaseLayout>
