---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';

const articles = [
  {
    slug: '5-fine-motor-activities-you-can-do-today',
    title: '5 Fine Motor Activities You Can Do Today',
    desc: 'Simple, sensory-rich fine motor activities for autistic children — no fancy equipment required.',
    readTime: '5 min',
  },
  {
    slug: 'unlocking-potential-how-games-drive-neurodevelopment',
    title: 'Unlocking Potential: How Games Drive Neurodevelopment',
    desc: 'How therapeutic games activate key neural pathways — and why enjoyment is the secret ingredient in neuroplasticity.',
    readTime: '6 min',
  },
];
---

<BaseLayout
  title="Regulation in Autism: Activities & Strategies | Neurosage Hub"
  description="Tools, activities, and approaches for building emotional and nervous system regulation in autistic children — for families and practitioners."
>
  <Header />

  <main>

    <section class="py-20" style="background:#082438;">
      <div class="container">
        <div class="max-w-2xl mx-auto">
          <nav class="mb-6">
            <a href="/resources" style="font-family:'DM Sans',sans-serif; font-size:0.8125rem; color:rgba(255,255,255,0.5); text-decoration:none;">← Resources</a>
          </nav>
          <p class="nsh-eyebrow mb-4 fade-up" style="color:#D8896A;">Hub 4 of 7</p>
          <h1 class="fade-up mb-5" style="font-family:'DM Sans',sans-serif; font-weight:800; font-size:clamp(2rem,5vw,3rem); color:white; line-height:1.1;">
            Regulation
          </h1>
          <p class="fade-up" style="font-family:'DM Sans',sans-serif; font-size:1.125rem; color:rgba(255,255,255,0.65); line-height:1.7; max-width:34rem;">
            Building emotional and nervous system regulation isn't about controlling behavior — it's about giving children the neurological foundation to manage themselves.
          </p>
        </div>
      </div>
    </section>

    <section class="py-16" style="background:white;">
      <div class="container">
        <div class="max-w-3xl mx-auto">
          <p class="nsh-eyebrow mb-8 fade-up" style="color:#7B9E8B;">{articles.length} Guides</p>
          <div>
            {articles.map((article, i) => (
              <a
                href={`/resources/regulation/${article.slug}`}
                class="fade-up group"
                style={`display:block; padding:1.5rem 0; border-bottom:1px solid #ddd9d2; ${i === 0 ? 'border-top:1px solid #ddd9d2;' : ''} text-decoration:none; transition-delay:${i * 50}ms;`}
              >
                <div class="flex items-start gap-4">
                  <div style="width:36px; height:36px; border-radius:50%; background:#E4EFF6; flex-shrink:0; display:flex; align-items:center; justify-content:center; margin-top:2px;">
                    <span style="font-family:'DM Sans',sans-serif; font-size:0.75rem; font-weight:700; color:#1A4A6B;">{i + 1}</span>
                  </div>
                  <div class="flex-1">
                    <div class="flex items-center gap-2 mb-1">
                      <p class="group-hover:underline" style="font-family:'DM Sans',sans-serif; font-weight:700; font-size:1rem; color:#082438; line-height:1.4;">{article.title}</p>
                      <span style="font-family:'DM Sans',sans-serif; font-size:0.75rem; color:#7B9E8B; white-space:nowrap;">{article.readTime}</span>
                    </div>
                    <p style="font-family:'DM Sans',sans-serif; font-size:0.875rem; color:#5F6975; line-height:1.65;">{article.desc}</p>
                  </div>
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#2E6E8E" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="flex-shrink:0; margin-top:4px;"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
                </div>
              </a>
            ))}
          </div>
          <div class="mt-12 rounded-2xl p-7 text-center fade-up" style="background:#F7F2EB; border:1px solid #ddd9d2;">
            <p style="font-family:'DM Sans',sans-serif; font-size:0.9375rem; color:#5F6975;">More regulation guides coming soon.</p>
          </div>
        </div>
      </div>
    </section>

    <section class="py-16" style="background:#082438;">
      <div class="container">
        <div class="max-w-xl mx-auto text-center">
          <p class="nsh-eyebrow mb-3" style="color:#D8896A;">Neurosage Hub</p>
          <h2 style="font-family:'DM Sans',sans-serif; font-weight:800; font-size:clamp(1.5rem,3.5vw,2.125rem); color:white; margin-bottom:0.875rem; line-height:1.25;">
            Turn movement into momentum
          </h2>
          <p style="font-family:'DM Sans',sans-serif; font-size:1rem; color:rgba(255,255,255,0.65); max-width:28rem; margin:0 auto 2rem; line-height:1.7;">
            Guided activities and therapeutic games that build regulation capacity from the inside out — at home, every day.
          </p>
          <a href="/family-sign-up" style="font-family:'DM Sans',sans-serif; font-size:0.9375rem; font-weight:700; background:#D8896A; color:white; padding:0.875rem 2rem; border-radius:9999px; text-decoration:none; display:inline-block;">
            Get Started Free
          </a>
        </div>
      </div>
    </section>

    <!-- ===== GET NOTIFIED ===== -->
    <section class="py-12" style="background:#F7F2EB;">
      <div class="container">
        <div class="max-w-3xl mx-auto">
          <div style="background:white; border-radius:1.5rem; padding:1.5rem 1.75rem; border:1px solid #ddd9d2; display:flex; align-items:center; justify-content:space-between; gap:1.25rem; flex-wrap:wrap;">
            <div style="display:flex; align-items:center; gap:0.875rem; flex:1; min-width:180px;">
              <div style="width:40px; height:40px; border-radius:10px; background:#E4EFF6; display:flex; align-items:center; justify-content:center; flex-shrink:0;">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#1A4A6B" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"/><path d="M13.73 21a2 2 0 0 1-3.46 0"/></svg>
              </div>
              <div>
                <p style="font-family:'DM Sans',sans-serif; font-weight:700; font-size:0.9375rem; color:#082438; margin:0 0 0.125rem;">Get notified of new regulation guides</p>
                <p style="font-family:'DM Sans',sans-serif; font-size:0.8125rem; color:#5F6975; margin:0; line-height:1.5;">We'll email you when new content is added to this hub.</p>
              </div>
            </div>
            <button onclick="window.nshOpenNotify('regulation')" style="padding:0.625rem 1.25rem; background:#2E6E8E; color:white; border:none; border-radius:0.75rem; cursor:pointer; font-family:'DM Sans',sans-serif; font-size:0.875rem; font-weight:700; white-space:nowrap; transition:background 0.15s;" onmouseover="this.style.background='#1A4A6B'" onmouseout="this.style.background='#2E6E8E'">
              Notify Me →
            </button>
          </div>
        </div>
      </div>
    </section>

  </main>
  <Footer />
</BaseLayout>
