---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Welcome to Neurosage Hub!"
  description="Your free account is being set up. Welcome to the Neurosage Hub family."
  noindex={true}
>

  <!-- Minimal header -->
  <header style="background:#082438; border-bottom:1px solid rgba(255,255,255,0.08); padding:1rem 0;">
    <div class="container">
      <a href="/" class="flex items-center gap-2.5" style="width:fit-content;">
        <img src="/logo-white.png" alt="Neurosage Hub" class="h-10 w-auto"
          onerror="this.style.display='none'; document.getElementById('logo-text').style.display='block'" />
        <span id="logo-text" style="display:none; font-family:'DM Sans',sans-serif; font-size:1.125rem; font-weight:800; color:white;">Neurosage Hub</span>
      </a>
    </div>
  </header>

  <main style="background:#082438; min-height:calc(100vh - 65px); display:flex; align-items:center;">
    <div class="container py-16">
      <div class="max-w-2xl mx-auto text-center">

        <!-- Checkmark icon -->
        <div style="width:80px; height:80px; border-radius:50%; background:rgba(123,158,139,0.15); border:2px solid #7B9E8B; margin:0 auto 2rem; display:flex; align-items:center; justify-content:center;">
          <svg width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="#7B9E8B" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
        </div>

        <p style="font-family:'DM Sans',sans-serif; font-size:0.8125rem; font-weight:700; letter-spacing:0.12em; text-transform:uppercase; color:#7B9E8B; margin-bottom:1rem;">You're in!</p>

        <h1 id="welcome-heading" style="font-family:'DM Sans',sans-serif; font-weight:800; font-size:clamp(1.875rem,4vw,2.75rem); color:white; line-height:1.15; margin-bottom:1.25rem;">
          Welcome to Neurosage Hub!
        </h1>

        <p id="welcome-body" style="font-family:'DM Sans',sans-serif; font-size:1.125rem; color:rgba(255,255,255,0.72); line-height:1.75; margin-bottom:2.5rem; max-width:30rem; margin-left:auto; margin-right:auto;">
          Your free account is being set up. Check your inbox — we've sent you a confirmation email with your next steps.
        </p>

        <!-- What happens next -->
        <div class="rounded-2xl p-8 mb-8 text-left" style="background:rgba(255,255,255,0.05); border:1px solid rgba(255,255,255,0.1);">
          <h2 style="font-family:'DM Sans',sans-serif; font-weight:700; font-size:1.125rem; color:white; margin-bottom:1.25rem;">What happens next:</h2>
          <div class="flex flex-col gap-4">
            <div class="flex items-start gap-3">
              <div style="width:28px; height:28px; border-radius:50%; background:#1A4A6B; flex-shrink:0; display:flex; align-items:center; justify-content:center; margin-top:1px;">
                <span style="font-family:'DM Sans',sans-serif; font-size:0.75rem; font-weight:700; color:white;">1</span>
              </div>
              <p style="font-family:'DM Sans',sans-serif; font-size:0.9375rem; color:rgba(255,255,255,0.75); line-height:1.6;">
                <strong style="color:white;">Check your inbox</strong> — a welcome email is on its way with your login details.
              </p>
            </div>
            <div class="flex items-start gap-3">
              <div style="width:28px; height:28px; border-radius:50%; background:#1A4A6B; flex-shrink:0; display:flex; align-items:center; justify-content:center; margin-top:1px;">
                <span style="font-family:'DM Sans',sans-serif; font-size:0.75rem; font-weight:700; color:white;">2</span>
              </div>
              <p style="font-family:'DM Sans',sans-serif; font-size:0.9375rem; color:rgba(255,255,255,0.75); line-height:1.6;">
                <strong style="color:white;">Take the Autism Pathways Quiz</strong> — it takes about 3 minutes and gives you a personalised starting point.
              </p>
            </div>
            <div class="flex items-start gap-3">
              <div style="width:28px; height:28px; border-radius:50%; background:#1A4A6B; flex-shrink:0; display:flex; align-items:center; justify-content:center; margin-top:1px;">
                <span style="font-family:'DM Sans',sans-serif; font-size:0.75rem; font-weight:700; color:white;">3</span>
              </div>
              <p style="font-family:'DM Sans',sans-serif; font-size:0.9375rem; color:rgba(255,255,255,0.75); line-height:1.6;">
                <strong style="color:white;">Explore your pathway</strong> — structured lessons, home routines, and tools built for your family's situation.
              </p>
            </div>
          </div>
        </div>

        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a href="/quiz" class="nsh-btn-cta" style="font-size:1rem; padding:0.875rem 2rem;">
            Take the Pathways Quiz Now
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
          </a>
          <a href="https://app.neurosagehub.com/login" class="inline-flex items-center justify-center px-7 py-3.5 rounded-xl font-semibold" style="font-family:'DM Sans',sans-serif; font-size:1rem; color:white; border:1.5px solid rgba(255,255,255,0.25); text-decoration:none;">
            Go to My Account
          </a>
        </div>

        <p style="font-family:'DM Sans',sans-serif; font-size:0.875rem; color:rgba(255,255,255,0.3); margin-top:2.5rem; letter-spacing:0.06em; text-transform:uppercase;">
          Build Hope. Walk Together.
        </p>

      </div>
    </div>
  </main>

</BaseLayout>

<script is:inline>
  // Read URL params and personalise the page
  var params = new URLSearchParams(window.location.search);
  var firstName = params.get('first_name') || '';
  var email     = params.get('email') || '';

  if (firstName) {
    document.getElementById('welcome-heading').textContent =
      'Welcome, ' + firstName + '!';
  }

  if (email) {
    document.getElementById('welcome-body').innerHTML =
      'Your free account is being set up, <strong style="color:white;">' + email + '</strong>. ' +
      'Check your inbox — we\'ve sent you a confirmation with your next steps.';
  }
</script>
