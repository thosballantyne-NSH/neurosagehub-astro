---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Start Your Free Family Account | Neurosage Hub"
  description="Join Neurosage Hub — structured pathways, educational tools, and trusted guidance for families navigating autism."
  noindex={true}
>

  <!-- Minimal header — no nav, just logo -->
  <header style="background:#082438; border-bottom:1px solid rgba(255,255,255,0.08); padding:1rem 0;">
    <div class="container">
      <a href="/" class="flex items-center gap-2.5" style="width:fit-content;">
        <img src="/logo-white.png" alt="Neurosage Hub" class="h-10 w-auto"
          onerror="this.style.display='none'; document.getElementById('logo-text').style.display='block'" />
        <span id="logo-text" style="display:none; font-family:'DM Sans',sans-serif; font-size:1.125rem; font-weight:800; color:white;">Neurosage Hub</span>
      </a>
    </div>
  </header>

  <main>

    <!-- ===== MAIN SPLIT ===== -->
    <div style="background:#082438; min-height:calc(100vh - 65px);">
      <div class="container py-12 lg:py-16">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16 items-start">

          <!-- ===== LEFT — VALUE PROP ===== -->
          <div>
            <p style="font-family:'DM Sans',sans-serif; font-size:0.8125rem; font-weight:700; letter-spacing:0.12em; text-transform:uppercase; color:#7B9E8B; margin-bottom:1rem;">For Parents Navigating Autism</p>

            <h1 style="font-family:'DM Sans',sans-serif; font-weight:800; font-size:clamp(1.875rem,4vw,2.5rem); color:white; line-height:1.15; margin-bottom:1.25rem;">
              Overwhelmed by autism<br>and don't know where to start?
            </h1>

            <p style="font-family:'DM Sans',sans-serif; font-size:1.0625rem; color:rgba(255,255,255,0.72); line-height:1.75; margin-bottom:2.5rem; max-width:32rem;">
              Neurosage Hub helps families find clarity through structured pathways, educational tools, and trusted guidance.
            </p>

            <!-- 4 Steps -->
            <div class="flex flex-col gap-5 mb-10">

              <div class="flex items-start gap-4">
                <div style="width:44px; height:44px; border-radius:0.75rem; background:#1A4A6B; flex-shrink:0; display:flex; align-items:center; justify-content:center;">
                  <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#7B9E8B" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 11l3 3L22 4"/><path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"/></svg>
                </div>
                <div>
                  <p style="font-family:'DM Sans',sans-serif; font-size:0.75rem; font-weight:700; letter-spacing:0.1em; text-transform:uppercase; color:#2E6E8E; margin-bottom:0.2rem;">Step 1</p>
                  <p style="font-family:'DM Sans',sans-serif; font-weight:700; font-size:1rem; color:white; line-height:1.4;">Take the Autism Pathways Quiz</p>
                </div>
              </div>

              <div class="flex items-start gap-4">
                <div style="width:44px; height:44px; border-radius:0.75rem; background:#1A4A6B; flex-shrink:0; display:flex; align-items:center; justify-content:center;">
                  <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#7B9E8B" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/></svg>
                </div>
                <div>
                  <p style="font-family:'DM Sans',sans-serif; font-size:0.75rem; font-weight:700; letter-spacing:0.1em; text-transform:uppercase; color:#2E6E8E; margin-bottom:0.2rem;">Step 2</p>
                  <p style="font-family:'DM Sans',sans-serif; font-weight:700; font-size:1rem; color:white; line-height:1.4;">Get Personalized Content & Guidance</p>
                </div>
              </div>

              <div class="flex items-start gap-4">
                <div style="width:44px; height:44px; border-radius:0.75rem; background:#1A4A6B; flex-shrink:0; display:flex; align-items:center; justify-content:center;">
                  <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#7B9E8B" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>
                </div>
                <div>
                  <p style="font-family:'DM Sans',sans-serif; font-size:0.75rem; font-weight:700; letter-spacing:0.1em; text-transform:uppercase; color:#2E6E8E; margin-bottom:0.2rem;">Step 3</p>
                  <p style="font-family:'DM Sans',sans-serif; font-weight:700; font-size:1rem; color:white; line-height:1.4;">Track Progress & Build Consistency</p>
                </div>
              </div>

              <div class="flex items-start gap-4">
                <div style="width:44px; height:44px; border-radius:0.75rem; background:#1A4A6B; flex-shrink:0; display:flex; align-items:center; justify-content:center;">
                  <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#7B9E8B" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
                </div>
                <div>
                  <p style="font-family:'DM Sans',sans-serif; font-size:0.75rem; font-weight:700; letter-spacing:0.1em; text-transform:uppercase; color:#2E6E8E; margin-bottom:0.2rem;">Step 4</p>
                  <p style="font-family:'DM Sans',sans-serif; font-weight:700; font-size:1rem; color:white; line-height:1.4;">Connect With Help</p>
                </div>
              </div>

            </div>

            <!-- Trust line -->
            <div class="flex items-start gap-3 rounded-xl px-5 py-4" style="background:rgba(255,255,255,0.05); border:1px solid rgba(255,255,255,0.08); max-width:32rem;">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#7B9E8B" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="flex-shrink:0; margin-top:2px;"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
              <p style="font-family:'DM Sans',sans-serif; font-size:0.9375rem; color:rgba(255,255,255,0.65); line-height:1.6;">
                <strong style="color:white; font-weight:600;">No hype. No miracle cures.</strong> Just proven, structured guidance designed to help families take the next right step.
              </p>
            </div>

          </div>

          <!-- ===== RIGHT — FORM ===== -->
          <div>
            <div class="rounded-2xl p-8 md:p-10" style="background:white;">

              <div class="flex items-center gap-3 mb-6">
                <img src="/logo-blue.png" alt="Neurosage Hub" class="h-8 w-auto"
                  onerror="this.style.display='none'" />
              </div>

              <h2 style="font-family:'DM Sans',sans-serif; font-weight:800; font-size:1.5rem; color:#082438; line-height:1.25; margin-bottom:0.5rem;">
                Start Your Free Parent Account
              </h2>
              <p style="font-family:'DM Sans',sans-serif; font-size:0.9375rem; color:#5F6975; margin-bottom:1.75rem;">
                No diagnosis required. No credit card. Cancel anytime.
              </p>

              <form id="signup-form" novalidate>

                <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mb-4">
                  <div>
                    <label for="first_name" style="font-family:'DM Sans',sans-serif; font-size:0.875rem; font-weight:600; color:#082438; display:block; margin-bottom:0.375rem;">First Name</label>
                    <input
                      type="text"
                      id="first_name"
                      name="first_name"
                      placeholder="Thomas"
                      required
                      autocomplete="given-name"
                      style="width:100%; padding:0.75rem 1rem; border:1.5px solid #ddd9d2; border-radius:0.625rem; font-family:'DM Sans',sans-serif; font-size:1rem; color:#082438; outline:none; transition:border-color 150ms; box-sizing:border-box;"
                      onfocus="this.style.borderColor='#2E6E8E'"
                      onblur="this.style.borderColor='#ddd9d2'"
                    />
                  </div>
                  <div>
                    <label for="last_name" style="font-family:'DM Sans',sans-serif; font-size:0.875rem; font-weight:600; color:#082438; display:block; margin-bottom:0.375rem;">Last Name</label>
                    <input
                      type="text"
                      id="last_name"
                      name="last_name"
                      placeholder="Ballantyne"
                      required
                      autocomplete="family-name"
                      style="width:100%; padding:0.75rem 1rem; border:1.5px solid #ddd9d2; border-radius:0.625rem; font-family:'DM Sans',sans-serif; font-size:1rem; color:#082438; outline:none; transition:border-color 150ms; box-sizing:border-box;"
                      onfocus="this.style.borderColor='#2E6E8E'"
                      onblur="this.style.borderColor='#ddd9d2'"
                    />
                  </div>
                </div>

                <div class="mb-4">
                  <label for="email" style="font-family:'DM Sans',sans-serif; font-size:0.875rem; font-weight:600; color:#082438; display:block; margin-bottom:0.375rem;">Email Address</label>
                  <input
                    type="email"
                    id="email"
                    name="email"
                    placeholder="you@email.com"
                    required
                    autocomplete="email"
                    style="width:100%; padding:0.75rem 1rem; border:1.5px solid #ddd9d2; border-radius:0.625rem; font-family:'DM Sans',sans-serif; font-size:1rem; color:#082438; outline:none; transition:border-color 150ms; box-sizing:border-box;"
                    onfocus="this.style.borderColor='#2E6E8E'"
                    onblur="this.style.borderColor='#ddd9d2'"
                  />
                </div>

                <div class="mb-6">
                  <label for="phone" style="font-family:'DM Sans',sans-serif; font-size:0.875rem; font-weight:600; color:#082438; display:block; margin-bottom:0.375rem;">
                    Phone
                    <span style="font-weight:400; color:#5F6975;">(optional)</span>
                  </label>
                  <input
                    type="tel"
                    id="phone"
                    name="phone"
                    placeholder="(480) 313-9545"
                    autocomplete="tel"
                    style="width:100%; padding:0.75rem 1rem; border:1.5px solid #ddd9d2; border-radius:0.625rem; font-family:'DM Sans',sans-serif; font-size:1rem; color:#082438; outline:none; transition:border-color 150ms; box-sizing:border-box;"
                    onfocus="this.style.borderColor='#2E6E8E'"
                    onblur="this.style.borderColor='#ddd9d2'"
                  />
                </div>

                <!-- Error message -->
                <p id="form-error" style="display:none; font-family:'DM Sans',sans-serif; font-size:0.875rem; color:#c0392b; margin-bottom:1rem; background:#fdf0ea; border-radius:0.5rem; padding:0.75rem 1rem;"></p>

                <button
                  type="submit"
                  id="submit-btn"
                  style="width:100%; background:#D8896A; color:white; font-family:'DM Sans',sans-serif; font-weight:700; font-size:1.0625rem; padding:1rem; border-radius:0.625rem; border:none; cursor:pointer; transition:all 160ms; display:flex; align-items:center; justify-content:center; gap:0.5rem;"
                  onmouseover="this.style.background='#b8694a'"
                  onmouseout="this.style.background='#D8896A'"
                >
                  <span id="btn-label">Create My Free Account</span>
                  <svg id="btn-arrow" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
                  <svg id="btn-spinner" style="display:none;" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><path d="M21 12a9 9 0 1 1-6.219-8.56"/></svg>
                </button>

                <p style="font-family:'DM Sans',sans-serif; font-size:0.8125rem; color:#5F6975; text-align:center; margin-top:1rem; line-height:1.5;">
                  By signing up you agree to our
                  <a href="/privacy-policy" style="color:#2E6E8E; text-decoration:underline;" target="_blank">Privacy Policy</a>
                  and
                  <a href="/terms-of-service" style="color:#2E6E8E; text-decoration:underline;" target="_blank">Terms of Service</a>.
                </p>

              </form>

              <!-- Trust badges -->
              <div class="flex flex-wrap gap-2 mt-6 pt-5" style="border-top:1px solid #ddd9d2;">
                {['Free to join', 'No diagnosis required', 'Secure & private'].map((badge) => (
                  <span class="flex items-center gap-1.5 text-xs font-medium px-3 py-1.5 rounded-full" style="background:#E4EFF6; color:#1A4A6B; font-family:'DM Sans',sans-serif;">
                    <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><polyline points="20 6 9 17 4 12"/></svg>
                    {badge}
                  </span>
                ))}
              </div>

            </div>

            <!-- Tagline under card -->
            <p class="text-center mt-5" style="font-family:'DM Sans',sans-serif; font-size:0.875rem; color:rgba(255,255,255,0.35); letter-spacing:0.06em; text-transform:uppercase;">
              Build Hope. Walk Together.
            </p>
          </div>

        </div>
      </div>
    </div>

  </main>

</BaseLayout>

<script is:inline>
  document.getElementById('signup-form').addEventListener('submit', function(e) {
    e.preventDefault();

    var first  = document.getElementById('first_name').value.trim();
    var last   = document.getElementById('last_name').value.trim();
    var email  = document.getElementById('email').value.trim();
    var phone  = document.getElementById('phone').value.trim();
    var errEl  = document.getElementById('form-error');

    // Basic validation
    errEl.style.display = 'none';
    if (!first) { showError('Please enter your first name.'); return; }
    if (!last)  { showError('Please enter your last name.'); return; }
    if (!email || !email.includes('@')) { showError('Please enter a valid email address.'); return; }

    // Loading state
    document.getElementById('btn-label').textContent = 'Creating your account…';
    document.getElementById('btn-arrow').style.display = 'none';
    document.getElementById('btn-spinner').style.display = 'block';
    document.getElementById('submit-btn').disabled = true;
    document.getElementById('submit-btn').style.opacity = '0.8';

    // Build thank-you URL with params (mirrors the existing WordPress pattern)
    var params = new URLSearchParams({
      first_name: first,
      last_name:  last,
      email:      email,
      phone:      phone
    });

    // Small delay so the user sees the loading state
    setTimeout(function() {
      window.location.href = '/family-signup-thank-you/?' + params.toString();
    }, 600);
  });

  function showError(msg) {
    var el = document.getElementById('form-error');
    el.textContent = msg;
    el.style.display = 'block';
    el.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
  }
</script>
