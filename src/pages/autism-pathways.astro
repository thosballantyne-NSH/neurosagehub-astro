---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout
  title="Autism Pathways for Parents | Neurosage Hub"
  description="Structured autism support pathways for parents — understand the brain-body foundations behind autism, build home routines, and support your child's regulation and development."
>
  <Header />
  <main class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-20">
    <h1 class="text-display font-bold text-stone-900 mb-4">Autism Pathways for Parents</h1>
    <p class="text-xl text-stone-500 leading-relaxed mb-10">
      Structured, science-backed pathways to help you understand autism, build home support routines, and feel more confident every day.
    </p>
    <div class="prose prose-stone max-w-none">
      <p class="text-stone-500 text-sm italic">Full page content goes here (Day 10 of build timeline).</p>
    </div>
  </main>
  <Footer />
</BaseLayout>
