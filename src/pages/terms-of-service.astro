---

<BaseLayout
  title="Terms of Service | Neurosage Hub"
  description="Terms of Service for Neurosage Hub, operated by Learning Source, LLC. Please read these terms carefully before using the site."
>
  <Header />

  <main>

    <!-- Hero -->
    <section class="py-16" style="background:#082438;">
      <div class="container">
        <div class="max-w-2xl mx-auto text-center">
          <p class="nsh-eyebrow mb-3" style="color:#7B9E8B;">Legal</p>
          <h1 style="font-family:'DM Sans',sans-serif; font-weight:800; font-size:clamp(2rem,4vw,2.75rem); color:white; line-height:1.15;">Terms of Service</h1>
          <p style="font-family:'DM Sans',sans-serif; font-size:0.9375rem; color:rgba(255,255,255,0.45); margin-top:0.75rem;">Last Updated: August 19, 2025</p>
        </div>
      </div>
    </section>

    <!-- Content -->
    <section class="py-16" style="background:white;">
      <div class="container">
        <div class="max-w-3xl mx-auto">

          <!-- Intro notice -->
          <div class="rounded-2xl p-6 mb-10" style="background:#E4EFF6; border-left:4px solid #2E6E8E;">
            <p style="font-family:'DM Sans',sans-serif; font-size:0.9375rem; color:#082438; line-height:1.7;">
              <strong>Please read these Terms carefully before using the Site.</strong> By using the Site, you accept and agree to be bound by these Terms and our <a href="/privacy-policy" style="color:#2E6E8E; text-decoration:underline;">Privacy Policy</a>. These Terms contain a dispute resolution and arbitration provision, including a class action waiver, that affects your legal rights.
            </p>
          </div>

          <!-- Intro paragraph -->
          <p style="font-family:'DM Sans',sans-serif; font-size:0.9375rem; color:#3d5a6e; line-height:1.8; margin-bottom:2.5rem;">
            These Website Terms of Use (these "<strong style="color:#082438;">Terms</strong>") are a legal contract between <strong style="color:#082438;">Learning Source, LLC</strong> ("Learning Source," "we," "us," or "our") and you ("you" or "your") and govern your access to and use of neurosagehub.com, including without limitation all the text, data, information, software, graphics, photographs, content, functionality, and services offered on or through this website (the "<strong style="color:#082438;">Site</strong>").
          </p>

          <!-- Sections -->
          {sections.map(({ title, body }) => (
            <div style="margin-bottom:2.25rem; padding-bottom:2.25rem; border-bottom:1px solid #ddd9d2;">
              <h2 style="font-family:'DM Sans',sans-serif; font-weight:700; font-size:1.0625rem; color:#082438; margin-bottom:0.875rem;">{title}</h2>
              {body.map((para) => (
                <p style="font-family:'DM Sans',sans-serif; font-size:0.9375rem; color:#3d5a6e; line-height:1.8; margin-bottom:0.625rem;">{para}</p>
              ))}
            </div>
          ))}

          <!-- Contact box -->
          <div class="rounded-2xl p-7 mt-4" style="background:#F7F2EB; border:1px solid #ddd9d2;">
            <h2 style="font-family:'DM Sans',sans-serif; font-weight:700; font-size:1.0625rem; color:#082438; margin-bottom:0.75rem;">Contact Us</h2>
            <p style="font-family:'DM Sans',sans-serif; font-size:0.9375rem; color:#3d5a6e; line-height:1.8;">
              If you have any questions about these Terms, you can reach us at:<br/>
              <strong style="color:#082438;">Learning Source, LLC</strong><br/>
              1701 Directors Blvd, Suite 800, Austin, TX 78744<br/>
              <a href="mailto:info@neurosagehub.com" style="color:#2E6E8E; text-decoration:underline;">info@neurosagehub.com</a>
              &nbsp;·&nbsp;
              <a href="tel:8559607220" style="color:#2E6E8E; text-decoration:underline;">(855) 960-7220</a>
            </p>
          </div>

        </div>
      </div>
    </section>

  </main>

  <Footer />
</BaseLayout>
