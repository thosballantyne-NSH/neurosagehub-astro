---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const episodes = [
  { title: 'The Surprising Connection Between Autism and Video Games', desc: 'What if video games could do more than entertain? Dr. Kyle shares how a speech therapist\'s question sparked 13+ years of research into video games as a therapeutic tool.' },
  { title: '"Their Whole Life Becomes Therapy" — Autism Burnout & Family Overwhelm', desc: 'At what point does a child get to just be a kid again? Thomas Ballantyne and Dr. Kyle Daigle discuss therapy fatigue, nervous system development, and the need for better collaboration between practitioners.' },
  { title: 'What Parents Notice Before an Autism Diagnosis', desc: 'Dr. Kyle Daigle joins an honest conversation about what parents often notice before a diagnosis — early signs, sensory issues, and the importance of trusting your intuition.' },
  { title: 'Why Early Identification Matters in Autism Care', desc: 'How early is "early enough"? Ashley Tamayo shares insights on developmental milestones, neuroplasticity, and why waitlists are becoming such a challenge for families.' },
  { title: 'Navigating School Support and IEPs in Autism Care', desc: 'What is an IEP and do you need a diagnosis to get one? Ashley Tamayo shares both professional and personal perspective on how schools, parents, and practitioners work together.' },
  { title: 'Autism Assessments: What Actually Matters (and What Doesn\'t)', desc: 'Ashley Tamayo breaks down the most common autism assessments, the difference between a screening and a formal diagnosis, and why patience during the diagnostic process matters.' },
  { title: 'What Progress Really Looks Like in Autism Care', desc: 'Progress in autism care is not always obvious or linear. Ashley Tamayo shares a grounded perspective on how progress unfolds — from communication milestones to behavioral shifts.' },
  { title: 'Guiding Families Between Visits: Where Progress Happens', desc: 'What happens between therapy sessions matters more than most people realize. This episode explores how practitioners can support families outside the clinic.' },
  { title: 'First Steps After an Autism Diagnosis (Don\'t Skip the Fundamentals)', desc: 'After a diagnosis, most families feel the urge to do everything immediately. But that instinct leads to overwhelm. This episode is about where to actually start.' },
  { title: 'What to Do When Parents Are in Denial About Autism', desc: 'Denial is often one of the first responses when a parent faces the possibility of an autism diagnosis. How a practitioner responds in that moment can shape everything.' },
  { title: 'How to Tell a Parent Their Child May Be Autistic', desc: 'One of the most important and difficult moments in autism care. Ashley Tamayo shares what it means to navigate that conversation with clarity, compassion, and responsibility.' },
  { title: 'Choosing the Right Autism Practitioner Without the Overwhelm', desc: 'When a parent first suspects autism, one of the first questions is: where do I go, and who do I trust? Ashley Tamayo shares how to find the right practitioner.' },
  { title: 'Early Signs of Autism: What Parents, Practitioners, and Educators Should Look For', desc: 'What are the early signs of autism, and how can parents recognise them without jumping to fear? Ashley Tamayo and Justin Barton explore early indicators thoughtfully.' },
];
---

<BaseLayout
  title="Practitioner Perspectives in Autism Care — Podcast | Neurosage Hub"
  description="Real conversations about what autism care actually looks like — from assessments and school support to family overwhelm. Hosted by Justin Barton and Thomas Ballantyne."
>
  <Header />

  <main>

    <!-- ===== HERO ===== -->
    <section class="py-20" style="background:#082438;">
      <div class="container">
        <div class="max-w-2xl mx-auto text-center">

          <p class="nsh-eyebrow mb-4 fade-up" style="color:#D8896A;">Podcast</p>
          <h1 class="fade-up mb-5" style="font-family:'DM Sans',sans-serif; font-weight:800; font-size:clamp(2rem,5vw,3rem); color:white; line-height:1.1;">
            Practitioner Perspectives<br>in Autism Care
          </h1>
          <p class="fade-up mb-8" style="font-family:'DM Sans',sans-serif; font-size:1.125rem; color:rgba(255,255,255,0.65); line-height:1.7; max-width:36rem; margin-left:auto; margin-right:auto;">
            Real conversations about what autism care actually looks like — from assessments and school support to family overwhelm and what progress really means. Hosted by <strong style="color:rgba(255,255,255,0.9);">Justin Barton</strong> and <strong style="color:rgba(255,255,255,0.9);">Thomas Ballantyne</strong>.
          </p>

          <div class="flex flex-wrap justify-center gap-3 fade-up">
            <a
              href="https://open.spotify.com/show/3AkgD8H7t6uPww4buFprla"
              target="_blank"
              rel="noopener"
              class="inline-flex items-center gap-2 px-5 py-3 rounded-full font-semibold"
              style="background:#1DB954; color:white; font-family:'DM Sans',sans-serif; font-size:0.9375rem;"
            >
              <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.4 0 0 5.4 0 12s5.4 12 12 12 12-5.4 12-12S18.66 0 12 0zm5.521 17.34c-.24.359-.66.48-1.021.24-2.82-1.74-6.36-2.101-10.561-1.141-.418.122-.779-.179-.899-.539-.12-.421.18-.78.54-.9 4.56-1.021 8.52-.6 11.64 1.32.42.18.479.659.301 1.02zm1.44-3.3c-.301.42-.841.6-1.262.3-3.239-1.98-8.159-2.58-11.939-1.38-.479.12-1.02-.12-1.14-.6-.12-.48.12-1.021.6-1.141C9.6 9.9 15 10.561 18.72 12.84c.361.181.54.78.241 1.2zm.12-3.36C15.24 8.4 8.82 8.16 5.16 9.301c-.6.179-1.2-.181-1.38-.721-.18-.601.18-1.2.72-1.381 4.26-1.26 11.28-1.02 15.721 1.621.539.3.719 1.02.419 1.56-.299.421-1.02.599-1.559.3z"/></svg>
              Listen on Spotify
            </a>
            <a
              href="https://feeds.captivate.fm/practitioner"
              target="_blank"
              rel="noopener"
              class="inline-flex items-center gap-2 px-5 py-3 rounded-full font-semibold"
              style="background:rgba(255,255,255,0.10); color:white; font-family:'DM Sans',sans-serif; font-size:0.9375rem; border:1px solid rgba(255,255,255,0.2);"
            >
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 11a9 9 0 0 1 9 9"/><path d="M4 4a16 16 0 0 1 16 16"/><circle cx="5" cy="19" r="1"/></svg>
              RSS Feed
            </a>
          </div>

        </div>
      </div>
    </section>

    <!-- ===== EPISODE LIST ===== -->
    <section class="py-16" style="background:white;">
      <div class="container">
        <div class="max-w-3xl mx-auto">

          <div class="flex items-center justify-between mb-8">
            <p class="nsh-eyebrow fade-up" style="color:#7B9E8B;">{episodes.length} Episodes</p>
            <a
              href="https://open.spotify.com/show/3AkgD8H7t6uPww4buFprla"
              target="_blank"
              rel="noopener"
              class="inline-flex items-center gap-2 fade-up"
              style="font-family:'DM Sans',sans-serif; font-size:0.875rem; font-weight:600; color:#1DB954; text-decoration:none;"
            >
              <svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.4 0 0 5.4 0 12s5.4 12 12 12 12-5.4 12-12S18.66 0 12 0zm5.521 17.34c-.24.359-.66.48-1.021.24-2.82-1.74-6.36-2.101-10.561-1.141-.418.122-.779-.179-.899-.539-.12-.421.18-.78.54-.9 4.56-1.021 8.52-.6 11.64 1.32.42.18.479.659.301 1.02zm1.44-3.3c-.301.42-.841.6-1.262.3-3.239-1.98-8.159-2.58-11.939-1.38-.479.12-1.02-.12-1.14-.6-.12-.48.12-1.021.6-1.141C9.6 9.9 15 10.561 18.72 12.84c.361.181.54.78.241 1.2zm.12-3.36C15.24 8.4 8.82 8.16 5.16 9.301c-.6.179-1.2-.181-1.38-.721-.18-.601.18-1.2.72-1.381 4.26-1.26 11.28-1.02 15.721 1.621.539.3.719 1.02.419 1.56-.299.421-1.02.599-1.559.3z"/></svg>
              Subscribe on Spotify
            </a>
          </div>

          <div>
            {episodes.map(({ title, desc }, i) => (
              <div
                class="fade-up"
                style={`padding:1.5rem 0; border-bottom:1px solid #ddd9d2; ${i === 0 ? 'border-top:1px solid #ddd9d2;' : ''} transition-delay:${Math.min(i, 5) * 40}ms;`}
              >
                <div class="flex items-start gap-4">
                  <div style="width:36px; height:36px; border-radius:50%; background:#ebf3f8; flex-shrink:0; display:flex; align-items:center; justify-content:center; margin-top:2px;">
                    <span style="font-family:'DM Sans',sans-serif; font-size:0.75rem; font-weight:700; color:#123D5A;">{i + 1}</span>
                  </div>
                  <div class="flex-1">
                    <p style="font-family:'DM Sans',sans-serif; font-weight:700; font-size:1rem; color:#082438; line-height:1.4; margin-bottom:0.375rem;">{title}</p>
                    <p style="font-family:'DM Sans',sans-serif; font-size:0.875rem; color:#5F6975; line-height:1.65;">{desc}</p>
                  </div>
                </div>
              </div>
            ))}
          </div>

          <div class="mt-12 rounded-2xl p-8 text-center fade-up" style="background:#F7F2EB;">
            <p class="nsh-eyebrow mb-3" style="color:#7B9E8B;">Listen Anywhere</p>
            <h3 style="font-family:'DM Sans',sans-serif; font-weight:700; font-size:1.375rem; color:#082438; margin-bottom:0.625rem;">All episodes on Spotify</h3>
            <p style="font-family:'DM Sans',sans-serif; font-size:0.9375rem; color:#5F6975; margin-bottom:1.5rem;">Follow the show so you never miss a new conversation.</p>
            <a
              href="https://open.spotify.com/show/3AkgD8H7t6uPww4buFprla"
              target="_blank"
              rel="noopener"
              class="inline-flex items-center gap-2 px-6 py-3 rounded-full font-bold"
              style="background:#1DB954; color:white; font-family:'DM Sans',sans-serif; font-size:0.9375rem; text-decoration:none;"
            >
              <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.4 0 0 5.4 0 12s5.4 12 12 12 12-5.4 12-12S18.66 0 12 0zm5.521 17.34c-.24.359-.66.48-1.021.24-2.82-1.74-6.36-2.101-10.561-1.141-.418.122-.779-.179-.899-.539-.12-.421.18-.78.54-.9 4.56-1.021 8.52-.6 11.64 1.32.42.18.479.659.301 1.02zm1.44-3.3c-.301.42-.841.6-1.262.3-3.239-1.98-8.159-2.58-11.939-1.38-.479.12-1.02-.12-1.14-.6-.12-.48.12-1.021.6-1.141C9.6 9.9 15 10.561 18.72 12.84c.361.181.54.78.241 1.2zm.12-3.36C15.24 8.4 8.82 8.16 5.16 9.301c-.6.179-1.2-.181-1.38-.721-.18-.601.18-1.2.72-1.381 4.26-1.26 11.28-1.02 15.721 1.621.539.3.719 1.02.419 1.56-.299.421-1.02.599-1.559.3z"/></svg>
              Open on Spotify
            </a>
          </div>

        </div>
      </div>
    </section>

  </main>

  <Footer />
</BaseLayout>
