<!-- ===== STYLES ===== -->
<style>
  .quiz-screen { animation: fadeSlide 360ms ease forwards; }
  .quiz-screen.hidden { display: none; }

  @keyframes fadeSlide {
    from { opacity: 0; transform: translateY(16px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  .quiz-option {
    display: flex;
    align-items: flex-start;
    gap: 1rem;
    width: 100%;
    text-align: left;
    padding: 1rem 1.25rem;
    border-radius: 0.75rem;
    border: 1.5px solid #ddd9d2;
    background: white;
    cursor: pointer;
    font-family: 'DM Sans', sans-serif;
    font-size: 0.9375rem;
    color: #082438;
    line-height: 1.5;
    transition: all 160ms ease;
  }
  .quiz-option:hover {
    border-color: #7B9E8B;
    background: #f7faf8;
  }
  .quiz-option.selected {
    border-color: #123D5A;
    background: #ebf3f8;
  }
  .quiz-option-letter {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 28px;
    height: 28px;
    min-width: 28px;
    border-radius: 50%;
    background: #F7F2EB;
    color: #123D5A;
    font-weight: 700;
    font-size: 0.8125rem;
    font-family: 'DM Sans', sans-serif;
    transition: all 160ms ease;
  }
  .quiz-option.selected .quiz-option-letter {
    background: #123D5A;
    color: white;
  }

  .disabled-btn {
    opacity: 0.45;
    cursor: not-allowed;
    pointer-events: none;
  }
  .disabled-btn:not([disabled]) {
    opacity: 1;
    cursor: pointer;
    pointer-events: auto;
  }

  .nsh-card {
    text-decoration: none;
    display: block;
  }
</style>

<!-- ===== QUIZ LOGIC ===== -->
<script>
  // State
  const answers: Record<number, string> = {};
  let userName = '';

  // Pathway definitions
  const pathways: Record<string, { name: string; desc: string }> = {
    essentials: {
      name: 'ASD Essentials',
      desc: "You're at the beginning of understanding your child's autism — or you want to go back to basics and build a stronger foundation. This pathway gives you the neuroscience behind behaviour, explains the brain-body model, and helps you see your child's world more clearly. It's the best place to start.",
    },
    sensory: {
      name: 'Sensory Regulation',
      desc: "Sensory processing is at the heart of your child's daily challenges. This pathway helps you identify your child's sensory profile, understand what triggers distress or seeking behaviour, and build calming routines that actually work at home — in real life, not just in a therapy room.",
    },
    home: {
      name: 'Home-Based Support',
      desc: "What happens between appointments matters just as much as the appointments themselves. This pathway gives you a step-by-step daily framework — morning activation sequences, after-school resets, meal strategies, and evening calm-down protocols — built for families like yours.",
    },
    sleep: {
      name: 'Sleep & Regulation',
      desc: "Poor sleep affects everything: behaviour, learning, mood, and your family's wellbeing. This pathway supports your child's circadian rhythm, evening regulation, and sleep readiness through gentle, science-informed routines — so that your whole family can rest.",
    },
    communication: {
      name: 'Communication Readiness',
      desc: "Connection is at the centre of everything. This pathway gives you practical strategies for supporting communication, play-based engagement, and language readiness through your daily home interactions — whether your child is pre-verbal, developing language, or verbal but struggling to connect.",
    },
  };

  function computePathway(): string {
    // Simple scoring: weight answers toward pathway recommendations
    const scores: Record<string, number> = {
      essentials: 0, sensory: 0, home: 0, sleep: 0, communication: 0,
    };

    const a = answers;

    // Q1: Journey stage
    if (a[1] === 'new' || a[1] === 'established-lost') scores.essentials += 2;
    if (a[1] === 'managing') { scores.home += 1; scores.sensory += 1; }

    // Q2: Biggest challenge
    if (a[2] === 'sensory')        scores.sensory       += 3;
    if (a[2] === 'sleep')          scores.sleep         += 3;
    if (a[2] === 'communication')  scores.communication += 3;
    if (a[2] === 'routines')       scores.home          += 3;
    if (a[2] === 'understanding')  scores.essentials    += 3;

    // Q3: Sensory profile
    if (a[3] === 'overwhelmed' || a[3] === 'seeking' || a[3] === 'mixed') scores.sensory += 2;

    // Q4: Sleep
    if (a[4] === 'serious' || a[4] === 'variable') scores.sleep += 2;

    // Q5: Communication
    if (a[5] === 'limited-verbal' || a[5] === 'speaks-struggles') scores.communication += 2;
    if (a[5] === 'connect-more') { scores.communication += 1; scores.essentials += 1; }

    // Q6: Support gap
    if (a[6] === 'very-alone' || a[6] === 'no-practitioners') scores.home += 1;

    // Q7: Biggest wish
    if (a[7] === 'understand')       scores.essentials    += 3;
    if (a[7] === 'meltdowns')        scores.sensory       += 3;
    if (a[7] === 'daily-plan')       scores.home          += 3;
    if (a[7] === 'sleep-regulation') scores.sleep         += 3;
    if (a[7] === 'connection')       scores.communication += 3;

    // Find highest score
    return Object.entries(scores).sort((a, b) => b[1] - a[1])[0][0];
  }

  function goToScreen(n: number) {
    // Hide all
    document.querySelectorAll('.quiz-screen').forEach(el => el.classList.add('hidden'));

    // Show target
    const target = document.getElementById(`screen-${n}`);
    if (target) {
      target.classList.remove('hidden');
      window.scrollTo({ top: 0, behavior: 'smooth' });
    }

    // Progress bar
    const progressWrap = document.getElementById('quiz-progress-wrap');
    const progressBar  = document.getElementById('quiz-progress-bar');
    const progressLabel = document.getElementById('quiz-progress-label');
    const progressPct  = document.getElementById('quiz-progress-pct');

    if (n >= 1 && n <= 7 && progressWrap && progressBar && progressLabel && progressPct) {
      progressWrap.classList.remove('hidden');
      const pct = Math.round((n / 7) * 100);
      progressBar.style.width = `${pct}%`;
      progressLabel.textContent = `Question ${n} of 7`;
      progressPct.textContent = `${pct}%`;
    } else if (progressWrap) {
      progressWrap.classList.add('hidden');
    }
  }

  function selectOption(btn: HTMLButtonElement) {
    // Deselect siblings
    const group = btn.closest('.quiz-options');
    if (!group) return;
    group.querySelectorAll('.quiz-option').forEach(el => el.classList.remove('selected'));

    // Select this
    btn.classList.add('selected');

    // Store answer
    const qNum = parseInt(group.getAttribute('data-q') || '0');
    answers[qNum] = btn.getAttribute('data-value') || '';

    // Enable next button
    const nextBtn = document.getElementById(`next-${qNum}`) as HTMLButtonElement | null;
    if (nextBtn) {
      nextBtn.disabled = false;
      nextBtn.classList.remove('disabled-btn');
    }
  }

  // Lead form submission
  document.getElementById('quiz-lead-form')?.addEventListener('submit', (e) => {
    e.preventDefault();

    const firstNameInput = document.getElementById('quiz-first-name') as HTMLInputElement;
    const emailInput     = document.getElementById('quiz-email') as HTMLInputElement;
    const emailError     = document.getElementById('quiz-email-error');

    const firstName = firstNameInput.value.trim();
    const email     = emailInput.value.trim();

    if (!email || !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)) {
      if (emailError) emailError.style.display = 'block';
      emailInput.style.borderColor = '#D8896A';
      return;
    }
    if (emailError) emailError.style.display = 'none';

    userName = firstName || 'there';

    // Compute pathway
    const pathway = computePathway();
    const p = pathways[pathway];

    // Populate results
    const resultName         = document.getElementById('result-name');
    const resultPathwayName  = document.getElementById('result-pathway-name');
    const resultPathwayDesc  = document.getElementById('result-pathway-desc');

    if (resultName)        resultName.textContent        = firstName || 'there';
    if (resultPathwayName) resultPathwayName.textContent = p.name;
    if (resultPathwayDesc) resultPathwayDesc.textContent = p.desc;

    // Send to console (wire up to your email platform here)
    console.log('Quiz lead:', { firstName, email, answers, pathway });

    // Navigate to results
    goToScreen(9);
  });

  // Initialise
  goToScreen(0);
</script>
