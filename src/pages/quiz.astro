---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout
  title="Autism Pathways Quiz | Neurosage Hub"
  description="Answer a few short questions and we'll point your family to the right starting place on Neurosage Hub."
>
  <Header />

  <main style="background:white; min-height:80vh;">
    <div class="container" style="max-width:680px; padding-top:3rem; padding-bottom:4rem;">

      <!-- Progress bar -->
      <div id="quiz-progress-wrap" class="mb-8">
        <div class="flex items-center justify-between mb-2">
          <span id="quiz-progress-label" style="font-family:'DM Sans',sans-serif; font-size:0.8125rem; font-weight:600; color:#5F6975;">Question 1 of 7</span>
          <span id="quiz-progress-pct" style="font-family:'DM Sans',sans-serif; font-size:0.8125rem; color:#5F6975;">14%</span>
        </div>
        <div style="height:6px; background:#ddd9d2; border-radius:100px; overflow:hidden;">
          <div id="quiz-progress-bar" style="height:100%; background:#D8896A; border-radius:100px; width:14%; transition:width 400ms ease;"></div>
        </div>
      </div>

      <!-- ── Q1: Warm commitment opener ── -->
      <div id="screen-1" class="quiz-screen">
        <div class="mb-6" style="background:#ebf3f8; border-radius:1rem; padding:1.5rem 1.75rem;">
          <p style="font-family:'DM Sans',sans-serif; font-size:1.0625rem; color:#082438; line-height:1.75; margin:0;">
            Great job! Looking for understanding and wanting to find hope is the right next step. We are here to walk this journey with you. So let's take that next step together!
          </p>
        </div>
        <h2 style="font-family:'DM Sans',sans-serif; font-weight:800; font-size:clamp(1.375rem,3vw,1.875rem); line-height:1.2; color:#082438; margin-bottom:1.5rem;">
          How are you feeling about starting?
        </h2>
        <div class="quiz-options space-y-3" data-q="1">
          <button class="quiz-option" data-value="yes" onclick="selectOption(this)">
            <span class="quiz-option-letter">A</span>
            <span>Ready to get started? Yes. Please. and thank you!</span>
          </button>
          <button class="quiz-option" data-value="here" onclick="selectOption(this)">
            <span class="quiz-option-letter">B</span>
            <span>Okay, I am here, let's start.</span>
          </button>
          <button class="quiz-option" data-value="unsure" onclick="selectOption(this)">
            <span class="quiz-option-letter">C</span>
            <span>Not sure, but let's try this.</span>
          </button>
        </div>
        <div class="mt-8 flex justify-end">
          <button id="next-1" onclick="goToScreen(2)" class="nsh-btn-cta" disabled style="padding:0.625rem 1.5rem; font-size:0.9375rem; opacity:0.4; cursor:not-allowed;">Next →</button>
        </div>
      </div>

      <!-- ── Q2 ── -->
      <div id="screen-2" class="quiz-screen hidden">
        <p class="nsh-eyebrow mb-3" style="color:#7B9E8B;">Question 2 of 7</p>
        <h2 style="font-family:'DM Sans',sans-serif; font-weight:800; font-size:clamp(1.375rem,3vw,1.875rem); line-height:1.2; color:#082438; margin-bottom:0.625rem;">
          Where are you right now in your family's autism journey?
        </h2>
        <p class="nsh-body mb-6">Choose the option that feels most true today.</p>
        <div class="quiz-options space-y-3" data-q="2">
          <button class="quiz-option" data-value="new" onclick="selectOption(this)">
            <span class="quiz-option-letter">A</span>
            <span>We just received a diagnosis — we're brand new to all of this</span>
          </button>
          <button class="quiz-option" data-value="lost" onclick="selectOption(this)">
            <span class="quiz-option-letter">B</span>
            <span>We've had the diagnosis a while but still feel lost or unsure of next steps</span>
          </button>
          <button class="quiz-option" data-value="managing" onclick="selectOption(this)">
            <span class="quiz-option-letter">C</span>
            <span>We're managing day-to-day but I know we could be doing more</span>
          </button>
          <button class="quiz-option" data-value="thriving" onclick="selectOption(this)">
            <span class="quiz-option-letter">D</span>
            <span>We have good routines — I want to deepen my knowledge and keep building</span>
          </button>
        </div>
        <div class="mt-8 flex items-center justify-between">
          <button onclick="goToScreen(1)" class="nsh-btn-secondary" style="padding:0.625rem 1.25rem; font-size:0.9375rem;">← Back</button>
          <button id="next-2" onclick="goToScreen(3)" class="nsh-btn-cta" disabled style="padding:0.625rem 1.5rem; font-size:0.9375rem; opacity:0.4; cursor:not-allowed;">Next →</button>
        </div>
      </div>

      <!-- ── Q3 ── -->
      <div id="screen-3" class="quiz-screen hidden">
        <p class="nsh-eyebrow mb-3" style="color:#7B9E8B;">Question 3 of 7</p>
        <h2 style="font-family:'DM Sans',sans-serif; font-weight:800; font-size:clamp(1.375rem,3vw,1.875rem); line-height:1.2; color:#082438; margin-bottom:0.625rem;">
          What's your family's biggest daily challenge right now?
        </h2>
        <p class="nsh-body mb-6">Pick the one that causes the most stress in your household.</p>
        <div class="quiz-options space-y-3" data-q="3">
          <button class="quiz-option" data-value="sensory" onclick="selectOption(this)">
            <span class="quiz-option-letter">A</span>
            <span>Meltdowns, sensory overload, or emotional dysregulation</span>
          </button>
          <button class="quiz-option" data-value="sleep" onclick="selectOption(this)">
            <span class="quiz-option-letter">B</span>
            <span>Sleep — bedtime battles, night waking, or chronic exhaustion</span>
          </button>
          <button class="quiz-option" data-value="communication" onclick="selectOption(this)">
            <span class="quiz-option-letter">C</span>
            <span>Communication and connection — getting through to my child</span>
          </button>
          <button class="quiz-option" data-value="routines" onclick="selectOption(this)">
            <span class="quiz-option-letter">D</span>
            <span>Routines and transitions — mornings, after school, meals</span>
          </button>
          <button class="quiz-option" data-value="understanding" onclick="selectOption(this)">
            <span class="quiz-option-letter">E</span>
            <span>Understanding my child's diagnosis — why they do what they do</span>
          </button>
        </div>
        <div class="mt-8 flex items-center justify-between">
          <button onclick="goToScreen(2)" class="nsh-btn-secondary" style="padding:0.625rem 1.25rem; font-size:0.9375rem;">← Back</button>
          <button id="next-3" onclick="goToScreen(4)" class="nsh-btn-cta" disabled style="padding:0.625rem 1.5rem; font-size:0.9375rem; opacity:0.4; cursor:not-allowed;">Next →</button>
        </div>
      </div>

      <!-- ── Q4 ── -->
      <div id="screen-4" class="quiz-screen hidden">
        <p class="nsh-eyebrow mb-3" style="color:#7B9E8B;">Question 4 of 7</p>
        <h2 style="font-family:'DM Sans',sans-serif; font-weight:800; font-size:clamp(1.375rem,3vw,1.875rem); line-height:1.2; color:#082438; margin-bottom:0.625rem;">
          How would you describe your child's relationship with sensory input?
        </h2>
        <p class="nsh-body mb-6">Think about sounds, touch, crowds, textures, and movement.</p>
        <div class="quiz-options space-y-3" data-q="4">
          <button class="quiz-option" data-value="overwhelmed" onclick="selectOption(this)">
            <span class="quiz-option-letter">A</span>
            <span>Easily overwhelmed — everyday sensory input causes distress or shutdown</span>
          </button>
          <button class="quiz-option" data-value="seeking" onclick="selectOption(this)">
            <span class="quiz-option-letter">B</span>
            <span>Constantly seeking — my child can't stop moving, touching, or crashing</span>
          </button>
          <button class="quiz-option" data-value="mixed" onclick="selectOption(this)">
            <span class="quiz-option-letter">C</span>
            <span>Mixed — sometimes overwhelmed, sometimes seeking, depending on the day</span>
          </button>
          <button class="quiz-option" data-value="mild" onclick="selectOption(this)">
            <span class="quiz-option-letter">D</span>
            <span>Mild sensory differences — present but not our main challenge</span>
          </button>
        </div>
        <div class="mt-8 flex items-center justify-between">
          <button onclick="goToScreen(3)" class="nsh-btn-secondary" style="padding:0.625rem 1.25rem; font-size:0.9375rem;">← Back</button>
          <button id="next-4" onclick="goToScreen(5)" class="nsh-btn-cta" disabled style="padding:0.625rem 1.5rem; font-size:0.9375rem; opacity:0.4; cursor:not-allowed;">Next →</button>
        </div>
      </div>

      <!-- ── Q5 ── -->
      <div id="screen-5" class="quiz-screen hidden">
        <p class="nsh-eyebrow mb-3" style="color:#7B9E8B;">Question 5 of 7</p>
        <h2 style="font-family:'DM Sans',sans-serif; font-weight:800; font-size:clamp(1.375rem,3vw,1.875rem); line-height:1.2; color:#082438; margin-bottom:0.625rem;">
          How is sleep affecting your family right now?
        </h2>
        <p class="nsh-body mb-6">Be honest — sleep deprivation affects everything else.</p>
        <div class="quiz-options space-y-3" data-q="5">
          <button class="quiz-option" data-value="serious" onclick="selectOption(this)">
            <span class="quiz-option-letter">A</span>
            <span>Serious ongoing problem — nobody in the family is sleeping well</span>
          </button>
          <button class="quiz-option" data-value="variable" onclick="selectOption(this)">
            <span class="quiz-option-letter">B</span>
            <span>Variable — some nights okay, others really hard, can't predict</span>
          </button>
          <button class="quiz-option" data-value="improving" onclick="selectOption(this)">
            <span class="quiz-option-letter">C</span>
            <span>Getting better — made some progress but still room to improve</span>
          </button>
          <button class="quiz-option" data-value="okay" onclick="selectOption(this)">
            <span class="quiz-option-letter">D</span>
            <span>Mostly okay — sleep isn't a major concern right now</span>
          </button>
        </div>
        <div class="mt-8 flex items-center justify-between">
          <button onclick="goToScreen(4)" class="nsh-btn-secondary" style="padding:0.625rem 1.25rem; font-size:0.9375rem;">← Back</button>
          <button id="next-5" onclick="goToScreen(6)" class="nsh-btn-cta" disabled style="padding:0.625rem 1.5rem; font-size:0.9375rem; opacity:0.4; cursor:not-allowed;">Next →</button>
        </div>
      </div>

      <!-- ── Q6 ── -->
      <div id="screen-6" class="quiz-screen hidden">
        <p class="nsh-eyebrow mb-3" style="color:#7B9E8B;">Question 6 of 7</p>
        <h2 style="font-family:'DM Sans',sans-serif; font-weight:800; font-size:clamp(1.375rem,3vw,1.875rem); line-height:1.2; color:#082438; margin-bottom:0.625rem;">
          When it comes to communication and connection, what's your situation?
        </h2>
        <p class="nsh-body mb-6">Think about language, emotional expression, and day-to-day connection.</p>
        <div class="quiz-options space-y-3" data-q="6">
          <button class="quiz-option" data-value="limited-verbal" onclick="selectOption(this)">
            <span class="quiz-option-letter">A</span>
            <span>My child has limited verbal communication — I want to support language development</span>
          </button>
          <button class="quiz-option" data-value="speaks-struggles" onclick="selectOption(this)">
            <span class="quiz-option-letter">B</span>
            <span>My child speaks but struggles to connect emotionally or express feelings</span>
          </button>
          <button class="quiz-option" data-value="connect-more" onclick="selectOption(this)">
            <span class="quiz-option-letter">C</span>
            <span>Communication is okay but I want to deepen how we connect</span>
          </button>
          <button class="quiz-option" data-value="strength" onclick="selectOption(this)">
            <span class="quiz-option-letter">D</span>
            <span>Communication is a relative strength — not our primary focus</span>
          </button>
        </div>
        <div class="mt-8 flex items-center justify-between">
          <button onclick="goToScreen(5)" class="nsh-btn-secondary" style="padding:0.625rem 1.25rem; font-size:0.9375rem;">← Back</button>
          <button id="next-6" onclick="goToScreen(7)" class="nsh-btn-cta" disabled style="padding:0.625rem 1.5rem; font-size:0.9375rem; opacity:0.4; cursor:not-allowed;">Next →</button>
        </div>
      </div>

      <!-- ── Q7 ── -->
      <div id="screen-7" class="quiz-screen hidden">
        <p class="nsh-eyebrow mb-3" style="color:#7B9E8B;">Question 7 of 7</p>
        <h2 style="font-family:'DM Sans',sans-serif; font-weight:800; font-size:clamp(1.375rem,3vw,1.875rem); line-height:1.2; color:#082438; margin-bottom:0.625rem;">
          If you could change one thing — what would make the biggest difference for your family?
        </h2>
        <p class="nsh-body mb-6">Pick the one that would change things the most.</p>
        <div class="quiz-options space-y-3" data-q="7">
          <button class="quiz-option" data-value="understand" onclick="selectOption(this)">
            <span class="quiz-option-letter">A</span>
            <span>Understanding why my child does what they do — the neuroscience behind the behaviour</span>
          </button>
          <button class="quiz-option" data-value="meltdowns" onclick="selectOption(this)">
            <span class="quiz-option-letter">B</span>
            <span>Practical tools for the hard moments — meltdowns, shutdowns, sensory overload</span>
          </button>
          <button class="quiz-option" data-value="daily-plan" onclick="selectOption(this)">
            <span class="quiz-option-letter">C</span>
            <span>A daily plan that actually works — mornings, after school, meals, bedtime</span>
          </button>
          <button class="quiz-option" data-value="sleep-regulation" onclick="selectOption(this)">
            <span class="quiz-option-letter">D</span>
            <span>Better sleep and emotional regulation — a calmer, more predictable child</span>
          </button>
          <button class="quiz-option" data-value="connection" onclick="selectOption(this)">
            <span class="quiz-option-letter">E</span>
            <span>Deeper connection and communication — truly understanding and reaching my child</span>
          </button>
        </div>
        <div class="mt-8 flex items-center justify-between">
          <button onclick="goToScreen(6)" class="nsh-btn-secondary" style="padding:0.625rem 1.25rem; font-size:0.9375rem;">← Back</button>
          <button id="next-7" onclick="goToScreen(8)" class="nsh-btn-cta" disabled style="padding:0.625rem 1.5rem; font-size:0.9375rem; opacity:0.4; cursor:not-allowed;">See My Results →</button>
        </div>
      </div>

      <!-- ── Lead capture ── -->
      <div id="screen-8" class="quiz-screen hidden">
        <div class="text-center mb-8">
          <div class="mx-auto mb-5 flex items-center justify-center" style="width:60px; height:60px; background:#deeae5; border-radius:50%;">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#4F7563" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
          </div>
          <p class="nsh-eyebrow mb-3" style="color:#7B9E8B;">Almost there</p>
          <h2 style="font-family:'DM Sans',sans-serif; font-weight:800; font-size:clamp(1.5rem,3.5vw,2.25rem); line-height:1.1; color:#082438; margin-bottom:0.75rem;">
            Your personalised pathway is ready.
          </h2>
          <p class="nsh-body" style="max-width:32rem; margin:0 auto;">
            Enter your name and email and we'll show you your recommended starting point on Neurosage Hub.
          </p>
        </div>

        <div class="rounded-2xl p-7" style="background:white; border:1px solid #ddd9d2; box-shadow:0 4px 32px rgba(8,36,56,0.07);">
          <form id="quiz-lead-form" novalidate>
            <div class="space-y-4">
              <div>
                <label for="quiz-first-name" style="font-family:'DM Sans',sans-serif; font-size:0.875rem; font-weight:600; color:#082438; display:block; margin-bottom:0.375rem;">First name</label>
                <input type="text" id="quiz-first-name" placeholder="Your first name"
                  style="width:100%; padding:0.75rem 1rem; border-radius:0.625rem; border:1.5px solid #ddd9d2; font-family:'DM Sans',sans-serif; font-size:1rem; color:#082438; outline:none; box-sizing:border-box;"
                  onfocus="this.style.borderColor='#7B9E8B'" onblur="this.style.borderColor='#ddd9d2'" />
              </div>
              <div>
                <label for="quiz-email" style="font-family:'DM Sans',sans-serif; font-size:0.875rem; font-weight:600; color:#082438; display:block; margin-bottom:0.375rem;">Email address</label>
                <input type="email" id="quiz-email" placeholder="you@example.com" required
                  style="width:100%; padding:0.75rem 1rem; border-radius:0.625rem; border:1.5px solid #ddd9d2; font-family:'DM Sans',sans-serif; font-size:1rem; color:#082438; outline:none; box-sizing:border-box;"
                  onfocus="this.style.borderColor='#7B9E8B'" onblur="this.style.borderColor='#ddd9d2'" />
                <p id="quiz-email-error" style="font-family:'DM Sans',sans-serif; font-size:0.75rem; color:#D8896A; margin-top:0.375rem; display:none;">Please enter a valid email address.</p>
              </div>
            </div>
            <button type="submit" class="nsh-btn-cta w-full justify-center mt-6" style="font-size:1rem; padding:0.9375rem;">
              Show Me My Results →
            </button>
            <p style="font-family:'DM Sans',sans-serif; font-size:0.8125rem; color:#5F6975; text-align:center; margin-top:0.875rem;">We respect your privacy. No spam, ever.</p>
          </form>
        </div>
        <div class="mt-4">
          <button onclick="goToScreen(7)" style="font-family:'DM Sans',sans-serif; font-size:0.875rem; color:#5F6975; background:none; border:none; cursor:pointer;">← Change my answers</button>
        </div>
      </div>

      <!-- ── Results ── -->
      <div id="screen-9" class="quiz-screen hidden">
        <div class="text-center mb-8">
          <div class="mx-auto mb-5 flex items-center justify-center" style="width:64px; height:64px; background:#F7F2EB; border-radius:50%; border:3px solid #E8C98F;">
            <svg width="30" height="30" viewBox="0 0 24 24" fill="none" stroke="#E8C98F" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
          </div>
          <p class="nsh-eyebrow mb-3" style="color:#D8896A;">Your Results</p>
          <h2 style="font-family:'DM Sans',sans-serif; font-weight:800; font-size:clamp(1.75rem,4vw,2.5rem); line-height:1.1; color:#082438; margin-bottom:0.75rem;">
            Thank you, <span id="result-name">there</span>.
          </h2>
          <p class="nsh-body-lg" style="max-width:36rem; margin:0 auto; color:#2d3f4c;">
            Based on your answers, here's where we recommend you begin.
          </p>
        </div>

        <div class="rounded-2xl p-7 mb-6" style="border:2px solid #deeae5; background:#ebf3f8;">
          <p class="nsh-eyebrow mb-2" style="color:#123D5A;">Your Starting Pathway</p>
          <h3 id="result-pathway-name" class="nsh-heading-2 mb-3" style="color:#082438;"></h3>
          <p id="result-pathway-desc" class="nsh-body-lg mb-6" style="color:#2d3f4c;"></p>
          <a href="https://app.neurosagehub.com/signup" class="nsh-btn-primary">
            Start This Pathway Free →
          </a>
        </div>

        <div class="mb-8">
          <p style="font-family:'DM Sans',sans-serif; font-size:0.9375rem; font-weight:600; color:#082438; margin-bottom:1rem;">You may also find these helpful:</p>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <a href="/home-routines" class="nsh-card p-5" style="text-decoration:none; display:block;">
              <p style="font-family:'DM Sans',sans-serif; font-weight:700; font-size:0.9375rem; color:#082438; margin-bottom:0.25rem;">Home Routines Library</p>
              <p style="font-family:'DM Sans',sans-serif; font-size:0.875rem; color:#5F6975;">Morning, afternoon &amp; evening protocols</p>
            </a>
            <a href="/for-parents" class="nsh-card p-5" style="text-decoration:none; display:block;">
              <p style="font-family:'DM Sans',sans-serif; font-weight:700; font-size:0.9375rem; color:#082438; margin-bottom:0.25rem;">For Parents</p>
              <p style="font-family:'DM Sans',sans-serif; font-size:0.875rem; color:#5F6975;">Explore all five learning pathways</p>
            </a>
          </div>
        </div>

        <div class="rounded-2xl p-7 text-center" style="background:#082438;">
          <p class="nsh-eyebrow mb-3" style="color:#E8C98F;">Ready to go deeper?</p>
          <h3 style="font-family:'DM Sans',sans-serif; font-weight:700; font-size:1.375rem; color:white; margin-bottom:0.625rem;">Get full access — free to start.</h3>
          <p style="font-family:'DM Sans',sans-serif; font-size:0.9375rem; color:rgba(255,255,255,0.7); margin-bottom:1.5rem;">Video content, home routines, therapeutic games, and your own progress tracker.</p>
          <a href="https://app.neurosagehub.com/signup" class="nsh-btn-cta" style="font-size:1rem; padding:0.9375rem 2rem;">
            Create Your Free Account →
          </a>
        </div>
      </div>

    </div><!-- /container -->

    <!-- ── Why take the quiz ── -->
    <div id="why-section" style="background:#F7F2EB; padding:4rem 0;">
      <div class="container" style="max-width:720px;">
        <div class="text-center mb-10">
          <p class="nsh-eyebrow mb-3" style="color:#7B9E8B;">Why This Quiz?</p>
          <h2 class="nsh-heading-2" style="color:#082438;">You deserve a starting point that actually fits.</h2>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
          {[
            { icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>`, title: 'Under 3 minutes', body: 'Seven short questions — no lengthy forms, no sign-up walls before you see results.' },
            { icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>`, title: 'Built for families like yours', body: 'Questions designed around the real challenges autism families face at home every day.' },
            { icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>`, title: 'Matched to a pathway', body: 'Your answers map to one of five learning pathways on Neurosage Hub — so you start in the right place.' },
          ].map(({ icon, title, body }) => (
            <div class="nsh-card p-6 text-center">
              <div class="mx-auto mb-4 flex items-center justify-center" style="width:48px; height:48px; background:#deeae5; border-radius:0.75rem; color:#123D5A;">
                <Fragment set:html={icon} />
              </div>
              <h3 class="nsh-heading-3 mb-2">{title}</h3>
              <p class="nsh-body" style="font-size:0.9rem;">{body}</p>
            </div>
          ))}
        </div>
      </div>
    </div>

  </main>

  <Footer />
</BaseLayout>

<style>
  .quiz-screen { animation: fadeIn 300ms ease forwards; }
  .quiz-screen.hidden { display: none !important; }

  @keyframes fadeIn {
    from { opacity: 0; transform: translateY(12px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  .quiz-option {
    display: flex;
    align-items: flex-start;
    gap: 0.875rem;
    width: 100%;
    text-align: left;
    padding: 0.9rem 1.125rem;
    border-radius: 0.75rem;
    border: 1.5px solid #ddd9d2;
    background: white;
    cursor: pointer;
    font-family: 'DM Sans', sans-serif;
    font-size: 0.9375rem;
    color: #082438;
    line-height: 1.5;
    transition: border-color 140ms ease, background 140ms ease;
  }
  .quiz-option:hover { border-color: #7B9E8B; background: #f7faf8; }
  .quiz-option.selected { border-color: #123D5A; background: #ebf3f8; }

  .quiz-option-letter {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 26px;
    height: 26px;
    min-width: 26px;
    border-radius: 50%;
    background: #F7F2EB;
    color: #123D5A;
    font-weight: 700;
    font-size: 0.75rem;
    font-family: 'DM Sans', sans-serif;
    transition: background 140ms ease, color 140ms ease;
  }
  .quiz-option.selected .quiz-option-letter { background: #123D5A; color: white; }
</style>

<script is:inline>
  var answers = {};

  var pathways = {
    essentials: {
      name: 'ASD Essentials',
      desc: "You're building the foundation — or you want to go back to basics. This pathway explains the neuroscience behind your child's behaviour, unpacks the brain-body model, and helps you see your child's world more clearly. It's the best place to start.",
    },
    sensory: {
      name: 'Sensory Regulation',
      desc: "Sensory processing is at the heart of your child's daily challenges. This pathway helps you identify your child's sensory profile, understand what triggers distress or seeking behaviour, and build calming routines that work in real home life.",
    },
    home: {
      name: 'Home-Based Support',
      desc: "What happens between appointments matters just as much as the appointments themselves. This pathway gives you a step-by-step daily framework — morning activation, after-school resets, meal strategies, and evening calm-down protocols.",
    },
    sleep: {
      name: 'Sleep & Regulation',
      desc: "Poor sleep affects everything: behaviour, learning, mood, and your family's wellbeing. This pathway supports your child's circadian rhythm, evening regulation, and sleep readiness through gentle, science-informed routines.",
    },
    communication: {
      name: 'Communication Readiness',
      desc: "Connection is at the centre of everything. This pathway gives you practical strategies for supporting communication, play-based engagement, and language readiness through your daily home interactions.",
    },
  };

  function computePathway() {
    var scores = { essentials: 0, sensory: 0, home: 0, sleep: 0, communication: 0 };
    var a = answers;

    if (a[2] === 'new' || a[2] === 'lost') scores.essentials += 2;
    if (a[2] === 'managing') { scores.home += 1; scores.sensory += 1; }

    if (a[3] === 'sensory')       scores.sensory       += 3;
    if (a[3] === 'sleep')         scores.sleep         += 3;
    if (a[3] === 'communication') scores.communication += 3;
    if (a[3] === 'routines')      scores.home          += 3;
    if (a[3] === 'understanding') scores.essentials    += 3;

    if (a[4] === 'overwhelmed' || a[4] === 'seeking' || a[4] === 'mixed') scores.sensory += 2;
    if (a[5] === 'serious' || a[5] === 'variable') scores.sleep += 2;
    if (a[6] === 'limited-verbal' || a[6] === 'speaks-struggles') scores.communication += 2;
    if (a[6] === 'connect-more') { scores.communication += 1; scores.essentials += 1; }

    if (a[7] === 'understand')       scores.essentials    += 3;
    if (a[7] === 'meltdowns')        scores.sensory       += 3;
    if (a[7] === 'daily-plan')       scores.home          += 3;
    if (a[7] === 'sleep-regulation') scores.sleep         += 3;
    if (a[7] === 'connection')       scores.communication += 3;

    var best = 'essentials';
    var bestScore = -1;
    for (var key in scores) {
      if (scores[key] > bestScore) { bestScore = scores[key]; best = key; }
    }
    return best;
  }

  function goToScreen(n) {
    document.querySelectorAll('.quiz-screen').forEach(function(el) {
      el.classList.add('hidden');
    });
    var target = document.getElementById('screen-' + n);
    if (target) {
      target.classList.remove('hidden');
      window.scrollTo({ top: 0, behavior: 'smooth' });
    }

    // Progress bar (questions 1-7)
    var wrap  = document.getElementById('quiz-progress-wrap');
    var bar   = document.getElementById('quiz-progress-bar');
    var label = document.getElementById('quiz-progress-label');
    var pct   = document.getElementById('quiz-progress-pct');
    if (n >= 1 && n <= 7 && wrap && bar && label && pct) {
      wrap.style.display = 'block';
      var p = Math.round((n / 7) * 100);
      bar.style.width = p + '%';
      label.textContent = 'Question ' + n + ' of 7';
      pct.textContent = p + '%';
    } else if (wrap) {
      wrap.style.display = 'none';
    }
  }

  function selectOption(btn) {
    var group = btn.closest('.quiz-options');
    if (!group) return;
    group.querySelectorAll('.quiz-option').forEach(function(el) {
      el.classList.remove('selected');
    });
    btn.classList.add('selected');

    var qNum = parseInt(group.getAttribute('data-q') || '0');
    answers[qNum] = btn.getAttribute('data-value') || '';

    var nextBtn = document.getElementById('next-' + qNum);
    if (nextBtn) {
      nextBtn.disabled = false;
      nextBtn.style.opacity = '1';
      nextBtn.style.cursor = 'pointer';
    }
  }

  document.addEventListener('DOMContentLoaded', function() {
    var form = document.getElementById('quiz-lead-form');
    if (form) {
      form.addEventListener('submit', function(e) {
        e.preventDefault();
        var firstNameEl = document.getElementById('quiz-first-name');
        var emailEl     = document.getElementById('quiz-email');
        var errorEl     = document.getElementById('quiz-email-error');
        var firstName   = firstNameEl ? firstNameEl.value.trim() : '';
        var email       = emailEl ? emailEl.value.trim() : '';

        if (!email || !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)) {
          if (errorEl) errorEl.style.display = 'block';
          if (emailEl) emailEl.style.borderColor = '#D8896A';
          return;
        }
        if (errorEl) errorEl.style.display = 'none';

        var pathway = computePathway();
        var p = pathways[pathway];

        var nameEl = document.getElementById('result-name');
        var pathNameEl = document.getElementById('result-pathway-name');
        var pathDescEl = document.getElementById('result-pathway-desc');
        if (nameEl) nameEl.textContent = firstName || 'there';
        if (pathNameEl) pathNameEl.textContent = p.name;
        if (pathDescEl) pathDescEl.textContent = p.desc;

        console.log('Quiz lead:', { firstName: firstName, email: email, answers: answers, pathway: pathway });
        goToScreen(9);
      });
    }
  });
</script>
