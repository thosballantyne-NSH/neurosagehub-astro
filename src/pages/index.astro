---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const HERO_IMG     = "https://d2xsxph8kpxj0f.cloudfront.net/310519663645323174/cAF6S26VtT36Uyb4yyZGdw/nsh_hero-HdcUuJoW8jCr5tJf4wwPnk.webp";
const PARENT_CHILD = "https://d2xsxph8kpxj0f.cloudfront.net/310519663645323174/cAF6S26VtT36Uyb4yyZGdw/nsh_parent_child-ivuL9QAhsMZpMhgtzbS5ot.webp";
const PYRAMID_IMG  = "https://d2xsxph8kpxj0f.cloudfront.net/310519663645323174/cAF6S26VtT36Uyb4yyZGdw/nsh_brain_pyramid-6LxDvQVqZti4smMdjvWBjv.webp";

const pillars = [
  {
    title: 'From Overwhelm to Clarity',
    desc: 'We help families replace uncertainty with understanding — organizing information so you can see the bigger picture and know where to start.',
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg>`,
  },
  {
    title: 'From Fragmentation to Pathways',
    desc: 'We provide a clear path forward so you can turn information into consistent, daily action that actually supports your child.',
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M3 12h18M3 6h18M3 18h18"/></svg>`,
  },
  {
    title: 'From Access Gaps to Connection',
    desc: 'We offer trusted education and responsible practitioner connections all in one place — so you\'re never searching alone.',
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>`,
  },
  {
    title: 'From Follow-Through to Consistency',
    desc: 'We deliver structured guidance to help you make informed decisions and take the next step with greater confidence and clarity.',
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 11 12 14 22 4"/><path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"/></svg>`,
  },
];

const commitments = [
  {
    title: 'We Provide Education, Not Therapy',
    desc: 'Neurosage Hub does not provide therapy. We offer a platform for structured education that helps parents understand and support their child\'s journey.',
  },
  {
    title: 'No False Promises',
    desc: 'You will never find cure language, reversal claims, or guaranteed outcomes on our platform. We believe in honest, grounded support.',
  },
  {
    title: 'Evidence-Based Guidance',
    desc: 'We do not make biochemical claims without peer-reviewed support. Every resource on our platform is held to a standard of responsible, evidence-aligned education.',
  },
];

const steps = [
  { num: '01', title: 'Learn',    desc: 'Understand the why behind your child\'s regulation, sensory, and learning needs through short, parent-friendly lessons.' },
  { num: '02', title: 'Practice', desc: 'Follow guided home routines designed for real family life — 10 to 20 minutes a day, no special equipment needed.' },
  { num: '03', title: 'Track',    desc: 'Use simple logs to notice patterns, celebrate wins, and come prepared to your next practitioner appointment.' },
  { num: '04', title: 'Connect',  desc: 'Stay aligned with practitioner-informed guidance, organized next steps, and a supportive parent community.' },
];

const stories = [
  {
    quote: "I finally feel like I understand what my son needs. The morning routine alone changed our whole day.",
    name: "Sarah M.",
    detail: "Parent of a 7-year-old with ASD",
  },
  {
    quote: "Neurosage gave me a framework I could explain to my child's teacher and therapist. We're all on the same page now.",
    name: "Marcus T.",
    detail: "Father of two, sensory processing support",
  },
  {
    quote: "I was overwhelmed for years. This helped me slow down, understand the foundations, and start small. It made a real difference.",
    name: "Priya K.",
    detail: "Parent of a child with developmental delays",
  },
];

const footerLinks = [
  { href: '/parent-pathways', label: 'Browse Learning Paths' },
  { href: '/for-parents',     label: 'Explore Parent Resources' },
  { href: '/for-practitioners', label: 'Meet Our Practitioners' },
];
---

<BaseLayout
  title="Neurosage Hub — A Clear Path Forward for Autism Families"
  description="When you're overwhelmed by conflicting information and appointments, Neurosage Hub helps you organize the autism journey with structured education, trusted resources, and practitioner connections."
>
  <Header />

  <main>

    <!-- ===== HERO ===== -->
    <section class="relative overflow-hidden" style="min-height:90vh;">
      <div class="absolute inset-0 z-0">
        <img
          src={HERO_IMG}
          alt="Parent and child doing a calming activity at home"
          class="w-full h-full object-cover object-center"
        />
        <div class="absolute inset-0" style="background:linear-gradient(100deg, oklch(0.22 0.12 258 / 0.88) 0%, oklch(0.22 0.12 258 / 0.65) 50%, oklch(0.22 0.12 258 / 0.15) 100%);"></div>
      </div>

      <div class="container relative z-10 flex items-center" style="min-height:calc(90vh - 4rem);">
        <div class="max-w-2xl py-16">
          <p class="nsh-eyebrow mb-5 fade-up" style="color:oklch(0.75 0.12 195);">
            Autism · ADHD · Sensory Processing · Developmental Support
          </p>
          <h1 class="nsh-heading-display mb-6 fade-up" style="color:white; transition-delay:80ms;">
            You Don't Need More Autism Advice.<br>You Need a Clear Path Forward.
          </h1>
          <p class="nsh-body-lg mb-8 max-w-xl fade-up" style="color:rgba(255,255,255,0.85); transition-delay:160ms;">
            When you're overwhelmed by conflicting information, appointments, and uncertainty, Neurosage Hub helps you organize the journey with structured education, trusted resources, and practitioner connections.
          </p>
          <div class="flex flex-wrap gap-4 mb-8 fade-up" style="transition-delay:240ms;">
            <a href="/start-here" class="nsh-btn-cta">
              Get Started Free
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
            </a>
            <a href="#how-it-works" class="nsh-btn-secondary" style="border-color:rgba(255,255,255,0.4); color:white;">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><polygon points="5 3 19 12 5 21 5 3"/></svg>
              See How It Works
            </a>
          </div>
          <p class="text-sm fade-up" style="color:rgba(255,255,255,0.55); font-family:'DM Sans',sans-serif; transition-delay:320ms;">
            Education-first support for parents, caregivers, and practitioners. Not a replacement for medical care or therapy.
          </p>
        </div>
      </div>
    </section>

    <!-- ===== SECTION 2 — PROBLEM ===== -->
    <section class="py-20" style="background:oklch(0.97 0.02 258);">
      <div class="container">
        <div class="max-w-3xl mx-auto text-center">
          <p class="nsh-eyebrow mb-4 fade-up">We Understand</p>
          <h2 class="nsh-heading-2 mb-6 fade-up">
            When Every Expert Says Something Different, Where Do You Turn?
          </h2>
          <p class="nsh-body-lg mb-8 fade-up">
            You are overwhelmed, lost in a fragmented system, and unsure what to do next. Autism resources are everywhere — but true clarity is rare. You shouldn't have to figure this out alone.
          </p>
          <p class="nsh-body fade-up" style="max-width:36rem; margin:0 auto;">
            Neurosage Hub exists to help you organize the noise into a structured path forward — so you can move from confusion to confidence, one step at a time.
          </p>
        </div>
      </div>
    </section>

    <!-- ===== SECTION 3 — SOLUTION FRAMEWORK ===== -->
    <section class="py-20" style="background:white;">
      <div class="container">
        <div class="max-w-2xl mx-auto text-center mb-14">
          <p class="nsh-eyebrow mb-4 fade-up">The Neurosage Framework</p>
          <h2 class="nsh-heading-2 mb-4 fade-up">
            Waiting for Answers Is Hard.<br>Navigating Them Shouldn't Be.
          </h2>
          <p class="nsh-body fade-up">
            We are building a roadmap designed for families navigating autism — built on four core pillars to support your journey.
          </p>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          {pillars.map(({ title, desc, icon }, i) => (
            <div class="nsh-card p-8 fade-up" style={`transition-delay:${i * 80}ms;`}>
              <div class="w-12 h-12 rounded-xl flex items-center justify-center mb-5" style="background:oklch(0.95 0.04 258); color:oklch(0.46 0.22 258);">
                <Fragment set:html={icon} />
              </div>
              <h3 class="nsh-heading-3 mb-3">{title}</h3>
              <p class="nsh-body">{desc}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ===== FOUNDATION IMAGE BREAK ===== -->
    <section class="py-20" style="background:oklch(0.97 0.02 258);">
      <div class="container">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16 items-center">
          <div class="flex justify-center fade-up">
            <img
              src={PYRAMID_IMG}
              alt="Brain Development Pyramid — Sensory, Movement, Sleep, Communication, Learning"
              class="w-full max-w-sm rounded-xl"
              style="box-shadow:0 16px 48px oklch(0.22 0.12 258 / 0.12);"
              loading="lazy"
            />
          </div>
          <div>
            <p class="nsh-eyebrow mb-4 fade-up">Why It Works</p>
            <h2 class="nsh-heading-2 mb-6 fade-up">Regulation before learning. Movement before cognition.</h2>
            <p class="nsh-body-lg mb-5 fade-up">
              A child's development is built from the bottom up. Sensory processing, movement, sleep, nutrition, and emotional safety all create the foundation for higher-level skills — attention, communication, learning, and social connection.
            </p>
            <p class="nsh-body mb-8 fade-up">
              Neurosage Hub turns that foundation-first model into education, practical home routines, and progress tracking parents can actually use — without needing to become a therapist.
            </p>
            <a href="/for-parents" class="nsh-btn-primary fade-up">
              Explore Parent Resources
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
            </a>
          </div>
        </div>
      </div>
    </section>

    <!-- ===== HOW IT WORKS ===== -->
    <section id="how-it-works" class="py-20" style="background:white;">
      <div class="container">
        <div class="max-w-2xl mx-auto text-center mb-14">
          <p class="nsh-eyebrow mb-4 fade-up">How It Works</p>
          <h2 class="nsh-heading-2 mb-4 fade-up">Four simple steps to home-based support</h2>
          <p class="nsh-body fade-up">You don't have to figure everything out at once. Neurosage guides you through a clear, repeatable process.</p>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
          {steps.map(({ num, title, desc }, i) => (
            <div class="nsh-card p-7 fade-up" style={`transition-delay:${i * 80}ms;`}>
              <div class="text-4xl font-bold mb-4" style="color:oklch(0.85 0.08 258); font-family:'DM Sans',sans-serif;">{num}</div>
              <h3 class="nsh-heading-3 mb-3">{title}</h3>
              <p class="nsh-body" style="font-size:0.9375rem;">{desc}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ===== SECTION 4 — COMMITMENT ===== -->
    <section class="py-20" style="background:oklch(0.22 0.12 258);">
      <div class="container">
        <div class="max-w-2xl mx-auto text-center mb-14">
          <p class="nsh-eyebrow mb-4 fade-up" style="color:oklch(0.75 0.12 195);">Our Commitment</p>
          <h2 class="nsh-heading-2 mb-4 fade-up" style="color:white;">
            A Better Autism Journey Starts With Understanding.
          </h2>
          <p class="nsh-body fade-up" style="color:rgba(255,255,255,0.7);">
            At Neurosage Hub, our mission is to provide structured education and access to practitioners. We are committed to absolute transparency with every family we serve.
          </p>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
          {commitments.map(({ title, desc }, i) => (
            <div class="rounded-xl p-7 fade-up" style={`background:oklch(0.28 0.10 258); border:1px solid oklch(0.35 0.10 258); transition-delay:${i * 80}ms;`}>
              <div class="w-10 h-10 rounded-lg flex items-center justify-center mb-5" style="background:oklch(0.46 0.22 258 / 0.3);">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="oklch(0.75 0.12 195)" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
              </div>
              <h3 class="mb-3 font-bold" style="font-family:'DM Sans',sans-serif; font-size:1.0625rem; color:white;">{title}</h3>
              <p style="font-family:'DM Sans',sans-serif; font-size:0.9375rem; color:rgba(255,255,255,0.65); line-height:1.7;">{desc}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ===== PARENT STORIES ===== -->
    <section class="py-20" style="background:white;">
      <div class="container">
        <div class="max-w-2xl mx-auto text-center mb-14">
          <p class="nsh-eyebrow mb-4 fade-up">Family Stories</p>
          <h2 class="nsh-heading-2 mb-4 fade-up">Parents share what changed for their families</h2>
          <p class="nsh-body fade-up">Individual experiences vary. These stories reflect personal journeys, not guaranteed outcomes.</p>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
          {stories.map(({ quote, name, detail }, i) => (
            <div class="nsh-card p-8 fade-up" style={`transition-delay:${i * 80}ms;`}>
              <div class="flex items-center gap-1 mb-5">
                {Array.from({ length: 5 }).map(() => (
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="oklch(0.75 0.15 70)" style="flex-shrink:0;"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
                ))}
              </div>
              <p class="mb-6 leading-relaxed" style="font-family:'DM Sans',sans-serif; font-size:1rem; color:oklch(0.30 0.06 258); font-style:italic;">
                "{quote}"
              </p>
              <p class="font-semibold text-sm" style="font-family:'DM Sans',sans-serif; color:oklch(0.22 0.12 258);">{name}</p>
              <p class="text-xs mt-0.5" style="font-family:'DM Sans',sans-serif; color:oklch(0.55 0.04 258);">{detail}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ===== FINAL CTA ===== -->
    <section id="get-started" class="py-24 relative overflow-hidden">
      <div class="absolute inset-0" style="background:linear-gradient(135deg, oklch(0.46 0.22 258) 0%, oklch(0.38 0.20 265) 100%);"></div>
      <div class="container relative z-10">
        <div class="max-w-2xl mx-auto text-center">
          <p class="nsh-eyebrow mb-5 fade-up" style="color:oklch(0.80 0.12 195);">Your First Step</p>
          <h2 class="nsh-heading-2 mb-6 fade-up" style="color:white;">
            Stop Guessing. Start Understanding.
          </h2>
          <p class="nsh-body-lg mb-8 fade-up" style="color:rgba(255,255,255,0.82);">
            Join a community built to help families navigate autism with greater confidence and support. Build hope and walk together.
          </p>
          <div class="flex flex-col sm:flex-row gap-4 justify-center mb-10 fade-up">
            <a href="/start-here" class="nsh-btn-cta" style="font-size:1.0625rem; padding:1rem 2.25rem;">
              Create Your Free Account
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
            </a>
            <a href="/start-here#assessment" class="nsh-btn-secondary" style="border-color:rgba(255,255,255,0.4); color:white;">
              Take the Assessment
            </a>
          </div>
          <div class="flex flex-wrap justify-center gap-6 fade-up">
            {['Free to join', 'No commitment required', 'Practitioner-informed content'].map((item) => (
              <div class="flex items-center gap-2 text-sm" style="color:rgba(255,255,255,0.7); font-family:'DM Sans',sans-serif;">
                <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="oklch(0.80 0.12 195)" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
                {item}
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>

    <!-- ===== PRACTITIONERS BLOCK ===== -->
    <section class="py-16" style="background:white;">
      <div class="container">
        <div class="max-w-4xl mx-auto">
          <div
            class="rounded-xl p-8 md:p-12 flex flex-col md:flex-row items-center gap-8 fade-up"
            style="background:oklch(0.95 0.04 258); border:1px solid oklch(0.90 0.03 258);"
          >
            <div class="flex-1">
              <p class="nsh-eyebrow mb-3">For Practitioners</p>
              <h3 class="nsh-heading-3 mb-3">Extend your care into the home</h3>
              <p class="nsh-body">
                Assign structured parent pathways, home protocols, and progress tracking to your patients. Keep families supported and aligned between visits — without adding to your workload.
              </p>
            </div>
            <div class="flex-shrink-0">
              <a href="/for-practitioners" class="nsh-btn-primary">
                Book a Practitioner Demo
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
              </a>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ===== PROMISE ===== -->
    <section class="py-20" style="background:oklch(0.97 0.02 258);">
      <div class="container">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
          <div>
            <p class="nsh-eyebrow mb-4 fade-up">The Neurosage Promise</p>
            <h2 class="nsh-heading-2 mb-6 fade-up">
              You don't have to become a therapist.<br>You need a clear plan.
            </h2>
            <p class="nsh-body-lg mb-6 fade-up">
              Small, consistent routines — done with love and guided by neuroscience — can help you support your child's nervous system, understand what patterns to watch, and feel more confident in your daily decisions.
            </p>
            <p class="nsh-body mb-8 fade-up">
              Neurosage Hub is not just a course library. It's a guided ecosystem where parents learn what matters, practice small routines, observe progress, and feel supported between professional appointments.
            </p>
            <a href="/start-here" class="nsh-btn-primary fade-up">
              Start Your Family's Journey
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
            </a>
          </div>
          <div class="fade-up">
            <img
              src={PARENT_CHILD}
              alt="Parent and child doing a calming sensory activity together at home"
              class="w-full rounded-xl"
              style="box-shadow:0 16px 48px oklch(0.22 0.12 258 / 0.12);"
              loading="lazy"
            />
          </div>
        </div>
      </div>
    </section>

  </main>

  <Footer />
</BaseLayout>
