<script>
  // ── Vimeo lightbox ──────────────────────────────────────────────
  (function () {
    var modal     = document.getElementById('vimeo-modal');
    var iframe    = document.getElementById('vimeo-iframe');
    var closeBtn  = document.getElementById('vimeo-close');
    var container = document.getElementById('vimeo-container');

    function openModal(vimeoId) {
      iframe.src = 'https://player.vimeo.com/video/' + vimeoId + '?autoplay=1&title=0&byline=0&portrait=0';
      modal.style.display = 'flex';
      document.body.style.overflow = 'hidden';
    }
    function closeModal() {
      iframe.src = '';
      modal.style.display = 'none';
      document.body.style.overflow = '';
    }

    document.querySelectorAll('[data-vimeo-id]').forEach(function (btn) {
      btn.addEventListener('click', function () {
        openModal(btn.getAttribute('data-vimeo-id'));
      });
    });

    if (closeBtn) closeBtn.addEventListener('click', closeModal);
    if (modal) modal.addEventListener('click', function (e) {
      if (e.target === modal) closeModal();
    });
    document.addEventListener('keydown', function (e) {
      if (e.key === 'Escape' && modal && modal.style.display === 'flex') closeModal();
    });
  })();

  // Podcast inline player — play/pause toggle per card
  document.querySelectorAll('.nsh-podcast-card').forEach((card) => {
    const audio = card.querySelector('audio');
    if (!audio) return; // no audio = greyed-out placeholder card

    const playIcon  = card.querySelector('.icon-play');
    const pauseIcon = card.querySelector('.icon-pause');
    const playBtn   = card.querySelector('.nsh-podcast-play');
    const statusEl  = card.querySelector('.episode-status');
    const origDuration = statusEl?.textContent ?? '';

    card.addEventListener('click', () => {
      // Pause all other cards first
      document.querySelectorAll('.nsh-podcast-card').forEach((other) => {
        if (other === card) return;
        const otherAudio = other.querySelector('audio');
        if (otherAudio && !otherAudio.paused) {
          otherAudio.pause();
          other.querySelector('.icon-play')?.classList.remove('hidden');
          other.querySelector('.icon-pause')?.classList.add('hidden');
          other.querySelector('.nsh-podcast-play')?.style.setProperty('background', '#2E6E8E');
        }
      });

      if (audio.paused) {
        audio.play();
        playIcon?.classList.add('hidden');
        pauseIcon?.classList.remove('hidden');
        playBtn?.style.setProperty('background', '#7B9E8B'); // teal = playing
      } else {
        audio.pause();
        playIcon?.classList.remove('hidden');
        pauseIcon?.classList.add('hidden');
        playBtn?.style.setProperty('background', '#2E6E8E');
      }
    });

    // Live time display while playing
    audio.addEventListener('timeupdate', () => {
      if (!statusEl) return;
      const cur = Math.floor(audio.currentTime);
      const tot = Math.floor(audio.duration) || 0;
      if (tot > 0) {
        const fmt = (s: number) => `${Math.floor(s/60)}:${String(s%60).padStart(2,'0')}`;
        statusEl.textContent = `${fmt(cur)} / ${fmt(tot)}`;
      }
    });

    audio.addEventListener('ended', () => {
      playIcon?.classList.remove('hidden');
      pauseIcon?.classList.add('hidden');
      playBtn?.style.setProperty('background', '#2E6E8E');
      if (statusEl) statusEl.textContent = origDuration;
    });
  });
</script>
