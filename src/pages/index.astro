---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const HERO_IMG     = "https://d2xsxph8kpxj0f.cloudfront.net/310519663645323174/cAF6S26VtT36Uyb4yyZGdw/nsh_hero-HdcUuJoW8jCr5tJf4wwPnk.webp";
const PARENT_CHILD = "https://d2xsxph8kpxj0f.cloudfront.net/310519663645323174/cAF6S26VtT36Uyb4yyZGdw/nsh_parent_child-ivuL9QAhsMZpMhgtzbS5ot.webp";
const ROUTINE_IMG  = "https://d2xsxph8kpxj0f.cloudfront.net/310519663645323174/cAF6S26VtT36Uyb4yyZGdw/nsh_routine-5oBVftRTACqFxfipA9J7dY.webp";
const PYRAMID_IMG  = "https://d2xsxph8kpxj0f.cloudfront.net/310519663645323174/cAF6S26VtT36Uyb4yyZGdw/nsh_brain_pyramid-6LxDvQVqZti4smMdjvWBjv.webp";

const concerns = [
  'Meltdowns and emotional dysregulation',
  'Sensory seeking or sensory avoidance',
  'Sleep challenges and bedtime struggles',
  'Difficulty with transitions and routines',
  'Speech delays and communication gaps',
  'Focus, attention, and learning readiness',
  'Retained primitive reflexes',
  'Gut-brain connection and nutrition',
];

const steps = [
  { num: '01', title: 'Learn',    desc: "Understand the why behind your child's regulation, movement, sensory, and learning needs through short, parent-friendly lessons." },
  { num: '02', title: 'Practice', desc: 'Follow guided home routines designed for real family life — 10 to 20 minutes a day, no special equipment needed.' },
  { num: '03', title: 'Track',    desc: 'Use simple logs and journals to notice patterns, celebrate small wins, and prepare questions for your care team.' },
  { num: '04', title: 'Connect',  desc: 'Stay aligned with practitioner-informed guidance, organized next steps, and a supportive parent community.' },
];

const pathways = [
  {
    label: 'ASD Essentials',
    desc: 'Understand the foundations behind autism, sensory processing, and daily regulation.',
    color: 'oklch(0.38 0.09 240)',
    bg: 'oklch(0.955 0.015 220)',
    icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M9.5 2A2.5 2.5 0 0 1 12 4.5v15a2.5 2.5 0 0 1-4.96-.46 2.5 2.5 0 0 1-2.96-3.08 3 3 0 0 1-.34-5.58 2.5 2.5 0 0 1 1.32-4.24 2.5 2.5 0 0 1 1.98-3A2.5 2.5 0 0 1 9.5 2Z"/><path d="M14.5 2A2.5 2.5 0 0 0 12 4.5v15a2.5 2.5 0 0 0 4.96-.46 2.5 2.5 0 0 0 2.96-3.08 3 3 0 0 0 .34-5.58 2.5 2.5 0 0 0-1.32-4.24 2.5 2.5 0 0 0-1.98-3A2.5 2.5 0 0 0 14.5 2Z"/></svg>`,
    href: '/autism-pathways',
  },
  {
    label: 'Sensory Regulation',
    desc: 'Identify sensory triggers, build calming routines, and support daily transitions.',
    color: 'oklch(0.45 0.08 162)',
    bg: 'oklch(0.65 0.06 162 / 0.12)',
    icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>`,
    href: '/sensory-processing',
  },
  {
    label: 'Home-Based Support',
    desc: 'A practical daily plan with morning activation, resets, and progress tracking.',
    color: 'oklch(0.55 0.12 28)',
    bg: 'oklch(0.67 0.13 28 / 0.1)',
    icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="m3 9 9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>`,
    href: '/home-routines',
  },
  {
    label: 'Sleep & Regulation',
    desc: 'Evening calm routines, circadian support, and sleep-regulation strategies.',
    color: 'oklch(0.45 0.08 270)',
    bg: 'oklch(0.55 0.08 270 / 0.1)',
    icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3a6 6 0 0 0 9 9 9 9 0 1 1-9-9Z"/></svg>`,
    href: '/parent-pathways',
  },
  {
    label: 'Communication Readiness',
    desc: 'Play-based engagement, visual supports, and language-readiness routines.',
    color: 'oklch(0.45 0.1 200)',
    bg: 'oklch(0.58 0.1 200 / 0.1)',
    icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>`,
    href: '/parent-pathways',
  },
  {
    label: 'Movement & Reflexes',
    desc: 'Primitive reflex integration, balance, coordination, and movement-based brain support.',
    color: 'oklch(0.5 0.12 15)',
    bg: 'oklch(0.62 0.12 15 / 0.1)',
    icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>`,
    href: '/parent-pathways',
  },
];

const routines = [
  { title: 'Morning Brain-Body Activation', time: '10 min', desc: 'Cross-crawl, balance, and vestibular warm-up to prepare the nervous system for the day.' },
  { title: 'After-School Sensory Reset',    time: '8 min',  desc: 'Proprioceptive input, deep pressure, and calming activities to help transition from school.' },
  { title: 'Evening Calm-Down Routine',     time: '12 min', desc: 'Breathing, gentle movement, and sensory wind-down to support sleep readiness.' },
];

const stories = [
  {
    quote: "I finally feel like I understand what my son needs. The morning routine alone changed our whole day.",
    name: "Sarah M.",
    detail: "Parent of a 7-year-old with ASD",
  },
  {
    quote: "Neurosage gave me a framework I could actually explain to my child's teacher and therapist. We're all on the same page now.",
    name: "Marcus T.",
    detail: "Father of two, sensory processing support",
  },
  {
    quote: "I was overwhelmed for years. This platform helped me slow down, understand the foundations, and start small. It made a real difference.",
    name: "Priya K.",
    detail: "Parent of a child with developmental delays",
  },
];

const quizPerks = [
  'Free to take',
  'No sign-up required',
  'Results in under 3 minutes',
  'Personalized pathway recommendation',
];
---

<BaseLayout
  title="Neurosage Hub — Neurodevelopment for Families"
  description="Neurosage Hub helps parents support their child's sensory regulation, brain development, and daily routines at home. Guided pathways for autism, ADHD, sensory processing, and developmental support."
>
  <Header />

  <main>

    <!-- ===== HERO ===== -->
    <section class="relative overflow-hidden" style="min-height:92vh;">
      <!-- Background image -->
      <div class="absolute inset-0 z-0">
        <img
          src={HERO_IMG}
          alt="Parent and child doing a calming movement activity at home"
          class="w-full h-full object-cover object-center"
        />
        <div
          class="absolute inset-0"
          style="background:linear-gradient(105deg, oklch(0.975 0.012 85 / 0.94) 0%, oklch(0.975 0.012 85 / 0.80) 45%, oklch(0.975 0.012 85 / 0.15) 100%);"
        ></div>
      </div>

      <!-- Content -->
      <div class="container relative z-10 flex items-center" style="min-height:calc(92vh - 4rem);">
        <div class="max-w-2xl py-16">
          <p class="nsh-eyebrow mb-5 fade-up">Autism · Sensory Regulation · Home-Based Brain Development</p>
          <h1 class="nsh-heading-display mb-6 fade-up" style="transition-delay:80ms;">
            Help your child feel more regulated, connected, and
            <em style="color:oklch(0.45 0.08 162); font-style:italic;"> ready to learn</em>
          </h1>
          <p class="nsh-body-lg mb-8 max-w-xl fade-up" style="transition-delay:160ms;">
            Neurosage Hub gives parents a calm, structured way to understand their child's brain-body foundations, follow guided home routines, track progress, and stay connected with practitioner-informed support.
          </p>
          <div class="flex flex-wrap gap-4 mb-10 fade-up" style="transition-delay:240ms;">
            <a href="/start-here#quiz" class="nsh-btn-primary">
              Take the Parent Pathway Quiz
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
            </a>
            <a href="#how-it-works" class="nsh-btn-secondary">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><polygon points="5 3 19 12 5 21 5 3"/></svg>
              See How It Works
            </a>
          </div>
          <p class="text-sm fade-up" style="color:oklch(0.48 0.04 240); font-family:'DM Sans',sans-serif; transition-delay:320ms;">
            Education-first support for parents, caregivers, and practitioners. Not a replacement for medical care or therapy.
          </p>
        </div>
      </div>

      <!-- Wave divider -->
      <div class="absolute bottom-0 left-0 right-0 z-10">
        <svg viewBox="0 0 1440 60" fill="none" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="none" style="display:block; width:100%; height:60px;">
          <path d="M0 60V30C240 0 480 60 720 30C960 0 1200 60 1440 30V60H0Z" fill="oklch(0.975 0.012 85)" />
        </svg>
      </div>
    </section>

    <!-- ===== YOU ARE NOT ALONE ===== -->
    <section class="py-20 nsh-section-ivory">
      <div class="container">
        <div class="max-w-3xl mx-auto text-center mb-14">
          <p class="nsh-eyebrow mb-4 fade-up">You Are Not Alone</p>
          <h2 class="nsh-heading-2 mb-6 fade-up">
            Many parents feel overwhelmed when they don't know where to begin
          </h2>
          <p class="nsh-body-lg fade-up">
            When sleep, sensory overwhelm, meltdowns, communication delays, or attention struggles overlap, it can feel impossible to know what matters most. Neurosage Hub gives families a calmer way to understand the bigger picture.
          </p>
        </div>
        <div class="grid grid-cols-2 md:grid-cols-4 gap-3 max-w-4xl mx-auto">
          {concerns.map((c, i) => (
            <div
              class="nsh-pill nsh-pill-sage text-center justify-center py-3 px-4 rounded-xl fade-up"
              style={`transition-delay:${i * 40}ms; font-family:'DM Sans',sans-serif; font-size:0.875rem;`}
            >
              {c}
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ===== FOUNDATION-FIRST MODEL ===== -->
    <section class="py-20 nsh-section-mist overflow-hidden">
      <div class="container">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16 items-center">
          <div>
            <p class="nsh-eyebrow mb-4 fade-up">The Foundation-First Model</p>
            <h2 class="nsh-heading-2 mb-6 fade-up">
              Regulation before learning. Movement before cognition.
            </h2>
            <p class="nsh-body-lg mb-6 fade-up">
              A child's development is built from the bottom up. Sensory processing, movement, primitive reflex integration, sleep, nutrition, and emotional safety all help create the foundation for higher-level skills like attention, communication, learning, and social connection.
            </p>
            <p class="nsh-body mb-8 fade-up">
              Neurosage Hub turns that foundation-first model into simple education, practical home routines, and progress tracking parents can actually use — without needing to become a therapist.
            </p>
            <div class="flex flex-wrap gap-3 fade-up">
              <a href="/parent-pathways" class="nsh-btn-primary">
                Explore Parent Pathways
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
              </a>
            </div>
          </div>
          <div class="flex justify-center fade-up">
            <img
              src={PYRAMID_IMG}
              alt="Brain Development Pyramid — Sensory, Movement, Sleep, Communication, Learning"
              class="w-full max-w-sm rounded-2xl"
              style="box-shadow:0 20px 60px oklch(0.22 0.02 240 / 0.12);"
              loading="lazy"
            />
          </div>
        </div>
      </div>
    </section>

    <!-- ===== HOW IT WORKS ===== -->
    <section id="how-it-works" class="py-20 nsh-section-ivory">
      <div class="container">
        <div class="max-w-2xl mx-auto text-center mb-14">
          <p class="nsh-eyebrow mb-4 fade-up">The Neurosage Journey</p>
          <h2 class="nsh-heading-2 mb-4 fade-up">Four simple steps to home-based support</h2>
          <p class="nsh-body fade-up">You don't have to figure everything out at once. Neurosage guides you through a clear, repeatable process.</p>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
          {steps.map(({ num, title, desc }, i) => (
            <div class="nsh-card p-7 fade-up" style={`transition-delay:${i * 80}ms;`}>
              <div class="text-4xl font-bold mb-4 leading-none" style="font-family:'DM Serif Display',serif; color:oklch(0.88 0.015 220);">
                {num}
              </div>
              <h3 class="nsh-heading-3 mb-3">{title}</h3>
              <p class="nsh-body" style="font-size:0.9375rem;">{desc}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ===== PARENT PATHWAYS ===== -->
    <section class="py-20 nsh-section-white">
      <div class="container">
        <div class="max-w-2xl mx-auto text-center mb-14">
          <p class="nsh-eyebrow mb-4 fade-up">Guided Parent Pathways</p>
          <h2 class="nsh-heading-2 mb-4 fade-up">Find the path that fits your child's needs</h2>
          <p class="nsh-body fade-up">Each pathway is a structured learning journey — not a random course library. Start where your child is right now.</p>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
          {pathways.map(({ label, desc, color, bg, icon, href }, i) => (
            <div class="nsh-card p-7 fade-up" style={`transition-delay:${i * 60}ms;`}>
              <div class="w-12 h-12 rounded-xl flex items-center justify-center mb-5" style={`background:${bg}; color:${color};`}>
                <Fragment set:html={icon} />
              </div>
              <div class="nsh-pill mb-3" style={`background:${bg}; color:${color}; font-size:0.75rem;`}>
                {label}
              </div>
              <p class="nsh-body" style="font-size:0.9375rem;">{desc}</p>
              <a
                href={href}
                class="inline-flex items-center gap-1.5 mt-5 text-sm font-semibold transition-colors"
                style={`color:${color}; font-family:'DM Sans',sans-serif;`}
              >
                Explore pathway
                <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
              </a>
            </div>
          ))}
        </div>
        <div class="text-center mt-10 fade-up">
          <a href="/parent-pathways" class="nsh-btn-primary">
            View All Parent Pathways
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
          </a>
        </div>
      </div>
    </section>

    <!-- ===== HOME ROUTINES PREVIEW ===== -->
    <section class="py-20 nsh-section-mist overflow-hidden">
      <div class="container">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16 items-center">
          <div class="order-2 lg:order-1 fade-up">
            <img
              src={ROUTINE_IMG}
              alt="Parent supporting child on a balance board during a home movement routine"
              class="w-full rounded-2xl"
              style="box-shadow:0 20px 60px oklch(0.22 0.02 240 / 0.12);"
              loading="lazy"
            />
          </div>
          <div class="order-1 lg:order-2">
            <p class="nsh-eyebrow mb-4 fade-up">What You'll Actually Do</p>
            <h2 class="nsh-heading-2 mb-6 fade-up">Simple routines designed for real home life</h2>
            <p class="nsh-body-lg mb-8 fade-up">
              Neurosage doesn't just teach concepts — it gives you protocol cards, daily routines, sensory logs, and progress tracking you can use starting today.
            </p>
            <div class="space-y-4 mb-8">
              {routines.map(({ title, time, desc }, i) => (
                <div class="nsh-protocol-card fade-up" style={`transition-delay:${i * 80}ms;`}>
                  <div class="flex items-start justify-between gap-4">
                    <div>
                      <h4 class="font-semibold mb-1" style="font-family:'DM Sans',sans-serif; color:oklch(0.22 0.02 240); font-size:0.9375rem;">
                        {title}
                      </h4>
                      <p class="text-sm" style="color:oklch(0.48 0.04 240); font-family:'DM Sans',sans-serif;">
                        {desc}
                      </p>
                    </div>
                    <span class="nsh-pill nsh-pill-sage flex-shrink-0" style="font-size:0.75rem;">
                      {time}
                    </span>
                  </div>
                </div>
              ))}
            </div>
            <a href="/home-routines" class="nsh-btn-primary fade-up">
              Explore Home Routines
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
            </a>
          </div>
        </div>
      </div>
    </section>

    <!-- ===== FAMILY STORIES ===== -->
    <section class="py-20 nsh-section-ivory">
      <div class="container">
        <div class="max-w-2xl mx-auto text-center mb-14">
          <p class="nsh-eyebrow mb-4 fade-up">Family Stories</p>
          <h2 class="nsh-heading-2 mb-4 fade-up">Parents share what changed for their families</h2>
          <p class="nsh-body fade-up">Individual experiences vary. These stories reflect personal journeys, not guaranteed outcomes.</p>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-10">
          {stories.map(({ quote, name, detail }, i) => (
            <div class="nsh-card p-8 fade-up" style={`transition-delay:${i * 80}ms;`}>
              <svg width="28" height="28" viewBox="0 0 24 24" fill="none" class="mb-4" style="color:oklch(0.65 0.06 162);">
                <path d="M3 21c3 0 7-1 7-8V5c0-1.25-.756-2.017-2-2H4c-1.25 0-2 .75-2 1.972V11c0 1.25.75 2 2 2 1 0 1 0 1 1v1c0 1-1 2-2 2s-1 .008-1 1.031V20c0 1 0 1 1 1z" fill="currentColor" opacity="0.6"/>
                <path d="M15 21c3 0 7-1 7-8V5c0-1.25-.757-2.017-2-2h-4c-1.25 0-2 .75-2 1.972V11c0 1.25.75 2 2 2h.75c0 2.25.25 4-2.75 4v3c0 1 0 1 1 1z" fill="currentColor" opacity="0.6"/>
              </svg>
              <p class="mb-6 leading-relaxed" style="font-family:'DM Serif Display',serif; font-size:1.0625rem; color:oklch(0.28 0.02 240); font-style:italic;">
                "{quote}"
              </p>
              <div class="flex items-center gap-1 mb-3">
                {Array.from({ length: 5 }).map(() => (
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="oklch(0.78 0.14 75)" style="color:oklch(0.78 0.14 75);"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
                ))}
              </div>
              <p class="font-semibold text-sm" style="font-family:'DM Sans',sans-serif; color:oklch(0.22 0.02 240);">{name}</p>
              <p class="text-xs mt-0.5" style="font-family:'DM Sans',sans-serif; color:oklch(0.55 0.04 240);">{detail}</p>
            </div>
          ))}
        </div>
        <div class="text-center fade-up">
          <a href="/podcast" class="nsh-btn-secondary">
            Read More Family Stories
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
          </a>
        </div>
      </div>
    </section>

    <!-- ===== QUIZ CTA ===== -->
    <section id="quiz" class="py-20 relative overflow-hidden">
      <div class="absolute inset-0" style="background:linear-gradient(135deg, oklch(0.38 0.09 240) 0%, oklch(0.32 0.07 250) 100%);"></div>
      <div class="absolute inset-0" style="opacity:0.1; background-image:radial-gradient(circle at 20% 50%, oklch(0.65 0.06 162) 0%, transparent 50%), radial-gradient(circle at 80% 20%, oklch(0.67 0.13 28) 0%, transparent 40%);"></div>
      <div class="container relative z-10">
        <div class="max-w-2xl mx-auto text-center">
          <p class="nsh-eyebrow mb-5 fade-up" style="color:oklch(0.65 0.06 162);">Your First Step</p>
          <h2 class="nsh-heading-2 mb-6 fade-up" style="color:white;">
            Not sure where to begin? Take the Parent Pathway Quiz.
          </h2>
          <p class="nsh-body-lg mb-8 fade-up" style="color:oklch(0.82 0.015 220);">
            Answer a few simple questions about your child's current needs and we'll recommend the best Neurosage starting path for your family — no sign-up required.
          </p>
          <div class="flex flex-col sm:flex-row gap-4 justify-center mb-8 fade-up">
            <a
              href="/start-here#quiz"
              class="nsh-btn-primary"
              style="background:oklch(0.67 0.13 28); font-size:1.0625rem; padding:1rem 2.25rem;"
            >
              Take the Parent Pathway Quiz
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
            </a>
            <a
              href="/start-here"
              class="nsh-btn-secondary"
              style="border-color:rgba(255,255,255,0.4); color:white;"
            >
              Download the Free Calm Start Guide
            </a>
          </div>
          <div class="flex flex-wrap justify-center gap-6 fade-up">
            {quizPerks.map((item) => (
              <div class="flex items-center gap-2 text-sm" style="color:oklch(0.82 0.015 220); font-family:'DM Sans',sans-serif;">
                <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="oklch(0.65 0.06 162)" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
                {item}
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>

    <!-- ===== PRACTITIONERS BLOCK ===== -->
    <section class="py-16 nsh-section-white">
      <div class="container">
