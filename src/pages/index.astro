---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const HERO_IMG     = "https://d2xsxph8kpxj0f.cloudfront.net/310519663645323174/cAF6S26VtT36Uyb4yyZGdw/nsh_hero-HdcUuJoW8jCr5tJf4wwPnk.webp";
const PARENT_CHILD = "https://d2xsxph8kpxj0f.cloudfront.net/310519663645323174/cAF6S26VtT36Uyb4yyZGdw/nsh_parent_child-ivuL9QAhsMZpMhgtzbS5ot.webp";
const PYRAMID_IMG  = "https://d2xsxph8kpxj0f.cloudfront.net/310519663645323174/cAF6S26VtT36Uyb4yyZGdw/nsh_brain_pyramid-6LxDvQVqZti4smMdjvWBjv.webp";

const pillars = [
  {
    title: 'From Overwhelm to Clarity',
    desc: 'We help families replace uncertainty with understanding — organizing information so you can see the bigger picture and know where to start.',
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg>`,
  },
  {
    title: 'From Fragmentation to Pathways',
    desc: 'We provide a clear path forward so you can turn information into consistent, daily action that actually supports your child.',
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M3 12h18M3 6h18M3 18h18"/></svg>`,
  },
  {
    title: 'From Access Gaps to Connection',
    desc: 'We offer trusted education and responsible practitioner connections all in one place — so you\'re never searching alone.',
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>`,
  },
  {
    title: 'From Follow-Through to Consistency',
    desc: 'We deliver structured guidance to help you make informed decisions and take the next step with greater confidence and clarity.',
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 11 12 14 22 4"/><path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"/></svg>`,
  },
];

const commitments = [
  {
    title: 'We Provide Education, Not Therapy',
    desc: 'Neurosage Hub does not provide therapy. We offer a platform for structured education that helps parents understand and support their child\'s journey.',
  },
  {
    title: 'No False Promises',
    desc: 'You will never find cure language, reversal claims, or guaranteed outcomes on our platform. We believe in honest, grounded support.',
  },
  {
    title: 'Evidence-Based Guidance',
    desc: 'We do not make biochemical claims without peer-reviewed support. Every resource on our platform is held to a standard of responsible, evidence-aligned education.',
  },
];

const steps = [
  { num: '01', title: 'Learn',    desc: 'Understand the why behind your child\'s regulation, sensory, and learning needs through short, parent-friendly lessons.' },
  { num: '02', title: 'Practice', desc: 'Follow guided home routines designed for real family life — 10 to 20 minutes a day, no special equipment needed.' },
  { num: '03', title: 'Track',    desc: 'Use simple logs to notice patterns, celebrate wins, and come prepared to your next practitioner appointment.' },
  { num: '04', title: 'Connect',  desc: 'Stay aligned with practitioner-informed guidance, organized next steps, and a supportive parent community.' },
];

const stories = [
  {
    quote: "I finally feel like I understand what my son needs. The morning routine alone changed our whole day.",
    name: "Sarah M.",
    detail: "Parent of a 7-year-old with ASD",
  },
  {
    quote: "Neurosage gave me a framework I could explain to my child's teacher and therapist. We're all on the same page now.",
    name: "Marcus T.",
    detail: "Father of two, sensory processing support",
  },
  {
    quote: "I was overwhelmed for years. This helped me slow down, understand the foundations, and start small. It made a real difference.",
    name: "Priya K.",
    detail: "Parent of a child with developmental delays",
  },
];

const footerLinks = [
  { href: '/parent-pathways', label: 'Browse Learning Paths' },
  { href: '/for-parents',     label: 'Explore Parent Resources' },
  { href: '/for-practitioners', label: 'Meet Our Practitioners' },
];
---

<BaseLayout
  title="Neurosage Hub — A Clear Path Forward for Autism Families"
  description="When you're overwhelmed by conflicting information and appointments, Neurosage Hub helps you organize the autism journey with structured education, trusted resources, and practitioner connections."
>
  <Header />

  <main>

    <!-- ===== HERO ===== -->
    <section class="relative overflow-hidden" style="min-height:90vh;">
      <div class="absolute inset-0 z-0">
        <img
          src={HERO_IMG}
          alt="Parent and child doing a calming activity at home"
          class="w-full h-full object-cover object-center"
        />
        <div class="absolute inset-0" style="background:linear-gradient(100deg, rgba(8,36,56,0.97) 0%, rgba(8,36,56,0.85) 50%, rgba(8,36,56,0.55) 100%);"></div>
      </div>

      <div class="container relative z-10 flex items-center" style="min-height:calc(90vh - 4rem);">
        <div class="max-w-2xl py-16">
          <p class="nsh-eyebrow mb-5 fade-up" style="color:#7B9E8B;">
            For Parents Navigating Autism
          </p>
          <h1 class="nsh-heading-display mb-4 fade-up" style="color:white; transition-delay:80ms;">
            Stop Guessing.<br>Start Making Progress.
          </h1>
          <p class="mb-2 fade-up" style="color:#D8896A; font-family:'DM Sans',sans-serif; font-weight:600; font-size:1.0625rem; transition-delay:120ms;">
            You don't need more advice. You need a clear path forward.
          </p>
          <p class="nsh-body-lg mb-8 max-w-xl fade-up" style="color:rgba(255,255,255,0.80); transition-delay:160ms;">
            Neurosage Hub is a structured parent-support platform — combining personalised learning pathways, home routines, therapeutic games, and AI mentorship to help your family move forward with confidence.
          </p>
          <div class="flex flex-wrap gap-4 mb-6 fade-up" style="transition-delay:240ms;">
            <a href="/quiz" class="nsh-btn-cta">
              Take the Free Quiz
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
            </a>
            <a href="/family-sign-up" class="nsh-btn-secondary" style="border-color:rgba(255,255,255,0.3); color:white;">
              Start Free Account
            </a>
          </div>
          <a href="/for-practitioners" class="inline-block text-sm mb-8 fade-up" style="color:rgba(255,255,255,0.55); font-family:'DM Sans',sans-serif; transition-delay:280ms; text-decoration:underline; text-underline-offset:3px;">
            Are you a Practitioner? Join here →
          </a>
          <!-- Trust badges -->
          <div class="flex flex-wrap gap-3 fade-up" style="transition-delay:320ms;">
            {[
              'No Official Diagnosis Required',
              'Designed with Functional Neurologists',
              '100% Educational Model',
            ].map((badge) => (
              <span class="flex items-center gap-1.5 text-xs font-medium px-3 py-1.5 rounded-full" style="background:rgba(255,255,255,0.12); color:rgba(255,255,255,0.8); font-family:'DM Sans',sans-serif; border:1px solid rgba(255,255,255,0.2);">
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
                {badge}
              </span>
            ))}
          </div>

          <!-- Mission tagline -->
          <p class="mt-10 fade-up" style="color:rgba(255,255,255,0.45); font-family:'DM Sans',sans-serif; font-size:0.875rem; letter-spacing:0.08em; text-transform:uppercase; transition-delay:360ms;">
            Build Hope. Walk Together.
          </p>
        </div>
      </div>
    </section>

    <!-- ===== SECTION 2 — PROBLEM ===== -->
    <section class="py-20" style="background:#E4EFF6;">
      <div class="container">
        <div class="max-w-3xl mx-auto text-center">
          <p class="nsh-eyebrow mb-4 fade-up" style="color:#1A4A6B;">We Understand</p>
          <h2 class="nsh-heading-2 mb-6 fade-up">
            Great Advice Shouldn't Live in Silos.
          </h2>
          <p class="nsh-body-lg mb-5 fade-up">
            You are doing everything you can to find the right answers, but navigating a fragmented system of resources, therapies, and endless research is exhausting. You don't need more disconnected information — you need a unified path.
          </p>
          <p class="nsh-body fade-up" style="max-width:38rem; margin:0 auto 0;">
            At Neurosage Hub we bring experienced practitioners, parents, and proven developmental pathways into one centralised Hub. Here you can move from overwhelm to clarity, building hope and walking side-by-side with a team that gets it.
          </p>
          <div class="flex flex-col sm:flex-row gap-4 justify-center mt-10 fade-up">
            <a href="/quiz" class="nsh-btn-cta">
              Parents: Take the Quiz
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
            </a>
            <a href="/for-practitioners#demo" class="nsh-btn-primary">
              Practitioners: Schedule a Demo
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
            </a>
          </div>
        </div>
      </div>
    </section>

    <!-- ===== TWO PATHS SECTION ===== -->
    <section class="py-20" style="background:white;">
      <div class="container">
        <div class="max-w-2xl mx-auto text-center mb-12">
          <p class="nsh-eyebrow mb-4 fade-up">Choose Your Path</p>
          <h2 class="nsh-heading-2 mb-4 fade-up">One platform. Two dedicated experiences.</h2>
          <p class="nsh-body fade-up">Whether you're a parent navigating daily challenges or a practitioner extending your care, there's a path built for you.</p>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6 max-w-4xl mx-auto">

          <!-- For Parents -->
          <div class="nsh-card p-8 fade-up" style="border-top:4px solid #D8896A;">
            <div class="w-12 h-12 rounded-xl flex items-center justify-center mb-5" style="background:rgba(216,137,106,0.1);">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#b8694a" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
            </div>
            <h3 class="nsh-heading-3 mb-3">For Parents & Caregivers</h3>
            <p class="nsh-body mb-6">Replace daily meltdowns with structured routines. Get 15-minute neurological warm-up tools, step-by-step pathways, and access to our AI Mentor to help your child self-regulate at home.</p>
            <a href="/for-parents" class="nsh-btn-cta">
              Explore Parent Features
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
            </a>
          </div>

          <!-- For Practitioners -->
          <div class="nsh-card p-8 fade-up" style="border-top:4px solid #2E6E8E; transition-delay:80ms;">
            <div class="w-12 h-12 rounded-xl flex items-center justify-center mb-5" style="background:#deeae5;">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#2E6E8E" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="3" width="20" height="14" rx="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>
            </div>
            <h3 class="nsh-heading-3 mb-3">For Practitioners & Clinics</h3>
            <p class="nsh-body mb-6">The clinical bridge between assessment and action. Extend your educational continuity between visits, track compliance, and scale your impact with your own dedicated portal.</p>
            <a href="/for-practitioners" class="nsh-btn-primary">
              Explore Practitioner Features
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
            </a>
          </div>

        </div>
      </div>
    </section>

    <!-- ===== WHAT'S INSIDE NSH ===== -->
    <section class="py-20" style="background:#F7F2EB;">
      <div class="container">
        <div class="max-w-2xl mx-auto text-center mb-14">
          <p class="nsh-eyebrow mb-4 fade-up" style="color:#7B9E8B;">What You Get</p>
          <h2 class="nsh-heading-2 mb-4 fade-up">Everything your family needs. One platform.</h2>
          <p class="nsh-body fade-up">No jumping between apps, practitioners, and YouTube rabbit holes. Neurosage Hub brings structure, guidance, and support together in one place — built specifically for autism families.</p>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5 max-w-5xl mx-auto">

          {[
            {
              icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>`,
              label: 'Autism Pathways Quiz',
              desc: 'A 3-minute personalised quiz that matches your child to the right learning pathway from day one.',
              color: '#D8896A',
            },
            {
              icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/></svg>`,
              label: 'Structured Learning Modules',
              desc: 'Bite-sized, parent-friendly lessons on regulation, sensory development, sleep, communication, and more.',
              color: '#2E6E8E',
            },
            {
              icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>`,
              label: 'Home Routine Protocols',
              desc: '10–20 minutes a day. Guided activities designed for real family life — no special equipment required.',
              color: '#7B9E8B',
            },
            {
              icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="6" width="20" height="12" rx="3"/><path d="M8 12h.01M12 10v4M10 12h4"/></svg>`,
              label: 'Therapeutic Sensory Games',
              desc: 'A library of video games purposefully designed for autistic children — free with every family account.',
              color: '#1A4A6B',
            },
            {
              icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2a10 10 0 1 0 0 20 10 10 0 0 0 0-20z"/><path d="M12 8v4l3 3"/></svg>`,
              label: 'Eva — AI Mentor',
              desc: '24/7 guidance from Eva, your AI autism mentor. Ask questions, get clarity, and get unstuck at any hour.',
              color: '#D8896A',
            },
            {
              icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>`,
              label: 'Progress Tracking',
              desc: 'Simple logs to notice patterns, celebrate wins, and come prepared to every practitioner appointment.',
              color: '#7B9E8B',
            },
          ].map(({ icon, label, desc, color }, i) => (
            <div class="nsh-card p-7 fade-up" style={`transition-delay:${i * 60}ms;`}>
              <div class="w-11 h-11 rounded-xl flex items-center justify-center mb-4 flex-shrink-0" style={`background:${color}18; color:${color};`}>
                <Fragment set:html={icon} />
              </div>
              <h3 style="font-family:'DM Sans',sans-serif; font-weight:700; font-size:1rem; color:#082438; margin-bottom:0.4rem;">{label}</h3>
              <p style="font-family:'DM Sans',sans-serif; font-size:0.875rem; color:#5F6975; line-height:1.65;">{desc}</p>
            </div>
          ))}

        </div>

        <div class="text-center mt-10 fade-up">
          <a href="/family-sign-up" class="nsh-btn-cta" style="font-size:0.9375rem;">
            Get Everything — Free to Start
            <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
          </a>
        </div>
      </div>
    </section>

    <!-- ===== SOCIAL PROOF — TESTIMONIALS (moved up) ===== -->
    <section class="py-20" style="background:white;">
      <div class="container">
        <div class="max-w-2xl mx-auto text-center mb-14">
          <p class="nsh-eyebrow mb-4 fade-up">Real Families. Real Progress.</p>
          <h2 class="nsh-heading-2 mb-4 fade-up">Hear from parents who found their way</h2>
          <p class="nsh-body fade-up">Individual experiences vary. These stories reflect personal journeys, not guaranteed outcomes.</p>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
          {stories.map(({ quote, name, detail }, i) => (
            <div class="nsh-card p-8 fade-up" style={`transition-delay:${i * 80}ms; border-top:3px solid #D8896A;`}>
              <div class="flex items-center gap-1 mb-5">
                {Array.from({ length: 5 }).map(() => (
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="#E8C98F" style="flex-shrink:0;"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
                ))}
              </div>
              <p class="mb-6 leading-relaxed" style="font-family:'DM Sans',sans-serif; font-size:1rem; color:#1F2A33; font-style:italic;">
                "{quote}"
              </p>
              <p class="font-semibold text-sm" style="font-family:'DM Sans',sans-serif; color:#082438;">{name}</p>
              <p class="text-xs mt-0.5" style="font-family:'DM Sans',sans-serif; color:#5F6975;">{detail}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ===== VIDEO GAMES FEATURE ===== -->
    <section class="py-20 relative overflow-hidden" style="background:#082438;">
      <!-- Neural network graphic — decorative right side -->
      <div class="absolute right-0 top-0 bottom-0 w-1/2 pointer-events-none hidden lg:block" style="opacity:0.18;">
        <img
          src="/games-neural.jpg"
          alt=""
          aria-hidden="true"
          class="w-full h-full object-cover object-left"
        />
      </div>

      <div class="container relative">
        <div class="max-w-4xl mx-auto">

          <div class="text-center mb-10">
            <p class="nsh-eyebrow mb-3 fade-up" style="color:#7B9E8B;">Inside the Hub</p>
            <h2 class="nsh-heading-2 mb-4 fade-up" style="color:white;">
              Games Built for Autistic Kids.<br>Backed by Neuroscience.
            </h2>
            <p class="nsh-body-lg fade-up" style="color:rgba(255,255,255,0.75); max-width:34rem; margin:0 auto;">
              Play isn't a break from development — it <em>is</em> development. Neurosage Hub includes a library of video games designed specifically for autistic children, available free to families and as a clinical tool for practitioners.
            </p>
          </div>

          <div class="grid grid-cols-1 md:grid-cols-2 gap-5 fade-up">

            <!-- Parents card -->
            <div class="rounded-2xl p-8" style="background:#0f3450; border:1px solid #1e4568;">
              <div class="w-12 h-12 rounded-xl flex items-center justify-center mb-5" style="background:rgba(216,137,106,0.2);">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#e0a088" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
                  <rect x="2" y="6" width="20" height="12" rx="3"/>
                  <path d="M8 12h.01M12 10v4M10 12h4"/>
                </svg>
              </div>
              <h3 class="mb-2 font-bold text-lg" style="font-family:'DM Sans',sans-serif; color:white;">For Kids &amp; Families</h3>
              <p class="mb-6 text-sm leading-relaxed" style="font-family:'DM Sans',sans-serif; color:rgba(255,255,255,0.65);">
                Let your child play — knowing every game is purposefully designed to support regulation, social processing, and focused attention. Included free with your parent account.
              </p>
              <a href="/games/play-free" class="nsh-btn-cta" style="font-size:0.875rem; padding:0.625rem 1.25rem;">
                Kids Play for Free
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
              </a>
            </div>

            <!-- Practitioners card -->
            <div class="rounded-2xl p-8" style="background:#0f3450; border:1px solid #1e4568;">
              <div class="w-12 h-12 rounded-xl flex items-center justify-center mb-5" style="background:rgba(18,61,90,0.3);">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#a8c4b8" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M2 12s3-7 10-7 10 7 10 7-3 7-10 7-10-7-10-7z"/>
                  <circle cx="12" cy="12" r="3"/>
                </svg>
              </div>
              <h3 class="mb-2 font-bold text-lg" style="font-family:'DM Sans',sans-serif; color:white;">For Clinics &amp; Practitioners</h3>
              <p class="mb-6 text-sm leading-relaxed" style="font-family:'DM Sans',sans-serif; color:rgba(255,255,255,0.65);">
                Integrate games into your practice as structured engagement tools. Assign specific titles between visits, track play patterns, and bridge the gap between the clinic and home environment.
              </p>
              <a href="/games#clinic" class="nsh-btn-secondary" style="font-size:0.875rem; padding:0.625rem 1.25rem; border-color:rgba(255,255,255,0.35); color:white;">
                Use Games in Your Clinic
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
              </a>
            </div>

          </div>

          <div class="flex flex-col sm:flex-row items-center justify-center gap-4 mt-8 fade-up">
            <a
              href="/games"
              class="inline-flex items-center gap-1.5 text-sm font-semibold"
