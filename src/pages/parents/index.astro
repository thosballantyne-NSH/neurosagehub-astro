---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';

const pathways = [
  {
    name: 'ASD Essentials',
    color: '#123D5A',
    colorBg: '#deeae5',
    icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M9.5 2A2.5 2.5 0 0 1 12 4.5v15a2.5 2.5 0 0 1-4.96-.44L7 19H5a2 2 0 0 1-2-2V7a2 2 0 0 1 2-2h2.5A2.5 2.5 0 0 1 9.5 2z"/><path d="M14.5 2A2.5 2.5 0 0 0 12 4.5v15a2.5 2.5 0 0 0 4.96-.44L17 19h2a2 2 0 0 0 2-2V7a2 2 0 0 0-2-2h-2.5A2.5 2.5 0 0 0 14.5 2z"/></svg>`,
    quote: "I need to understand what is happening and where to begin.",
    desc: "A foundational pathway for parents who are newly navigating autism or want a clearer understanding of the brain-body model behind their child's needs.",
    learn: [
      "Understanding the autism spectrum and neurodiversity",
      "Sensory processing and the nervous system",
      "Primitive reflexes and developmental foundations",
      "Gut-brain connection basics",
      "Family-centered support strategies",
      "Communication milestones and what to observe",
    ],
    cta: 'Start ASD Essentials',
  },
  {
    name: 'Sensory Regulation',
    color: '#7B9E8B',
    colorBg: '#eaf5f0',
    icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/></svg>`,
    quote: "My child melts down, seeks input, avoids input, or struggles with transitions.",
    desc: "Learn to identify your child's sensory profile, understand triggers, and build calming routines that work in real home life.",
    learn: [
      "Sensory seeking vs. sensory avoiding",
      "The 8 sensory systems explained simply",
      "Building a sensory-friendly home environment",
      "Calming vs. alerting activities",
      "Sensory trigger log and observation tools",
      "Transition support strategies",
    ],
    cta: 'Start Sensory Regulation',
  },
  {
    name: 'Home-Based Support',
    color: '#D8896A',
    colorBg: '#fdf0ea',
    icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>`,
    quote: "I want a practical daily plan I can follow.",
    desc: "A step-by-step daily framework with morning activation, after-school resets, meal routines, and evening calm-down sequences.",
    learn: [
      "Morning brain-body activation routine",
      "After-school sensory reset protocol",
      "Meal and nutrition support strategies",
      "Evening calm-down and sleep readiness",
      "Weekly progress tracking and journaling",
      "Building consistency without burnout",
    ],
    cta: 'Start Home-Based Support',
  },
  {
    name: 'Sleep & Regulation',
    color: '#4F7563',
    colorBg: '#eaf2ed',
    icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg>`,
    quote: "Sleep, mood, and transitions are affecting our whole family.",
    desc: "Support your child's circadian rhythm, evening regulation, and sleep readiness through gentle, science-informed routines.",
    learn: [
      "Why sleep and regulation are connected",
      "Circadian rhythm and light exposure",
      "Evening sensory wind-down routine",
      "Bedtime visual schedule and predictability",
      "Sleep tracker and pattern observation",
      "Parent regulation and co-regulation",
    ],
    cta: 'Start Sleep & Regulation',
  },
  {
    name: 'Communication Readiness',
    color: '#B8944A',
    colorBg: '#faf5e4',
    icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>`,
    quote: "I want to support connection, language, and engagement at home.",
    desc: "Practical strategies for supporting communication, play-based engagement, and language readiness through daily home interactions.",
    learn: [
      "Communication readiness and pre-language skills",
      "Play-based engagement routines",
      "Visual supports and AAC introduction",
      "Responsive interaction strategies",
      "Documenting communication progress",
      "Working with your speech therapist at home",
    ],
    cta: 'Start Communication Readiness',
  },
  {
    name: 'Movement & Reflexes',
    color: '#082438',
    colorBg: '#e8edf0',
    icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="5" r="2"/><path d="M9.5 8.5L7 22"/><path d="M14.5 8.5L17 22"/><path d="M7 13h10"/></svg>`,
    quote: "My child struggles with coordination, posture, focus, or developmental foundations.",
    desc: "Understand primitive reflexes, support reflex integration, and use movement-based routines to support attention, coordination, and learning readiness.",
    learn: [
      "What are primitive reflexes and why they matter",
      "Identifying retained reflexes at home",
      "Cross-crawl and bilateral coordination",
      "Balance, posture, and vestibular support",
      "Movement breaks for focus and regulation",
      "Coordinating with your occupational therapist",
    ],
    cta: 'Start Movement & Reflexes',
  },
];
---

<BaseLayout
  title="For Parents | Neurosage Hub"
  description="Every child's neurological development follows the same foundation-first model. Discover the pathways that help autism families build from sensory regulation all the way to learning and connection."
>
  <Header />
  <main>

    <!-- ===== HERO ===== -->
    <section class="py-16 lg:py-20" style="background:white;">
      <div class="container">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-10 lg:gap-16 items-center">
          <!-- Left: copy -->
          <div>
            <p class="nsh-eyebrow mb-4 fade-up" style="color:#D8896A;">For Parents</p>
            <h1 class="fade-up mb-5" style="font-family:'DM Sans',sans-serif; font-weight:800; font-size:clamp(2.25rem, 5vw, 3.5rem); line-height:1.1; color:#082438;">
              Regulation before learning.<br>Movement before cognition.
            </h1>
            <div class="mb-6" style="width:3rem; height:3px; background:#D8896A; border-radius:2px;"></div>
            <p class="nsh-body-lg mb-8 fade-up" style="color:#2d3f4c; max-width:34rem;">
              Every child's path is different — but the steps of neurological development are universal. We start where your child is today and build from there. The pyramid below shows how each layer creates the foundation for the next.
            </p>
            <div class="flex flex-wrap gap-4 fade-up">
              <a href="#pathways" class="nsh-btn-cta" style="font-size:1rem; padding:0.9rem 1.75rem;">
                Explore Pathways
                <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
              </a>
              <a href="/family-sign-up" class="nsh-btn-secondary" style="font-size:1rem; padding:0.9rem 1.5rem;">Start Free</a>
            </div>
            <button
              onclick="document.getElementById('pdf-popup').style.display='flex'"
              class="fade-up flex items-center gap-2 mt-4"
              style="background:none; border:none; cursor:pointer; font-family:'DM Sans',sans-serif; font-size:0.9375rem; font-weight:600; color:#2E6E8E; padding:0; text-decoration:underline; text-underline-offset:3px;"
            >
              <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
              Download Pathways &amp; Pyramid Guide
            </button>
          </div>
          <!-- Right: hero image -->
          <div class="fade-up hidden lg:block" style="transition-delay:80ms;">
            <img
              src="/hero-parents.png"
              alt="Mother hugging child warmly at home"
              class="w-full rounded-2xl object-cover"
              style="max-height:520px; object-position:center top; box-shadow:0 12px 40px rgba(8,36,56,0.10);"
            />
          </div>
        </div>
      </div>
    </section>

    <!-- ===== FOUNDATION-FIRST PYRAMID ===== -->
    <section class="py-16 lg:py-20" style="background:#F7F2EB;">
      <div class="container">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16 items-center">

          <!-- Left: copy -->
          <div class="fade-up">
            <p class="nsh-eyebrow mb-4" style="color:#123D5A;">The Foundation-First Model</p>
            <h2 class="nsh-heading-2 mb-5" style="color:#082438;">Development builds from the ground up.</h2>
            <p class="nsh-body-lg mb-5" style="color:#2d3f4c;">
              A child's development is built from the bottom up. Sensory processing, movement, primitive reflex integration, sleep, nutrition, and emotional safety all create the foundation for higher-level skills like attention, communication, learning, and social connection.
            </p>
            <p class="nsh-body mb-8" style="color:#3d4f5c;">
              Neurosage Hub turns that foundation-first model into simple education, practical home routines, and progress tracking parents can actually use — without needing to become a therapist.
            </p>
            <div class="flex flex-wrap gap-4 items-center">
              <button
                onclick="document.getElementById('pdf-popup').style.display='flex'"
                class="nsh-btn-cta"
                style="font-size:1rem; padding:0.9rem 1.75rem; display:inline-flex; align-items:center; gap:0.5rem; cursor:pointer; border:none;"
              >
                <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
                Download Pathways and Pyramid Guide
              </button>
            </div>
          </div>

          <!-- Right: pyramid SVG -->
          <div class="fade-up flex justify-center" style="transition-delay:80ms;">
            <div class="w-full max-w-sm rounded-2xl p-8" style="background:#F7F2EB; box-shadow:0 8px 40px rgba(8,36,56,0.08);">
              <svg viewBox="0 0 340 420" xmlns="http://www.w3.org/2000/svg" role="img" aria-label="Neurodevelopmental pyramid: from Sensory & Regulation at the base to Learning & Cognition at the top">

                <!-- Tier 1 top: Learning & Cognition -->
                <polygon points="150,8 190,8 220,88 120,88" fill="#D8896A" />
                <!-- icon: brain outline (simplified) -->
                <g transform="translate(159,28)" fill="none" stroke="white" stroke-width="1.5" stroke-linecap="round">
                  <path d="M11 2.5C9.3 2.5 8 3.8 8 5.5v.2C6.3 6.2 5 7.6 5 9.3c0 1 .4 1.9 1.1 2.5C5.4 12.4 5 13.4 5 14.5c0 2 1.3 3.7 3.2 4.3V20h7.6v-1.2c1.9-.6 3.2-2.3 3.2-4.3 0-1.1-.4-2.1-1.1-2.7.7-.6 1.1-1.5 1.1-2.5 0-1.7-1.3-3.1-3-3.6v-.2c0-1.7-1.3-3-3-3z"/>
                  <line x1="11" y1="8" x2="11" y2="20"/>
                </g>
                <text x="170" y="72" text-anchor="middle" font-family="DM Sans, sans-serif" font-size="11" font-weight="700" fill="white">Learning &amp;</text>
                <text x="170" y="84" text-anchor="middle" font-family="DM Sans, sans-serif" font-size="11" font-weight="700" fill="white">Cognition</text>

                <!-- Tier 2: Communication & Connection -->
                <polygon points="120,92 220,92 250,172 90,172" fill="#E8C98F" />
                <!-- icon: two people -->
                <g transform="translate(151,104)" fill="none" stroke="white" stroke-width="1.5" stroke-linecap="round">
                  <circle cx="7" cy="5" r="3"/>
                  <path d="M1 18c0-3.3 2.7-6 6-6"/>
                  <circle cx="17" cy="5" r="3"/>
                  <path d="M23 18c0-3.3-2.7-6-6-6"/>
                  <path d="M13 18c0-2.8-1.8-5-4-5.8"/>
                </g>
                <text x="170" y="148" text-anchor="middle" font-family="DM Sans, sans-serif" font-size="11" font-weight="700" fill="white">Communication &amp;</text>
                <text x="170" y="161" text-anchor="middle" font-family="DM Sans, sans-serif" font-size="11" font-weight="700" fill="white">Connection</text>

                <!-- Tier 3: Sleep & Nutrition -->
                <polygon points="90,176 250,176 280,256 60,256" fill="#7B9E8B" />
                <!-- icon: moon + bowl (simplified as moon) -->
                <g transform="translate(152,188)" fill="none" stroke="white" stroke-width="1.5" stroke-linecap="round">
                  <path d="M18 12.5A8 8 0 1 1 9.5 4a6 6 0 0 0 8.5 8.5z"/>
                  <path d="M8 20h8M10 20v2M14 20v2"/>
                </g>
                <text x="170" y="232" text-anchor="middle" font-family="DM Sans, sans-serif" font-size="11" font-weight="700" fill="white">Sleep &amp;</text>
                <text x="170" y="245" text-anchor="middle" font-family="DM Sans, sans-serif" font-size="11" font-weight="700" fill="white">Nutrition</text>

                <!-- Tier 4: Movement & Reflexes -->
                <polygon points="60,260 280,260 310,340 30,340" fill="#4F7563" />
                <!-- icon: figure crawling/moving -->
                <g transform="translate(150,272)" fill="none" stroke="white" stroke-width="1.5" stroke-linecap="round">
                  <circle cx="16" cy="4" r="2.5"/>
                  <path d="M14 7l-4 4 4 3"/>
                  <path d="M10 11l-4 3"/>
                  <path d="M14 10l4 4-2 4"/>
                  <path d="M18 14l3 2"/>
                </g>
                <text x="170" y="314" text-anchor="middle" font-family="DM Sans, sans-serif" font-size="11" font-weight="700" fill="white">Movement &amp;</text>
                <text x="170" y="327" text-anchor="middle" font-family="DM Sans, sans-serif" font-size="11" font-weight="700" fill="white">Reflexes</text>

                <!-- Tier 5 base: Sensory & Regulation -->
                <polygon points="30,344 310,344 340,416 0,416" fill="#082438" />
                <!-- icon: wave/signal (sensory) -->
                <g transform="translate(147,354)" fill="none" stroke="white" stroke-width="1.5" stroke-linecap="round">
                  <path d="M2 12c1.5-3 3-4.5 4.5-4.5S9.5 9 11 9s2.5-1.5 4-1.5 3 1.5 4.5 1.5"/>
                  <path d="M2 16c1.5-3 3-4.5 4.5-4.5S9.5 13 11 13s2.5-1.5 4-1.5 3 1.5 4.5 1.5"/>
                </g>
                <text x="170" y="392" text-anchor="middle" font-family="DM Sans, sans-serif" font-size="12" font-weight="700" fill="white">Sensory &amp; Regulation</text>

              </svg>
            </div>
          </div>

        </div>
      </div>
    </section>

    <!-- ===== PATHWAYS ===== -->
    <section id="pathways" class="py-20" style="background:white;">
      <div class="container">

        <div class="max-w-2xl mx-auto text-center mb-14">
          <p class="nsh-eyebrow mb-3 fade-up" style="color:#D8896A;">Guided Learning Journeys</p>
          <h2 class="nsh-heading-2 mb-4 fade-up" style="color:#082438;">Find the pathway that fits your child's needs.</h2>
          <p class="nsh-body fade-up" style="color:#3d4f5c;">Each pathway is a structured learning journey — not a random course library. Start where your child is right now and build from there. Below are the most common starting points.</p>
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
          {pathways.map(({ name, color, colorBg, icon, quote, desc, learn, cta }, i) => (
            <div class="rounded-2xl overflow-hidden fade-up" style={`background:white; border:1px solid #ddd9d2; box-shadow:0 4px 24px rgba(8,36,56,0.05); transition-delay:${i * 60}ms;`}>

              <!-- Card top -->
              <div class="px-7 pt-6 pb-5" style={`border-bottom:1px solid #e5e1da;`}>
                <div class="flex items-start gap-4 mb-4">
                  <div class="w-11 h-11 rounded-xl flex items-center justify-center flex-shrink-0" style={`background:${colorBg}; color:${color};`}>
                    <Fragment set:html={icon} />
                  </div>
                  <div>
                    <p class="nsh-eyebrow mb-1" style={`color:${color}; font-size:0.65rem;`}>{name}</p>
                    <p class="text-sm italic" style={`font-family:'DM Sans',sans-serif; color:#2d3f4c; line-height:1.5;`}>"{quote}"</p>
                  </div>
                </div>
                <p class="text-sm" style="font-family:'DM Sans',sans-serif; color:#3d4f5c; line-height:1.65;">{desc}</p>
              </div>

              <!-- What you'll learn -->
              <div class="px-7 py-5">
                <p class="text-xs font-bold mb-3" style="font-family:'DM Sans',sans-serif; color:#5F6975; letter-spacing:0.08em; text-transform:uppercase;">What you'll learn</p>
                <div class="grid grid-cols-1 sm:grid-cols-2 gap-x-4 gap-y-2 mb-5">
                  {learn.map((item) => (
                    <div class="flex items-start gap-2">
                      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke={color} stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" style="flex-shrink:0; margin-top:3px;"><polyline points="20 6 9 17 4 12"/></svg>
                      <span class="text-xs" style="font-family:'DM Sans',sans-serif; color:#3d4f5c; line-height:1.5;">{item}</span>
                    </div>
                  ))}
                </div>
                <a href="/family-sign-up" class="flex items-center gap-1.5 font-semibold text-sm" style={`font-family:'DM Sans',sans-serif; color:${color}; text-decoration:none;`}>
                  {cta}
                  <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
                </a>
              </div>

            </div>
          ))}
        </div>

        <!-- Download PDF CTA below pathways -->
        <div class="mt-12 text-center fade-up">
          <button
            onclick="document.getElementById('pdf-popup').style.display='flex'"
            style="display:inline-flex; align-items:center; gap:0.625rem; background:white; border:2px solid #082438; color:#082438; font-family:'DM Sans',sans-serif; font-size:1rem; font-weight:700; padding:0.9rem 2rem; border-radius:9999px; cursor:pointer; transition:all 0.15s; box-shadow:0 2px 8px rgba(8,36,56,0.08);"
            onmouseover="this.style.background='#082438'; this.style.color='white';"
            onmouseout="this.style.background='white'; this.style.color='#082438';"
          >
            <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
            Download PDF Guide
          </button>
          <p style="font-family:'DM Sans',sans-serif; font-size:0.8125rem; color:#5F6975; margin-top:0.75rem;">Free · No sign-up required</p>
        </div>

      </div>
    </section>

    <!-- ===== BOTTOM CTA ===== -->
    <section class="py-16" style="background:#082438;">
      <div class="container max-w-2xl mx-auto text-center fade-up">
        <h2 class="nsh-heading-2 mb-4" style="color:white;">Not sure which pathway to start with?</h2>
        <p class="nsh-body mb-8" style="color:rgba(255,255,255,0.65);">Take the free Parent Pathway Quiz and we'll recommend the best starting point based on your child's current needs.</p>
        <div class="flex flex-wrap justify-center gap-4">
          <a href="/family-sign-up" class="nsh-btn-cta" style="font-size:1rem; padding:0.9rem 1.75rem;">
            Take the Pathway Quiz
            <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
          </a>
          <a href="/family-sign-up" class="nsh-btn-secondary" style="font-size:1rem; padding:0.9rem 1.5rem; color:white; border-color:rgba(255,255,255,0.3);">Start Free</a>
        </div>
      </div>
    </section>

    <!-- ===== TAGLINE ===== -->
    <div style="background:#123D5A; padding:1.25rem 0;">
      <div class="container flex items-center gap-4">
        <div class="w-10 h-10 rounded-full flex items-center justify-center flex-shrink-0" style="background:rgba(255,255,255,0.15);">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
        </div>
        <p style="font-family:'DM Sans',sans-serif; font-size:1.0625rem; color:white;">
          <strong>Build hope.</strong> Walk together.
        </p>
      </div>
    </div>

  </main>
  <Footer />

  <!-- ===== PDF DOWNLOAD POPUP ===== -->
  <div
    id="pdf-popup"
    style="display:none; position:fixed; inset:0; z-index:99999; background:rgba(8,36,56,0.80); backdrop-filter:blur(5px); align-items:center; justify-content:center; padding:1rem;"
    role="dialog"
    aria-modal="true"
    aria-label="Download the PDF Guide"
  >
    <div style="background:white; border-radius:1.5rem; max-width:440px; width:100%; padding:2.5rem 2.25rem 2rem; position:relative; box-shadow:0 32px 80px rgba(0,0,0,0.35); animation:popup-in 0.25s ease;">

      <button
        onclick="document.getElementById('pdf-popup').style.display='none'"
        aria-label="Close"
        style="position:absolute; top:1rem; right:1rem; width:32px; height:32px; border-radius:50%; border:none; background:#F7F2EB; cursor:pointer; display:flex; align-items:center; justify-content:center; font-size:1.125rem; color:#5F6975; line-height:1;"
      >✕</button>

      <!-- Icon -->
      <div style="width:48px; height:48px; border-radius:0.875rem; background:#E4EFF6; display:flex; align-items:center; justify-content:center; margin-bottom:1.25rem;">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#2E6E8E" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><polyline points="10 9 9 9 8 9"/></svg>
      </div>

      <p style="font-family:'DM Sans',sans-serif; font-size:0.8125rem; font-weight:700; letter-spacing:0.1em; text-transform:uppercase; color:#D8896A; margin-bottom:0.5rem;">Free Download</p>
      <h2 style="font-family:'DM Sans',sans-serif; font-weight:800; font-size:1.5rem; color:#082438; line-height:1.2; margin-bottom:0.75rem;">
        Pathways &amp; Pyramid Guide
      </h2>
      <p style="font-family:'DM Sans',sans-serif; font-size:0.9375rem; color:#5F6975; line-height:1.65; margin-bottom:1.5rem;">
        The Neurosage Hub Foundation-First model — all five developmental layers, the six learning pathways, and how to find your child's starting point. Enter your email and we'll send it straight to your inbox.
      </p>

      <!-- Form -->
      <div id="pdf-form-wrap">
        <form id="pdf-form" novalidate>
          <input
            type="email"
            id="pdf-email"
            placeholder="Your email address"
            required
            autocomplete="email"
            style="width:100%; padding:0.875rem 1rem; border:1.5px solid #ddd9d2; border-radius:0.625rem; font-family:'DM Sans',sans-serif; font-size:1rem; color:#082438; outline:none; box-sizing:border-box; margin-bottom:0.75rem; transition:border-color 150ms;"
            onfocus="this.style.borderColor='#2E6E8E'"
            onblur="this.style.borderColor='#ddd9d2'"
          />
          <button
            type="submit"
            style="width:100%; background:#D8896A; color:white; font-family:'DM Sans',sans-serif; font-weight:700; font-size:1rem; padding:0.9375rem; border-radius:0.625rem; border:none; cursor:pointer; display:flex; align-items:center; justify-content:center; gap:0.5rem; transition:background 160ms;"
            onmouseover="this.style.background='#b8694a'"
            onmouseout="this.style.background='#D8896A'"
          >
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
            Send Me the Guide
          </button>
        </form>
        <p style="font-family:'DM Sans',sans-serif; font-size:0.8rem; color:#5F6975; text-align:center; margin-top:0.875rem;">
          No spam · No diagnosis required · Unsubscribe anytime
        </p>
      </div>

      <!-- Success state (hidden until submit) -->
      <div id="pdf-success" style="display:none; text-align:center; padding:1rem 0;">
        <div style="width:48px; height:48px; border-radius:50%; background:#deeae5; display:flex; align-items:center; justify-content:center; margin:0 auto 1rem;">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#4F7563" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
        </div>
        <h3 style="font-family:'DM Sans',sans-serif; font-weight:700; font-size:1.125rem; color:#082438; margin-bottom:0.5rem;">Check your inbox!</h3>
        <p style="font-family:'DM Sans',sans-serif; font-size:0.9375rem; color:#5F6975; line-height:1.65;">Your Pathways &amp; Pyramid Guide is on its way. While you wait, explore the pathways below.</p>
      </div>

    </div>
  </div>

  <style>
    @keyframes popup-in {
      from { opacity: 0; transform: translateY(16px) scale(0.97); }
      to   { opacity: 1; transform: translateY(0) scale(1); }
    }
  </style>

  <script is:inline>
    // Close popup on backdrop click
    document.getElementById('pdf-popup').addEventListener('click', function(e) {
      if (e.target === this) this.style.display = 'none';
    });
    document.addEventListener('keydown', function(e) {
      if (e.key === 'Escape') document.getElementById('pdf-popup').style.display = 'none';
    });

    // PDF form submit
    document.getElementById('pdf-form').addEventListener('submit', function(e) {
      e.preventDefault();
      var email = document.getElementById('pdf-email').value.trim();
      if (!email || !email.includes('@')) {
        document.getElementById('pdf-email').style.borderColor = '#c0392b';
        return;
      }
      // Show success state
      document.getElementById('pdf-form-wrap').style.display = 'none';
      document.getElementById('pdf-success').style.display = 'block';
      // Redirect after 2.5s
      setTimeout(function() {
        window.location.href = '/family-sign-up?email=' + encodeURIComponent(email) + '&ref=pdf-guide';
      }, 2500);
    });
  </script>

  <script>
    const observer = new IntersectionObserver(
      (entries) => entries.forEach(e => { if (e.isIntersecting) e.target.classList.add('visible'); }),
      { threshold: 0.08, rootMargin: '0px 0px -30px 0px' }
    );
    document.querySelectorAll('.fade-up').forEach(el => observer.observe(el));
  </script>

</BaseLayout>
