---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Practitioner Early Access | Neurosage Hub"
  description="Join Neurosage Hub's Early Access Program. A platform designed for practitioners to bridge the gap between home and clinic — AI guidance, progress tracking, and evidence-based tools for autism care."
>

  <!-- Minimal header — logo only, no nav -->
  <header style="background:#E4EFF6; padding:1.25rem 0; border-bottom:1px solid rgba(8,36,56,0.08);">
    <div class="container">
      <a href="/for-practitioners" style="display:inline-flex; align-items:center; gap:0.625rem; text-decoration:none;">
        <img src="/logo-blue.png" alt="Neurosage Hub" style="height:44px; width:auto;" />
      </a>
    </div>
  </header>

  <main style="background:#E4EFF6; min-height:calc(100vh - 73px);">
    <div class="container py-16">

      <div style="display:grid; grid-template-columns:2fr 3fr; gap:4rem; max-width:82rem; margin:0 auto; align-items:start;">

        <!-- ===== LEFT: Copy ===== -->
        <div>
          <p style="font-family:'DM Sans',sans-serif; font-size:0.875rem; font-weight:700; color:#D8896A; text-transform:uppercase; letter-spacing:0.1em; margin-bottom:1rem;">
            Join Neurosage Hub's Early Access Program
          </p>

          <h1 style="font-family:'DM Sans',sans-serif; font-weight:800; font-size:clamp(2rem,4vw,2.75rem); color:#082438; line-height:1.15; margin-bottom:1.25rem;">
            Empower Autism Care<br>with Neurosage Hub
          </h1>

          <p style="font-family:'DM Sans',sans-serif; font-size:1rem; color:#3d5a6e; line-height:1.75; margin-bottom:2rem; max-width:30rem;">
            Neurosage Hub brings cutting-edge neuroscience and practical tools together in one platform — bridging the gap between home and clinic for the individuals you serve.
          </p>

          <!-- Simple bullet list -->
          <ul style="list-style:none; padding:0; margin:0 0 3rem; display:flex; flex-direction:column; gap:0.875rem;">
            {[
              'AI Mentor for real-time guidance on next steps',
              'Practical home plans for sensory, movement, and nutrition',
              'Training modules through the Hub Academy',
              'Track and share progress with care providers',
              'Evidence-based strategies for sustained growth',
            ].map(item => (
              <li style="display:flex; align-items:flex-start; gap:0.75rem; font-family:'DM Sans',sans-serif; font-size:0.9375rem; color:#1A4A6B; line-height:1.55;">
                <span style="color:#D8896A; font-size:1.1rem; line-height:1.4; flex-shrink:0;">■</span>
                {item}
              </li>
            ))}
          </ul>

          <!-- Arrow -->
          <div style="display:flex; justify-content:center; padding-left:2rem;">
            <svg width="160" height="120" viewBox="0 0 160 120" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path
                d="M10 20 C10 20, 20 100, 140 90"
                stroke="#082438"
                stroke-width="7"
                stroke-linecap="round"
                fill="none"
              />
              <polyline
                points="110,70 142,90 122,115"
                stroke="#082438"
                stroke-width="7"
                stroke-linecap="round"
                stroke-linejoin="round"
                fill="none"
              />
            </svg>
          </div>
        </div>

        <!-- ===== RIGHT: GHL Form ===== -->
        <div>
          <div style="background:white; border-radius:1rem; padding:2rem; box-shadow:0 4px 40px rgba(8,36,56,0.1); border:1px solid rgba(8,36,56,0.06);">
            <iframe
              src="https://links.campusadmin.ai/widget/form/fhTwh2inwJDj5MBjj4yg"
              style="display:block; width:100%; min-height:1224px; border:none;"
              title="Practitioner Early Access Sign Up"
              allow="fullscreen"
              loading="lazy"
            ></iframe>
          </div>
        </div>

      </div>
    </div>
  </main>

  <!-- Minimal footer -->
  <footer style="background:#082438; padding:1.25rem 0;">
    <div class="container" style="display:flex; align-items:center; justify-content:space-between; flex-wrap:wrap; gap:1rem;">
      <p style="font-family:'DM Sans',sans-serif; font-size:0.8125rem; color:rgba(255,255,255,0.4); margin:0;">
        © {new Date().getFullYear()} Neurosage Hub. All rights reserved.
      </p>
      <div style="display:flex; gap:1.5rem;">
        <a href="/privacy-policy" style="font-family:'DM Sans',sans-serif; font-size:0.8125rem; color:rgba(255,255,255,0.4); text-decoration:none;">Privacy Policy</a>
        <a href="/terms-of-service" style="font-family:'DM Sans',sans-serif; font-size:0.8125rem; color:rgba(255,255,255,0.4); text-decoration:none;">Terms of Service</a>
        <a href="https://app.neurosagehub.com/login" style="font-family:'DM Sans',sans-serif; font-size:0.8125rem; color:rgba(255,255,255,0.4); text-decoration:none;">Login</a>
      </div>
    </div>
  </footer>

</BaseLayout>

<style>
  @media (max-width: 768px) {
    main > div > div {
      grid-template-columns: 1fr !important;
      gap: 2rem !important;
    }
  }
</style>
