---
const year = new Date().getFullYear();

const familyLinks = [
  { href: '/for-parents',     label: 'For Parents' },
  { href: '/parent-pathways', label: 'Browse Learning Paths' },
  { href: '/home-routines',   label: 'Home Routines' },
  { href: '/games',           label: 'Sensory Games' },
  { href: '/resources',        label: 'Free Resource Library' },
];
const practitionerLinks = [
  { href: '/for-practitioners',                                      label: 'For Practitioners' },
  { href: '/pricing-practitioners',                                  label: 'Practitioner Pricing' },
  { href: '/practitioner-perspectives',                              label: 'Practitioner Perspectives' },
  { href: 'https://open.spotify.com/show/3AkgD8H7t6uPww4buFprla',  label: 'Podcast', external: true },
];
const companyLinks = [
  { href: '/about',            label: 'About Us' },
  { href: '/pricing',          label: 'Pricing' },
  { href: '/privacy-policy',   label: 'Privacy Policy' },
  { href: '/terms-of-service', label: 'Terms of Service' },
];
---

<footer class="pt-16 pb-8" style="background:#082438; color:#e8e4dc;">
  <div class="container">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-10 pb-12 border-b" style="border-color:rgba(255,255,255,0.1);">

      <!-- Brand -->
      <div class="lg:col-span-1">
        <a href="/" class="flex items-center gap-2.5 mb-4">
          <img
            src="/logo-white.png"
            alt="Neurosage Hub"
            class="h-9 w-auto"
            onerror="this.style.display='none'; this.nextElementSibling.style.display='block'"
          />
          <span style="display:none; font-family:'DM Serif Display',serif; font-size:1.125rem; color:white;">
            Neurosage Hub
          </span>
        </a>
        <p class="text-sm leading-relaxed mb-4" style="color:#a8b8c4; font-family:'DM Sans',sans-serif;">
          Helping parents support regulation, development, and daily progress at home through guided learning and practitioner-connected support.
        </p>
        <p class="text-xs leading-relaxed p-3 rounded-lg" style="background:rgba(255,255,255,0.06); color:#6B7A86; font-family:'DM Sans',sans-serif;">
          Neurosage Hub provides educational resources and parent support tools. It does not diagnose, treat, or replace medical care.
        </p>
        <div class="flex items-center gap-4 mt-5">
          <a href="http://instagram.com/neurosagehub/" aria-label="Instagram" class="transition-colors hover:text-white" style="color:#6B7A86;">
            <svg width="18" height="18" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/></svg>
          </a>
          <a href="http://facebook.com/neurosagehub/" aria-label="Facebook" class="transition-colors hover:text-white" style="color:#6B7A86;">
            <svg width="18" height="18" fill="currentColor" viewBox="0 0 24 24"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
          </a>
          <a href="https://www.youtube.com/@neurosagehub" aria-label="YouTube" class="transition-colors hover:text-white" style="color:#6B7A86;">
            <svg width="18" height="18" fill="currentColor" viewBox="0 0 24 24"><path d="M23.495 6.205a3.007 3.007 0 0 0-2.088-2.088c-1.87-.501-9.396-.501-9.396-.501s-7.507-.01-9.396.501A3.007 3.007 0 0 0 .527 6.205a31.247 31.247 0 0 0-.522 5.805 31.247 31.247 0 0 0 .522 5.783 3.007 3.007 0 0 0 2.088 2.088c1.868.502 9.396.502 9.396.502s7.506 0 9.396-.502a3.007 3.007 0 0 0 2.088-2.088 31.247 31.247 0 0 0 .5-5.783 31.247 31.247 0 0 0-.5-5.805zM9.609 15.601V8.408l6.264 3.602z"/></svg>
          </a>
        </div>
      </div>

      <!-- For Families -->
      <div>
        <h4 class="text-xs font-semibold uppercase tracking-widest mb-4" style="color:#7B9E8B; font-family:'DM Sans',sans-serif;">For Families</h4>
        <ul class="space-y-2.5">
          {familyLinks.map(({ href, label }) => (
            <li>
              <a href={href} class="text-sm transition-colors hover:text-white" style="color:#a8b8c4; font-family:'DM Sans',sans-serif;">{label}</a>
            </li>
          ))}
        </ul>
      </div>

      <!-- For Practitioners -->
      <div>
        <h4 class="text-xs font-semibold uppercase tracking-widest mb-4" style="color:#7B9E8B; font-family:'DM Sans',sans-serif;">For Practitioners</h4>
        <ul class="space-y-2.5">
          {practitionerLinks.map(({ href, label, external }) => (
            <li>
              <a href={href} class="text-sm transition-colors hover:text-white" style="color:#a8b8c4; font-family:'DM Sans',sans-serif;" target={external ? '_blank' : undefined} rel={external ? 'noopener noreferrer' : undefined}>{label}</a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Company -->
      <div>
        <h4 class="text-xs font-semibold uppercase tracking-widest mb-4" style="color:#7B9E8B; font-family:'DM Sans',sans-serif;">Company</h4>
        <ul class="space-y-2.5">
          {companyLinks.map(({ href, label }) => (
            <li>
              <a href={href} class="text-sm transition-colors hover:text-white" style="color:#a8b8c4; font-family:'DM Sans',sans-serif;">{label}</a>
            </li>
          ))}
        </ul>
      </div>
    </div>

    <div class="pt-8 flex flex-col md:flex-row items-center justify-between gap-4">
      <p class="text-xs" style="color:#6B7A86; font-family:'DM Sans',sans-serif;">
        &copy; {year} Neurosage Hub. All rights reserved.
      </p>
      <p class="text-xs" style="color:#6B7A86; font-family:'DM Sans',sans-serif;">
        Made with ♥ for families navigating neurodevelopment
      </p>
    </div>
  </div>
</footer>
