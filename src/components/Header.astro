---
interface Props {
  ctaText?: string;
  ctaHref?: string;
}
const { ctaText = 'Take the Quiz', ctaHref = '/quiz' } = Astro.props;

const navLinks = [
  { href: '/start-here',        label: 'Start Here' },
  { href: '/parents',       label: 'For Parents' },
  { href: '/practitioner', label: 'For Practitioners' },
  { href: '/resources',         label: 'Resources' },
  { href: '/games',             label: 'Sensory Games' },
];
const current = Astro.url.pathname;

// Replace whichever nav link the visitor is currently on with Pricing.
const activeIndex = navLinks.findIndex(({ href }) =>
  current === href || current.startsWith(href + '/')
);
const displayLinks = navLinks.map((link, i) => {
  if (i === activeIndex) {
    const pricingHref = current.startsWith('/practitioner')
      ? '/pricing-practitioners'
      : '/pricing';
    return { href: pricingHref, label: 'Pricing', isPricing: true };
  }
  return { ...link, isPricing: false };
});
---

<header
  id="nsh-header"
  class="fixed top-0 left-0 right-0 z-50 transition-all duration-300"
  style="background: rgba(255,255,255,0.92); backdrop-filter: blur(12px); border-bottom: 1px solid transparent;"
>
  <div class="container">
    <div class="flex items-center justify-between h-16">

      <!-- Logo -->
      <a href="/" class="flex items-center gap-2.5 shrink-0">
        <img
          src="/logo-blue.png"
          alt="Neurosage Hub"
          class="h-14 w-auto"
          id="nav-logo"
          onerror="this.style.display='none'; document.getElementById('logo-fallback').style.display='block'"
        />
        <span
          id="logo-fallback"
          style="display:none; font-family:'DM Sans',sans-serif; color:#1A4A6B; font-size:1.125rem; font-weight:800;"
        >
          Neurosage Hub
        </span>
      </a>

      <!-- Desktop Nav -->
      <nav class="hidden lg:flex items-center gap-1">
        {displayLinks.map(({ href, label, isPricing }) => (
          <a
            href={href}
            class="px-4 py-2 rounded-lg text-sm transition-all duration-200"
            style={isPricing
              ? `font-family:'DM Sans',sans-serif; color:#D8896A; font-weight:700; background:rgba(216,137,106,0.08);`
              : `font-family:'DM Sans',sans-serif; color:#1F2A33; font-weight:500;`}
          >
            {label}
          </a>
        ))}
      </nav>

      <!-- Right actions + mobile toggle -->
      <div class="flex items-center gap-2">

        <!-- Search icon -->
        <button
          id="search-trigger"
          aria-label="Search"
          class="p-2 rounded-lg transition-colors"
          style="color:#5F6975;"
        >
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
        </button>

        <a
          href="https://app.neurosagehub.com/login"
          class="hidden md:inline-block text-sm font-medium"
          style="color:#5F6975; font-family:'DM Sans',sans-serif;"
        >
          Login
        </a>
        <a
          href={ctaHref}
          class="hidden md:inline-flex nsh-btn-cta"
          style="font-size:0.875rem; padding:0.5rem 1.25rem;"
        >
          {ctaText}
        </a>
        <button
          id="mobile-toggle"
          class="lg:hidden p-2 rounded-lg"
          style="color:#1A4A6B;"
          aria-label="Toggle menu"
        >
          <svg id="icon-menu" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/></svg>
          <svg id="icon-close" class="hidden" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
        </button>
      </div>
    </div>
  </div>

  <!-- Mobile Menu -->
  <div
    id="mobile-menu"
    class="lg:hidden hidden border-t"
    style="background:rgba(255,255,255,0.98); border-color:#ddd9d2;"
  >
    <div class="container py-4 flex flex-col gap-1">
      {displayLinks.map(({ href, label, isPricing }) => (
        <a
          href={href}
          class="px-4 py-3 rounded-xl text-sm font-medium"
          style={isPricing
            ? `font-family:'DM Sans',sans-serif; color:#D8896A; font-weight:700; background:rgba(216,137,106,0.06);`
            : `font-family:'DM Sans',sans-serif; color:#1F2A33;`}
        >
          {label}
        </a>
      ))}
      <a
        href="https://app.neurosagehub.com/login"
        class="px-4 py-3 rounded-xl text-sm font-medium mt-1"
        style="font-family:'DM Sans',sans-serif; color:#5F6975;"
      >
        Login
      </a>
      <a href={ctaHref} class="nsh-btn-cta mt-2 justify-center">
        {ctaText}
      </a>
    </div>
  </div>
</header>

<!-- ===== SEARCH MODAL ===== -->
<div
  id="search-overlay"
  style="display:none; position:fixed; inset:0; z-index:200; background:rgba(8,36,56,0.6); backdrop-filter:blur(4px);"
  aria-modal="true"
  role="dialog"
  aria-label="Search"
>
  <div style="display:flex; align-items:flex-start; justify-content:center; padding:5rem 1rem 1rem;">
    <div style="width:100%; max-width:600px; background:white; border-radius:1.25rem; box-shadow:0 24px 64px rgba(8,36,56,0.22); overflow:hidden;">

      <!-- Search input row -->
      <div style="display:flex; align-items:center; gap:0.75rem; padding:1rem 1.25rem; border-bottom:1px solid #ddd9d2;">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#7B9E8B" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="flex-shrink:0;"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
        <input
          id="search-input"
          type="text"
          placeholder="Search resources, topics, articles…"
          autocomplete="off"
          style="flex:1; border:none; outline:none; font-family:'DM Sans',sans-serif; font-size:1rem; color:#082438; background:transparent;"
        />
        <button id="search-close" style="color:#9aa3ad; padding:0.25rem; border:none; background:none; cursor:pointer; border-radius:0.375rem;" aria-label="Close search">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
        </button>
      </div>

      <!-- Results -->
      <div id="search-results" style="max-height:420px; overflow-y:auto; padding:0.5rem;">
        <!-- Populated by JS -->
      </div>

    </div>
  </div>
</div>

<div class="h-16"></div>

<!-- Mobile sticky CTA -->
<div
  id="mobile-sticky-cta"
  class="fixed bottom-0 left-0 right-0 z-40 md:hidden"
  style="background:white; border-top:1px solid #ddd9d2; padding:0.75rem 1.25rem; box-shadow:0 -4px 16px rgba(8,36,56,0.08);"
>
  <a
    href="/quiz"
    class="nsh-btn-cta w-full justify-center"
    style="font-size:1rem; padding:0.875rem;"
  >
    Get Started Free — Take the Quiz
  </a>
</div>

<script is:inline>
(function () {

  /* ── Scroll / shadow ── */
  const header = document.getElementById('nsh-header');
  window.addEventListener('scroll', () => {
    if (window.scrollY > 20) {
      header.style.background = 'rgba(255,255,255,0.97)';
      header.style.borderBottomColor = '#ddd9d2';
      header.style.boxShadow = '0 2px 16px rgba(8,36,56,0.07)';
    } else {
      header.style.background = 'rgba(255,255,255,0.92)';
      header.style.borderBottomColor = 'transparent';
      header.style.boxShadow = 'none';
    }
  }, { passive: true });

  /* ── Mobile menu ── */
  const toggle = document.getElementById('mobile-toggle');
  const menu = document.getElementById('mobile-menu');
  const iconMenu = document.getElementById('icon-menu');
  const iconClose = document.getElementById('icon-close');
  toggle.addEventListener('click', () => {
    const isHidden = menu.classList.toggle('hidden');
    iconMenu.classList.toggle('hidden', !isHidden);
    iconClose.classList.toggle('hidden', isHidden);
  });

  /* ── Fade-up observer ── */
  const observer = new IntersectionObserver(
    (entries) => entries.forEach(e => { if (e.isIntersecting) e.target.classList.add('visible'); }),
    { threshold: 0.08, rootMargin: '0px 0px -30px 0px' }
  );
  document.querySelectorAll('.fade-up').forEach(el => observer.observe(el));

  /* ── Search ── */
  const PAGES = [
    // Resource Center
    { title: 'Resource Center', desc: 'Autism guides organized by topic — assessments, meltdowns, sensory, regulation and more.', url: '/resources', tags: 'resources hub' },

    // Assessments
    { title: 'Autism Assessments', desc: 'Everything families need to know about the autism assessment process.', url: '/resources/assessments', tags: 'assessments diagnosis' },
    { title: 'What Is an Autism Assessment?', desc: 'A clear explanation of what an assessment involves, who conducts it, and what it tells you.', url: '/resources/assessments/what-is-an-autism-assessment', tags: 'assessment diagnosis evaluation' },
    { title: 'How Long Does an Autism Assessment Take?', desc: 'From referral to results — a realistic timeline including what causes delays.', url: '/resources/assessments/how-long-does-autism-assessment-take', tags: 'assessment timeline waitlist' },
    { title: 'What Happens During an Autism Assessment?', desc: 'A step-by-step walkthrough of the evaluation — ADOS, parent interview, cognitive testing.', url: '/resources/assessments/what-happens-during-autism-assessment', tags: 'assessment ADOS evaluation process' },
    { title: 'How to Prepare for an Autism Assessment', desc: 'Practical steps before assessment day to reduce anxiety and gather the right information.', url: '/resources/assessments/how-to-prepare-for-autism-assessment', tags: 'assessment prepare anxiety child' },

    // Meltdowns
    { title: 'Autism Meltdowns', desc: 'What causes meltdowns, how to help in the moment, and how to reduce them over time.', url: '/resources/meltdowns', tags: 'meltdowns behavior regulation' },
    { title: 'What Causes Autism Meltdowns?', desc: 'The neurological and sensory roots of autistic meltdowns, explained clearly.', url: '/resources/meltdowns/what-causes-autism-meltdowns', tags: 'meltdowns causes sensory nervous system' },
    { title: 'Autism Meltdown vs Tantrum', desc: 'A meltdown and a tantrum look similar but have completely different causes and responses.', url: '/resources/meltdowns/meltdown-vs-tantrum', tags: 'meltdown tantrum difference behavior' },
    { title: 'Common Autism Meltdown Triggers', desc: 'Understanding what triggers meltdowns is the first step toward preventing them.', url: '/resources/meltdowns/common-meltdown-triggers', tags: 'meltdown triggers sensory overload' },
    { title: 'How to Help During and After a Meltdown', desc: 'What to do — and what not to do — in the moment, and how to support recovery.', url: '/resources/meltdowns/how-to-help', tags: 'meltdown help support recovery calm' },

    // Sensory Processing
    { title: 'Sensory Processing', desc: 'How autistic children experience the sensory world and how to create environments where they thrive.', url: '/resources/sensory-processing', tags: 'sensory processing integration' },
    { title: 'Vestibular Activities That Calm and Center', desc: 'Five vestibular activities that help regulate the nervous system at home or in the clinic.', url: '/resources/sensory-processing/vestibular-activities-that-calm-and-center', tags: 'vestibular sensory regulation calm activities' },

    // Regulation
    { title: 'Regulation', desc: 'Tools and activities for building emotional and nervous system regulation.', url: '/resources/regulation', tags: 'regulation emotional nervous system' },
    { title: '5 Fine Motor Activities You Can Do Today', desc: 'Simple sensory-rich fine motor activities — no fancy equipment required.', url: '/resources/regulation/5-fine-motor-activities-you-can-do-today', tags: 'fine motor activities regulation home' },
    { title: 'How Games Drive Neurodevelopment', desc: 'How therapeutic games activate neural pathways and why enjoyment drives neuroplasticity.', url: '/resources/regulation/unlocking-potential-how-games-drive-neurodevelopment', tags: 'games neurodevelopment neuroplasticity therapy' },

    // Other hubs
    { title: 'Communication Resources', desc: 'Guides on supporting communication development in autistic children.', url: '/resources/communication', tags: 'communication speech AAC language' },
    { title: 'Behavior Resources', desc: 'Understanding behavior function and strategies that address root causes.', url: '/resources/behavior', tags: 'behavior ABA function strategies' },
    { title: 'Sleep Resources', desc: 'Why autistic children struggle with sleep and approaches that improve it.', url: '/resources/sleep', tags: 'sleep insomnia bedtime routine' },
    { title: 'Nutrition Resources', desc: 'Diet, gut health, and sensory-related feeding challenges for autistic children.', url: '/resources/nutrition', tags: 'nutrition diet food feeding gut' },
    { title: 'Routines Resources', desc: 'Why predictable routines are a regulation tool and how to build them.', url: '/resources/routines', tags: 'routines schedule structure morning bedtime' },

    // Main pages
    { title: 'For Parents & Caregivers', desc: 'How Neurosage Hub supports families navigating autism at home.', url: '/parents', tags: 'parents families home support' },
    { title: 'For Practitioners', desc: 'Clinical partnership portal for OTs, SLPs, neurologists and more.', url: '/practitioner', tags: 'practitioners OT SLP portal clinical' },
    { title: 'Sensory Games', desc: 'Therapeutic video games that build regulation, focus, and sensory integration.', url: '/games', tags: 'games sensory therapeutic neurodevelopment' },
    { title: 'Podcast: Practitioner Perspectives', desc: 'Real conversations about what autism care actually looks like.', url: '/practitioner-perspectives', tags: 'podcast autism care practitioners' },
    { title: 'Pricing for Families', desc: 'Plans and pricing for families using the Neurosage Hub platform.', url: '/pricing', tags: 'pricing cost families subscription' },
    { title: 'Practitioner Pricing', desc: 'Branded portal pricing for practitioners partnering with Neurosage Hub.', url: '/pricing-practitioners', tags: 'pricing practitioners portal partnership' },
  ];

  const overlay  = document.getElementById('search-overlay');
  const input    = document.getElementById('search-input');
  const results  = document.getElementById('search-results');
  const trigger  = document.getElementById('search-trigger');
  const closeBtn = document.getElementById('search-close');

  function openSearch() {
    overlay.style.display = 'block';
    setTimeout(() => input.focus(), 50);
    renderResults('');
    document.body.style.overflow = 'hidden';
  }

  function closeSearch() {
    overlay.style.display = 'none';
    input.value = '';
    document.body.style.overflow = '';
  }

  trigger.addEventListener('click', openSearch);
  closeBtn.addEventListener('click', closeSearch);
  overlay.addEventListener('click', (e) => { if (e.target === overlay) closeSearch(); });

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') closeSearch();
    if ((e.metaKey || e.ctrlKey) && e.key === 'k') { e.preventDefault(); openSearch(); }
  });

  function renderResults(query) {
    const q = query.trim().toLowerCase();
    const matches = q.length < 2
      ? PAGES.slice(0, 8)
      : PAGES.filter(p =>
          p.title.toLowerCase().includes(q) ||
          p.desc.toLowerCase().includes(q) ||
          p.tags.toLowerCase().includes(q)
        ).slice(0, 10);

    if (matches.length === 0) {
      results.innerHTML = `<p style="padding:1.25rem 1rem; font-family:'DM Sans',sans-serif; font-size:0.9375rem; color:#9aa3ad; text-align:center;">No results for "${query}"</p>`;
      return;
    }

    const label = q.length < 2
      ? `<p style="padding:0.5rem 1rem 0.25rem; font-family:'DM Sans',sans-serif; font-size:0.75rem; font-weight:600; color:#9aa3ad; text-transform:uppercase; letter-spacing:0.07em;">Browse pages</p>`
      : `<p style="padding:0.5rem 1rem 0.25rem; font-family:'DM Sans',sans-serif; font-size:0.75rem; font-weight:600; color:#9aa3ad; text-transform:uppercase; letter-spacing:0.07em;">${matches.length} result${matches.length !== 1 ? 's' : ''}</p>`;

    results.innerHTML = label + matches.map(p => `
      <a href="${p.url}" style="display:flex; flex-direction:column; gap:0.2rem; padding:0.75rem 1rem; border-radius:0.75rem; text-decoration:none; transition:background 0.12s;" onmouseover="this.style.background='#F7F2EB'" onmouseout="this.style.background='transparent'">
        <span style="font-family:'DM Sans',sans-serif; font-size:0.9375rem; font-weight:600; color:#082438;">${p.title}</span>
        <span style="font-family:'DM Sans',sans-serif; font-size:0.8125rem; color:#5F6975; line-height:1.5;">${p.desc}</span>
      </a>
    `).join('');
  }

  input.addEventListener('input', () => renderResults(input.value));

})();
</script>
