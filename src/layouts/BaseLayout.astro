---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  image?: string;
  noindex?: boolean;
}

const {
  title,
  description = 'Neurosage Hub — Structured Next Steps for Families Navigating Autism.',
  image = '/neurosage_hub_og.png',
  noindex = false,
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- Primary Meta -->
    <title>{title}</title>
    <meta name="description" content={description} />
    {noindex && <meta name="robots" content="noindex, nofollow" />}
    <link rel="canonical" href={canonicalURL} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={new URL(image, Astro.site)} />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={new URL(image, Astro.site)} />

    <!-- ===== Google Analytics 4 + Google Ads ===== -->
    <!-- GA4 Measurement ID: G-ZV4TDQH8X5 | Google Ads ID: AW-18151207119 -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-ZV4TDQH8X5" is:inline></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-ZV4TDQH8X5');
      gtag('config', 'AW-18151207119');
    </script>

    <!-- Fonts: DM Serif Display + DM Sans -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=DM+Serif+Display:ital@0;1&family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;0,9..40,600;0,9..40,700;1,9..40,400&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <slot />

    <!-- ===== EXIT INTENT POPUP ===== -->
    <div
      id="nsh-exit-popup"
      style="display:none; position:fixed; inset:0; z-index:99999; background:rgba(8,36,56,0.80); backdrop-filter:blur(5px); align-items:center; justify-content:center; padding:1rem;"
      role="dialog"
      aria-modal="true"
      aria-label="Before you go"
    >
      <div style="background:white; border-radius:1.5rem; max-width:440px; width:100%; padding:2.5rem 2.25rem 2rem; position:relative; box-shadow:0 32px 80px rgba(0,0,0,0.35); animation:nsh-popup-in 0.25s ease;">

        <button
          id="nsh-exit-close"
          aria-label="Close"
          style="position:absolute; top:1rem; right:1rem; width:32px; height:32px; border-radius:50%; border:none; background:#F7F2EB; cursor:pointer; display:flex; align-items:center; justify-content:center; font-size:1.125rem; color:#5F6975; line-height:1;"
        >✕</button>

        <div style="width:40px; height:4px; border-radius:2px; background:#D8896A; margin-bottom:1.5rem;"></div>
        <p style="font-family:'DM Sans',sans-serif; font-size:0.8125rem; font-weight:700; letter-spacing:0.1em; text-transform:uppercase; color:#D8896A; margin-bottom:0.5rem;">Before you go…</p>
        <h2 style="font-family:'DM Sans',sans-serif; font-weight:800; font-size:1.625rem; color:#082438; line-height:1.2; margin-bottom:0.875rem;">
          Get your personalized<br>next-step guide.
        </h2>
        <p style="font-family:'DM Sans',sans-serif; font-size:0.9375rem; color:#5F6975; line-height:1.65; margin-bottom:1.5rem;">
          Free resources, early access to new pathways, and the guidance most families never find on their own. No spam — ever.
        </p>

        <form id="nsh-exit-form" novalidate>
          <div style="margin-bottom:0.75rem;">
            <input
              type="email"
              id="nsh-exit-email"
              placeholder="Your email address"
              required
              autocomplete="email"
              style="width:100%; padding:0.875rem 1rem; border:1.5px solid #ddd9d2; border-radius:0.625rem; font-family:'DM Sans',sans-serif; font-size:1rem; color:#082438; outline:none; box-sizing:border-box; transition:border-color 150ms;"
              onfocus="this.style.borderColor='#2E6E8E'"
              onblur="this.style.borderColor='#ddd9d2'"
            />
          </div>
          <button
            type="submit"
            style="width:100%; background:#D8896A; color:white; font-family:'DM Sans',sans-serif; font-weight:700; font-size:1rem; padding:0.9375rem; border-radius:0.625rem; border:none; cursor:pointer; transition:background 160ms;"
            onmouseover="this.style.background='#b8694a'"
            onmouseout="this.style.background='#D8896A'"
          >
            Send Me the Guide →
          </button>
        </form>

        <p style="font-family:'DM Sans',sans-serif; font-size:0.8rem; color:#5F6975; text-align:center; margin-top:1rem;">
          No diagnosis required · No credit card · Unsubscribe anytime
        </p>

      </div>
    </div>

    <!-- ===== GET NOTIFIED MODAL ===== -->
    <div
      id="nsh-notify-modal"
      style="display:none; position:fixed; inset:0; z-index:99998; background:rgba(8,36,56,0.82); backdrop-filter:blur(5px); align-items:center; justify-content:center; padding:1rem;"
      role="dialog"
      aria-modal="true"
      aria-label="Get notified of new guides"
    >
      <div style="background:white; border-radius:1.5rem; max-width:420px; width:100%; padding:2.25rem 2rem 1.75rem; position:relative; box-shadow:0 32px 80px rgba(0,0,0,0.35); animation:nsh-popup-in 0.25s ease;">

        <button
          id="nsh-notify-close"
          aria-label="Close"
          style="position:absolute; top:1rem; right:1rem; width:32px; height:32px; border-radius:50%; border:none; background:#F7F2EB; cursor:pointer; display:flex; align-items:center; justify-content:center; font-size:1.125rem; color:#5F6975; line-height:1;"
        >✕</button>

        <!-- Bell icon -->
        <div style="width:44px; height:44px; border-radius:12px; background:#E4EFF6; display:flex; align-items:center; justify-content:center; margin-bottom:1.25rem;">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#1A4A6B" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"/><path d="M13.73 21a2 2 0 0 1-3.46 0"/></svg>
        </div>

        <h2 id="nsh-notify-title" style="font-family:'DM Sans',sans-serif; font-weight:800; font-size:1.375rem; color:#082438; line-height:1.3; margin-bottom:0.5rem;">
          Get notified of new guides
        </h2>
        <p style="font-family:'DM Sans',sans-serif; font-size:0.9375rem; color:#5F6975; line-height:1.65; margin-bottom:1.5rem;">
          We'll send you an email when we publish new content in this hub. No spam — ever.
        </p>

        <!-- Form -->
        <form id="nsh-notify-form" novalidate>
          <div style="margin-bottom:0.75rem;">
            <input
              type="email"
              id="nsh-notify-email"
              placeholder="Your email address"
              required
              autocomplete="email"
              style="width:100%; padding:0.875rem 1rem; border:1.5px solid #ddd9d2; border-radius:0.625rem; font-family:'DM Sans',sans-serif; font-size:1rem; color:#082438; outline:none; box-sizing:border-box; transition:border-color 150ms;"
              onfocus="this.style.borderColor='#2E6E8E'"
              onblur="this.style.borderColor='#ddd9d2'"
            />
          </div>
          <button
            type="submit"
            id="nsh-notify-submit"
            style="width:100%; background:#D8896A; color:white; font-family:'DM Sans',sans-serif; font-weight:700; font-size:1rem; padding:0.875rem; border-radius:0.625rem; border:none; cursor:pointer; transition:background 160ms;"
            onmouseover="this.style.background='#b8694a'"
            onmouseout="this.style.background='#D8896A'"
          >
            Notify Me →
          </button>
        </form>

        <!-- Success state (hidden until submit) -->
        <div id="nsh-notify-success" style="display:none; text-align:center; padding:0.5rem 0;">
          <div style="font-size:2rem; margin-bottom:0.75rem;">✅</div>
          <p style="font-family:'DM Sans',sans-serif; font-weight:700; font-size:1rem; color:#082438; margin:0 0 0.375rem;">You're on the list!</p>
          <p id="nsh-notify-success-text" style="font-family:'DM Sans',sans-serif; font-size:0.875rem; color:#5F6975; line-height:1.65; margin:0;"></p>
        </div>

        <p style="font-family:'DM Sans',sans-serif; font-size:0.8rem; color:#5F6975; text-align:center; margin-top:1rem; margin-bottom:0;">
          No spam · Unsubscribe anytime
        </p>

      </div>
    </div>

    <!-- ===== EVA™ FLOATING WIDGET ===== -->
    <div id="eva-widget" style="position:fixed; bottom:1.5rem; right:1.5rem; z-index:9998; font-family:'DM Sans',sans-serif;">

      <!-- Trigger button -->
      <button
        id="eva-trigger"
        aria-label="Chat with Eva™"
        title="Chat with Eva™"
        style="width:72px; height:72px; border:none; cursor:pointer; padding:0; background:none; display:flex; align-items:center; justify-content:center; transition:transform 0.2s ease, filter 0.2s ease; filter:drop-shadow(0 6px 18px rgba(8,36,56,0.35));"
        onmouseover="this.style.transform='scale(1.08)'; this.style.filter='drop-shadow(0 10px 28px rgba(8,36,56,0.5))'"
        onmouseout="this.style.transform='scale(1)'; this.style.filter='drop-shadow(0 6px 18px rgba(8,36,56,0.35))'"
      >
        <img src="/eva-bubble.png" alt="Eva™" style="width:72px; height:72px; object-fit:contain;" />
      </button>

      <!-- Unread badge -->
      <span id="eva-badge" style="position:absolute; top:2px; right:2px; width:18px; height:18px; background:#D8896A; border-radius:50%; border:2px solid white; display:flex; align-items:center; justify-content:center; font-size:0.6875rem; font-weight:700; color:white; line-height:1;">1</span>

      <!-- Chat panel -->
      <div
        id="eva-panel"
        style="display:none; position:absolute; bottom:82px; right:0; width:330px; background:white; border-radius:1.375rem; box-shadow:0 16px 56px rgba(8,36,56,0.28); overflow:hidden; animation:eva-in 0.22s ease;"
        role="dialog"
        aria-label="Chat with Eva™"
      >
        <!-- Header -->
        <div style="background:#082438; padding:1rem 1.125rem; display:flex; align-items:center; gap:0.75rem;">
          <img src="/eva-face.png" alt="" style="width:42px; height:42px; border-radius:50%; flex-shrink:0; object-fit:cover;" />
          <div style="flex:1;">
            <p style="margin:0; font-weight:700; font-size:0.9375rem; color:white; line-height:1.2;">Eva™</p>
            <p style="margin:0; font-size:0.75rem; color:rgba(255,255,255,0.45);">Neurosage Guide · Online now</p>
          </div>
          <button
            id="eva-panel-close"
            aria-label="Close"
            style="background:none; border:none; color:rgba(255,255,255,0.45); cursor:pointer; font-size:1.25rem; line-height:1; padding:0.25rem; border-radius:4px; transition:color 0.15s;"
            onmouseover="this.style.color='white'"
            onmouseout="this.style.color='rgba(255,255,255,0.45)'"
          >✕</button>
        </div>
        <!-- Messages -->
        <div id="eva-msgs" style="padding:1rem; min-height:80px; max-height:260px; overflow-y:auto; display:flex; flex-direction:column; gap:0.625rem;"></div>
        <!-- Input area -->
        <div id="eva-input-area" style="padding:0.75rem 1rem 1rem; border-top:1px solid #f0ede8;"></div>
      </div>
    </div>

    <style>
      @keyframes nsh-popup-in {
        from { opacity: 0; transform: translateY(16px) scale(0.97); }
        to   { opacity: 1; transform: translateY(0) scale(1); }
      }
      @keyframes eva-in {
        from { opacity: 0; transform: translateY(12px) scale(0.96); }
        to   { opacity: 1; transform: translateY(0) scale(1); }
      }
      #eva-msgs::-webkit-scrollbar { width: 4px; }
      #eva-msgs::-webkit-scrollbar-track { background: transparent; }
      #eva-msgs::-webkit-scrollbar-thumb { background: #ddd9d2; border-radius: 2px; }
      /* Suppress browser native red :invalid styling on email inputs */
      input[type="email"]:invalid { box-shadow: none !important; outline: none; }
      input[type="email"]:invalid:not(:focus) { border-color: #ddd9d2 !important; }
    </style>

    <script is:inline>
    (function () {

      /* ─── Cookie helpers ─── */
      function getCookie(n) {
        var m = document.cookie.match(new RegExp('(^| )' + n + '=([^;]+)'));
        return m ? m[2] : null;
      }
      function setCookie(n, v, days) {
        var e = new Date(Date.now() + days * 864e5).toUTCString();
        document.cookie = n + '=' + v + '; expires=' + e + '; path=/; SameSite=Lax';
      }

      /* ─── Eva™ panel — question → offer → email / bypass → /chat ─── */
      var trigger   = document.getElementById('eva-trigger');
      var panel     = document.getElementById('eva-panel');
      var closeBtn  = document.getElementById('eva-panel-close');
      var msgs      = document.getElementById('eva-msgs');
      var inputArea = document.getElementById('eva-input-area');
      var badge     = document.getElementById('eva-badge');
      var isOpen    = false;
      var userQ     = '';

      var CHAT_URL  = '/chat';

      /* Add a chat bubble */
      function addMsg(html, from) {
        var wrap = document.createElement('div');
        wrap.style.cssText = 'display:flex; align-items:flex-start; gap:0.5rem;' + (from === 'user' ? 'flex-direction:row-reverse;' : '');
        var bub = document.createElement('div');
        bub.innerHTML = html;
        bub.style.cssText = from === 'sage'
          ? 'background:#F7F2EB; border-radius:4px 14px 14px 14px; padding:0.75rem 0.875rem; font-size:0.875rem; color:#082438; line-height:1.65; max-width:230px;'
          : 'background:#082438; border-radius:14px 4px 14px 14px; padding:0.75rem 0.875rem; font-size:0.875rem; color:white; line-height:1.65; max-width:210px; margin-left:auto;';
        if (from === 'sage') {
          var av = document.createElement('img');
          av.src = '/eva-face.png';
          av.style.cssText = 'width:32px; height:32px; border-radius:50%; flex-shrink:0; object-fit:cover; margin-top:2px;';
          wrap.appendChild(av);
        }
        wrap.appendChild(bub);
        msgs.appendChild(wrap);
        msgs.scrollTop = msgs.scrollHeight;
      }

      /* STEP 1 — Ask the question */
      function renderAsk() {
        addMsg("Hi — what's your question? I'm happy to help.", 'sage');
        inputArea.innerHTML =
          '<textarea id="eva-q-in" rows="2" placeholder="Type your question…" style="width:100%; padding:0.625rem 0.875rem; border:1.5px solid #ddd9d2; border-radius:0.75rem; font-family:\'DM Sans\',sans-serif; font-size:0.875rem; color:#082438; outline:none; resize:none; box-sizing:border-box; transition:border-color 0.15s;" onfocus="this.style.borderColor=\'#2E6E8E\'" onblur="this.style.borderColor=\'#ddd9d2\'"></textarea>'
          + '<button id="eva-q-send" style="margin-top:0.5rem; width:100%; padding:0.625rem; background:#D8896A; color:white; border:none; border-radius:0.75rem; cursor:pointer; font-family:\'DM Sans\',sans-serif; font-size:0.875rem; font-weight:700; transition:background 0.15s;" onmouseover="this.style.background=\'#b8694a\'" onmouseout="this.style.background=\'#D8896A\'">Ask →</button>';
        var qIn = document.getElementById('eva-q-in');
        var qSend = document.getElementById('eva-q-send');
        function submitQ() {
          var val = qIn ? qIn.value.trim() : '';
          if (!val) return;
          userQ = val;
          addMsg(val, 'user');
          inputArea.innerHTML = '';
          setTimeout(renderOffer, 400);
        }
        if (qSend) qSend.addEventListener('click', submitQ);
        if (qIn) qIn.addEventListener('keydown', function(e) {
          if (e.key === '