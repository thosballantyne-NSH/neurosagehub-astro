---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  image?: string;
  noindex?: boolean;
}

const {
  title,
  description = 'Neurosage Hub — Structured Next Steps for Families Navigating Autism.',
  image = '/neurosage_hub_og.png',
  noindex = false,
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- Primary Meta -->
    <title>{title}</title>
    <meta name="description" content={description} />
    {noindex && <meta name="robots" content="noindex, nofollow" />}
    <link rel="canonical" href={canonicalURL} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={new URL(image, Astro.site)} />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={new URL(image, Astro.site)} />

    <!-- Fonts: DM Serif Display + DM Sans -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=DM+Serif+Display:ital@0;1&family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;0,9..40,600;0,9..40,700;1,9..40,400&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <slot />

    <!-- ===== EXIT INTENT POPUP ===== -->
    <div
      id="nsh-exit-popup"
      style="display:none; position:fixed; inset:0; z-index:99999; background:rgba(8,36,56,0.80); backdrop-filter:blur(5px); align-items:center; justify-content:center; padding:1rem;"
      role="dialog"
      aria-modal="true"
      aria-label="Before you go"
    >
      <div style="background:white; border-radius:1.5rem; max-width:440px; width:100%; padding:2.5rem 2.25rem 2rem; position:relative; box-shadow:0 32px 80px rgba(0,0,0,0.35); animation:nsh-popup-in 0.25s ease;">

        <button
          id="nsh-exit-close"
          aria-label="Close"
          style="position:absolute; top:1rem; right:1rem; width:32px; height:32px; border-radius:50%; border:none; background:#F7F2EB; cursor:pointer; display:flex; align-items:center; justify-content:center; font-size:1.125rem; color:#5F6975; line-height:1;"
        >✕</button>

        <div style="width:40px; height:4px; border-radius:2px; background:#D8896A; margin-bottom:1.5rem;"></div>
        <p style="font-family:'DM Sans',sans-serif; font-size:0.8125rem; font-weight:700; letter-spacing:0.1em; text-transform:uppercase; color:#D8896A; margin-bottom:0.5rem;">Before you go…</p>
        <h2 style="font-family:'DM Sans',sans-serif; font-weight:800; font-size:1.625rem; color:#082438; line-height:1.2; margin-bottom:0.875rem;">
          Get your personalised<br>next-step guide.
        </h2>
        <p style="font-family:'DM Sans',sans-serif; font-size:0.9375rem; color:#5F6975; line-height:1.65; margin-bottom:1.5rem;">
          Free resources, early access to new pathways, and the guidance most families never find on their own. No spam — ever.
        </p>

        <form id="nsh-exit-form" novalidate>
          <div style="margin-bottom:0.75rem;">
            <input
              type="email"
              id="nsh-exit-email"
              placeholder="Your email address"
              required
              autocomplete="email"
              style="width:100%; padding:0.875rem 1rem; border:1.5px solid #ddd9d2; border-radius:0.625rem; font-family:'DM Sans',sans-serif; font-size:1rem; color:#082438; outline:none; box-sizing:border-box; transition:border-color 150ms;"
              onfocus="this.style.borderColor='#2E6E8E'"
              onblur="this.style.borderColor='#ddd9d2'"
            />
          </div>
          <button
            type="submit"
            style="width:100%; background:#D8896A; color:white; font-family:'DM Sans',sans-serif; font-weight:700; font-size:1rem; padding:0.9375rem; border-radius:0.625rem; border:none; cursor:pointer; transition:background 160ms;"
            onmouseover="this.style.background='#b8694a'"
            onmouseout="this.style.background='#D8896A'"
          >
            Send Me the Guide →
          </button>
        </form>

        <p style="font-family:'DM Sans',sans-serif; font-size:0.8rem; color:#5F6975; text-align:center; margin-top:1rem;">
          No diagnosis required · No credit card · Unsubscribe anytime
        </p>

      </div>
    </div>

    <!-- ===== GET NOTIFIED MODAL ===== -->
    <div
      id="nsh-notify-modal"
      style="display:none; position:fixed; inset:0; z-index:99998; background:rgba(8,36,56,0.82); backdrop-filter:blur(5px); align-items:center; justify-content:center; padding:1rem;"
      role="dialog"
      aria-modal="true"
      aria-label="Get notified of new guides"
    >
      <div style="background:white; border-radius:1.5rem; max-width:420px; width:100%; padding:2.25rem 2rem 1.75rem; position:relative; box-shadow:0 32px 80px rgba(0,0,0,0.35); animation:nsh-popup-in 0.25s ease;">

        <button
          id="nsh-notify-close"
          aria-label="Close"
          style="position:absolute; top:1rem; right:1rem; width:32px; height:32px; border-radius:50%; border:none; background:#F7F2EB; cursor:pointer; display:flex; align-items:center; justify-content:center; font-size:1.125rem; color:#5F6975; line-height:1;"
        >✕</button>

        <!-- Bell icon -->
        <div style="width:44px; height:44px; border-radius:12px; background:#E4EFF6; display:flex; align-items:center; justify-content:center; margin-bottom:1.25rem;">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#1A4A6B" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"/><path d="M13.73 21a2 2 0 0 1-3.46 0"/></svg>
        </div>

        <h2 id="nsh-notify-title" style="font-family:'DM Sans',sans-serif; font-weight:800; font-size:1.375rem; color:#082438; line-height:1.3; margin-bottom:0.5rem;">
          Get notified of new guides
        </h2>
        <p style="font-family:'DM Sans',sans-serif; font-size:0.9375rem; color:#5F6975; line-height:1.65; margin-bottom:1.5rem;">
          We'll send you an email when we publish new content in this hub. No spam — ever.
        </p>

        <!-- Form -->
        <form id="nsh-notify-form" novalidate>
          <div style="margin-bottom:0.75rem;">
            <input
              type="email"
              id="nsh-notify-email"
              placeholder="Your email address"
              required
              autocomplete="email"
              style="width:100%; padding:0.875rem 1rem; border:1.5px solid #ddd9d2; border-radius:0.625rem; font-family:'DM Sans',sans-serif; font-size:1rem; color:#082438; outline:none; box-sizing:border-box; transition:border-color 150ms;"
              onfocus="this.style.borderColor='#2E6E8E'"
              onblur="this.style.borderColor='#ddd9d2'"
            />
          </div>
          <button
            type="submit"
            id="nsh-notify-submit"
            style="width:100%; background:#D8896A; color:white; font-family:'DM Sans',sans-serif; font-weight:700; font-size:1rem; padding:0.875rem; border-radius:0.625rem; border:none; cursor:pointer; transition:background 160ms;"
            onmouseover="this.style.background='#b8694a'"
            onmouseout="this.style.background='#D8896A'"
          >
            Notify Me →
          </button>
        </form>

        <!-- Success state (hidden until submit) -->
        <div id="nsh-notify-success" style="display:none; text-align:center; padding:0.5rem 0;">
          <div style="font-size:2rem; margin-bottom:0.75rem;">✅</div>
          <p style="font-family:'DM Sans',sans-serif; font-weight:700; font-size:1rem; color:#082438; margin:0 0 0.375rem;">You're on the list!</p>
          <p id="nsh-notify-success-text" style="font-family:'DM Sans',sans-serif; font-size:0.875rem; color:#5F6975; line-height:1.65; margin:0;"></p>
        </div>

        <p style="font-family:'DM Sans',sans-serif; font-size:0.8rem; color:#5F6975; text-align:center; margin-top:1rem; margin-bottom:0;">
          No spam · Unsubscribe anytime
        </p>

      </div>
    </div>

    <!-- ===== SAGE™ FLOATING WIDGET ===== -->
    <div id="sage-widget" style="position:fixed; bottom:1.5rem; right:1.5rem; z-index:9998; font-family:'DM Sans',sans-serif;">

      <!-- Trigger button -->
      <button
        id="sage-trigger"
        aria-label="Chat with Sage™"
        title="Chat with Sage™"
        style="width:72px; height:72px; border:none; cursor:pointer; padding:0; background:none; display:flex; align-items:center; justify-content:center; transition:transform 0.2s ease, filter 0.2s ease; filter:drop-shadow(0 6px 18px rgba(8,36,56,0.35));"
        onmouseover="this.style.transform='scale(1.08)'; this.style.filter='drop-shadow(0 10px 28px rgba(8,36,56,0.5))'"
        onmouseout="this.style.transform='scale(1)'; this.style.filter='drop-shadow(0 6px 18px rgba(8,36,56,0.35))'"
      >
        <img src="/sage-bubble.png" alt="Sage™" style="width:72px; height:72px; object-fit:contain;" />
      </button>

      <!-- Unread badge -->
      <span id="sage-badge" style="position:absolute; top:2px; right:2px; width:18px; height:18px; background:#D8896A; border-radius:50%; border:2px solid white; display:flex; align-items:center; justify-content:center; font-size:0.6875rem; font-weight:700; color:white; line-height:1;">1</span>

      <!-- Chat panel -->
      <div
        id="sage-panel"
        style="display:none; position:absolute; bottom:82px; right:0; width:330px; background:white; border-radius:1.375rem; box-shadow:0 16px 56px rgba(8,36,56,0.28); overflow:hidden; animation:sage-in 0.22s ease;"
        role="dialog"
        aria-label="Chat with Sage™"
      >
        <!-- Header -->
        <div style="background:#082438; padding:1rem 1.125rem; display:flex; align-items:center; gap:0.75rem;">
          <img src="/sage-face.png" alt="" style="width:42px; height:42px; border-radius:50%; flex-shrink:0; object-fit:cover;" />
          <div style="flex:1;">
            <p style="margin:0; font-weight:700; font-size:0.9375rem; color:white; line-height:1.2;">Sage™</p>
            <p style="margin:0; font-size:0.75rem; color:rgba(255,255,255,0.45);">Neurosage Guide · Online now</p>
          </div>
          <button
            id="sage-panel-close"
            aria-label="Close"
            style="background:none; border:none; color:rgba(255,255,255,0.45); cursor:pointer; font-size:1.25rem; line-height:1; padding:0.25rem; border-radius:4px; transition:color 0.15s;"
            onmouseover="this.style.color='white'"
            onmouseout="this.style.color='rgba(255,255,255,0.45)'"
          >✕</button>
        </div>
        <!-- Messages -->
        <div id="sage-msgs" style="padding:1rem; min-height:80px; max-height:260px; overflow-y:auto; display:flex; flex-direction:column; gap:0.625rem;"></div>
        <!-- Input area -->
        <div id="sage-input-area" style="padding:0.75rem 1rem 1rem; border-top:1px solid #f0ede8;"></div>
      </div>
    </div>

    <style>
      @keyframes nsh-popup-in {
        from { opacity: 0; transform: translateY(16px) scale(0.97); }
        to   { opacity: 1; transform: translateY(0) scale(1); }
      }
      @keyframes sage-in {
        from { opacity: 0; transform: translateY(12px) scale(0.96); }
        to   { opacity: 1; transform: translateY(0) scale(1); }
      }
      #sage-msgs::-webkit-scrollbar { width: 4px; }
      #sage-msgs::-webkit-scrollbar-track { background: transparent; }
      #sage-msgs::-webkit-scrollbar-thumb { background: #ddd9d2; border-radius: 2px; }
      /* Suppress browser native red :invalid styling on email inputs */
      input[type="email"]:invalid { box-shadow: none !important; outline: none; }
      input[type="email"]:invalid:not(:focus) { border-color: #ddd9d2 !important; }
    </style>

    <script is:inline>
    (function () {

      /* ─── Cookie helpers ─── */
      function getCookie(n) {
        var m = document.cookie.match(new RegExp('(^| )' + n + '=([^;]+)'));
        return m ? m[2] : null;
      }
      function setCookie(n, v, days) {
        var e = new Date(Date.now() + days * 864e5).toUTCString();
        document.cookie = n + '=' + v + '; expires=' + e + '; path=/; SameSite=Lax';
      }

      /* ─── Sage™ panel — question → offer → email / bypass → /chat ─── */
      var trigger   = document.getElementById('sage-trigger');
      var panel     = document.getElementById('sage-panel');
      var closeBtn  = document.getElementById('sage-panel-close');
      var msgs      = document.getElementById('sage-msgs');
      var inputArea = document.getElementById('sage-input-area');
      var badge     = document.getElementById('sage-badge');
      var isOpen    = false;
      var userQ     = '';

      var CHAT_URL  = '/chat';

      /* Add a chat bubble */
      function addMsg(html, from) {
        var wrap = document.createElement('div');
        wrap.style.cssText = 'display:flex; align-items:flex-start; gap:0.5rem;' + (from === 'user' ? 'flex-direction:row-reverse;' : '');
        var bub = document.createElement('div');
        bub.innerHTML = html;
        bub.style.cssText = from === 'sage'
          ? 'background:#F7F2EB; border-radius:4px 14px 14px 14px; padding:0.75rem 0.875rem; font-size:0.875rem; color:#082438; line-height:1.65; max-width:230px;'
          : 'background:#082438; border-radius:14px 4px 14px 14px; padding:0.75rem 0.875rem; font-size:0.875rem; color:white; line-height:1.65; max-width:210px; margin-left:auto;';
        if (from === 'sage') {
          var av = document.createElement('img');
          av.src = '/sage-face.png';
          av.style.cssText = 'width:32px; height:32px; border-radius:50%; flex-shrink:0; object-fit:cover; margin-top:2px;';
          wrap.appendChild(av);
        }
        wrap.appendChild(bub);
        msgs.appendChild(wrap);
        msgs.scrollTop = msgs.scrollHeight;
      }

      /* STEP 1 — Ask the question */
      function renderAsk() {
        addMsg("Hi — what's your question? I'm happy to help.", 'sage');
        inputArea.innerHTML =
          '<textarea id="sage-q-in" rows="2" placeholder="Type your question…" style="width:100%; padding:0.625rem 0.875rem; border:1.5px solid #ddd9d2; border-radius:0.75rem; font-family:\'DM Sans\',sans-serif; font-size:0.875rem; color:#082438; outline:none; resize:none; box-sizing:border-box; transition:border-color 0.15s;" onfocus="this.style.borderColor=\'#2E6E8E\'" onblur="this.style.borderColor=\'#ddd9d2\'"></textarea>'
          + '<button id="sage-q-send" style="margin-top:0.5rem; width:100%; padding:0.625rem; background:#D8896A; color:white; border:none; border-radius:0.75rem; cursor:pointer; font-family:\'DM Sans\',sans-serif; font-size:0.875rem; font-weight:700; transition:background 0.15s;" onmouseover="this.style.background=\'#b8694a\'" onmouseout="this.style.background=\'#D8896A\'">Ask →</button>';
        var qIn = document.getElementById('sage-q-in');
        var qSend = document.getElementById('sage-q-send');
        function submitQ() {
          var val = qIn ? qIn.value.trim() : '';
          if (!val) return;
          userQ = val;
          addMsg(val, 'user');
          inputArea.innerHTML = '';
          setTimeout(renderOffer, 400);
        }
        if (qSend) qSend.addEventListener('click', submitQ);
        if (qIn) qIn.addEventListener('keydown', function(e) {
          if (e.key === 'Enter' && !e.shiftKey) { e.preventDefault(); submitQ(); }
        });
      }

      /* STEP 2 — Informed-answer offer */
      function renderOffer() {
        addMsg('I can pull answers from the Hub — curated autism content from trusted, verified sources. How would you like me to help?', 'sage');
        function makeBtn(id, text) {
          return '<button id="' + id + '" style="display:block; width:100%; padding:0.7rem 0.875rem; margin-bottom:0.375rem; border-radius:0.75rem; border:1.5px solid #ddd9d2; background:white; font-family:\'DM Sans\',sans-serif; font-size:0.8125rem; color:#082438; font-weight:500; cursor:pointer; text-align:left; transition:border-color 0.15s, background 0.15s;" onmouseover="this.style.borderColor=\'#2E6E8E\'; this.style.background=\'#f0f6fa\'" onmouseout="this.style.borderColor=\'#ddd9d2\'; this.style.background=\'white\'">' + text + '</button>';
        }
        inputArea.innerHTML =
          makeBtn('sage-yes', 'Yes, give me Hub resourced answers')
          + makeBtn('sage-no',  'No, just fast chat answers');
        document.getElementById('sage-yes').addEventListener('click', renderEmail);
        document.getElementById('sage-no').addEventListener('click', function() {
          addMsg('No problem — connecting you now.', 'user');
          inputArea.innerHTML = '';
          setTimeout(function() {
            window.location.href = CHAT_URL + '?q=' + encodeURIComponent(userQ);
          }, 600);
        });
      }

      /* STEP 3 — Email capture (Yes path) */
      function renderEmail() {
        addMsg('Please share your email address to access the Hub.', 'sage');
        inputArea.innerHTML =
          '<div style="display:flex; gap:0.5rem;">'
          + '<input id="sage-email-in" type="email" placeholder="Your email" autocomplete="email" style="flex:1; padding:0.625rem 0.875rem; border:1.5px solid #ddd9d2; border-radius:0.75rem; font-family:\'DM Sans\',sans-serif; font-size:0.875rem; color:#082438; outline:none; transition:border-color 0.15s;" onfocus="this.style.borderColor=\'#2E6E8E\'" onblur="this.style.borderColor=\'#ddd9d2\'" />'
          + '<button id="sage-email-send" style="padding:0 0.875rem; background:#D8896A; color:white; border:none; border-radius:0.75rem; cursor:pointer; font-size:0.875rem; font-weight:700; font-family:\'DM Sans\',sans-serif; white-space:nowrap; transition:background 0.15s;" onmouseover="this.style.background=\'#b8694a\'" onmouseout="this.style.background=\'#D8896A\'">Send →</button>'
          + '</div>'
          + '<p style="font-size:0.7rem; color:#9a9187; margin:0.375rem 0 0 0.25rem;">No spam · Unsubscribe anytime</p>';
        function submitEmail() {
          var emailEl = document.getElementById('sage-email-in');
          var email   = emailEl ? emailEl.value.trim() : '';
          if (!email || !email.includes('@')) { if (emailEl) emailEl.style.borderColor = '#c0392b'; return; }
          setCookie('nsh_visitor',   '1', 365);
          setCookie('nsh_exit_seen', '1', 30);
          addMsg(email, 'user');
          inputArea.innerHTML = '';
          setTimeout(function() {
            window.location.href = CHAT_URL + '?email=' + encodeURIComponent(email) + '&q=' + encodeURIComponent(userQ);
          }, 500);
        }
        var sendBtn = document.getElementById('sage-email-send');
        var emailIn = document.getElementById('sage-email-in');
        if (sendBtn) sendBtn.addEventListener('click', submitEmail);
        if (emailIn) emailIn.addEventListener('keydown', function(e) { if (e.key === 'Enter') submitEmail(); });
      }

      function openPanel() {
        if (isOpen) return;
        isOpen = true;
        panel.style.display = 'block';
        if (badge) badge.style.display = 'none';
        if (msgs.children.length === 0) renderAsk();
      }
      function closePanel() {
        isOpen = false;
        panel.style.display = 'none';
      }

      /* Global helper — start-here options & 404 "Something else?" both route here */
      window.nshOpenLC = function(message) {
        window.location.href = CHAT_URL + (message ? '?q=' + encodeURIComponent(message) : '');
      };

      if (trigger)  trigger.addEventListener('click', function() { isOpen ? closePanel() : openPanel(); });
      if (closeBtn) closeBtn.addEventListener('click', closePanel);
      document.addEventListener('keydown', function(e) {
        if (e.key === 'Escape' && isOpen) closePanel();
      });

      /* ─── Exit Intent Popup ─── */
      var popup      = document.getElementById('nsh-exit-popup');
      var exitClose  = document.getElementById('nsh-exit-close');
      var exitForm   = document.getElementById('nsh-exit-form');
      var exitEmail  = document.getElementById('nsh-exit-email');
      var popupFired = false;
      var alreadySeen = !!getCookie('nsh_exit_seen');

      function showPopup() {
        if (popupFired || alreadySeen) return;
        popupFired = true;
        popup.style.display = 'flex';
      }
      function hidePopup() {
        popup.style.display = 'none';
        setCookie('nsh_exit_seen', '1', 7);
      }

      document.addEventListener('mouseleave', function(e) { if (e.clientY < 10) showPopup(); });
      var lastY = window.scrollY;
      window.addEventListener('scroll', function() {
        var y = window.scrollY;
        if (lastY - y > 80 && y < 120) showPopup();
        lastY = y;
      }, { passive: true });
      if (exitClose) exitClose.addEventListener('click', hidePopup);
      if (popup)     popup.addEventListener('click', function(e) { if (e.target === popup) hidePopup(); });
      document.addEventListener('keydown', function(e) {
        if (e.key === 'Escape' && popup && popup.style.display === 'flex') hidePopup();
      });
      if (exitForm) {
        exitForm.addEventListener('submit', function(e) {
          e.preventDefault();
          var email = exitEmail ? exitEmail.value.trim() : '';
          if (!email || !email.includes('@')) { if (exitEmail) exitEmail.style.borderColor='#c0392b'; return; }
          setCookie('nsh_exit_seen', '1', 30);
          window.location.href = '/family-sign-up?email=' + encodeURIComponent(email);
        });
      }

      /* ─── Get Notified Modal ─── */
      var notifyModal        = document.getElementById('nsh-notify-modal');
      var notifyClose        = document.getElementById('nsh-notify-close');
      var notifyForm         = document.getElementById('nsh-notify-form');
      var notifyEmailIn      = document.getElementById('nsh-notify-email');
      var notifyTitle        = document.getElementById('nsh-notify-title');
      var notifySuccess      = document.getElementById('nsh-notify-success');
      var notifySuccessText  = document.getElementById('nsh-notify-success-text');
      var _notifyTopic       = '';

      window.nshOpenNotify = function(topic) {
        _notifyTopic = topic || '';
        if (notifyTitle) {
          notifyTitle.textContent = _notifyTopic
            ? 'Get notified of new ' + _notifyTopic + ' guides'
            : 'Get notified of new guides';
        }
        /* Reset to form state */
        if (notifyForm)    { notifyForm.style.display    = 'block'; notifyForm.reset(); }
        if (notifySuccess) { notifySuccess.style.display = 'none'; }
        if (notifyEmailIn) { notifyEmailIn.style.borderColor = '#ddd9d2'; }
        if (notifyModal)   {
          notifyModal.style.display = 'flex';
          document.body.style.overflow = 'hidden';
          setTimeout(function() { if (notifyEmailIn) notifyEmailIn.focus(); }, 50);
        }
      };

      function closeNotifyModal() {
        if (notifyModal) notifyModal.style.display = 'none';
        document.body.style.overflow = '';
      }

      if (notifyClose)  notifyClose.addEventListener('click', closeNotifyModal);
      if (notifyModal)  notifyModal.addEventListener('click', function(e) { if (e.target === notifyModal) closeNotifyModal(); });
      document.addEventListener('keydown', function(e) {
        if (e.key === 'Escape' && notifyModal && notifyModal.style.display === 'flex') closeNotifyModal();
      });

      if (notifyForm) {
        notifyForm.addEventListener('submit', function(e) {
          e.preventDefault();
          var email = notifyEmailIn ? notifyEmailIn.value.trim() : '';
          if (!email || !email.includes('@')) {
            if (notifyEmailIn) notifyEmailIn.style.borderColor = '#c0392b';
            return;
          }
          setCookie('nsh_visitor', '1', 365);
          /* Show inline success — backend team wires up email storage to CRM */
          if (notifyForm)    notifyForm.style.display    = 'none';
          if (notifySuccess) notifySuccess.style.display = 'block';
          if (notifySuccessText) {
            notifySuccessText.textContent = _notifyTopic
              ? "We'll let you know when new " + _notifyTopic + " guides are published."
              : "We'll send you new guides as they're published.";
          }
          /* Auto-close after 3 s */
          setTimeout(closeNotifyModal, 3000);
        });
      }

      /* ─── Fade-up observer (global — ensures all .fade-up elements animate in) ─── */
      var _fadeEls = document.querySelectorAll('.fade-up');
      if ('IntersectionObserver' in window) {
        var _fadeObs = new IntersectionObserver(
          function(entries) {
            entries.forEach(function(e) {
              if (e.isIntersecting) e.target.classList.add('visible');
            });
          },
          { threshold: 0.05, rootMargin: '0px 0px -20px 0px' }
        );
        _fadeEls.forEach(function(el) { _fadeObs.observe(el); });
      } else {
        _fadeEls.forEach(function(el) { el.classList.add('visible'); });
      }

    })();
    </script>

    <!-- LC chat loads inside the Sage™ lightbox iframe — no external script needed -->

  </body>
</html>
