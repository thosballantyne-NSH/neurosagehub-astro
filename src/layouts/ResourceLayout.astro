---
import BaseLayout from './BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

export interface Props {
  title: string;
  description: string;
  hub: string;
  hubSlug: string;
  articleTitle: string;
  publishDate?: string;
  readTime?: string;
}

const { title, description, hub, hubSlug, articleTitle, publishDate, readTime = '5 min read' } = Astro.props;
---

<BaseLayout title={title} description={description}>
  <Header />

  <main>

    <!-- ===== BREADCRUMB + HERO ===== -->
    <section class="py-14" style="background:#082438;">
      <div class="container">
        <div class="max-w-3xl mx-auto">

          <!-- Breadcrumb -->
          <nav class="mb-6" aria-label="Breadcrumb">
            <ol style="display:flex; align-items:center; gap:0.5rem; list-style:none; padding:0; margin:0; flex-wrap:wrap;">
              <li>
                <a href="/resources" style="font-family:'DM Sans',sans-serif; font-size:0.8125rem; color:rgba(255,255,255,0.5); text-decoration:none;">
                  Resources
                </a>
              </li>
              <li style="color:rgba(255,255,255,0.3); font-size:0.8125rem;">/</li>
              <li>
                <a href={`/resources/${hubSlug}`} style="font-family:'DM Sans',sans-serif; font-size:0.8125rem; color:rgba(255,255,255,0.5); text-decoration:none;">
                  {hub}
                </a>
              </li>
              <li style="color:rgba(255,255,255,0.3); font-size:0.8125rem;">/</li>
              <li style="font-family:'DM Sans',sans-serif; font-size:0.8125rem; color:rgba(255,255,255,0.7);">{articleTitle}</li>
            </ol>
          </nav>

          <!-- Meta -->
          <div class="flex items-center gap-3 mb-4">
            <span style="font-family:'DM Sans',sans-serif; font-size:0.75rem; font-weight:600; letter-spacing:0.08em; text-transform:uppercase; color:#7B9E8B;">{hub}</span>
            {readTime && (
              <>
                <span style="color:rgba(255,255,255,0.2);">·</span>
                <span style="font-family:'DM Sans',sans-serif; font-size:0.8125rem; color:rgba(255,255,255,0.45);">{readTime}</span>
              </>
            )}
          </div>

          <h1 style="font-family:'DM Sans',sans-serif; font-weight:800; font-size:clamp(1.625rem,4vw,2.5rem); color:white; line-height:1.2; margin-bottom:0;">
            {articleTitle}
          </h1>

          {publishDate && (
            <p style="font-family:'DM Sans',sans-serif; font-size:0.8125rem; color:rgba(255,255,255,0.4); margin-top:0.875rem;">
              Published {publishDate}
            </p>
          )}

        </div>
      </div>
    </section>

    <!-- ===== ARTICLE BODY ===== -->
    <section class="py-14" style="background:white;">
      <div class="container">
        <div class="max-w-3xl mx-auto">

          <slot />

          <!-- Get Notified banner -->
          <div class="mt-12" style="background:#F7F2EB; border-radius:1.25rem; padding:1.5rem 1.75rem; display:flex; align-items:center; justify-content:space-between; gap:1.25rem; flex-wrap:wrap; border:1px solid #ede9e2;">
            <div style="display:flex; align-items:center; gap:0.875rem; flex:1; min-width:180px;">
              <div style="width:40px; height:40px; border-radius:10px; background:#E4EFF6; display:flex; align-items:center; justify-content:center; flex-shrink:0;">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#1A4A6B" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"/><path d="M13.73 21a2 2 0 0 1-3.46 0"/></svg>
              </div>
              <div>
                <p style="font-family:'DM Sans',sans-serif; font-weight:700; font-size:0.9375rem; color:#082438; margin:0 0 0.125rem;">Get notified of new guides for {hub}</p>
                <p style="font-family:'DM Sans',sans-serif; font-size:0.8125rem; color:#5F6975; margin:0; line-height:1.5;">We'll email you when new content is added to this hub.</p>
              </div>
            </div>
            <button
              onclick={`window.nshOpenNotify('${hub}')`}
              style="padding:0.625rem 1.25rem; background:#2E6E8E; color:white; border:none; border-radius:0.75rem; cursor:pointer; font-family:'DM Sans',sans-serif; font-size:0.875rem; font-weight:700; white-space:nowrap; transition:background 0.15s;"
              onmouseover="this.style.background='#1A4A6B'"
              onmouseout="this.style.background='#2E6E8E'"
            >
              Notify Me →
            </button>
          </div>

          <!-- Hub navigation -->
          <div class="mt-10 pt-10" style="border-top:1px solid #ddd9d2;">
            <p class="nsh-eyebrow mb-4" style="color:#7B9E8B;">More in {hub}</p>
            <a
              href={`/resources/${hubSlug}`}
              style="font-family:'DM Sans',sans-serif; font-size:0.9375rem; font-weight:600; color:#2E6E8E; text-decoration:none; display:inline-flex; align-items:center; gap:0.375rem;"
            >
              ← Back to {hub} resources
            </a>
          </div>

        </div>
      </div>
    </section>

    <!-- ===== CTA ===== -->
    <section class="py-16" style="background:#082438;">
      <div class="container">
        <div class="max-w-2xl mx-auto text-center">
          <p class="nsh-eyebrow mb-3" style="color:#D8896A;">Neurosage Hub</p>
          <h2 style="font-family:'DM Sans',sans-serif; font-weight:800; font-size:clamp(1.5rem,3.5vw,2.125rem); color:white; margin-bottom:0.875rem; line-height:1.25;">
            Turn insights into daily progress
          </h2>
          <p style="font-family:'DM Sans',sans-serif; font-size:1rem; color:rgba(255,255,255,0.65); max-width:30rem; margin:0 auto 2rem; line-height:1.7;">
            Get guided activities, practitioner support, and therapeutic games designed for children on the spectrum.
          </p>
          <div class="flex flex-wrap justify-center gap-3">
            <a
              href="/family-sign-up"
              style="font-family:'DM Sans',sans-serif; font-size:0.9375rem; font-weight:700; background:#D8896A; color:white; padding:0.875rem 2rem; border-radius:9999px; text-decoration:none; display:inline-block;"
            >
              Get Started Free
            </a>
            <a
              href="/for-practitioners"
              style="font-family:'DM Sans',sans-serif; font-size:0.9375rem; font-weight:600; background:rgba(255,255,255,0.1); color:white; padding:0.875rem 2rem; border-radius:9999px; text-decoration:none; display:inline-block; border:1px solid rgba(255,255,255,0.2);"
            >
              I'm a Practitioner
            </a>
          </div>
        </div>
      </div>
    </section>

  </main>

  <Footer />
</BaseLayout>

<style>
  .resource-body h2 {
    font-family: 'DM Sans', sans-serif;
    font-weight: 700;
    font-size: 1.1875rem;
    color: #082438;
    margin-top: 2.25rem;
    margin-bottom: 0.625rem;
    line-height: 1.3;
  }
  .resource-body p {
    font-family: 'DM Sans', sans-serif;
    font-size: 0.9375rem;
    color: #3d5a6e;
    line-height: 1.85;
    margin-bottom: 1rem;
  }
  .resource-body ul, .resource-body ol {
    font-family: 'DM Sans', sans-serif;
    font-size: 0.9375rem;
    color: #3d5a6e;
    line-height: 1.85;
    padding-left: 1.5rem;
    margin-bottom: 1rem;
  }
  .resource-body li {
    margin-bottom: 0.25rem;
  }
  .resource-body strong {
    color: #082438;
    font-weight: 700;
  }
  .resource-body .direct-answer {
    background: #E4EFF6;
    border-left: 3px solid #2E6E8E;
    border-radius: 0 0.5rem 0.5rem 0;
    padding: 0.875rem 1.125rem;
    margin-bottom: 1rem;
    font-family: 'DM Sans', sans-serif;
    font-size: 0.9375rem;
    color: #082438;
    font-weight: 600;
    line-height: 1.7;
  }
  .resource-body .tip-box {
    background: #F7F2EB;
    border: 1px solid #ddd9d2;
    border-radius: 0.75rem;
    padding: 1.125rem 1.25rem;
    margin: 1.5rem 0;
    font-family: 'DM Sans', sans-serif;
    font-size: 0.9375rem;
    color: #3d5a6e;
    line-height: 1.8;
  }
  .resource-body .tip-box .tip-label {
    font-weight: 700;
    color: #082438;
    display: block;
    margin-bottom: 0.25rem;
    font-size: 0.8125rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }
  .resource-body hr {
    border: none;
    border-top: 1px solid #ddd9d2;
    margin: 2.25rem 0;
  }
</style>
